---
interface Props {
  planId: number;
  priceUsd: number;
  clientId: string;
}

const { planId, priceUsd, clientId } = Astro.props;
const usePayPal = clientId && clientId !== 'sandbox' && clientId.length > 10;
---

<div id="payment-wrapper" class="mt-4">

{usePayPal ? (
  <!-- PayPal mode -->
  <div>
    <div id="paypal-button-container"></div>
    <div id="paypal-loading" class="text-center py-4 text-sm text-gray-500">
      Loading payment options...
    </div>

    <!-- Error box (hidden by default) -->
    <div id="payment-error-box" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
      <div class="flex items-start gap-3">
        <span class="text-xl">⚠️</span>
        <div>
          <p class="font-semibold">Payment Failed</p>
          <p id="payment-error-msg" class="mt-1 text-red-600">Please try again or use a different payment method.</p>
          <button id="retry-payment-btn" class="mt-3 px-4 py-2 bg-red-100 hover:bg-red-200 text-red-700 rounded-lg text-sm font-medium transition-colors">
            Try Again
          </button>
        </div>
      </div>
    </div>
  </div>
) : (
  <!-- Bypass mode: direct booking without payment -->
  <div>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-4 text-sm text-amber-800">
      💳 <strong>Pay at hotel</strong> — No online payment required. Pay directly at check-in.
    </div>
    <button id="direct-book-btn" type="button"
      class="w-full py-4 px-6 bg-teal-600 hover:bg-teal-700 text-white font-bold rounded-xl text-lg transition-colors flex items-center justify-center gap-2">
      <span id="btn-text">✅ Confirm Booking</span>
      <span id="btn-spinner" class="hidden">
        <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
        </svg>
      </span>
    </button>
    <p class="text-xs text-center text-gray-500 mt-2">Free cancellation · Instant confirmation</p>

    <!-- Error box for direct booking mode -->
    <div id="direct-error-box" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
      <div class="flex items-start gap-3">
        <span class="text-xl">⚠️</span>
        <div>
          <p class="font-semibold">Booking Failed</p>
          <p id="direct-error-msg" class="mt-1 text-red-600">Please try again.</p>
        </div>
      </div>
    </div>
  </div>
)}

</div>

<script define:vars={{ planId, priceUsd, clientId, usePayPal }}>
  function validateForm() {
    const form = document.getElementById('booking-form');
    if (!form) return false;
    const guestName = (form.querySelector('#guest_name') as HTMLInputElement)?.value.trim();
    const guestEmail = (form.querySelector('#guest_email') as HTMLInputElement)?.value.trim();
    const checkInDate = (form.querySelector('#check_in_date') as HTMLInputElement)?.value;
    const adults = parseInt((form.querySelector('#adults') as HTMLSelectElement)?.value || '0');
    const errorEl = document.getElementById('form-error');

    // Check each field individually for better error messages
    const checkinY = (document.getElementById('checkin-y') as HTMLSelectElement)?.value;
    const checkinM = (document.getElementById('checkin-m') as HTMLSelectElement)?.value;
    const checkinD = (document.getElementById('checkin-d') as HTMLSelectElement)?.value;
    const dateSelected = checkinY && checkinM && checkinD;

    let msg = '';
    if (!guestName) msg = 'Please enter your name.';
    else if (!guestEmail) msg = 'Please enter your email address.';
    else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(guestEmail)) msg = 'Please enter a valid email address.';
    else if (!dateSelected || !checkInDate) msg = 'Please select a check-in date (YYYY / MM / DD).';
    else if (adults < 1) msg = 'Please select at least 1 adult.';

    if (msg) {
      if (errorEl) { errorEl.textContent = msg; errorEl.classList.remove('hidden'); }
      return false;
    }
    if (errorEl) errorEl.classList.add('hidden');
    return true;
  }

  if (!usePayPal) {
    // Direct booking (PayPal bypass)
    document.getElementById('direct-book-btn')?.addEventListener('click', async () => {
      if (!validateForm()) return;

      const btn = document.getElementById('direct-book-btn');
      const btnText = document.getElementById('btn-text');
      const spinner = document.getElementById('btn-spinner');
      const errorBox = document.getElementById('direct-error-box');
      const errorMsg = document.getElementById('direct-error-msg');

      btn.disabled = true;
      btnText.textContent = 'Processing...';
      spinner.classList.remove('hidden');
      if (errorBox) errorBox.classList.add('hidden');

      const form = document.getElementById('booking-form');
      const fd = new FormData(form);

      try {
        const res = await fetch('/api/bookings/direct', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            plan_id: planId,
            guest_name: fd.get('guest_name'),
            guest_email: fd.get('guest_email'),
            guest_phone: fd.get('guest_phone') || '',
            check_in_date: fd.get('check_in_date'),
            adults: parseInt(fd.get('adults') || '1'),
            children: parseInt(fd.get('children') || '0'),
            notes: fd.get('notes') || '',
          }),
        });

        const data = await res.json();
        if (res.ok && data.booking_id) {
          window.location.href = `/booking/confirmation?booking_id=${data.booking_id}`;
        } else {
          if (errorBox && errorMsg) {
            errorMsg.textContent = data.error || 'Booking failed. Please try again.';
            errorBox.classList.remove('hidden');
          }
          btn.disabled = false;
          btnText.textContent = '✅ Confirm Booking';
          spinner.classList.add('hidden');
        }
      } catch (e) {
        if (errorBox && errorMsg) {
          errorMsg.textContent = 'Network error. Please check your connection and try again.';
          errorBox.classList.remove('hidden');
        }
        btn.disabled = false;
        btnText.textContent = '✅ Confirm Booking';
        spinner.classList.add('hidden');
      }
    });
  } else {
    // PayPal mode

    function showPaymentError(message: string) {
      const errorBox = document.getElementById('payment-error-box');
      const errorMsg = document.getElementById('payment-error-msg');
      if (errorBox) errorBox.classList.remove('hidden');
      if (errorMsg) errorMsg.textContent = message || 'Please try again or use a different payment method.';
    }

    function hidePaymentError() {
      const errorBox = document.getElementById('payment-error-box');
      if (errorBox) errorBox.classList.add('hidden');
    }

    function renderPayPalButtons() {
      // Clear container before (re-)rendering
      const container = document.getElementById('paypal-button-container');
      if (container) container.innerHTML = '';
      hidePaymentError();

      paypal.Buttons({
        style: { layout: 'vertical', color: 'blue', shape: 'rect', label: 'pay' },
        createOrder: async () => {
          hidePaymentError();
          if (!validateForm()) throw new Error('Form validation failed');
          const form = document.getElementById('booking-form');
          const fd = new FormData(form);
          const res = await fetch('/api/payments/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              plan_id: planId,
              guest_name: fd.get('guest_name'),
              guest_email: fd.get('guest_email'),
              guest_phone: fd.get('guest_phone'),
              check_in_date: fd.get('check_in_date'),
              adults: parseInt(fd.get('adults') || '1'),
              children: parseInt(fd.get('children') || '0'),
              notes: fd.get('notes'),
            }),
          });
          if (!res.ok) throw new Error((await res.json().catch(()=>({}))).error || 'Failed to create order');
          return (await res.json()).order_id;
        },
        onApprove: async (data) => {
          const res = await fetch('/api/payments/capture', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ order_id: data.orderID }),
          });
          if (res.ok) {
            window.location.href = '/booking/confirmation?order=' + data.orderID;
          } else {
            const errData = await res.json().catch(() => ({}));
            showPaymentError(errData.error || 'Payment capture failed. Please contact support if this continues.');
          }
        },
        onError: (err) => {
          if (err.message !== 'Form validation failed') {
            showPaymentError('Payment failed. Please try again or use a different payment method.');
          }
        },
      }).render('#paypal-button-container');
    }

    const script = document.createElement('script');
    script.src = `https://www.paypal.com/sdk/js?client-id=${clientId}&currency=USD`;
    script.onload = () => {
      const loadingEl = document.getElementById('paypal-loading');
      if (loadingEl) loadingEl.style.display = 'none';
      renderPayPalButtons();

      // Wire up the "Try Again" retry button
      document.getElementById('retry-payment-btn')?.addEventListener('click', () => {
        renderPayPalButtons();
      });
    };
    script.onerror = () => {
      const el = document.getElementById('paypal-loading');
      if (el) { el.textContent = 'Failed to load payment. Please refresh.'; el.classList.add('text-red-500'); }
    };
    document.head.appendChild(script);
  }
</script>
