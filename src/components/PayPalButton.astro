---
const { planId, priceUsd, clientId, testMode = false, hotelSlug = '', locale = 'en_US' } = Astro.props || { planId: 0, priceUsd: 0, clientId: '', testMode: false, hotelSlug: '', locale: 'en_US' }
const usePayPal = !testMode && clientId && clientId !== 'sandbox' && clientId.length > 10;
// Adjust isDev definition for broader compatibility
const isDev = (typeof import !== 'undefined' && import.meta && import.meta.env) ? import.meta.env.DEV : false;
console.log(`PayPal Button Initialized - clientId: ${clientId}`);
if (!clientId || clientId === 'sandbox' || clientId.length <= 10) {
  console.warn('Invalid clientId detected:', clientId);
  const el = document.getElementById('paypal-loading');
  if (el) {
    el.innerHTML = `<div style='text-align:center;color:#FF0000;'>Invalid PayPal clientId</div>`;
    el.style.padding = '0';
  }
}
// simulate_error is only available for the test hotel
const isTestHotel = hotelSlug.includes('test-hotel');
---

<!-- Error overlay: shared across all payment modes, fixed center overlay -->
<div id="payment-error-overlay"
  style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); align-items:center; justify-content:center; z-index:9999;">
  <!-- Popup body -->
  <div style="background:white; border-radius:12px; padding:20px; width:calc(100% - 40px); max-width:320px; box-shadow:0 8px 32px rgba(0,0,0,0.24); margin:0 auto;">
    <!-- Icon -->
    <div id="popup-icon" style="width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:12px;font-size:20px;"></div>
    <!-- Title -->
    <p id="popup-title" style="font-size:15px;font-weight:700;color:#111827;margin-bottom:6px;"></p>
    <!-- Body -->
    <p id="popup-body" style="font-size:13px;color:#374151;margin-bottom:4px;"></p>
    <!-- Tip -->
    <p id="popup-tip" style="font-size:12px;color:#6b7280;margin-bottom:16px;"></p>
    <!-- Button 1 (main action) -->
    <button id="popup-btn1"
      style="width:100%;border:0.5px solid #d1d5db;border-radius:8px;padding:10px;font-size:13px;font-weight:500;background:#f9fafb;cursor:pointer;margin-bottom:10px;">
    </button>
    <!-- Button 2 (sub action / text link) -->
    <div style="text-align:center;">
      <button id="popup-btn2"
        style="font-size:12px;text-decoration:underline;border:none;background:none;color:#6b7280;cursor:pointer;padding:0;">
      </button>
    </div>
  </div>
</div>

<div id="payment-wrapper" class="mt-4">

{usePayPal ? (
  <!-- PayPal mode -->
  <div>
    <!-- Card form + PayPal button container -->
    <div id="paypal-card-wrapper" class="relative">
      <div id="paypal-button-container" data-locale={locale}></div>
      <div id="paypal-loading" class="text-center py-4 text-sm text-gray-500">
        Loading payment options...
      </div>
    </div>
  </div>
) : testMode ? (
  <!-- Test mode: simulate PayPal payment -->
  <div>
    <button id="test-pay-btn" type="button"
      class="w-full py-4 px-6 bg-[#003087] hover:bg-[#001f6b] text-white font-bold rounded-xl text-lg transition-colors flex items-center justify-center gap-3">
      <svg class="h-5 w-6" viewBox="0 0 24 24" fill="currentColor">
        <path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106zm14.146-14.42a3.35 3.35 0 0 0-.607-.541c-.013.076-.026.175-.041.254-.93 4.778-4.005 7.201-9.138 7.201h-2.19a.563.563 0 0 0-.556.479l-1.187 7.527h-.506l-.24 1.516a.56.56 0 0 0 .554.647h3.882c.46 0 .85-.334.922-.788.06-.26.76-4.852.816-5.09a.932.932 0 0 1 .923-.788h.58c3.76 0 6.705-1.528 7.565-5.946.36-1.847.174-3.388-.777-4.471z"/>
      </svg>
      <span id="test-btn-text">Pay with PayPal (Test)</span>
      <span id="test-btn-spinner" class="hidden">
        <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="...