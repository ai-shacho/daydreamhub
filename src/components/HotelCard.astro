---
import { t, localePath } from '../lib/i18n';

interface Props {
  hotel: any;
  plans?: any[];
  locale?: string;
}

const { hotel, plans = [], locale = 'en' } = Astro.props;
const displayName = locale === 'ja' && hotel.name_ja ? hotel.name_ja : hotel.name;

let categories: string[] = [];
try {
  const parsed = JSON.parse(hotel.categories);
  if (Array.isArray(parsed)) {
    categories = parsed;
  }
} catch {
  categories = [];
}

const categoryColors: Record<string, string> = {
  workspace: 'bg-blue-100 text-blue-700',
  luxury: 'bg-purple-100 text-purple-700',
  transit: 'bg-green-100 text-green-700',
  couple: 'bg-pink-100 text-pink-700',
  for_couple: 'bg-pink-100 text-pink-700',
  daycation: 'bg-yellow-100 text-yellow-700',
  personal_time: 'bg-orange-100 text-orange-700',
  early_checkin: 'bg-teal-100 text-teal-700',
};

const categoryLabelKeys: Record<string, string> = {
  workspace: 'search.workspace',
  luxury: 'search.luxury',
  transit: 'search.transit',
  couple: 'search.for_couple',
  for_couple: 'search.for_couple',
  daycation: 'search.daycation',
  personal_time: 'search.personal_time',
  early_checkin: 'search.early_checkin',
};

const minPrice = plans.length > 0 ? Math.min(...plans.map((p: any) => p.price_usd)) : null;
const hotelLink = localePath('/hotel/' + hotel.slug, locale);
const imageUrl = hotel.thumbnail_url || '/images/placeholder-hotel.jpg';
---

<div class="bg-white rounded-lg shadow overflow-hidden hover:shadow-lg transition-shadow duration-300">
  <!-- Image -->
  <div class="relative">
    <a href={hotelLink}>
      <div class="w-full aspect-[4/3] overflow-hidden">
        <img src={imageUrl} alt={displayName} loading="lazy" class="w-full h-full object-cover" />
      </div>
    </a>
    <!-- Wishlist heart button -->
    <button
      class="wishlist-btn absolute top-2 right-2 w-8 h-8 flex items-center justify-center bg-white/90 rounded-full shadow hover:scale-110 transition-transform"
      data-slug={hotel.slug}
      title="Save to wishlist"
      aria-label="Save to wishlist"
    >
      <svg class="wishlist-icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
      </svg>
    </button>
  </div>
  <!-- Content -->
  <div class="p-4">
    <!-- Title -->
    <h3 class="text-gray-900 font-semibold text-base mb-1 line-clamp-2">
      <a href={hotelLink} class="hover:text-[#45A2C1] transition-colors">
        {displayName}
      </a>
    </h3>
    <!-- Price -->
    {minPrice !== null && (
      <p class="text-[#45A2C1] font-bold text-lg mb-2">
        {t('hotel.from', locale)} {minPrice} {t('hotel.usd', locale)}
      </p>
    )}
    <!-- Location tags -->
    <div class="flex flex-wrap gap-1 mb-2">
      <span class="text-xs text-gray-500 bg-gray-100 rounded px-2 py-0.5">
        {hotel.city}
      </span>
      <span class="text-xs text-gray-500 bg-gray-100 rounded px-2 py-0.5">
        {hotel.country}
      </span>
    </div>
    <!-- Category badges -->
    {categories.length > 0 && (
      <div class="flex flex-wrap gap-1 mb-3">
        {categories.map((cat) => (
          <span class:list={[
            'text-xs font-medium rounded-full px-2.5 py-0.5',
            categoryColors[cat] || 'bg-gray-100 text-gray-700'
          ]}>
            {t(categoryLabelKeys[cat] || cat, locale)}
          </span>
        ))}
      </div>
    )}
    <!-- Plans list -->
    {plans.length > 0 && (
      <ul class="space-y-1 border-t border-gray-100 pt-2">
        {plans.slice(0, 3).map((plan: any) => {
          const planName = locale === 'ja' && plan.name_ja ? plan.name_ja : plan.name;
          const timeSlot = plan.check_in_time && plan.check_out_time
            ? `${plan.check_in_time} - ${plan.check_out_time}`
            : '';
          return (
            <li class="flex items-center justify-between text-xs text-gray-600">
              <span class="truncate mr-2">{planName}</span>
              {timeSlot && <span class="text-gray-400 whitespace-nowrap">{timeSlot}</span>}
            </li>
          );
        })}
      </ul>
    )}
  </div>
</div>
