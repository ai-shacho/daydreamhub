---
import { t, localePath } from '../lib/i18n';

interface Props {
  hotel: any;
  plans?: any[];
  locale?: string;
  /** min_price を直接渡す場合（plans未ロード時のオーバーライド） */
  minPrice?: number | null;
}

const { hotel, plans = [], locale = 'en', minPrice: minPriceProp } = Astro.props;
const displayName = locale === 'ja' && hotel.name_ja ? hotel.name_ja : hotel.name;

let categories: string[] = [];
try {
  const parsed = JSON.parse(hotel.categories);
  if (Array.isArray(parsed)) categories = parsed;
} catch { categories = []; }

const categoryColors: Record<string, string> = {
  workspace: 'bg-blue-100 text-blue-700',
  luxury: 'bg-purple-100 text-purple-700',
  transit: 'bg-green-100 text-green-700',
  couple: 'bg-pink-100 text-pink-700',
  for_couple: 'bg-pink-100 text-pink-700',
  daycation: 'bg-yellow-100 text-yellow-700',
  personal_time: 'bg-orange-100 text-orange-700',
  early_checkin: 'bg-teal-100 text-teal-700',
};

const categoryLabelKeys: Record<string, string> = {
  workspace: 'search.workspace',
  luxury: 'search.luxury',
  transit: 'search.transit',
  couple: 'search.for_couple',
  for_couple: 'search.for_couple',
  daycation: 'search.daycation',
  personal_time: 'search.personal_time',
  early_checkin: 'search.early_checkin',
};

// プランから最安値を計算。minPriceProp が渡されている場合はそちらを優先。
const plansMinPrice = plans.length > 0
  ? Math.min(...plans.map((p: any) => Number(p.price_usd)).filter(v => !isNaN(v)))
  : null;
const effectiveMinPrice: number | null =
  minPriceProp !== undefined ? minPriceProp : plansMinPrice;

const hotelLink = localePath('/hotel/' + hotel.slug, locale);
const imageUrl = hotel.thumbnail_url || '/images/placeholder-hotel.jpg';

// airport distance (populated by nearestAirport enrichment in some pages)
const airportKm: number | null = hotel._airport_km ?? null;
const airportCode: string | null = hotel._airport_code ?? null;
---

<div class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-gray-100 relative">
  <!-- Image -->
  <a href={hotelLink} class="block">
    <div class="aspect-[4/3] overflow-hidden bg-gray-100">
      <img src={imageUrl} alt={displayName} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
    </div>
  </a>

  <!-- Wishlist button -->
  <button
    class="wishlist-btn absolute top-2 right-2 w-8 h-8 flex items-center justify-center bg-white/90 rounded-full shadow hover:scale-110 transition-transform"
    data-slug={hotel.slug}
    title={locale === 'ja' ? 'ウィッシュリストに保存' : 'Save to wishlist'}
    aria-label={locale === 'ja' ? 'ウィッシュリストに保存' : 'Save to wishlist'}
  >
    <svg class="wishlist-icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
    </svg>
  </button>

  <!-- Content -->
  <a href={hotelLink} class="block p-4">
    <!-- Property type badge -->
    {hotel.property_type && (
      <span class="text-[10px] bg-gray-100 text-gray-500 rounded-full px-2 py-0.5 mb-2 inline-block capitalize">
        {hotel.property_type.replace(/_/g, ' ')}
      </span>
    )}

    <!-- Title -->
    <h3 class="text-gray-900 font-semibold text-sm mb-1 line-clamp-2 group-hover:text-teal-700 transition-colors">
      {displayName}
    </h3>

    <!-- Location -->
    <p class="text-xs text-gray-500 mb-1">
      {hotel.city}{hotel.country ? `, ${hotel.country}` : ''}
    </p>

    <!-- Airport distance (optional) -->
    {airportKm !== null && airportCode !== null && airportKm < 500 && (
      <p class="text-xs text-teal-700 mb-1 flex items-center gap-1">
        <span>✈</span>~{Math.round(airportKm)}km from {airportCode}
      </p>
    )}

    <!-- Rating (optional) -->
    {hotel.rating > 0 && (
      <div class="flex items-center gap-1 mb-1">
        <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        <span class="text-xs font-medium text-gray-700">{hotel.rating.toFixed(1)}</span>
      </div>
    )}

    <!-- Category badges -->
    {categories.length > 0 && (
      <div class="flex flex-wrap gap-1 mb-2">
        {categories.map((cat) => (
          <span class:list={[
            'text-xs font-medium rounded-full px-2.5 py-0.5',
            categoryColors[cat] || 'bg-gray-100 text-gray-700'
          ]}>
            {t(categoryLabelKeys[cat] || cat, locale)}
          </span>
        ))}
      </div>
    )}

    <!-- Price -->
    <div class="flex items-center justify-between mt-2 pt-2 border-t border-gray-100">
      <div>
        {effectiveMinPrice !== null ? (
          <div>
            <span class="text-base font-bold text-teal-700" data-usd={effectiveMinPrice}>
              ${effectiveMinPrice}
            </span>
            <span class="text-base font-bold text-teal-700">〜</span>
          </div>
        ) : (
          <span class="text-xs text-gray-400">
            {locale === 'ja' ? '料金はお問い合わせ' : 'Price on request'}
          </span>
        )}
      </div>
      <span class="text-xs text-teal-700 font-medium">
        {locale === 'ja' ? 'プランを見る →' : 'View Plans →'}
      </span>
    </div>

    <!-- Plans list (optional, when plans loaded separately) -->
    {plans.length > 0 && (
      <ul class="space-y-1 border-t border-gray-100 pt-2 mt-2">
        {plans.slice(0, 3).map((plan: any) => {
          const planName = locale === 'ja' && plan.name_ja ? plan.name_ja : plan.name;
          const timeSlot = plan.check_in_time && plan.check_out_time
            ? `${plan.check_in_time}–${plan.check_out_time}`
            : '';
          return (
            <li class="flex items-center justify-between text-xs text-gray-600">
              <span class="truncate mr-2">{planName}</span>
              {timeSlot && <span class="text-gray-400 whitespace-nowrap">{timeSlot}</span>}
            </li>
          );
        })}
      </ul>
    )}
  </a>
</div>
