---
// Floating chat widget for the homepage
// Connects to /api/concierge/chat (separate from booking form)
---

<!-- Chat Button (floating, bottom-right) -->
<div id="chat-widget" class="fixed bottom-[76px] md:bottom-6 right-6 z-[1100] flex flex-col items-end gap-3">
  <!-- Chat Panel -->
  <div
    id="chat-panel"
    class="hidden w-80 sm:w-96 bg-white rounded-2xl shadow-2xl border border-slate-200 flex-col overflow-hidden"
    style="max-height: 520px;"
  >
    <!-- Header -->
    <div class="bg-teal-600 px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center text-white text-sm font-bold">AI</div>
        <div>
          <p class="text-white font-semibold text-sm">AI Hotel Search</p>
          <p class="text-teal-100 text-xs">Powered by AI · Not a human agent</p>
        </div>
      </div>
      <button id="chat-close" class="text-white/80 hover:text-white transition-colors p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Messages -->
    <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-3" style="min-height:200px; max-height:320px;">
      <!-- Welcome message -->
      <div class="flex gap-2">
        <div class="w-7 h-7 bg-teal-100 rounded-full flex-shrink-0 flex items-center justify-center text-teal-600 text-xs font-bold mt-0.5">AI</div>
        <div class="bg-slate-100 rounded-2xl rounded-tl-none px-3 py-2 text-sm text-slate-700 max-w-[85%]">
          Hi! I'm the DayDreamHub <strong>AI Hotel Search</strong> 🤖<br>Tell me a city, dates, or what you need — I'll find day-use hotels instantly!<br><span class="text-xs text-slate-400 mt-1 block">Need human support? <a href="/contact" class="text-teal-600 underline">Contact Us</a></span>
        </div>
      </div>
    </div>
    <!-- Input -->
    <div class="border-t border-slate-100 p-3 flex gap-2 items-end">
      <textarea
        id="chat-input"
        placeholder="Type a message... (Shift+Enter for new line)"
        class="flex-1 text-sm border border-slate-200 rounded-xl px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-400 bg-white resize-none overflow-hidden min-h-[40px] max-h-[120px]"
        maxlength="500"
        rows="1"
      ></textarea>
      <button
        id="chat-send"
        class="bg-teal-600 hover:bg-teal-700 text-white rounded-xl px-3 py-2 transition-colors flex-shrink-0"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Toggle Button -->
  <button
    id="chat-toggle"
    class="w-14 h-14 bg-teal-600 hover:bg-teal-700 text-white rounded-full shadow-lg flex items-center justify-center transition-all hover:scale-105 active:scale-95"
    aria-label="Open chat"
  >
    <svg id="chat-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>
    <svg id="chat-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
    <!-- Unread badge -->
    <span id="chat-badge" class="absolute -top-1 -right-1 w-5 h-5 bg-amber-500 text-white text-xs rounded-full hidden items-center justify-center font-bold">1</span>
  </button>
</div>

<!-- Call-to-book confirmation card -->
<div id="call-booking-overlay" class="fixed inset-0 z-[1200] bg-black/40 hidden items-center justify-center p-4">
  <div class="w-full max-w-sm bg-white rounded-2xl shadow-xl border border-slate-200 p-4">
    <h3 class="text-sm font-bold text-slate-800 mb-2">AI Call to Book (+$7)</h3>
    <p class="text-xs text-slate-500 mb-3">Please confirm your details before we start calling the hotel.</p>
    <div class="space-y-2">
      <input id="cb-guest-name" type="text" placeholder="Your name" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
      <input id="cb-guest-email" type="email" placeholder="Email" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
      <input id="cb-guest-phone" type="tel" placeholder="Phone number" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
      <input id="cb-guests" type="number" min="1" max="10" value="2" placeholder="Guests" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
      <input id="cb-date" type="date" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
      <div class="grid grid-cols-2 gap-2">
        <input id="cb-checkin" type="time" value="10:00" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
        <input id="cb-checkout" type="time" value="18:00" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
      </div>
    </div>
    <p id="cb-error" class="hidden text-xs text-red-600 mt-2"></p>
    <div class="flex gap-2 mt-4">
      <button id="cb-cancel" class="flex-1 border border-slate-300 rounded-lg py-2 text-sm">Cancel</button>
      <button id="cb-submit" class="flex-1 bg-blue-600 text-white rounded-lg py-2 text-sm font-semibold">Continue</button>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  const sessionId = 'chat_' + Math.random().toString(36).slice(2, 11);
  const pageLocale = window.location.pathname.startsWith('/ja') ? 'ja' : 'en';
  let isOpen = false;
  let isTyping = false;

  const panel = document.getElementById('chat-panel');
  const toggle = document.getElementById('chat-toggle');
  const closeBtn = document.getElementById('chat-close');
  const input = document.getElementById('chat-input');
  const sendBtn = document.getElementById('chat-send');
  const messages = document.getElementById('chat-messages');
  const iconOpen = document.getElementById('chat-icon-open');
  const iconClose = document.getElementById('chat-icon-close');
  const badge = document.getElementById('chat-badge');
  const callOverlay = document.getElementById('call-booking-overlay');
  const callCancelBtn = document.getElementById('cb-cancel');
  const callSubmitBtn = document.getElementById('cb-submit');
  const callErr = document.getElementById('cb-error');

  let latestExternalHotels = [];
  let selectedExternalHotel = null;

  function openChat() {
    isOpen = true;
    panel.classList.remove('hidden');
    panel.classList.add('flex');
    iconOpen.classList.add('hidden');
    iconClose.classList.remove('hidden');
    badge.classList.add('hidden');
    setTimeout(() => input.focus(), 100);
  }

  function closeChat() {
    isOpen = false;
    panel.classList.add('hidden');
    panel.classList.remove('flex');
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
  }

  toggle.addEventListener('click', () => isOpen ? closeChat() : openChat());
  closeBtn.addEventListener('click', closeChat);

  function renderMarkdown(text) {
    if (!text) return '';

    // 0. Clean orphaned HTML attribute fragments before any other processing
    // Handles: /hotel/slug" target="_blank" class="...">Label
    let out = text.replace(/(\/hotel\/[\w-]+)"[^>]*>(.*?)(?=\s|$)/g, function(_, slug, afterText) {
      var label = afterText.replace(/<[^>]+>/g, '').trim() || 'Book Now';
      return '[' + label + '](' + slug + ')';
    });

    // 1. Strip remaining HTML tags
    out = out.replace(/<[^>]*>/g, '');

    // 2. **bold** → <strong>
    out = out.replace(/\*\*([^*<>\n]+)\*\*/g, '<strong>$1</strong>');

    // 3. [label](url) → <a>
    out = out.replace(/\[([^\]\n]+)\]\(([^)]+)\)/gi, function(_, label, rawHref) {
      // Strip any HTML attribute fragments that crept into the URL
      var cleanHref = rawHref
        .replace(/"[^"]*$/, '')
        .replace(/'\s*[a-z].*$/, '')
        .replace(/<[^>]*>/g, '')
        .replace(/\s+target\s*=.*$/, '')
        .replace(/\s+class\s*=.*$/, '')
        .trim();
      var finalHref = (cleanHref.startsWith('/') || cleanHref.startsWith('http')) ? cleanHref : '/' + cleanHref;
      return '<a href="' + finalHref + '" class="text-teal-600 underline hover:text-teal-800 font-semibold">' + label + '</a>';
    });

    // 4. Bare /hotel/slug paths → link (fallback, after Markdown links already handled)
    out = out.replace(/(^|[\s—–-])(\/hotel\/[a-z0-9-]+)(?=[\s—–\n,.]|$)/gm, function(_, pre, path) {
      var linkText = pageLocale === 'ja' ? '予約する' : 'Book Now';
      return pre + '<a href="' + path + '" class="text-teal-600 underline hover:text-teal-800 font-semibold">' + linkText + '</a>';
    });

    // 5. \n → <br>
    out = out.replace(/\n/g, '<br>');
    return out;
  }

  function addMessage(text, role, metadata) {
    const wrap = document.createElement('div');
    wrap.className = 'flex gap-2' + (role === 'user' ? ' flex-row-reverse' : '');

    if (role === 'assistant') {
      const avatar = document.createElement('div');
      avatar.className = 'w-7 h-7 bg-teal-100 rounded-full flex-shrink-0 flex items-center justify-center text-teal-600 text-xs font-bold mt-0.5';
      avatar.textContent = 'AI';

      const bubble = document.createElement('div');
      bubble.className = 'bg-slate-100 rounded-2xl rounded-tl-none px-3 py-2 text-sm text-slate-700 max-w-[85%]';
      bubble.innerHTML = renderMarkdown(text);

      // Task #47: render hotel cards from structured data
      const metaHotels = (metadata && Array.isArray(metadata.hotels) && metadata.hotels.length > 0) ? metadata.hotels : null;
      if (metaHotels) {
        const internal = metaHotels.filter(h => h.source === 'internal');
        const external = metaHotels.filter(h => h.source === 'external');
        let cardsHtml = '';
        if (internal.length > 0) {
          cardsHtml += internal.map(h => {
            const price = h.min_price ? ` · $${h.min_price}〜` : '';
            return `<a href="/hotel/${h.slug}" class="flex items-center justify-between bg-white border border-teal-100 rounded-xl px-3 py-2 mt-2 hover:bg-teal-50 transition-colors">
              <span class="font-semibold text-teal-700 text-xs">${h.name}</span>
              <span class="text-teal-500 text-xs font-bold">${price} 予約 →</span>
            </a>`;
          }).join('');
        }
        if (external.length > 0) {
          const extLabel = pageLocale === 'ja' ? 'AI電話予約（+$7）' : 'AI Call to Book (+$7)';
          latestExternalHotels = external.slice(0, 3);
          cardsHtml += `<div class="mt-2 space-y-1">` + latestExternalHotels.map((h, idx) =>
            `<div class="bg-white border border-slate-200 rounded-xl px-3 py-2 text-xs">
              <span class="font-semibold block">${h.name}</span>
              <span class="text-slate-400">${h.phone || ''}</span>
              <button data-call-book-index="${idx}" class="mt-2 w-full text-center bg-blue-500 hover:bg-blue-600 text-white rounded-lg py-1.5 text-xs font-bold">${extLabel}</button>
            </div>`
          ).join('') + `</div>`;
        }
        if (cardsHtml) bubble.innerHTML += cardsHtml;
      }

      wrap.appendChild(avatar);
      wrap.appendChild(bubble);
    } else {
      wrap.innerHTML = `
        <div class="bg-teal-600 text-white rounded-2xl rounded-tr-none px-3 py-2 text-sm max-w-[85%] whitespace-pre-wrap">${text}</div>
      `;
    }
    messages.appendChild(wrap);
    messages.scrollTop = messages.scrollHeight;
  }

  function hideCallOverlay() {
    selectedExternalHotel = null;
    callOverlay.classList.add('hidden');
    callOverlay.classList.remove('flex');
    callErr.classList.add('hidden');
    callErr.textContent = '';
  }

  function showCallOverlay(hotel) {
    selectedExternalHotel = hotel;
    callOverlay.classList.remove('hidden');
    callOverlay.classList.add('flex');
    const dateInput = document.getElementById('cb-date');
    if (dateInput && !dateInput.value) {
      const d = new Date();
      d.setDate(d.getDate() + 1);
      dateInput.value = d.toISOString().slice(0, 10);
    }
  }

  async function submitCallBooking() {
    const guestName = (document.getElementById('cb-guest-name').value || '').trim();
    const guestEmail = (document.getElementById('cb-guest-email').value || '').trim();
    const guestPhone = (document.getElementById('cb-guest-phone').value || '').trim();
    const guests = Number(document.getElementById('cb-guests').value || 0);
    const checkInDate = (document.getElementById('cb-date').value || '').trim();
    const checkInTime = (document.getElementById('cb-checkin').value || '10:00').trim();
    const checkOutTime = (document.getElementById('cb-checkout').value || '18:00').trim();

    if (!selectedExternalHotel) return;
    if (!guestName || !guestEmail || !guestPhone || !guests || !checkInDate) {
      callErr.textContent = pageLocale === 'ja'
        ? '氏名・メール・電話番号・人数・日付を入力してください。'
        : 'Please enter name, email, phone, guests, and date.';
      callErr.classList.remove('hidden');
      return;
    }

    callSubmitBtn.disabled = true;
    try {
      const payload = {
        session_id: sessionId,
        locale: pageLocale,
        message: '__create_call_group_direct',
        guests,
        guest_phone: guestPhone,
        _call_group: {
          guest_name: guestName,
          guest_email: guestEmail,
          guest_phone: guestPhone,
          guests,
          adults: guests,
          children: 0,
          check_in_date: checkInDate,
          check_in_time: checkInTime,
          check_out_time: checkOutTime,
          hotels: [{
            hotel_name: selectedExternalHotel.name,
            hotel_phone: selectedExternalHotel.phone || '',
            hotel_source: 'external',
            recommendation_reason: 'Requested via chat call-to-book card'
          }]
        }
      };

      const res = await fetch('/api/concierge/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      hideCallOverlay();
      if (data.paypal_url) {
        const groupId = data.group_id;
        const paypalOrderId = data.paypal_order_id;
        const win = window.open(data.paypal_url, '_blank', 'noopener,noreferrer');
        if (!win) {
          addMessage(pageLocale === 'ja' ? 'ポップアップを許可してPayPal決済を完了してください。' : 'Please allow popups and complete PayPal payment.', 'assistant');
          return;
        }

        addMessage(
          pageLocale === 'ja'
            ? 'PayPal決済ページを開きました。決済完了を自動確認し、確認後にAIがホテルへ電話します。'
            : 'Opened PayPal checkout. We will auto-detect payment completion and start AI calling right away.',
          'assistant'
        );

        let paid = false;
        const startedAt = Date.now();
        while (!paid && Date.now() - startedAt < 3 * 60 * 1000) {
          await new Promise((r) => setTimeout(r, 5000));
          try {
            const capRes = await fetch('/api/concierge/pay', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                action: 'capture',
                order_id: paypalOrderId,
                group_id: groupId,
                session_id: sessionId,
                guest_name: guestName,
                guest_email: guestEmail,
              }),
            });
            const capData = await capRes.json();
            if (capData.status === 'paid') {
              paid = true;
              const callRes = await fetch('/api/concierge/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  session_id: sessionId,
                  message: '__confirm_group_payment:' + groupId,
                  locale: pageLocale,
                  guest_name: guestName,
                  guest_email: guestEmail,
                  guest_phone: guestPhone,
                  guests,
                  details: { guest_phone: guestPhone, guests },
                }),
              });
              const callData = await callRes.json();
              const replyText = callData?.response || (pageLocale === 'ja'
                ? '✅ 決済を確認しました。AIがホテルへの架電を開始します。結果はメールでお知らせします。'
                : '✅ Payment confirmed. AI calling has started. We will email you the result.');
              addMessage(replyText, 'assistant', callData?.metadata);
            }
          } catch (_err) {
            // keep polling until timeout
          }
        }

        if (!paid) {
          addMessage(
            pageLocale === 'ja'
              ? '決済確認に時間がかかっています。決済完了後に自動で処理されます。数分後に再度お試しください。'
              : 'Payment confirmation is taking longer than expected. It will be processed automatically after checkout. Please check again in a few minutes.',
            'assistant'
          );
        }
      } else {
        const replyText = data.response || (pageLocale === 'ja' ? 'AI電話予約を開始しました。' : 'AI phone booking started.');
        addMessage(replyText, 'assistant');
      }
    } catch (_e) {
      callErr.textContent = pageLocale === 'ja' ? '送信に失敗しました。再度お試しください。' : 'Failed to submit. Please try again.';
      callErr.classList.remove('hidden');
    } finally {
      callSubmitBtn.disabled = false;
    }
  }

  function addTyping() {
    const el = document.createElement('div');
    el.id = 'typing-indicator';
    el.className = 'flex gap-2';
    el.innerHTML = `
      <div class="w-7 h-7 bg-teal-100 rounded-full flex-shrink-0 flex items-center justify-center text-teal-600 text-xs font-bold mt-0.5">AI</div>
      <div class="bg-slate-100 rounded-2xl rounded-tl-none px-3 py-2 text-sm text-slate-500 flex items-center gap-1">
        <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay:0ms"></span>
        <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay:150ms"></span>
        <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay:300ms"></span>
      </div>
    `;
    messages.appendChild(el);
    messages.scrollTop = messages.scrollHeight;
  }

  function removeTyping() {
    const el = document.getElementById('typing-indicator');
    if (el) el.remove();
  }

  async function sendMessage() {
    const text = input.value.trim();
    if (!text || isTyping) return;

    input.value = '';
    input.style.height = 'auto';
    addMessage(text, 'user');
    isTyping = true;
    sendBtn.disabled = true;
    addTyping();

    try {
      const res = await fetch('/api/concierge/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ session_id: sessionId, message: text, locale: pageLocale }),
      });
      const data = await res.json();
      removeTyping();
      const replyText = data.response || data.reply || data.message || (data.error ? "⚠️ " + data.error : "Sorry, something went wrong. Please try again.");
      addMessage(replyText, "assistant", data.metadata);
    } catch (e) {
      removeTyping();
      addMessage('Connection error. Please try again.', 'assistant');
    } finally {
      isTyping = false;
      sendBtn.disabled = false;
      input.focus();
    }
  }

  // Auto-resize textarea
  input.addEventListener('input', () => {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 120) + 'px';
  });

  messages.addEventListener('click', (e) => {
    const target = e.target;
    if (!target || !(target instanceof HTMLElement)) return;
    const idx = target.getAttribute('data-call-book-index');
    if (idx == null) return;
    const hotel = latestExternalHotels[Number(idx)];
    if (hotel) showCallOverlay(hotel);
  });

  callCancelBtn.addEventListener('click', hideCallOverlay);
  callSubmitBtn.addEventListener('click', submitCallBooking);
  callOverlay.addEventListener('click', (e) => {
    if (e.target === callOverlay) hideCallOverlay();
  });

  sendBtn.addEventListener('click', sendMessage);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  });

  // Show badge after 3 seconds if not opened
  setTimeout(() => {
    if (!isOpen) badge.classList.replace('hidden', 'flex');
  }, 3000);
})();
</script>