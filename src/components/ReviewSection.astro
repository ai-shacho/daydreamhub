---
import { t } from '../lib/i18n';

interface Props {
  hotelId: number;
  reviews: any[];
  avgRating: number;
  reviewCount: number;
  locale: string;
  ratingDistribution?: Record<number, number>;
}

const { hotelId, reviews, avgRating, reviewCount, locale, ratingDistribution } = Astro.props;

const ratingBreakdown = [5, 4, 3, 2, 1].map((star) => {
  const count = ratingDistribution ? (ratingDistribution[star] || 0) : reviews.filter((r: any) => r.rating === star).length;
  const total = reviewCount || reviews.length;
  const percentage = total > 0 ? Math.round((count / total) * 100) : 0;
  return { star, count, percentage };
});

function formatDate(dateStr: string, loc: string) {
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString(loc === 'ja' ? 'ja-JP' : 'en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  } catch {
    return dateStr;
  }
}
---

<section class="mb-10" id="reviews-section">
  <h2 class="text-xl font-bold text-slate-900 mb-6">
    {t('review.title', locale)}
  </h2>

  <!-- Rating Summary -->
  <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
    <div class="flex flex-col sm:flex-row gap-8">
      <!-- Average Rating Display -->
      <div class="flex flex-col items-center justify-center min-w-[140px]">
        <div class="text-4xl font-bold text-slate-900 mb-1">
          {avgRating > 0 ? avgRating.toFixed(1) : '-'}
        </div>
        <div class="flex items-center gap-0.5 mb-1" aria-label={locale === 'ja' ? `${avgRating}点（5点満点）` : `${avgRating} out of 5 stars`}>
          {[1, 2, 3, 4, 5].map((star) => (
            <svg class={`w-5 h-5 ${star <= Math.round(avgRating) ? 'text-yellow-500' : 'text-gray-300'}`} fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <div class="text-sm text-gray-500">
          {t('review.reviews_count', locale).replace('{count}', String(reviewCount))}
        </div>
      </div>

      <!-- Rating Breakdown -->
      <div class="flex-1 space-y-2">
        {ratingBreakdown.map(({ star, count, percentage }) => (
          <div class="flex items-center gap-3">
            <span class="text-sm text-gray-600 w-12 text-right">{star} {locale === 'ja' ? '' : star === 1 ? 'star' : 'stars'}</span>
            <div class="flex-1 bg-gray-200 rounded-full h-2.5">
              <div class="bg-teal-600 h-2.5 rounded-full transition-all" style={`width: ${percentage}%`}></div>
            </div>
            <span class="text-sm text-gray-500 w-8">{count}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Reviews List -->
  <div
    id="reviews-list"
    data-hotel-id={hotelId}
    data-locale={locale}
    data-msg-select-rating={t('review.select_rating', locale)}
    data-msg-thank-you={t('review.thank_you', locale)}
    data-msg-submit-error={t('review.submit_error', locale)}
    data-msg-load-more={t('review.load_more', locale)}
    data-msg-verified={t('review.verified', locale)}
  >
    {reviews.length === 0 ? (
      <div class="text-center py-8 text-gray-500">
        <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
        </svg>
        <p>{t('review.no_reviews', locale)}</p>
      </div>
    ) : (
      <div class="space-y-4" id="reviews-container">
        {reviews.map((review: any) => (
          <div class="border border-gray-200 rounded-lg p-5 bg-white">
            <div class="flex items-start justify-between mb-2">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-medium text-slate-900">{review.guest_name}</span>
                  {review.is_verified === 1 && (
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                      </svg>
                      {t('review.verified', locale)}
                    </span>
                  )}
                </div>
                <div class="flex items-center gap-0.5">
                  {[1, 2, 3, 4, 5].map((star) => (
                    <svg class={`w-4 h-4 ${star <= review.rating ? 'text-yellow-500' : 'text-gray-300'}`} fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
              </div>
              <span class="text-xs text-gray-400">{formatDate(review.created_at, locale)}</span>
            </div>
            {review.title && <h4 class="font-semibold text-slate-800 mb-1">{review.title}</h4>}
            {review.comment && <p class="text-gray-600 text-sm leading-relaxed">{review.comment}</p>}
            {review.owner_reply && (
              <div class="mt-3 pl-4 border-l-2 border-indigo-200">
                <p class="text-xs font-medium text-indigo-600 mb-1">{locale === 'ja' ? 'オーナーからの返信' : 'Owner Response'}</p>
                <p class="text-sm text-slate-600">{review.owner_reply}</p>
              </div>
            )}
          </div>
        ))}
      </div>
    )}

    <!-- Load More Button -->
    {reviewCount > reviews.length && (
      <div class="text-center mt-6">
        <button
          id="load-more-reviews"
          class="inline-flex items-center px-6 py-2.5 border border-teal-700 text-teal-700 font-medium rounded-lg hover:bg-teal-50 transition-colors text-sm"
          data-page="1"
          data-hotel-id={hotelId}
        >
          {t('review.load_more', locale)}
        </button>
      </div>
    )}
  </div>

  <!-- Write a Review (guests only) -->
  <div class="mt-8 border border-gray-200 rounded-lg p-6 bg-white text-center">
    <div class="text-3xl mb-3">⭐</div>
    <h3 class="text-base font-semibold text-slate-900 mb-2">
      {locale === 'ja' ? 'ご利用されましたか？感想をシェアしてください' : 'Stayed here? Share your experience'}
    </h3>
    <p class="text-sm text-gray-500 mb-4">
      {locale === 'ja'
        ? 'レビューは、このホテルで予約を完了したゲストのみ投稿できます。'
        : 'Reviews can only be submitted by guests who have completed a booking at this hotel.'}
    </p>
    <a href={locale === 'ja' ? '/ja/mypage' : '/mypage'} class="inline-flex items-center gap-2 bg-teal-700 hover:bg-teal-800 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
      {locale === 'ja' ? '予約履歴を見る' : 'View My Bookings'}
    </a>
  </div>
</section>

<script>
  // Star rating interaction
  (function() {
    const starBtns = document.querySelectorAll('#star-rating-input .star-btn');
    const ratingInput = document.getElementById('rating-value') as HTMLInputElement;
    let selectedRating = 0;

    starBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedRating = parseInt(btn.getAttribute('data-value')!);
        if (ratingInput) ratingInput.value = String(selectedRating);
        updateStars(selectedRating);
      });

      btn.addEventListener('mouseenter', () => {
        const hoverValue = parseInt(btn.getAttribute('data-value')!);
        updateStars(hoverValue);
      });

      btn.addEventListener('mouseleave', () => {
        updateStars(selectedRating);
      });
    });

    function updateStars(value: number) {
      starBtns.forEach((btn) => {
        const starValue = parseInt(btn.getAttribute('data-value')!);
        const svg = btn.querySelector('svg');
        if (svg) {
          svg.classList.toggle('text-yellow-500', starValue <= value);
          svg.classList.toggle('text-gray-300', starValue > value);
        }
      });
    }

    // Review form submission
    const form = document.getElementById('review-form') as HTMLFormElement;
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const msgEl = document.getElementById('review-form-message');
        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

        const formData = new FormData(form);
        const hotelId = form.getAttribute('data-hotel-id');
        const rating = formData.get('rating');

        if (!rating || rating === '0') {
          const reviewsList = document.getElementById('reviews-list');
          const selectRatingMsg = reviewsList?.getAttribute('data-msg-select-rating') || 'Please select a rating';
          showMessage(msgEl, selectRatingMsg, 'error');
          return;
        }

        if (submitBtn) submitBtn.disabled = true;

        try {
          const res = await fetch('/api/reviews', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              hotel_id: Number(hotelId),
              guest_name: formData.get('guest_name'),
              guest_email: formData.get('guest_email'),
              rating: Number(rating),
              title: formData.get('title') || null,
              comment: formData.get('comment') || null,
            }),
          });

          const data = await res.json();

          if (res.ok) {
            const reviewsList = document.getElementById('reviews-list');
            const thankYouMsg = reviewsList?.getAttribute('data-msg-thank-you') || 'Thank you for your review!';
            showMessage(msgEl, thankYouMsg, 'success');
            form.reset();
            selectedRating = 0;
            updateStars(0);
            if (ratingInput) ratingInput.value = '';
          } else {
            showMessage(msgEl, data.error || 'Failed to submit review', 'error');
          }
        } catch (err) {
          const reviewsList = document.getElementById('reviews-list');
          const errorMsg = reviewsList?.getAttribute('data-msg-submit-error') || 'An error occurred. Please try again.';
          showMessage(msgEl, errorMsg, 'error');
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });
    }

    function showMessage(el: HTMLElement | null, msg: string, type: string) {
      if (!el) return;
      el.textContent = msg;
      el.className = 'mb-4 px-4 py-3 rounded-lg text-sm ' +
        (type === 'success'
          ? 'bg-green-50 border border-green-200 text-green-700'
          : 'bg-red-50 border border-red-200 text-red-700');
    }

    // Load more reviews
    const loadMoreBtn = document.getElementById('load-more-reviews') as HTMLButtonElement;
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener('click', async () => {
        const hotelId = loadMoreBtn.getAttribute('data-hotel-id');
        let page = parseInt(loadMoreBtn.getAttribute('data-page') || '1');
        page += 1;

        loadMoreBtn.disabled = true;
        loadMoreBtn.textContent = '...';

        try {
          const res = await fetch(`/api/reviews?hotel_id=${hotelId}&page=${page}&limit=5`);
          const data = await res.json();

          if (res.ok && data.reviews && data.reviews.length > 0) {
            const container = document.getElementById('reviews-container');
            const reviewsList = document.getElementById('reviews-list');
            const locale = reviewsList ? reviewsList.getAttribute('data-locale') : 'en';

            data.reviews.forEach((review: any) => {
              const div = document.createElement('div');
              div.className = 'border border-gray-200 rounded-lg p-5 bg-white';

              const dateStr = formatDateJS(review.created_at, locale || 'en');
              const verifiedText = reviewsList?.getAttribute('data-msg-verified') || 'Verified Booking';
              const verifiedBadge = review.is_verified === 1
                ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                    ${verifiedText}
                  </span>`
                : '';

              const stars = [1,2,3,4,5].map(s =>
                `<svg class="w-4 h-4 ${s <= review.rating ? 'text-yellow-500' : 'text-gray-300'}" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>`
              ).join('');

              const ownerReplyLabel = locale === 'ja' ? 'オーナーからの返信' : 'Owner Response';
              const ownerReplyHtml = review.owner_reply
                ? `<div class="mt-3 pl-4 border-l-2 border-indigo-200">
                    <p class="text-xs font-medium text-indigo-600 mb-1">${ownerReplyLabel}</p>
                    <p class="text-sm text-slate-600">${escapeHtml(review.owner_reply)}</p>
                  </div>`
                : '';

              div.innerHTML = `
                <div class="flex items-start justify-between mb-2">
                  <div>
                    <div class="flex items-center gap-2 mb-1">
                      <span class="font-medium text-slate-900">${escapeHtml(review.guest_name)}</span>
                      ${verifiedBadge}
                    </div>
                    <div class="flex items-center gap-0.5">${stars}</div>
                  </div>
                  <span class="text-xs text-gray-400">${dateStr}</span>
                </div>
                ${review.title ? `<h4 class="font-semibold text-slate-800 mb-1">${escapeHtml(review.title)}</h4>` : ''}
                ${review.comment ? `<p class="text-gray-600 text-sm leading-relaxed">${escapeHtml(review.comment)}</p>` : ''}
                ${ownerReplyHtml}
              `;

              container?.appendChild(div);
            });

            loadMoreBtn.setAttribute('data-page', String(page));

            // Hide button if no more reviews
            if (!data.hasMore) {
              loadMoreBtn.style.display = 'none';
            }
          } else {
            loadMoreBtn.style.display = 'none';
          }
        } catch (err) {
          console.error('Failed to load more reviews:', err);
        } finally {
          loadMoreBtn.disabled = false;
          const reviewsList = document.getElementById('reviews-list');
          loadMoreBtn.textContent = reviewsList?.getAttribute('data-msg-load-more') || 'Load More Reviews';
        }
      });
    }

    function formatDateJS(dateStr: string, locale: string) {
      try {
        const date = new Date(dateStr);
        return date.toLocaleDateString(locale === 'ja' ? 'ja-JP' : 'en-US', {
          year: 'numeric', month: 'long', day: 'numeric'
        });
      } catch { return dateStr; }
    }

    function escapeHtml(str: string) {
      if (!str) return '';
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }
  })();
</script>
