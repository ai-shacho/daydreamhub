<div id="assign-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/60" id="assign-backdrop"></div>
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md">
      <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-slate-900">Assign Owner</h2>
        <button id="assign-close" class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
      </div>
      <div class="p-6 space-y-4">
        <p class="text-sm text-slate-500">Hotel: <strong id="assign-hotel-name"></strong></p>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Search Owner</label>
          <input id="assign-search" type="text" placeholder="Owner name or email..."
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" autocomplete="off" />
          <div id="assign-suggestions" class="border border-slate-200 rounded-lg mt-1 max-h-40 overflow-y-auto hidden"></div>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Owner Email</label>
          <input id="assign-email" type="email" placeholder="owner@example.com"
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" />
        </div>
        <div id="assign-error" class="hidden bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-3 py-2"></div>
        <div class="flex gap-3">
          <button id="assign-cancel" class="flex-1 py-2 border border-slate-200 rounded-lg text-sm text-slate-600 hover:bg-slate-50">Cancel</button>
          <button id="assign-save" class="flex-1 py-2 bg-teal-600 text-white rounded-lg text-sm font-medium hover:bg-teal-700">Assign</button>
        </div>
      </div>
    </div>
  </div>
</div>
