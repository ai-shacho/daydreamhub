<script>
  document.querySelectorAll('.status-select').forEach((sel) => {
    sel.addEventListener('change', async () => {
      const id = sel.getAttribute('data-id');
      const newStatus = sel.value;

      try {
        const res = await fetch('/api/admin/hotels', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: Number(id), status: newStatus }),
        });

        if (!res.ok) {
          const data = await res.json();
          alert('Failed: ' + (data.error || 'Unknown error'));
          location.reload();
        }
      } catch {
        alert('Network error');
        location.reload();
      }
    });
  });

  document.querySelectorAll('.delete-hotel-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      const name = btn.getAttribute('data-name');

      if (!confirm(`"${name}" を削除してもよいですか？\nこの操作は取り消せません。関連するプランや予約もすべて削除されます。`)) return;

      const deleteBtn = btn as HTMLButtonElement;
      const origText = deleteBtn.textContent;
      deleteBtn.disabled = true;
      deleteBtn.textContent = '削除中...';

      try {
        const res = await fetch(`/api/admin/hotels?id=${id}`, {
          method: 'DELETE',
        });

        let data: any = {};
        try { data = await res.json(); } catch {}

        if (res.ok) {
          const row = deleteBtn.closest('tr');
          if (row) row.remove();
          const countEl = document.querySelector('.hotel-count');
          if (countEl) {
            const n = Math.max(0, parseInt(countEl.textContent || '0') - 1);
            countEl.textContent = `${n} hotel${n !== 1 ? 's' : ''} found`;
          }
        } else {
          const reason = data.details ? `${data.error}: ${data.details}` : (data.error || '不明なエラー');
          alert(`削除に失敗しました\n${reason}`);
          deleteBtn.disabled = false;
          deleteBtn.textContent = origText;
        }
      } catch {
        alert('ネットワークエラーが発生しました。再試行してください。');
        deleteBtn.disabled = false;
        deleteBtn.textContent = origText;
      }
    });
  });

  const assignModal = document.getElementById('assign-modal')!;
  let assignHotelId: string | null = null;

  function openAssign(id: string, name: string, email: string) {
    assignHotelId = id;
    (document.getElementById('assign-hotel-name') as HTMLElement).textContent = name;
    (document.getElementById('assign-email') as HTMLInputElement).value = email || '';
    (document.getElementById('assign-search') as HTMLInputElement).value = '';
    document.getElementById('assign-suggestions')!.classList.add('hidden');
    document.getElementById('assign-error')!.classList.add('hidden');
    assignModal.classList.remove('hidden');
    (document.getElementById('assign-search') as HTMLInputElement).focus();
  }
  function closeAssign() { assignModal.classList.add('hidden'); }

  let searchTimer: any = null;
  const searchInput = document.getElementById('assign-search') as HTMLInputElement;
  const suggestions = document.getElementById('assign-suggestions') as HTMLElement;

  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTimer);
    const q = searchInput.value.trim();
    if (q.length < 2) { suggestions.classList.add('hidden'); return; }
    searchTimer = setTimeout(async () => {
      try {
        const res = await fetch(`/api/admin/users?search=${encodeURIComponent(q)}&role=owner&limit=10`);
        const data = await res.json();
        const users = data.users || [];
        if (users.length === 0) {
          suggestions.innerHTML = '<div class="px-3 py-2 text-xs text-slate-400">No owners found</div>';
        } else {
          suggestions.innerHTML = users.map((u: any) =>
            `<div class="owner-suggestion px-3 py-2 hover:bg-teal-50 cursor-pointer text-sm border-b border-slate-100 last:border-0" data-email="${u.email}">
              <span class="font-medium text-slate-800">${u.name}</span>
              <span class="text-xs text-slate-400 ml-2">${u.email}</span>
            </div>`
          ).join('');
          suggestions.querySelectorAll('.owner-suggestion').forEach(el => {
            el.addEventListener('click', () => {
              (document.getElementById('assign-email') as HTMLInputElement).value = el.getAttribute('data-email') || '';
              searchInput.value = el.querySelector('.font-medium')?.textContent || '';
              suggestions.classList.add('hidden');
            });
          });
        }
        suggestions.classList.remove('hidden');
      } catch {}
    }, 300);
  });

  document.querySelectorAll('.assign-owner-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      openAssign(
        btn.getAttribute('data-id') || '',
        btn.getAttribute('data-name') || '',
        btn.getAttribute('data-email') || ''
      );
    });
  });

  document.getElementById('assign-close')?.addEventListener('click', closeAssign);
  document.getElementById('assign-backdrop')?.addEventListener('click', closeAssign);
  document.getElementById('assign-cancel')?.addEventListener('click', closeAssign);

  document.getElementById('assign-save')?.addEventListener('click', async () => {
    if (!assignHotelId) return;
    const email = (document.getElementById('assign-email') as HTMLInputElement).value.trim();
    const errEl = document.getElementById('assign-error')!;
    errEl.classList.add('hidden');

    if (!email) { errEl.textContent = 'Email is required'; errEl.classList.remove('hidden'); return; }

    const btn = document.getElementById('assign-save') as HTMLButtonElement;
    btn.textContent = 'Assigning...'; btn.disabled = true;

    try {
      const res = await fetch(`/api/admin/hotels/${assignHotelId}/assign-owner`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ owner_email: email }),
      });
      const data = await res.json();
      if (res.ok) {
        location.reload();
      } else {
        errEl.textContent = data.error || 'Failed to assign owner';
        errEl.classList.remove('hidden');
      }
    } catch {
      errEl.textContent = 'Network error';
      errEl.classList.remove('hidden');
    }
    btn.textContent = 'Assign'; btn.disabled = false;
  });
</script>
