---
import Layout from '../layouts/Layout.astro';

const env = (Astro.locals as any).runtime?.env;
const RESEND_API_KEY = env?.RESEND_API_KEY || '';
const ADMIN_EMAIL = env?.ADMIN_EMAIL || 'info@daydreamhub.com';

let success = false;
let error = '';

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const name = (form.get('name') || '').toString().trim();
    const email = (form.get('email') || '').toString().trim();
    const subject = (form.get('subject') || '').toString().trim();
    const message = (form.get('message') || '').toString().trim();
    const category = (form.get('category') || 'general').toString();

    if (!name || !email || !message) {
      error = 'Please fill in all required fields.';
    } else if (RESEND_API_KEY) {
      const html = `
<div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto">
  <h2 style="color:#0d9488">New Contact Inquiry — DaydreamHub</h2>
  <table style="border-collapse:collapse;width:100%;margin:16px 0">
    <tr><td style="padding:8px 12px;border:1px solid #ddd;font-weight:bold;background:#f9f9f9;width:30%">Category</td><td style="padding:8px 12px;border:1px solid #ddd">${category}</td></tr>
    <tr><td style="padding:8px 12px;border:1px solid #ddd;font-weight:bold;background:#f9f9f9">Name</td><td style="padding:8px 12px;border:1px solid #ddd">${name}</td></tr>
    <tr><td style="padding:8px 12px;border:1px solid #ddd;font-weight:bold;background:#f9f9f9">Email</td><td style="padding:8px 12px;border:1px solid #ddd">${email}</td></tr>
    <tr><td style="padding:8px 12px;border:1px solid #ddd;font-weight:bold;background:#f9f9f9">Subject</td><td style="padding:8px 12px;border:1px solid #ddd">${subject || '-'}</td></tr>
    <tr><td style="padding:8px 12px;border:1px solid #ddd;font-weight:bold;background:#f9f9f9">Message</td><td style="padding:8px 12px;border:1px solid #ddd;white-space:pre-wrap">${message}</td></tr>
  </table>
</div>`;
      const res = await fetch('https://api.resend.com/emails', {
        method: 'POST',
        headers: { Authorization: `Bearer ${RESEND_API_KEY}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({
          from: 'DaydreamHub Contact <noreply@daydreamhub.com>',
          to: [ADMIN_EMAIL],
          reply_to: email,
          subject: `[Contact] ${category} — ${name}: ${subject || message.slice(0, 50)}`,
          html,
        }),
      });
      if (res.ok) {
        success = true;
      } else {
        error = 'Failed to send message. Please try again.';
      }
    } else {
      error = 'Email service not configured. Please contact us directly.';
    }
  } catch (e) {
    error = 'An error occurred. Please try again.';
  }
}
---

<Layout title="Contact Us — DaydreamHub" description="Contact DaydreamHub support team for booking help, partnership inquiries, or general questions.">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="text-center mb-10">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">Contact Us</h1>
      <p class="text-gray-500 max-w-xl mx-auto">Have a question about your booking, want to list your property, or just need help? We're here for you.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Left: Contact cards -->
      <div class="space-y-4">
        <a href="/concierge" class="group block rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300">
          <div class="relative h-36 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1677129666186-d29eba893fe3?w=600&q=80" alt="AI Concierge" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-teal-900/70 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-4">
              <h3 class="font-bold text-white text-base">AI Concierge</h3>
            </div>
          </div>
          <div class="bg-white border border-gray-100 px-4 py-3">
            <p class="text-sm text-gray-500">Find hotels, check availability, get instant recommendations 24/7.</p>
            <span class="text-xs font-semibold text-teal-600 mt-2 inline-block">Ask the AI →</span>
          </div>
        </a>

        <a href="/mypage" class="group block rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300">
          <div class="relative h-36 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1617368483303-100123b1d5b6?w=600&q=80" alt="Booking Status" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/70 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-4">
              <h3 class="font-bold text-white text-base">Booking Status</h3>
            </div>
          </div>
          <div class="bg-white border border-gray-100 px-4 py-3">
            <p class="text-sm text-gray-500">Already booked? Check your booking status in My Page.</p>
            <span class="text-xs font-semibold text-teal-600 mt-2 inline-block">View My Bookings →</span>
          </div>
        </a>

        <a href="/faq" class="group block rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300">
          <div class="relative h-36 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1768397003975-973cabec2818?w=600&q=80" alt="FAQ" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/70 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-4">
              <h3 class="font-bold text-white text-base">FAQ</h3>
            </div>
          </div>
          <div class="bg-white border border-gray-100 px-4 py-3">
            <p class="text-sm text-gray-500">Find answers to common questions about day-use hotel bookings.</p>
            <span class="text-xs font-semibold text-teal-600 mt-2 inline-block">View FAQ →</span>
          </div>
        </a>
      </div>

      <!-- Right: Contact Form -->
      <div class="md:col-span-2">
        {success ? (
          <div class="bg-teal-50 border border-teal-200 rounded-xl p-8 text-center">
            <div class="text-5xl mb-4">✅</div>
            <h2 class="text-xl font-bold text-teal-800 mb-2">Message Sent!</h2>
            <p class="text-teal-600 mb-6">We'll get back to you within 24 hours.</p>
            <a href="/" class="inline-block bg-teal-600 hover:bg-teal-700 text-white font-semibold px-6 py-2.5 rounded-lg transition-colors">Back to Home</a>
          </div>
        ) : (
          <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-gray-800 mb-5">Send a Message</h2>

            {error && (
              <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm mb-4">{error}</div>
            )}

            <form method="POST" class="space-y-4">
              <!-- Notice -->
              <div class="bg-amber-50 border border-amber-200 rounded-lg px-3 py-2 text-xs text-amber-700 space-y-1">
                <p>⚠️ This form is for general inquiries only. We are unable to respond to booking requests or availability checks. To make a reservation, please use the <a href="/search" class="underline hover:text-amber-900">hotel search</a>.</p>
                <p>🚫 Sales and solicitation messages will not be accepted or responded to.</p>
              </div>

              <!-- Category -->
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Category <span class="text-red-500">*</span></label>
                <select name="category" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-teal-400 outline-none bg-white">
                  <option value="booking">Booking / Reservation Question</option>
                  <option value="payment">Payment Issue</option>
                  <option value="property">List My Property</option>
                  <option value="general">General Inquiry</option>
                </select>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Name <span class="text-red-500">*</span></label>
                  <input type="text" name="name" required placeholder="Your name"
                    class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-teal-400 outline-none" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Email <span class="text-red-500">*</span></label>
                  <input type="email" name="email" required placeholder="your@email.com"
                    class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-teal-400 outline-none" />
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
                <input type="text" name="subject" placeholder="Brief summary of your question"
                  class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-teal-400 outline-none" />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Message <span class="text-red-500">*</span></label>
                <textarea name="message" required rows="5" placeholder="Please describe your question or issue in detail..."
                  class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-teal-400 outline-none resize-none"></textarea>
              </div>

              <button type="submit"
                class="w-full bg-teal-600 hover:bg-teal-700 text-white font-semibold py-3 rounded-lg transition-colors text-sm">
                Send Message
              </button>
            </form>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>
