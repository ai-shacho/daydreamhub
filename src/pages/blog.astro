---
import Layout from '../layouts/Layout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getLocale, t, localePath } from '../lib/i18n';

const locale = getLocale(Astro.url);
const url = Astro.url;
const cityFilter = url.searchParams.get('city') || '';
const countryFilter = url.searchParams.get('country') || '';
const page = Math.max(1, parseInt(url.searchParams.get('page') || '1'));
const perPage = 12;
const offset = (page - 1) * perPage;

let posts: any[] = [];
let total = 0;
let dbAvailable = false;
let blogCities: any[] = [];
let blogCountries: string[] = [];

try {
  const runtime = (Astro.locals as any).runtime;
  const db = runtime?.env?.DB;
  if (db) {
    dbAvailable = true;
    // Fetch cities with blog post counts
    const citiesResult = await db.prepare(
      `SELECT city, COUNT(*) as cnt FROM blog_posts
       WHERE city != '' AND city IS NOT NULL
       GROUP BY city ORDER BY city ASC LIMIT 30`
    ).all();
    blogCities = citiesResult?.results || [];

    // Fetch countries from hotels table for city→country mapping
    const countriesResult = await db.prepare(
      `SELECT DISTINCT country FROM hotels WHERE country IS NOT NULL AND country != '' ORDER BY country`
    ).all();
    blogCountries = (countriesResult?.results || []).map((r: any) => r.country);

    const whereClauses: string[] = [];
    const params: any[] = [];
    if (cityFilter) {
      whereClauses.push('city LIKE ?');
      params.push(`%${cityFilter}%`);
    }
    if (countryFilter) {
      // Map country to cities via hotels table
      const citiesForCountry = await db.prepare(
        `SELECT DISTINCT city FROM hotels WHERE country = ? AND city != ''`
      ).bind(countryFilter).all();
      const cityList = (citiesForCountry?.results || []).map((r: any) => `'${r.city.replace(/'/g, "''")}'`);
      if (cityList.length > 0) {
        whereClauses.push(`city IN (${cityList.join(',')})`);
      } else {
        whereClauses.push('1=0'); // no results if country has no cities
      }
    }
    const whereStr = whereClauses.length > 0 ? 'WHERE ' + whereClauses.join(' AND ') : '';

    const countResult = params.length
      ? await db.prepare(`SELECT COUNT(*) as count FROM blog_posts ${whereStr}`).bind(...params).first()
      : await db.prepare(`SELECT COUNT(*) as count FROM blog_posts ${whereStr}`).first();
    total = countResult?.count || 0;

    const result = params.length
      ? await db.prepare(
          `SELECT id, title, title_ja, slug, excerpt, city, thumbnail_url, published_at
           FROM blog_posts ${whereStr}
           ORDER BY published_at DESC LIMIT ? OFFSET ?`
        ).bind(...params, perPage, offset).all()
      : await db.prepare(
          `SELECT id, title, title_ja, slug, excerpt, city, thumbnail_url, published_at
           FROM blog_posts ${whereStr}
           ORDER BY published_at DESC LIMIT ? OFFSET ?`
        ).bind(perPage, offset).all();
    posts = result?.results || [];
  }
} catch (e) {
  dbAvailable = false;
}

if (!dbAvailable) {
  const samplePosts = [
    {
      id: 1,
      title: 'Best Day-Use Hotels in Bangkok for Remote Work',
      title_ja: 'バンコクでリモートワークに最適なデイユースホテル',
      slug: 'best-dayuse-hotels-bangkok-remote-work',
      excerpt: 'Discover the top hotels in Bangkok that offer comfortable workspaces, high-speed WiFi, and flexible day-use plans perfect for digital nomads.',
      excerpt_ja: 'バンコクでリモートワークに最適な、快適なワークスペースと高速Wi-Fiを備えたホテルをご紹介。デジタルノマドにぴったりのデイユースプランが揃っています。',
      city: 'Bangkok',
      thumbnail_url: 'https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&q=80',
      published_at: '2025-01-15T09:00:00Z',
    },
    {
      id: 2,
      title: 'Singapore Airport Transit Hotels: A Complete Guide',
      title_ja: 'シンガポール空港トランジットホテル完全ガイド',
      slug: 'singapore-airport-transit-hotels-guide',
      excerpt: 'Everything you need to know about transit hotels near Changi Airport, including pricing, amenities, and booking tips for layovers.',
      excerpt_ja: 'チャンギ空港近くのトランジットホテルについて、料金・設備・予約のコツまで徹底解説。乗り継ぎ時間を快適に過ごしましょう。',
      city: 'Singapore',
      thumbnail_url: 'https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=800&q=80',
      published_at: '2025-01-10T09:00:00Z',
    },
    {
      id: 3,
      title: 'Romantic Day-Use Hotels in Bali for Couples',
      title_ja: 'バリ島カップルにおすすめのデイユースホテル',
      slug: 'romantic-dayuse-hotels-bali-couples',
      excerpt: 'Looking for a romantic daytime escape in Bali? Here are the best day-use hotels and villas perfect for couples seeking privacy and luxury.',
      excerpt_ja: 'バリ島でロマンチックなひとときを。プライバシーと贅沢を求めるカップルにぴったりのデイユースホテル＆ヴィラを厳選しました。',
      city: 'Bali',
      thumbnail_url: 'https://images.unsplash.com/photo-1529543544282-ea669407fca3?w=800&q=80',
      published_at: '2025-01-05T09:00:00Z',
    },
    {
      id: 4,
      title: 'Top Luxury Day-Use Hotels in Kuala Lumpur',
      title_ja: 'クアラルンプールのラグジュアリーデイユースホテルTOP',
      slug: 'luxury-dayuse-hotels-kuala-lumpur',
      excerpt: 'Experience five-star luxury without the overnight stay. These Kuala Lumpur hotels offer premium day-use packages with spa, pool, and dining.',
      excerpt_ja: '宿泊なしで五つ星の贅沢を。クアラルンプールのトップホテルが提供するスパ・プール・ダイニング付きのプレミアムデイユースプランをご紹介。',
      city: 'Kuala Lumpur',
      thumbnail_url: 'https://images.unsplash.com/photo-1571896349842-33c89424de2d?w=800&q=80',
      published_at: '2024-12-28T09:00:00Z',
    },
    {
      id: 5,
      title: 'How to Book Day-Use Hotels: A Beginner Guide',
      title_ja: 'デイユースホテルの予約方法：初心者ガイド',
      slug: 'how-to-book-dayuse-hotels-beginner-guide',
      excerpt: 'New to day-use hotel booking? This guide covers everything from finding the right hotel to making the most of your short stay.',
      excerpt_ja: 'デイユースホテルが初めての方へ。ホテルの選び方から短時間滞在を最大限楽しむコツまで、すべてをわかりやすく解説します。',
      city: '',
      thumbnail_url: 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800&q=80',
      published_at: '2024-12-20T09:00:00Z',
    },
    {
      id: 6,
      title: 'Hong Kong Daycation: Pool & Spa Day Passes',
      title_ja: '香港デイケーション：プール＆スパのデイパス',
      slug: 'hong-kong-daycation-pool-spa-day-passes',
      excerpt: 'Enjoy a refreshing daycation in Hong Kong with pool and spa day passes at top hotels. Perfect for a weekend escape without leaving the city.',
      excerpt_ja: '香港のトップホテルでプール＆スパのデイパスを利用して、街を離れずに週末リフレッシュ。デイケーションを思う存分楽しもう。',
      city: 'Hong Kong',
      thumbnail_url: 'https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=800&q=80',
      published_at: '2024-12-15T09:00:00Z',
    },
  ];
  let filtered = samplePosts;
  if (cityFilter) {
    const cf = cityFilter.toLowerCase();
    filtered = filtered.filter((p) => p.city?.toLowerCase().includes(cf));
  }
  total = filtered.length;
  posts = filtered.slice(offset, offset + perPage);
}

const totalPages = Math.ceil(total / perPage);

function buildPageUrl(pageNum: number) {
  const params = new URLSearchParams();
  if (cityFilter) params.set('city', cityFilter);
  if (pageNum > 1) params.set('page', String(pageNum));
  const qs = params.toString();
  const basePath = localePath('/blog', locale);
  return qs ? `${basePath}?${qs}` : basePath;
}

function getPageNumbers(current: number, totalPg: number) {
  if (totalPg <= 7) {
    return Array.from({ length: totalPg }, (_, i) => i + 1);
  }
  const pages: (number | string)[] = [];
  if (current <= 4) {
    for (let i = 1; i <= 5; i++) pages.push(i);
    pages.push('...');
    pages.push(totalPg);
  } else if (current >= totalPg - 3) {
    pages.push(1);
    pages.push('...');
    for (let i = totalPg - 4; i <= totalPg; i++) pages.push(i);
  } else {
    pages.push(1);
    pages.push('...');
    for (let i = current - 1; i <= current + 1; i++) pages.push(i);
    pages.push('...');
    pages.push(totalPg);
  }
  return pages;
}

const pageNumbers = getPageNumbers(page, totalPages);
const resultsText = t('blog.posts_found', locale).replace('{count}', String(total));
---

<Layout title={t('blog.title', locale)} description={t('blog.title', locale)}>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <!-- Header -->
      <div class="mb-6">
        <h1 class="text-3xl font-bold text-gray-800">
          {t('blog.title', locale)}
        </h1>
        <p class="text-sm text-gray-500 mt-2">{resultsText}</p>
      </div>

      <!-- Search by City Cards -->
      {blogCities.length > 0 && !cityFilter && !countryFilter && (
        <div class="mb-6">
          <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Browse by City</h2>
          <div class="flex flex-wrap gap-2">
            {blogCities.map((c: any) => (
              <a
                href={`/blog?city=${encodeURIComponent(c.city)}`}
                class="group inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-gray-200 rounded-full text-xs font-medium text-gray-600 hover:border-teal-400 hover:text-teal-700 hover:bg-teal-50 transition-all"
              >
                <svg class="w-3 h-3 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                {c.city}
                <span class="text-gray-400">({c.cnt})</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Filters -->
      <div class="mb-6 flex flex-wrap gap-3 items-end">
        <!-- Country filter -->
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Country</label>
          <select
            onchange="window.location.href='/blog?country='+this.value"
            class="px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-teal-400"
          >
            <option value="">All Countries</option>
            {blogCountries.map((c: string) => (
              <option value={c} selected={c === countryFilter}>{c}</option>
            ))}
          </select>
        </div>
        <!-- City search input -->
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">City</label>
          <form method="GET" action="/blog" class="flex gap-2">
            {countryFilter && <input type="hidden" name="country" value={countryFilter} />}
            <input
              type="text"
              name="city"
              value={cityFilter}
              placeholder="Search city..."
              class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 w-40"
            />
            <button type="submit" class="px-3 py-2 bg-teal-600 text-white rounded-lg text-sm hover:bg-teal-700 transition-colors">
              Search
            </button>
          </form>
        </div>
        <!-- Active filters -->
        {(cityFilter || countryFilter) && (
          <div class="flex items-center gap-2 flex-wrap">
            {countryFilter && (
              <span class="flex items-center gap-1 bg-teal-50 text-teal-700 text-xs font-medium rounded-full px-3 py-1">
                {countryFilter}
                <a href={cityFilter ? `/blog?city=${cityFilter}` : '/blog'} class="hover:text-teal-900">✕</a>
              </span>
            )}
            {cityFilter && (
              <span class="flex items-center gap-1 bg-blue-50 text-blue-700 text-xs font-medium rounded-full px-3 py-1">
                {cityFilter}
                <a href={countryFilter ? `/blog?country=${countryFilter}` : '/blog'} class="hover:text-blue-900">✕</a>
              </span>
            )}
          </div>
        )}
      </div>

      {posts.length > 0 ? (
        <>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {posts.map((post) => (
              <BlogCard post={post} locale={locale} />
            ))}
          </div>

          {totalPages > 1 && (
            <nav class="mt-10 flex justify-center" aria-label="Pagination">
              <ul class="flex items-center gap-1.5">
                <!-- Previous -->
                <li>
                  {page > 1 ? (
                    <a href={buildPageUrl(page - 1)} class="inline-flex items-center px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                      <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                      </svg>
                      {t('search.previous', locale)}
                    </a>
                  ) : (
                    <span class="inline-flex items-center px-3 py-2 text-sm font-medium text-gray-400 bg-gray-100 border border-gray-200 rounded-lg cursor-not-allowed">
                      <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                      </svg>
                      {t('search.previous', locale)}
                    </span>
                  )}
                </li>
                <!-- Page numbers -->
                {pageNumbers.map((p) => (
                  <li>
                    {p === '...' ? (
                      <span class="inline-flex items-center justify-center w-10 h-10 text-sm text-gray-500">...</span>
                    ) : p === page ? (
                      <span class="inline-flex items-center justify-center w-10 h-10 text-sm font-medium text-white bg-[#45A2C1] rounded-lg">
                        {p}
                      </span>
                    ) : (
                      <a href={buildPageUrl(p as number)} class="inline-flex items-center justify-center w-10 h-10 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                        {p}
                      </a>
                    )}
                  </li>
                ))}
                <!-- Next -->
                <li>
                  {page < totalPages ? (
                    <a href={buildPageUrl(page + 1)} class="inline-flex items-center px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                      {t('search.next', locale)}
                      <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  ) : (
                    <span class="inline-flex items-center px-3 py-2 text-sm font-medium text-gray-400 bg-gray-100 border border-gray-200 rounded-lg cursor-not-allowed">
                      {t('search.next', locale)}
                      <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </span>
                  )}
                </li>
              </ul>
            </nav>
          )}
        </>
      ) : (
        <!-- No posts message -->
        <div class="text-center py-16">
          <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
          <h2 class="text-xl font-semibold text-gray-600 mb-2">
            {t('blog.no_posts', locale)}
          </h2>
          <p class="text-gray-400 max-w-md mx-auto">
            {t('blog.no_posts_desc', locale)}
          </p>
        </div>
      )}
    </div>
  </section>

</Layout>
