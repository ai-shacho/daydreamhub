---
import Layout from '../layouts/Layout.astro';
---

<Layout title="List Your Property - DayDreamHub" description="Apply to list your hotel or property on DayDreamHub and connect with travelers across Asia.">

<div class="bg-teal-50 py-10 sm:py-14">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-3">Owner Application Form</h1>
    <p class="text-gray-600">Fill in the form below and we'll get back to you shortly to set up your listing.</p>
  </div>
</div>

<div class="max-w-2xl mx-auto px-4 sm:px-6 py-10">
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
    <form id="owner-application-form" class="space-y-8">

      <!-- Property Information -->
      <div>
        <h2 class="text-base font-semibold text-teal-700 uppercase tracking-wide mb-4 pb-2 border-b border-gray-100">Property Information</h2>
        <div class="space-y-4">
          <div>
            <label for="hotel_name" class="block text-sm font-medium text-slate-700 mb-1.5">Hotel Name <span class="text-red-500">*</span></label>
            <input id="hotel_name" name="hotel_name" type="text" required placeholder="Your hotel or property name"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
          </div>
          <div>
            <label for="booking_email" class="block text-sm font-medium text-slate-700 mb-1.5">Email for Booking Management <span class="text-red-500">*</span></label>
            <p class="text-xs text-gray-500 mb-1.5">We will send reservation notifications to this address. Please use your reservation management email.</p>
            <input id="booking_email" name="booking_email" type="email" required placeholder="reservations@yourhotel.com"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
          </div>
          <div>
            <label for="hotel_phone" class="block text-sm font-medium text-slate-700 mb-1.5">Hotel Phone Number <span class="text-red-500">*</span></label>
            <p class="text-xs text-gray-500 mb-1.5">Please include the country code (e.g. +1, +81).</p>
            <input id="hotel_phone" name="hotel_phone" type="tel" required placeholder="+81-3-1234-5678"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
          </div>
          <div>
            <label for="site_url" class="block text-sm font-medium text-slate-700 mb-1.5">Website URL <span class="text-gray-400">(optional)</span></label>
            <p class="text-xs text-gray-500 mb-1.5">If not provided, we will contact you via the phone number on this form.</p>
            <input id="site_url" name="site_url" type="url" placeholder="https://yourhotel.com"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
          </div>
          <div>
            <label for="management_company" class="block text-sm font-medium text-slate-700 mb-1.5">Name of Management Company <span class="text-gray-400">(optional)</span></label>
            <input id="management_company" name="management_company" type="text" placeholder="Company name if applicable"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
          </div>
        </div>
      </div>

      <!-- Contact Person -->
      <div>
        <h2 class="text-base font-semibold text-teal-700 uppercase tracking-wide mb-4 pb-2 border-b border-gray-100">Contact Person</h2>
        <div class="space-y-4">
          <div>
            <label for="contact_name" class="block text-sm font-medium text-slate-700 mb-1.5">Name of Contact Person <span class="text-red-500">*</span></label>
            <input id="contact_name" name="contact_name" type="text" required placeholder="Full name"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
          </div>
          <div>
            <label for="contact_email" class="block text-sm font-medium text-slate-700 mb-1.5">Contact Person's Email <span class="text-red-500">*</span></label>
            <input id="contact_email" name="contact_email" type="email" required placeholder="contact@example.com"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
          </div>
          <div>
            <label for="contact_phone" class="block text-sm font-medium text-slate-700 mb-1.5">Contact Person's Direct Phone <span class="text-red-500">*</span></label>
            <input id="contact_phone" name="contact_phone" type="tel" required placeholder="+81-90-1234-5678"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
          </div>
          <div>
            <label for="contact_method" class="block text-sm font-medium text-slate-700 mb-1.5">Preferred Contact Method (other than email) <span class="text-red-500">*</span></label>
            <select id="contact_method" name="contact_method" required
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all bg-white">
              <option value="">Select a method</option>
              <option value="WhatsApp">WhatsApp</option>
              <option value="Messenger">Messenger</option>
              <option value="LINE">LINE</option>
              <option value="Other SNS">Other SNS</option>
              <option value="Phone">Phone only</option>
            </select>
          </div>
          <div>
            <label for="messenger_url" class="block text-sm font-medium text-slate-700 mb-1.5">Messenger URL</label>
            <input id="messenger_url" name="messenger_url" type="url" placeholder="https://m.me/yourpage"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
          </div>
          <div>
            <label for="whatsapp_url" class="block text-sm font-medium text-slate-700 mb-1.5">WhatsApp URL</label>
            <input id="whatsapp_url" name="whatsapp_url" type="url" placeholder="https://wa.me/your_number"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
          </div>
          <div>
            <label for="line_url" class="block text-sm font-medium text-slate-700 mb-1.5">LINE URL</label>
            <input id="line_url" name="line_url" type="url" placeholder="https://line.me/ti/p/..."
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
          </div>
          <div>
            <label for="other_sns_url" class="block text-sm font-medium text-slate-700 mb-1.5">Other SNS URL</label>
            <input id="other_sns_url" name="other_sns_url" type="url" placeholder="https://..."
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
          </div>
        </div>
      </div>

      <!-- Payment -->
      <div>
        <h2 class="text-base font-semibold text-teal-700 uppercase tracking-wide mb-4 pb-2 border-b border-gray-100">Payment from DayDreamHub</h2>
        <div class="space-y-4">
          <div>
            <label for="payment_method" class="block text-sm font-medium text-slate-700 mb-1.5">Preferred Payment Method <span class="text-red-500">*</span></label>
            <select id="payment_method" name="payment_method" required
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all bg-white">
              <option value="">Select a method</option>
              <option value="PayPal">PayPal</option>
              <option value="Wise">Wise</option>
              <option value="Payoneer">Payoneer</option>
              <option value="VCC">VCC (Virtual Credit Card)</option>
            </select>
          </div>
          <div id="payment-account-fields" class="space-y-4">
            <div>
              <label for="paypal_account" class="block text-sm font-medium text-slate-700 mb-1.5">PayPal Account</label>
              <input id="paypal_account" name="paypal_account" type="text" placeholder="PayPal email or account ID"
                class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
            </div>
            <div>
              <label for="wise_account" class="block text-sm font-medium text-slate-700 mb-1.5">Wise Account</label>
              <input id="wise_account" name="wise_account" type="text" placeholder="Wise email or account details"
                class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
            </div>
            <div>
              <label for="payoneer_account" class="block text-sm font-medium text-slate-700 mb-1.5">Payoneer Account</label>
              <input id="payoneer_account" name="payoneer_account" type="text" placeholder="Payoneer email or account details"
                class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
            </div>
          </div>
          <div id="vcc-notice" class="hidden bg-teal-50 border border-teal-200 text-teal-700 text-sm rounded-lg px-4 py-3">
            ✅ VCC (Virtual Credit Card) selected. We will provide your virtual card details after approval.
          </div>
        </div>
      </div>

      <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3"></div>
      <div id="form-success" class="hidden bg-green-50 border border-green-200 text-green-700 text-sm rounded-lg px-4 py-3"></div>

      <button type="submit" id="submit-btn"
        class="w-full bg-teal-600 hover:bg-teal-700 text-white font-semibold py-3 rounded-xl transition-colors text-base">
        Submit Application
      </button>

      <p class="text-center text-xs text-gray-400">
        By submitting, you agree to our
        <a href="/privacy" class="text-teal-600 hover:underline">Privacy Policy</a> and
        <a href="/terms" class="text-teal-600 hover:underline">Terms of Service</a>.
      </p>
    </form>
  </div>
</div>

</Layout>

<script is:inline>
// VCC toggle
document.getElementById('payment_method')?.addEventListener('change', function () {
  const isVCC = this.value === 'VCC';
  document.getElementById('payment-account-fields').style.display = isVCC ? 'none' : '';
  document.getElementById('vcc-notice').className = isVCC
    ? 'block bg-teal-50 border border-teal-200 text-teal-700 text-sm rounded-lg px-4 py-3'
    : 'hidden bg-teal-50 border border-teal-200 text-teal-700 text-sm rounded-lg px-4 py-3';
});

document.getElementById('owner-application-form')?.addEventListener('submit', async function (e) {
  e.preventDefault();
  const btn = document.getElementById('submit-btn');
  const errEl = document.getElementById('form-error');
  const successEl = document.getElementById('form-success');

  errEl.className = 'hidden';
  successEl.className = 'hidden';
  btn.disabled = true;
  btn.textContent = 'Sending...';

  const fields = [
    'hotel_name', 'booking_email', 'hotel_phone', 'site_url', 'management_company',
    'contact_name', 'contact_email', 'contact_phone', 'contact_method',
    'messenger_url', 'whatsapp_url', 'line_url', 'other_sns_url',
    'payment_method', 'paypal_account', 'wise_account', 'payoneer_account',
  ];
  const body = {};
  for (const f of fields) {
    body[f] = document.getElementById(f)?.value || '';
  }

  try {
    const res = await fetch('/api/owner-application', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json();
    if (res.ok && data.success) {
      successEl.className = 'block bg-green-50 border border-green-200 text-green-700 text-sm rounded-lg px-4 py-3';
      successEl.textContent = '✅ Your application has been submitted! We will be in touch soon.';
      document.getElementById('owner-application-form').reset();
    } else {
      errEl.className = 'block bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3';
      errEl.textContent = data.error || 'Something went wrong. Please try again.';
    }
  } catch {
    errEl.className = 'block bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3';
    errEl.textContent = 'Connection error. Please try again.';
  } finally {
    btn.disabled = false;
    btn.textContent = 'Submit Application';
  }
});
</script>
