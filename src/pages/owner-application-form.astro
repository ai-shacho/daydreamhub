---
import Layout from '../layouts/Layout.astro';
---

<Layout title="List Your Property - DayDreamHub" description="Apply to list your hotel or property on DayDreamHub and connect with travelers across Asia.">

<div class="bg-teal-50 py-10 sm:py-14">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-3">Owner Application Form</h1>
    <p class="text-gray-600">Fill in the form below and we'll get back to you shortly to set up your listing.</p>
  </div>
</div>

<div class="max-w-2xl mx-auto px-4 sm:px-6 py-10">
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
    <form id="owner-application-form" class="space-y-8">

      <!-- Property Information -->
      <div>
        <h2 class="text-base font-semibold text-teal-700 uppercase tracking-wide mb-4 pb-2 border-b border-gray-100">Property Information</h2>
        <div class="space-y-4">
          <div>
            <label for="hotel_name" class="block text-sm font-medium text-slate-700 mb-1.5">Property Name <span class="text-red-500">*</span></label>
