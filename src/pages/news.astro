---
import Layout from '../layouts/Layout.astro';

const db = (Astro.locals as any).runtime?.env?.DB;
let news: any[] = [];

if (db) {
  try {
    const result = await db.prepare(
      "SELECT * FROM news WHERE published_at IS NOT NULL ORDER BY published_at DESC LIMIT 50"
    ).all();
    news = result?.results || [];
  } catch {}
}

const categoryColors: Record<string, string> = {
  update: "bg-blue-100 text-blue-700",
  blog: "bg-teal-100 text-teal-700",
  policy: "bg-amber-100 text-amber-700",
  feature: "bg-purple-100 text-purple-700",
  maintenance: "bg-slate-100 text-slate-600",
};

function formatDate(dateStr: string): string {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title="What's New - DayDreamHub" description="Latest updates, announcements, and news from DayDreamHub.">
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">What's New</h1>
    <p class="text-gray-500 mb-8">Latest updates, announcements, and news from DayDreamHub.</p>

    {news.length === 0 ? (
      <div class="text-center py-16 text-gray-400">
        <p class="text-lg">No news yet. Check back soon!</p>
      </div>
    ) : (
      <div class="space-y-6">
        {news.map((n: any) => (
          <article class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center gap-3 mb-3">
              <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${categoryColors[n.category] || "bg-slate-100 text-slate-600"}`}>{n.category}</span>
              <time class="text-xs text-gray-400">{formatDate(n.published_at)}</time>
            </div>
            <h2 class="text-lg font-semibold text-gray-900 mb-2">{n.title}</h2>
            {n.content && (
              <p class="text-sm text-gray-600 leading-relaxed whitespace-pre-line">{n.content}</p>
            )}
          </article>
        ))}
      </div>
    )}
  </div>
</Layout>
