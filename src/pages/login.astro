---
import Layout from '../layouts/Layout.astro';

const redirectTo = Astro.url.searchParams.get('redirect') || '/';
const isOwnerLogin = redirectTo.startsWith('/owner');
const isAdminLogin = redirectTo.startsWith('/admin');
---
<Layout
  title={isOwnerLogin ? "Owner Portal Login - DayDreamHub" : isAdminLogin ? "Admin Login - DayDreamHub" : "Login - DayDreamHub"}
  description="Sign in to your DayDreamHub account."
>
  <div class="min-h-[80vh] flex items-center justify-center px-4 py-12 bg-slate-50">
    <div class="w-full max-w-md">

      {isOwnerLogin ? (
        <!-- Owner Login Header -->
        <div class="text-center mb-8">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-indigo-600 text-white text-3xl mb-4 shadow-lg">
            🏨
          </div>
          <h1 class="text-2xl font-bold text-slate-900">Owner Portal</h1>
          <p class="text-slate-500 text-sm mt-1">Sign in to manage your hotel</p>
          <a href="/" class="inline-flex items-center gap-1.5 mt-3 text-xs text-slate-400 hover:text-slate-600 transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
            Back to DayDreamHub
          </a>
        </div>
      ) : isAdminLogin ? (
        <!-- Admin Login Header -->
        <div class="text-center mb-8">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-slate-800 text-white text-3xl mb-4 shadow-lg">
            ⚙️
          </div>
          <h1 class="text-2xl font-bold text-slate-900">Admin Panel</h1>
          <p class="text-slate-500 text-sm mt-1">Sign in to manage the platform</p>
          <a href="/" class="inline-flex items-center gap-1.5 mt-3 text-xs text-slate-400 hover:text-slate-600 transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
            Back to DayDreamHub
          </a>
        </div>
      ) : (
        <!-- General Login Header -->
        <div class="text-center mb-8">
          <a href="/" class="inline-flex items-center gap-2 text-2xl font-bold text-teal-700">
            <svg class="w-9 h-9" viewBox="0 0 32 32" fill="none">
              <circle cx="16" cy="16" r="14" fill="#f59e0b"/>
              <path d="M10 20 Q16 10 22 20" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round"/>
              <circle cx="16" cy="13" r="3" fill="white"/>
            </svg>
            DayDreamHub
          </a>
          <p class="text-slate-500 text-sm mt-2">Sign in to your account</p>
        </div>
      )}

      <div class={`bg-white rounded-2xl shadow-sm border p-8 ${isOwnerLogin ? 'border-indigo-200' : isAdminLogin ? 'border-slate-300' : 'border-slate-200'}`}>

        {isOwnerLogin && (
          <div class="mb-5 p-3 bg-indigo-50 border border-indigo-200 rounded-xl text-sm text-indigo-700 text-center">
            🏨 Hotel Owner Portal — manage bookings, plans, and reviews
          </div>
        )}

        <form id="login-form" class="space-y-5">
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">Email</label>
            <input id="email" name="email" type="email" required autocomplete="email"
              placeholder="you@example.com"
              class={`w-full px-4 py-2.5 border rounded-xl text-sm focus:ring-2 focus:border-transparent outline-none transition-all ${isOwnerLogin ? 'border-slate-300 focus:ring-indigo-400' : 'border-slate-300 focus:ring-teal-400'}`} />
          </div>
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label for="password" class="block text-sm font-medium text-slate-700">Password</label>
              <a href="/forgot-password" class={`text-xs hover:underline ${isOwnerLogin ? 'text-indigo-600' : 'text-teal-600'}`}>Forgot password?</a>
            </div>
            <input id="password" name="password" type="password" required autocomplete="current-password"
              placeholder="••••••••"
              class={`w-full px-4 py-2.5 border rounded-xl text-sm focus:ring-2 focus:border-transparent outline-none transition-all ${isOwnerLogin ? 'border-slate-300 focus:ring-indigo-400' : 'border-slate-300 focus:ring-teal-400'}`} />
          </div>
          <div id="login-error" class="hidden bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3"></div>
          <button type="submit" id="login-btn"
            class={`w-full text-white font-semibold py-3 rounded-xl transition-colors ${isOwnerLogin ? 'bg-indigo-600 hover:bg-indigo-700' : isAdminLogin ? 'bg-slate-800 hover:bg-slate-900' : 'bg-teal-600 hover:bg-teal-700'}`}>
            Sign In
          </button>
        </form>

        {!isOwnerLogin && !isAdminLogin && (
          <>
            <div class="mt-6 text-center">
              <p class="text-sm text-slate-500">
                Don't have an account?
                <a href="/register" class="text-teal-600 font-medium hover:underline ml-1">Create one</a>
              </p>
            </div>

            <div class="relative my-6">
              <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-slate-200"></div></div>
              <div class="relative flex justify-center text-xs text-slate-400 bg-white px-2">or</div>
            </div>

            <div class="space-y-2">
              <p class="text-xs text-center text-slate-400 mb-3">Are you a hotel owner?</p>
              <a href="/owner" class="flex items-center justify-center gap-2 w-full border border-slate-200 rounded-xl py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors">
                🏨 Owner Portal
              </a>
              <a href="/admin" class="flex items-center justify-center gap-2 w-full border border-slate-200 rounded-xl py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors">
                ⚙️ Admin Panel
              </a>
            </div>
          </>
        )}

        {isOwnerLogin && (
          <div class="mt-6 text-center text-sm text-slate-500">
            Not a hotel owner?
            <a href="/login" class="text-indigo-600 font-medium hover:underline ml-1">Regular login →</a>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ redirectTo }}>
document.getElementById('login-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('login-btn');
  const err = document.getElementById('login-error');
  const email = document.getElementById('email').value;
  const password = document.getElementById('password').value;

  btn.disabled = true;
  btn.textContent = 'Signing in...';
  err.className = 'hidden';

  try {
    const res = await fetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password }),
    });
    if (res.ok) {
      window.location.href = redirectTo || '/';
    } else {
      const data = await res.json();
      err.className = 'block bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3';
      err.textContent = data.error || 'Invalid email or password';
    }
  } catch(ex) {
    err.className = 'block bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3';
    err.textContent = 'Connection error. Please try again.';
  } finally {
    btn.disabled = false;
    btn.textContent = 'Sign In';
  }
});
</script>
