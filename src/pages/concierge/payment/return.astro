---
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Finalizing payment...</title>
    <style>
      body { font-family: system-ui, sans-serif; margin: 0; background: #0f172a; color: #e2e8f0; }
      .wrap { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
      .card { width: min(640px, 100%); background: #111827; border: 1px solid #334155; border-radius: 12px; padding: 20px; }
      .muted { color: #94a3b8; font-size: 14px; }
      .ok { color: #4ade80; }
      .err { color: #f87171; }
      .btn { display: inline-block; margin-top: 12px; color: #0f172a; background: #67e8f9; padding: 10px 14px; border-radius: 8px; text-decoration: none; font-weight: 700; }
    </style>
  </head>
  <body>
    <main class="wrap">
      <section class="card">
        <h1 id="title">Finalizing your payment...</h1>
        <p id="status" class="muted">Confirming your PayPal payment. Please keep this page open.</p>
        <a id="back" class="btn" href="/concierge" style="display:none">Back to Concierge</a>
      </section>
    </main>

    <script>
      (async function () {
        const qp = new URLSearchParams(window.location.search);
        const orderId = qp.get('token') || qp.get('order_id');
        const groupId = qp.get('group_id');
        const sessionId = qp.get('session_id');
        const guestName = qp.get('guest_name');
        const guestEmail = qp.get('guest_email');
        const statusEl = document.getElementById('status');
        const titleEl = document.getElementById('title');
        const backEl = document.getElementById('back');
        const MAX_RETRIES = 20;
        const RETRY_INTERVAL_MS = 3000;

        if (!orderId || !groupId) {
          titleEl.textContent = 'Missing payment context';
          statusEl.className = 'err';
          statusEl.textContent = 'order_id or group_id is missing from return URL.';
          backEl.style.display = 'inline-block';
          return;
        }

        const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

        async function captureWithRetry() {
          for (let attempt = 1; attempt <= MAX_RETRIES; attempt += 1) {
            const res = await fetch('/api/concierge/pay', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                action: 'capture',
                order_id: orderId,
                group_id: Number(groupId),
                ...(sessionId ? { session_id: sessionId } : {}),
                ...(guestName ? { guest_name: guestName } : {}),
                ...(guestEmail ? { guest_email: guestEmail } : {}),
              }),
            });
            const data = await res.json().catch(() => ({}));
            if (data?.status === 'paid') {
              return data;
            }

            const isPending = data?.status === 'pending' || res.status === 202;
            if (!isPending) {
              throw new Error(data?.error || data?.detail || 'Failed to finalize payment');
            }

            if (attempt < MAX_RETRIES) {
              statusEl.className = 'muted';
              statusEl.textContent = `Payment is still pending (${attempt}/${MAX_RETRIES}). Retrying in a few seconds...`;
              await sleep(RETRY_INTERVAL_MS);
            }
          }
          throw new Error('Payment confirmation is taking longer than expected. Please try again shortly.');
        }

        try {
          await captureWithRetry();

          titleEl.textContent = 'Payment confirmed';
          statusEl.className = 'ok';
          statusEl.textContent = 'We started the hotel call flow. You can close this tab now.';
          try {
            if (window.opener && !window.opener.closed) {
              window.opener.postMessage({ type: 'ddh_concierge_payment_captured', ok: true, group_id: Number(groupId), order_id: orderId }, window.location.origin);
            }
          } catch {}
          backEl.style.display = 'inline-block';
          setTimeout(() => { if (window.opener && !window.opener.closed) window.close(); }, 1200);
        } catch (e) {
          titleEl.textContent = 'Payment confirmation error';
          statusEl.className = 'err';
          statusEl.textContent = (e && e.message) ? e.message : 'An error occurred while confirming payment.';
          backEl.style.display = 'inline-block';
        }
      })();
    </script>
  </body>
</html>
