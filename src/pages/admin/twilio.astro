---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';
import { formatDisplayDate } from '../../lib/dateFormat';

const runtime = (Astro.locals as any).runtime;
const db = runtime?.env?.DB;
const env = runtime?.env;
const jwtSecret = env?.JWT_SECRET || 'dev-secret';
const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect('/admin/login');

const cfg = {
  sid: env?.TWILIO_ACCOUNT_SID || '',
  token: env?.TWILIO_AUTH_TOKEN ? true : false,
  fromNumber: env?.TWILIO_FROM_NUMBER || '',
};

let callLogs: any[] = [];
let hotels: any[] = [];
const eventsByLogId: Record<string, any[]> = {};
if (db) {
  try {
    const logsResult = await db.prepare(`
      SELECT cl.*, h.name as hotel_name, h.phone as hotel_phone
      FROM call_logs cl
      LEFT JOIN hotels h ON h.id = cl.hotel_id
      WHERE cl.provider = 'twilio' OR cl.telnyx_call_id LIKE 'twilio:%' OR cl.note LIKE '%twilio%'
      ORDER BY cl.created_at DESC LIMIT 30
    `).all();
    callLogs = logsResult?.results || [];

    const ids = callLogs.map((l: any) => Number(l.id)).filter((n: number) => Number.isFinite(n) && n > 0);
    if (ids.length > 0) {
      const placeholders = ids.map(() => '?').join(',');
      const evResult = await db.prepare(`
        SELECT *
        FROM call_log_events
        WHERE call_log_id IN (${placeholders})
        ORDER BY created_at ASC, id ASC
      `).bind(...ids).all();
      const events = evResult?.results || [];
      for (const ev of events) {
        const key = String(ev.call_log_id);
        if (!eventsByLogId[key]) eventsByLogId[key] = [];
        eventsByLogId[key].push(ev);
      }
    }

    const hotelsResult = await db.prepare(
      `SELECT id, name, phone, city, country FROM hotels WHERE is_active = 1 AND phone IS NOT NULL AND phone != '' ORDER BY name LIMIT 200`
    ).all();
    hotels = hotelsResult?.results || [];
  } catch {}
}

const statusColor: Record<string, string> = {
  calling: 'bg-blue-100 text-blue-700',
  confirmed: 'bg-green-100 text-green-700',
  no_answer: 'bg-amber-100 text-amber-700',
  failed: 'bg-red-100 text-red-700',
  declined: 'bg-red-100 text-red-700',
  queued: 'bg-slate-100 text-slate-600',
  awaiting_response: 'bg-purple-100 text-purple-700',
};
---

<AdminLayout title="Concierge Dialer" activeNav="twilio">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-semibold text-slate-900">🛎️ Concierge Dialer</h2>
      <p class="text-sm text-slate-500 mt-1">コンシェルジュ架電（booking phase）専用のTwilioテスト画面</p>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-5 mb-6">
    <h3 class="font-semibold text-slate-800 mb-3">⚙️ Twilio環境変数ステータス</h3>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      {[
        { label: 'TWILIO_ACCOUNT_SID', ok: !!cfg.sid, val: cfg.sid ? `${cfg.sid.slice(0, 8)}...` : '' },
        { label: 'TWILIO_AUTH_TOKEN', ok: cfg.token },
        { label: 'TWILIO_FROM_NUMBER', ok: !!cfg.fromNumber, val: cfg.fromNumber },
      ].map(item => (
        <div class={`rounded-lg p-3 text-xs font-medium ${item.ok ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-600'}`}>
          <span class="text-base">{item.ok ? '✅' : '❌'}</span><br/>
          <span class="font-mono">{item.label}</span>
          {item.val && <div class="mt-0.5 text-slate-500 font-mono">{item.val}</div>}
        </div>
      ))}
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h3 class="font-semibold text-slate-800 mb-4">📲 Concierge テスト発信</h3>
      <form id="dial-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">ホテル選択（任意）</label>
          <select id="hotel-select" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm">
            <option value="">— ホテルを選択 —</option>
            {hotels.map(h => (
              <option value={h.id} data-phone={h.phone} data-name={h.name}>
                {h.name} ({h.city}) — {h.phone}
              </option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">電話番号 *</label>
          <input id="to-number" type="tel" placeholder="+81312345678" required
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm font-mono" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">ゲスト名</label>
            <input id="guest-name" type="text" value="Taro Yamada" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">人数</label>
            <input id="guest-count" type="number" min="1" value="2" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm" />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">チェックイン日</label>
            <input id="check-in-date" type="date" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">開始時刻</label>
            <input id="check-in-time" type="time" value="14:00" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">終了時刻</label>
            <input id="check-out-time" type="time" value="19:00" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">メモ（任意）</label>
          <input id="call-note" type="text" placeholder="Concierge booking test"
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm" />
        </div>

        <button type="submit" id="dial-btn"
          class="w-full bg-indigo-600 hover:bg-indigo-700 disabled:bg-slate-300 text-white font-medium py-2.5 rounded-lg transition-colors">
          Conciergeテスト発信（phase=booking）
        </button>
      </form>
      <div id="dial-result" class="hidden mt-4 p-3 rounded-lg text-sm"></div>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h3 class="font-semibold text-slate-800 mb-4">🧾 Twilio通話ログ（直近）</h3>
      <div class="space-y-2 max-h-80 overflow-y-auto">
        {callLogs.length === 0 ? (
          <p class="text-center text-slate-400 text-sm py-8">Twilioログなし</p>
        ) : callLogs.map(log => (
          <div class="py-2 border-b border-slate-100 last:border-0">
            <div class="flex items-center justify-between gap-2">
              <div class="min-w-0">
                <p class="text-sm font-medium text-slate-800 truncate">{log.hotel_name || log.to_number || '—'}</p>
                <p class="text-xs text-slate-400">{log.to_number || '—'} · {formatDisplayDate(log.created_at)}</p>
              </div>
              <span class={`ml-2 flex-shrink-0 inline-block px-2 py-0.5 rounded-full text-xs font-medium ${statusColor[log.status] || 'bg-slate-100 text-slate-600'}`}>
                {log.status}
              </span>
            </div>
            <div class="mt-1 flex items-center justify-between">
              <p class="text-[11px] text-slate-500 truncate">{log.last_event_type || '—'} {log.last_step ? `· ${log.last_step}` : ''}</p>
              <button
                class="twilio-log-detail text-xs text-indigo-600 hover:text-indigo-800 font-medium"
                data-log={JSON.stringify(log)}
                data-events={JSON.stringify(eventsByLogId[String(log.id)] || [])}
              >詳細</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div id="twilio-detail-modal" class="hidden fixed inset-0 z-50 bg-black/40 px-4 py-8 overflow-y-auto">
    <div class="max-w-2xl mx-auto bg-white rounded-xl border border-slate-200 shadow-xl">
      <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
        <h4 class="font-semibold text-slate-900">Twilio通話詳細</h4>
        <button id="twilio-detail-close" class="text-slate-400 hover:text-slate-600 text-xl leading-none">×</button>
      </div>
      <div class="p-5 space-y-4">
        <div id="twilio-detail-summary" class="text-sm text-slate-700"></div>
        <div>
          <h5 class="text-sm font-semibold text-slate-800 mb-2">イベントタイムライン</h5>
          <div id="twilio-detail-timeline" class="space-y-2 max-h-[420px] overflow-y-auto"></div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script is:inline>
(() => {
  const dateEl = document.getElementById('check-in-date');
  if (dateEl && !dateEl.value) {
    const d = new Date();
    d.setDate(d.getDate() + 1);
    dateEl.value = d.toISOString().slice(0, 10);
  }
})();

document.getElementById('hotel-select')?.addEventListener('change', function() {
  const opt = this.options[this.selectedIndex];
  const phone = opt?.getAttribute('data-phone') || '';
  document.getElementById('to-number').value = phone;
});

document.getElementById('dial-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('dial-btn');
  const result = document.getElementById('dial-result');
  const hotelSelect = document.getElementById('hotel-select');
  const hotelId = hotelSelect?.value || null;
  const toNumber = document.getElementById('to-number').value.trim();
  const note = document.getElementById('call-note').value.trim();
  const guestName = document.getElementById('guest-name').value.trim();
  const guestCount = Number(document.getElementById('guest-count').value || 1);
  const checkInDate = document.getElementById('check-in-date').value;
  const checkInTime = document.getElementById('check-in-time').value;
  const checkOutTime = document.getElementById('check-out-time').value;

  if (!toNumber) return;

  btn.disabled = true;
  btn.textContent = '発信中...';
  result.className = 'hidden mt-4 p-3 rounded-lg text-sm';

  try {
    const res = await fetch('/api/admin/twilio-call', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action: 'dial',
        phase: 'booking',
        to_number: toNumber,
        hotel_id: hotelId ? parseInt(hotelId) : null,
        guest_name: guestName || 'Test Guest',
        guest_count: Number.isFinite(guestCount) ? Math.max(1, guestCount) : 1,
        check_in_date: checkInDate,
        check_in_time: checkInTime,
        check_out_time: checkOutTime,
        note,
      }),
    });
    const data = await res.json();
    if (res.ok && data.success) {
      result.className = 'block mt-4 p-3 rounded-lg text-sm bg-green-50 text-green-700 border border-green-200';
      result.textContent = `✅ Concierge発信成功！Call SID: ${data.call_sid || '—'} (phase=${data.phase || 'booking'})`;
      setTimeout(() => location.reload(), 3000);
    } else {
      result.className = 'block mt-4 p-3 rounded-lg text-sm bg-red-50 text-red-700 border border-red-200';
      result.textContent = `❌ エラー: ${data.error || JSON.stringify(data)}`;
    }
  } catch (e) {
    result.className = 'block mt-4 p-3 rounded-lg text-sm bg-red-50 text-red-700 border border-red-200';
    result.textContent = `❌ 通信エラー: ${e.message}`;
  } finally {
    btn.disabled = false;
    btn.textContent = 'Conciergeテスト発信（phase=booking）';
  }
});

const detailModal = document.getElementById('twilio-detail-modal');
const detailClose = document.getElementById('twilio-detail-close');
const detailSummary = document.getElementById('twilio-detail-summary');
const detailTimeline = document.getElementById('twilio-detail-timeline');

function escHtml(v) {
  return String(v ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] || c));
}

function renderTimeline(events = []) {
  if (!events.length) {
    detailTimeline.innerHTML = '<p class="text-sm text-slate-400">イベント履歴なし</p>';
    return;
  }
  detailTimeline.innerHTML = events.map((ev) => {
    const at = escHtml(ev.created_at || '');
    const main = escHtml(ev.event_type || 'event');
    const sub = [ev.step, ev.call_status, ev.digits ? `digits:${ev.digits}` : ''].filter(Boolean).map(escHtml).join(' · ');
    const speech = ev.speech_result ? `<div class="mt-1 text-xs text-slate-600">speech: ${escHtml(ev.speech_result)}</div>` : '';
    const note = ev.note ? `<div class="mt-1 text-xs text-slate-600">${escHtml(ev.note)}</div>` : '';
    return `<div class="border border-slate-200 rounded-lg p-2.5 bg-slate-50">
      <div class="text-[11px] text-slate-500">${at}</div>
      <div class="text-sm font-medium text-slate-800">${main}</div>
      ${sub ? `<div class="text-xs text-slate-500">${sub}</div>` : ''}
      ${speech}
      ${note}
    </div>`;
  }).join('');
}

document.querySelectorAll('.twilio-log-detail').forEach((btn) => {
  btn.addEventListener('click', () => {
    const log = JSON.parse(btn.getAttribute('data-log') || '{}');
    const events = JSON.parse(btn.getAttribute('data-events') || '[]');
    detailSummary.innerHTML = `
      <div><span class="text-slate-500">Log ID:</span> <span class="font-mono">${escHtml(log.id)}</span></div>
      <div><span class="text-slate-500">ホテル/宛先:</span> ${escHtml(log.hotel_name || log.to_number || '—')}</div>
      <div><span class="text-slate-500">ステータス:</span> ${escHtml(log.status || '—')} ${log.last_step ? `· ${escHtml(log.last_step)}` : ''}</div>
      <div><span class="text-slate-500">作成:</span> ${escHtml(log.created_at || '—')}</div>
      <div><span class="text-slate-500">Call SID:</span> ${escHtml(log.telnyx_call_id || '—')}</div>
    `;
    renderTimeline(events);
    detailModal.classList.remove('hidden');
  });
});

detailClose?.addEventListener('click', () => detailModal?.classList.add('hidden'));
detailModal?.addEventListener('click', (e) => { if (e.target === detailModal) detailModal.classList.add('hidden'); });
</script>
