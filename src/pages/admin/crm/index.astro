---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../../lib/adminAuth';

const runtime = Astro.locals.runtime as any;
const jwtSecret = runtime?.env?.JWT_SECRET || 'dev-secret';
const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect('/admin/login');
---

<AdminLayout title="CRM" activeNav="crm">
  <div class="space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">CRM 案件管理</h1>
        <p class="text-sm text-slate-500 mt-0.5">ホテル獲得パイプラインの追跡・管理</p>
      </div>
      <div class="flex items-center gap-3">
        <button id="btn-export" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-all duration-150 shadow-sm">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          CSV
        </button>
        <button id="btn-add-lead" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-teal-600 rounded-lg hover:bg-teal-700 transition-all duration-150 shadow-sm">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          新規リード
        </button>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-5 gap-3">
      <div class="bg-white rounded-xl border border-slate-100 shadow-sm p-4 col-span-1">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">合計</p>
        <p id="stat-total" class="text-3xl font-bold text-slate-800 mt-1">—</p>
      </div>
      <div class="bg-blue-50 rounded-xl border border-blue-100 p-4">
        <p class="text-xs font-semibold text-blue-500 uppercase tracking-wider">新規</p>
        <p id="stat-new" class="text-3xl font-bold text-blue-700 mt-1">—</p>
      </div>
      <div class="bg-amber-50 rounded-xl border border-amber-100 p-4">
        <p class="text-xs font-semibold text-amber-500 uppercase tracking-wider">追客中</p>
        <p id="stat-inprogress" class="text-3xl font-bold text-amber-700 mt-1">—</p>
      </div>
      <div class="bg-green-50 rounded-xl border border-green-100 p-4">
        <p class="text-xs font-semibold text-green-600 uppercase tracking-wider">掲載</p>
        <p id="stat-won" class="text-3xl font-bold text-green-700 mt-1">—</p>
      </div>
      <div class="bg-red-50 rounded-xl border border-red-100 p-4">
        <p class="text-xs font-semibold text-red-500 uppercase tracking-wider">失注</p>
        <p id="stat-lost" class="text-3xl font-bold text-red-700 mt-1">—</p>
      </div>
    </div>

    <!-- Table card -->
    <div class="bg-white rounded-xl border border-slate-100 shadow-sm overflow-hidden">
      <!-- Tabs -->
      <div class="flex items-center gap-1 px-3 pt-3 border-b border-slate-100">
        <button class="tab-btn active px-4 py-2 text-sm font-medium rounded-t-lg transition-all duration-150" data-filter="all">すべて</button>
        <button class="tab-btn px-4 py-2 text-sm font-medium rounded-t-lg transition-all duration-150" data-filter="new">新規</button>
        <button class="tab-btn px-4 py-2 text-sm font-medium rounded-t-lg transition-all duration-150" data-filter="in_progress">追客中</button>
        <button class="tab-btn px-4 py-2 text-sm font-medium rounded-t-lg transition-all duration-150" data-filter="won">掲載</button>
        <button class="tab-btn px-4 py-2 text-sm font-medium rounded-t-lg transition-all duration-150" data-filter="lost">失注</button>
        <div class="ml-auto pr-2 pb-2">
          <button id="btn-refresh" class="p-1.5 text-slate-400 hover:text-slate-600 rounded-lg hover:bg-slate-100 transition-colors" title="更新">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
          </button>
        </div>
      </div>

      <!-- Table -->
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="bg-slate-50/60">
              <th class="text-left text-xs font-semibold text-slate-400 uppercase tracking-wider px-6 py-3">ホテル / 担当者</th>
              <th class="text-left text-xs font-semibold text-slate-400 uppercase tracking-wider px-4 py-3">ステータス</th>
              <th class="text-left text-xs font-semibold text-slate-400 uppercase tracking-wider px-4 py-3">場所</th>
              <th class="text-left text-xs font-semibold text-slate-400 uppercase tracking-wider px-4 py-3">連絡先</th>
              <th class="text-left text-xs font-semibold text-slate-400 uppercase tracking-wider px-4 py-3">最終更新</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody id="leads-tbody" class="divide-y divide-slate-50"></tbody>
        </table>
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden py-16 text-center">
        <svg class="w-12 h-12 mx-auto text-slate-200 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
        </svg>
        <p class="text-sm text-slate-400">リードがありません</p>
        <p class="text-xs text-slate-300 mt-1">「新規リード」ボタンで追加してください</p>
      </div>

      <!-- Loading -->
      <div id="loading-state" class="py-12 text-center text-slate-400 text-sm">
        <div class="inline-block w-5 h-5 border-2 border-slate-200 border-t-teal-500 rounded-full animate-spin mb-2"></div>
        <p>読み込み中...</p>
      </div>
    </div>
  </div>

  <!-- Add Lead Modal -->
  <div id="modal-bg" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-xl max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 sticky top-0 bg-white rounded-t-2xl">
        <h2 class="text-base font-semibold text-slate-800">新規リード登録</h2>
        <button id="modal-close" class="p-1.5 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-lg transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <form id="add-lead-form" class="px-6 py-5 space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">担当者名 <span class="text-red-500">*</span></label>
            <input type="text" name="contact_person" required class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500 transition-all" placeholder="山田 太郎" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">役職</label>
            <input type="text" name="position" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500 transition-all" placeholder="支配人" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">電話番号</label>
            <input type="tel" name="phone" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500 transition-all" placeholder="+66-2-000-0000" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">WhatsApp</label>
            <input type="text" name="whatsapp" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500 transition-all" placeholder="+66812345678" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">メールアドレス</label>
          <input type="email" name="email" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500 transition-all" placeholder="info@hotel.com" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">国</label>
            <input type="text" name="country" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500 transition-all" placeholder="Thailand" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">都市</label>
            <input type="text" name="city" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500 transition-all" placeholder="Bangkok" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">ホテルID <span class="text-slate-400 font-normal">(任意)</span></label>
            <input type="number" name="hotel_id" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500 transition-all" placeholder="既存ホテルと紐付ける場合" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">公式URL</label>
            <input type="url" name="official_url" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500 transition-all" placeholder="https://..." />
          </div>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" id="modal-cancel" class="flex-1 px-4 py-2.5 text-sm font-medium text-slate-600 bg-slate-100 rounded-lg hover:bg-slate-200 transition-all">キャンセル</button>
          <button type="submit" id="submit-btn" class="flex-1 px-4 py-2.5 text-sm font-medium text-white bg-teal-600 rounded-lg hover:bg-teal-700 transition-all">登録する</button>
        </div>
      </form>
    </div>
  </div>

  <style>
    .tab-btn { color: #64748b; }
    .tab-btn:hover { color: #334155; background: #f8fafc; }
    .tab-btn.active { color: #0d9488; background: #f0fdfa; border-bottom: 2px solid #0d9488; margin-bottom: -1px; }
  </style>

  <script is:inline>
    // 日付フォーマット（YYYY-MMM-DD）をブラウザ側に直接定義（Task #55: {formatDisplayDateJS} 展開の構文エラーを解消）
    function formatDisplayDate(dateStr) {
      if (!dateStr) return '-';
      var MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      var normalized = dateStr.includes('T') ? dateStr : dateStr.replace(' ', 'T') + 'Z';
      var d = new Date(normalized);
      if (isNaN(d.getTime())) return '-';
      return d.getUTCFullYear() + '-' + MONTHS[d.getUTCMonth()] + '-' + String(d.getUTCDate()).padStart(2, '0');
    }
    const STATUS = {
      new:         { label: '新規',   cls: 'bg-blue-50 text-blue-700 ring-1 ring-blue-200' },
      in_progress: { label: '追客中', cls: 'bg-amber-50 text-amber-700 ring-1 ring-amber-200' },
      won:         { label: '掲載',   cls: 'bg-green-50 text-green-700 ring-1 ring-green-200' },
      lost:        { label: '失注',   cls: 'bg-red-50 text-red-700 ring-1 ring-red-200' },
      completed:   { label: '完了',   cls: 'bg-slate-100 text-slate-600 ring-1 ring-slate-200' },
    };

    function statusBadge(p) {
      const s = STATUS[p] || { label: p || '—', cls: 'bg-slate-100 text-slate-500' };
      return `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${s.cls}">${s.label}</span>`;
    }

    function fmtDate(d) {
      return formatDisplayDate(d);
    }

    // Phone/Email/WhatsApp SVG icons
    const ICON_PHONE = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>`;
    const ICON_MAIL = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>`;
    const ICON_WA = `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`;

    let currentFilter = 'all';

    async function loadLeads(filter) {
      document.getElementById('loading-state').classList.remove('hidden');
      document.getElementById('empty-state').classList.add('hidden');
      document.getElementById('leads-tbody').innerHTML = '';

      try {
      const qs = filter && filter !== 'all' ? `?filter=${filter}` : '';
      const res = await fetch(`/api/crm${qs}`);
      if (!res.ok) throw new Error('API error ' + res.status);
      const data = await res.json();

      // Stats
      const s = data.stats || {};
      document.getElementById('stat-total').textContent = s.total ?? '—';
      document.getElementById('stat-new').textContent = s.new_count ?? '—';
      document.getElementById('stat-inprogress').textContent = s.in_progress_count ?? '—';
      document.getElementById('stat-won').textContent = s.won_count ?? '—';
      document.getElementById('stat-lost').textContent = s.lost_count ?? '—';

      const leads = data.leads || [];
      if (!leads.length) {
        document.getElementById('empty-state').classList.remove('hidden');
        return;
      }

      const tbody = document.getElementById('leads-tbody');
      leads.forEach(lead => {
        const contacts = [];
        if (lead.phone) contacts.push(`<a href="tel:${lead.phone}" onclick="event.stopPropagation()" class="p-1.5 text-slate-400 hover:text-teal-600 rounded-lg hover:bg-teal-50 transition-colors" title="${lead.phone}">${ICON_PHONE}</a>`);
        if (lead.email) contacts.push(`<a href="mailto:${lead.email}" onclick="event.stopPropagation()" class="p-1.5 text-slate-400 hover:text-blue-600 rounded-lg hover:bg-blue-50 transition-colors" title="${lead.email}">${ICON_MAIL}</a>`);
        if (lead.whatsapp) contacts.push(`<a href="https://wa.me/${lead.whatsapp.replace(/\D/g,'')}" target="_blank" onclick="event.stopPropagation()" class="p-1.5 text-slate-400 hover:text-green-600 rounded-lg hover:bg-green-50 transition-colors" title="WhatsApp">${ICON_WA}</a>`);

        const displayName = lead.hotel_name || lead.contact_person || '—';
        const subName = lead.hotel_name && lead.contact_person ? lead.contact_person : '';
        const location = [lead.city, lead.country].filter(Boolean).join(', ') || '—';

        const tr = document.createElement('tr');
        tr.className = 'hover:bg-slate-50 transition-colors cursor-pointer';
        tr.innerHTML = `
          <td class="px-6 py-4">
            <div class="font-medium text-slate-800">${displayName}</div>
            ${subName ? `<div class="text-xs text-slate-400 mt-0.5">${subName}</div>` : ''}
          </td>
          <td class="px-4 py-4">${statusBadge(lead.progress)}</td>
          <td class="px-4 py-4 text-sm text-slate-500">${location}</td>
          <td class="px-4 py-4"><div class="flex items-center gap-0.5">${contacts.join('')}</div></td>
          <td class="px-4 py-4 text-sm text-slate-400">${fmtDate(lead.last_updated)}</td>
          <td class="px-4 py-4 text-right">
            <span class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-teal-700 bg-teal-50 rounded-lg hover:bg-teal-100 transition-colors">
              詳細
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
            </span>
          </td>
        `;
        tr.addEventListener('click', () => { window.location.href = `/admin/crm/${lead.id}`; });
        tbody.appendChild(tr);
      });
      } catch (e) {
        console.error('[crm] loadLeads failed:', e);
        document.getElementById('empty-state')?.classList.remove('hidden');
      } finally {
        // Task #55: API失敗時も必ずローディング表示を解除（無限ローディング防止）
        document.getElementById('loading-state').classList.add('hidden');
      }
    }

    // Tab switching
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentFilter = btn.dataset.filter;
        loadLeads(currentFilter);
      });
    });

    // Refresh button
    document.getElementById('btn-refresh').addEventListener('click', () => loadLeads(currentFilter));

    // CSV export
    document.getElementById('btn-export').addEventListener('click', () => {
      window.location.href = '/api/crm?format=csv';
    });

    // Modal
    const modalBg = document.getElementById('modal-bg');
    function openModal() { modalBg.classList.remove('hidden'); modalBg.classList.add('flex'); }
    function closeModal() { modalBg.classList.add('hidden'); modalBg.classList.remove('flex'); }

    document.getElementById('btn-add-lead').addEventListener('click', openModal);
    document.getElementById('modal-close').addEventListener('click', closeModal);
    document.getElementById('modal-cancel').addEventListener('click', closeModal);
    modalBg.addEventListener('click', (e) => { if (e.target === modalBg) closeModal(); });

    // New lead form
    document.getElementById('add-lead-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submit-btn');
      btn.disabled = true;
      btn.textContent = '登録中...';

      const fd = new FormData(e.target);
      const data = {};
      fd.forEach((v, k) => { if (v) data[k] = v; });
      if (data.hotel_id) data.hotel_id = parseInt(data.hotel_id) || null;

      try {
        const res = await fetch('/api/crm', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const result = await res.json();
        if (result.success) {
          closeModal();
          e.target.reset();
          await loadLeads(currentFilter);
        } else {
          alert('登録に失敗しました: ' + (result.error || ''));
        }
      } finally {
        btn.disabled = false;
        btn.textContent = '登録する';
      }
    });

    // Initial load
    loadLeads('all');
  </script>
</AdminLayout>
