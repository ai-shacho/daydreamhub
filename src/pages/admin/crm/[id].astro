---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../../lib/adminAuth';
import { formatDisplayDateJS } from '../../../lib/dateFormat';

const runtime = Astro.locals.runtime as any;
const jwtSecret = runtime?.env?.JWT_SECRET || 'dev-secret';
const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect('/admin/login');

const { id } = Astro.params;
---

<AdminLayout title={`CRM #${id}`} activeNav="crm">
  <div class="max-w-4xl mx-auto space-y-6">

    <!-- Breadcrumb + actions -->
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2 text-sm">
        <a href="/admin/crm" class="text-slate-400 hover:text-slate-600 transition-colors">CRM</a>
        <svg class="w-4 h-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
        <span id="breadcrumb-name" class="text-slate-600 font-medium">リード #{id}</span>
      </div>
      <div class="flex items-center gap-2">
        <button id="btn-add-report" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-teal-600 rounded-lg hover:bg-teal-700 transition-all duration-150 shadow-sm">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          報告を追加
        </button>
        <button id="btn-lost" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-red-600 bg-red-50 border border-red-100 rounded-lg hover:bg-red-100 transition-all duration-150">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          失注・追客中止
        </button>
      </div>
    </div>

    <!-- Lead info card -->
    <div id="lead-card" class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
      <div class="flex items-start justify-between mb-5">
        <div>
          <div class="flex items-center gap-3 mb-1">
            <h1 id="lead-name" class="text-xl font-bold text-slate-900">—</h1>
            <span id="lead-status-badge"></span>
          </div>
          <p id="lead-sub" class="text-sm text-slate-400"></p>
        </div>
        <div id="lead-hotel-link"></div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="lead-meta"></div>
      <div id="lead-contact-row" class="flex items-center gap-3 mt-5 pt-5 border-t border-slate-50"></div>
    </div>

    <!-- Timeline section -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm">
      <div class="flex items-center justify-between px-6 py-4 border-b border-slate-50">
        <h2 class="text-base font-semibold text-slate-800">対応履歴</h2>
        <span id="report-count" class="text-xs font-medium text-slate-400"></span>
      </div>
      <div id="timeline" class="px-6 py-6">
        <!-- Populated by JS -->
        <div id="no-reports" class="py-10 text-center text-slate-400">
          <svg class="w-10 h-10 mx-auto text-slate-200 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 01.778-.332 48.294 48.294 0 005.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>
          <p class="text-sm">まだ報告がありません</p>
        </div>
      </div>
    </div>

  </div>

  <!-- ── Report Modal ────────────────────────────────────────────── -->
  <div id="report-modal-bg" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-xl max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 sticky top-0 bg-white rounded-t-2xl z-10">
        <h2 class="text-base font-semibold text-slate-800">報告を追加</h2>
        <button id="report-modal-close" class="p-1.5 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-lg transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Type tabs -->
      <div class="flex gap-1 px-6 pt-4">
        <button class="report-tab-btn active flex-1 py-2 text-sm font-medium rounded-lg transition-all" data-type="アポ">📋 アポ</button>
        <button class="report-tab-btn flex-1 py-2 text-sm font-medium rounded-lg transition-all" data-type="セットアップ">⚙️ セットアップ</button>
        <button class="report-tab-btn flex-1 py-2 text-sm font-medium rounded-lg transition-all" data-type="メール">📧 メール</button>
        <button class="report-tab-btn flex-1 py-2 text-sm font-medium rounded-lg transition-all" data-type="その他">💬 その他</button>
      </div>
      <input type="hidden" id="f-report-type" value="アポ" />

      <form id="report-form" class="px-6 pb-6 pt-4 space-y-4">
        <!-- Result + status change -->
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">対応結果</label>
            <select id="f-result" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500 bg-white">
              <option value="">選択...</option>
              <option value="in_progress">応答あり（継続）</option>
              <option value="in_progress">応答なし</option>
              <option value="in_progress">興味あり・検討中</option>
              <option value="won">掲載決定 ✅</option>
              <option value="lost">お断り / 失注</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">アポイント日</label>
            <input type="date" id="f-appointment-date" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500" />
          </div>
        </div>

        <!-- Content -->
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">対応内容・メモ <span class="text-red-500">*</span></label>
          <textarea id="f-content" required rows="5" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500 resize-none" placeholder="会話の要点、反応、懸念点など..."></textarea>
        </div>

        <!-- Next actions -->
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">次回アクション（DDH側）</label>
            <input type="text" id="f-next-ddh" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500" placeholder="再コールする、資料を送る..."/>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">次回アクション（ホテル側）</label>
            <input type="text" id="f-next-hotel" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500" placeholder="社内確認、書類準備..."/>
          </div>
        </div>

        <!-- Apo-specific fields -->
        <div id="apo-fields" class="space-y-4 border-t border-slate-100 pt-4">
          <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">アポ詳細</p>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1.5">直接電話番号</label>
              <input type="tel" id="f-direct-phone" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-teal-500/40 focus:border-teal-500" />
            </div>
            <div class="flex items-center gap-3 pt-6">
              <input type="checkbox" id="f-decision-maker" class="w-4 h-4 text-teal-600 rounded border-slate-300 focus:ring-teal-500" />
              <label for="f-decision-maker" class="text-sm font-medium text-slate-700">決定権者が同席</label>
            </div>
          </div>
        </div>

        <div class="flex gap-3 pt-2">
          <button type="button" id="report-modal-cancel" class="flex-1 px-4 py-2.5 text-sm font-medium text-slate-600 bg-slate-100 rounded-lg hover:bg-slate-200 transition-all">キャンセル</button>
          <button type="submit" id="report-submit-btn" class="flex-1 px-4 py-2.5 text-sm font-medium text-white bg-teal-600 rounded-lg hover:bg-teal-700 transition-all">報告を登録</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Lost Modal ──────────────────────────────────────────────── -->
  <div id="lost-modal-bg" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm">
      <div class="px-6 py-5 border-b border-slate-100">
        <div class="flex items-center gap-3 mb-1">
          <div class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center">
            <svg class="w-4 h-4 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
          </div>
          <h3 class="text-base font-semibold text-slate-800">失注・追客中止</h3>
        </div>
        <p class="text-sm text-slate-500 ml-11">この操作は元に戻せません。</p>
      </div>
      <div class="px-6 py-4 space-y-3">
        <label class="block text-sm font-medium text-slate-700 mb-2">失注理由</label>
        <select id="lost-reason" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-red-500/40 focus:border-red-400 bg-white">
          <option value="">選択してください</option>
          <option value="価格条件が合わない">価格条件が合わない</option>
          <option value="競合他社に決定">競合他社に決定</option>
          <option value="音信不通">音信不通</option>
          <option value="掲載意欲なし">掲載意欲なし</option>
          <option value="条件不一致">その他条件不一致</option>
        </select>
        <textarea id="lost-comment" rows="2" class="w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-red-500/40 focus:border-red-400 resize-none" placeholder="詳細メモ（任意）"></textarea>
      </div>
      <div class="flex gap-3 px-6 pb-5">
        <button id="lost-cancel" class="flex-1 px-4 py-2.5 text-sm font-medium text-slate-600 bg-slate-100 rounded-lg hover:bg-slate-200 transition-all">キャンセル</button>
        <button id="lost-confirm" class="flex-1 px-4 py-2.5 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 transition-all">失注確定</button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="fixed bottom-6 right-6 z-[100] hidden">
    <div class="flex items-center gap-3 px-4 py-3 bg-slate-800 text-white rounded-xl shadow-lg text-sm font-medium">
      <svg class="w-4 h-4 text-green-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
      <span id="toast-msg"></span>
    </div>
  </div>

  <style>
    .report-tab-btn { color: #64748b; }
    .report-tab-btn:hover { background: #f8fafc; color: #334155; }
    .report-tab-btn.active { background: #f0fdfa; color: #0d9488; font-weight: 600; }
  </style>

  <script is:inline define:vars={{ leadId: id }}>
    {formatDisplayDateJS}
    const STATUS = {
      new:         { label: '新規',   cls: 'bg-blue-50 text-blue-700 ring-1 ring-blue-200' },
      in_progress: { label: '追客中', cls: 'bg-amber-50 text-amber-700 ring-1 ring-amber-200' },
      won:         { label: '掲載',   cls: 'bg-green-50 text-green-700 ring-1 ring-green-200' },
      lost:        { label: '失注',   cls: 'bg-red-50 text-red-700 ring-1 ring-red-200' },
      completed:   { label: '完了',   cls: 'bg-slate-100 text-slate-600 ring-1 ring-slate-200' },
    };

    const REPORT_ICONS = {
      'アポ':        { icon: '📋', bg: 'bg-blue-100',  border: 'border-blue-300' },
      'セットアップ': { icon: '⚙️', bg: 'bg-purple-100', border: 'border-purple-300' },
      'メール':       { icon: '📧', bg: 'bg-sky-100',   border: 'border-sky-300' },
      '電話':        { icon: '📞', bg: 'bg-teal-100',  border: 'border-teal-300' },
      'WhatsApp':   { icon: '💬', bg: 'bg-green-100', border: 'border-green-300' },
      'その他':      { icon: '📝', bg: 'bg-slate-100', border: 'border-slate-300' },
    };

    const RESULT_LABELS = {
      in_progress: '継続',
      won: '掲載決定',
      lost: '失注',
      completed: '完了',
    };

    function statusBadge(p) {
      const s = STATUS[p] || { label: p || '—', cls: 'bg-slate-100 text-slate-500' };
      return `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${s.cls}">${s.label}</span>`;
    }

    function fmtDate(d, opts) {
      return formatDisplayDate(d);
    }

    function showToast(msg) {
      const t = document.getElementById('toast');
      document.getElementById('toast-msg').textContent = msg;
      t.classList.remove('hidden');
      setTimeout(() => t.classList.add('hidden'), 3000);
    }

    async function loadLead() {
      const res = await fetch(`/api/crm/${leadId}`);
      const data = await res.json();
      if (!res.ok || !data.lead) return;
      const lead = data.lead;
      renderLeadCard(lead);
      renderTimeline(data.reports || []);
    }

    function renderLeadCard(lead) {
      const displayName = lead.hotel_name || lead.contact_person || '—';
      document.getElementById('lead-name').textContent = displayName;
      document.getElementById('breadcrumb-name').textContent = displayName;
      document.getElementById('lead-status-badge').innerHTML = statusBadge(lead.progress);
      document.getElementById('lead-sub').textContent = lead.hotel_name && lead.contact_person
        ? `担当: ${lead.contact_person}${lead.position ? '（' + lead.position + '）' : ''}`
        : lead.position || '';

      // Hotel link
      if (lead.hotel_id) {
        document.getElementById('lead-hotel-link').innerHTML = `
          <a href="/admin/hotels/${lead.hotel_id}" class="inline-flex items-center gap-1.5 text-xs text-teal-600 bg-teal-50 px-3 py-1.5 rounded-lg hover:bg-teal-100 transition-colors font-medium">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
            ホテルページ
          </a>`;
      }

      // Meta grid
      const meta = [
        { label: '国 / 都市', val: [lead.country, lead.city || lead.hotel_city].filter(Boolean).join(' / ') || '—' },
        { label: '最終連絡', val: fmtDate(lead.last_contact_date, { year: 'numeric', month: 'short', day: 'numeric' }) },
        { label: '登録日', val: fmtDate(lead.created_at, { year: 'numeric', month: 'short', day: 'numeric' }) },
        { label: '失注理由', val: lead.lost_reason || '—' },
      ];
      document.getElementById('lead-meta').innerHTML = meta.map(m => `
        <div>
          <p class="text-xs text-slate-400 font-medium mb-0.5">${m.label}</p>
          <p class="text-sm text-slate-700 font-medium">${m.val}</p>
        </div>
      `).join('');

      // Contact row
      const contacts = [];
      if (lead.phone) contacts.push(`
        <a href="tel:${lead.phone}" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-teal-700 bg-teal-50 rounded-lg hover:bg-teal-100 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
          ${lead.phone}
        </a>`);
      if (lead.email) contacts.push(`
        <a href="mailto:${lead.email}" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-blue-700 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
          ${lead.email}
        </a>`);
      if (lead.whatsapp) contacts.push(`
        <a href="https://wa.me/${lead.whatsapp.replace(/\D/g,'')}" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-green-700 bg-green-50 rounded-lg hover:bg-green-100 transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>`);
      if (lead.official_url) contacts.push(`
        <a href="${lead.official_url}" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-600 bg-slate-50 rounded-lg hover:bg-slate-100 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
          公式サイト
        </a>`);
      document.getElementById('lead-contact-row').innerHTML = contacts.length ? contacts.join('') : '<span class="text-sm text-slate-400">連絡先未登録</span>';
    }

    function renderTimeline(reports) {
      const container = document.getElementById('timeline');
      const noReports = document.getElementById('no-reports');
      document.getElementById('report-count').textContent = reports.length ? `${reports.length}件` : '';

      if (!reports.length) {
        noReports.classList.remove('hidden');
        return;
      }
      noReports.classList.add('hidden');

      const items = reports.map((r, i) => {
        const meta = REPORT_ICONS[r.report_type] || REPORT_ICONS['その他'];
        const isLast = i === reports.length - 1;
        const resultLabel = RESULT_LABELS[r.result] || r.result || '';
        const resultCls = r.result === 'won' ? 'bg-green-50 text-green-700' : r.result === 'lost' ? 'bg-red-50 text-red-700' : 'bg-slate-50 text-slate-600';
        const contentEsc = (r.content || '').replace(/'/g, '&#39;').replace(/"/g, '&quot;');

        return `
          <div class="relative flex gap-4 ${isLast ? '' : 'pb-6'}">
            <!-- Timeline line -->
            ${!isLast ? `<div class="absolute left-5 top-10 bottom-0 w-px bg-slate-100"></div>` : ''}
            <!-- Icon node -->
            <div class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-base ${meta.bg} border-2 ${meta.border}">
              ${meta.icon}
            </div>
            <!-- Card -->
            <div class="flex-1 bg-slate-50 rounded-xl p-4 hover:bg-slate-100/80 transition-colors group">
              <div class="flex items-start justify-between gap-2 mb-2">
                <div class="flex items-center flex-wrap gap-2">
                  <span class="text-xs font-semibold text-slate-600">${r.report_type}</span>
                  ${resultLabel ? `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${resultCls}">${resultLabel}</span>` : ''}
                  ${r.appointment_date ? `<span class="text-xs text-slate-400">🗓 ${r.appointment_date}</span>` : ''}
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                  <span class="text-xs text-slate-400">${fmtDate(r.created_at)}</span>
                  <button
                    onclick="copyReport('${contentEsc}')"
                    class="opacity-0 group-hover:opacity-100 p-1.5 text-slate-400 hover:text-slate-700 rounded-lg hover:bg-white transition-all"
                    title="テキストをコピー"
                  >
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/></svg>
                  </button>
                </div>
              </div>
              ${r.content ? `<p class="text-sm text-slate-700 whitespace-pre-line leading-relaxed">${r.content}</p>` : ''}
              ${r.next_action_ddh ? `<div class="mt-2 pt-2 border-t border-slate-200"><p class="text-xs text-slate-500">→ DDH次回アクション: <span class="text-slate-700">${r.next_action_ddh}</span></p></div>` : ''}
              ${r.next_action_hotel ? `<p class="text-xs text-slate-500 mt-1">→ ホテル次回アクション: <span class="text-slate-700">${r.next_action_hotel}</span></p>` : ''}
            </div>
          </div>
        `;
      }).join('');

      container.innerHTML = `<div class="relative">${items}</div>`;
    }

    function copyReport(text) {
      navigator.clipboard.writeText(text).then(() => showToast('クリップボードにコピーしました'));
    }

    // ── Report Modal ──
    const reportModalBg = document.getElementById('report-modal-bg');
    function openReportModal() { reportModalBg.classList.remove('hidden'); reportModalBg.classList.add('flex'); }
    function closeReportModal() { reportModalBg.classList.add('hidden'); reportModalBg.classList.remove('flex'); document.getElementById('report-form').reset(); }

    document.getElementById('btn-add-report').addEventListener('click', openReportModal);
    document.getElementById('report-modal-close').addEventListener('click', closeReportModal);
    document.getElementById('report-modal-cancel').addEventListener('click', closeReportModal);
    reportModalBg.addEventListener('click', (e) => { if (e.target === reportModalBg) closeReportModal(); });

    // Type tabs
    document.querySelectorAll('.report-tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.report-tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('f-report-type').value = btn.dataset.type;
        const apoFields = document.getElementById('apo-fields');
        apoFields.style.display = btn.dataset.type === 'アポ' ? '' : 'none';
      });
    });

    document.getElementById('report-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('report-submit-btn');
      btn.disabled = true;
      btn.textContent = '登録中...';

      const content = document.getElementById('f-content').value;
      if (!content.trim()) { alert('対応内容を入力してください'); btn.disabled = false; btn.textContent = '報告を登録'; return; }

      const resultVal = document.getElementById('f-result').value;
      const payload = {
        report_type: document.getElementById('f-report-type').value,
        appointment_date: document.getElementById('f-appointment-date').value || null,
        result: resultVal || null,
        content,
        next_action_ddh: document.getElementById('f-next-ddh').value || null,
        next_action_hotel: document.getElementById('f-next-hotel').value || null,
        direct_phone: document.getElementById('f-direct-phone').value || null,
        decision_maker_present: document.getElementById('f-decision-maker').checked ? 1 : 0,
      };
      if (resultVal) payload.progress = resultVal;

      try {
        const res = await fetch(`/api/crm/${leadId}/reports`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();
        if (res.ok) {
          closeReportModal();
          showToast('報告を登録しました');
          await loadLead();
        } else {
          alert('登録に失敗しました: ' + (data.error || ''));
        }
      } finally {
        btn.disabled = false;
        btn.textContent = '報告を登録';
      }
    });

    // ── Lost Modal ──
    const lostModalBg = document.getElementById('lost-modal-bg');
    document.getElementById('btn-lost').addEventListener('click', () => { lostModalBg.classList.remove('hidden'); lostModalBg.classList.add('flex'); });
    document.getElementById('lost-cancel').addEventListener('click', () => { lostModalBg.classList.add('hidden'); lostModalBg.classList.remove('flex'); });
    lostModalBg.addEventListener('click', (e) => { if (e.target === lostModalBg) { lostModalBg.classList.add('hidden'); lostModalBg.classList.remove('flex'); } });

    document.getElementById('lost-confirm').addEventListener('click', async () => {
      const reason = document.getElementById('lost-reason').value;
      const comment = document.getElementById('lost-comment').value;
      if (!reason) { alert('失注理由を選択してください'); return; }

      const btn = document.getElementById('lost-confirm');
      btn.disabled = true;
      btn.textContent = '処理中...';

      try {
        const res = await fetch(`/api/crm/${leadId}/reports`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            report_type: 'アポ',
            result: 'lost',
            progress: 'lost',
            lost_reason: reason,
            content: `失注確定\n理由: ${reason}${comment ? '\nメモ: ' + comment : ''}`,
          }),
        });
        if (res.ok) {
          lostModalBg.classList.add('hidden');
          lostModalBg.classList.remove('flex');
          showToast('失注として記録しました');
          await loadLead();
        }
      } finally {
        btn.disabled = false;
        btn.textContent = '失注確定';
      }
    });

    // Init
    loadLead();
  </script>
</AdminLayout>
