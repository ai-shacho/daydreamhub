---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../../lib/adminAuth';

const runtime = (Astro.locals as any).runtime;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || 'dev-secret';
const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect('/admin/login');

const { id } = Astro.params;
let hotel: any = null;
let plans: any[] = [];
let bookings: any[] = [];
let error = '';

if (db && id) {
  try {
    hotel = await db.prepare(`
      SELECT h.*,
        (SELECT COUNT(*) FROM plans p WHERE p.hotel_id = h.id) as plan_count,
        (SELECT COUNT(*) FROM bookings b WHERE b.hotel_id = h.id) as booking_count
      FROM hotels h WHERE h.id = ?1
    `).bind(id).first();

    if (hotel) {
      const plansResult = await db.prepare(
        `SELECT * FROM plans WHERE hotel_id = ?1 ORDER BY price_usd ASC`
      ).bind(id).all();
      plans = plansResult?.results || [];

      const bookingsResult = await db.prepare(
        `SELECT b.*, p.name as plan_name FROM bookings b
         LEFT JOIN plans p ON p.id = b.plan_id
         WHERE b.hotel_id = ?1 ORDER BY b.created_at DESC LIMIT 20`
      ).bind(id).all();
      bookings = bookingsResult?.results || [];
    }
  } catch (e: any) {
    error = e.message || 'Failed to load hotel';
  }
}

if (!hotel) {
  return new Response('Hotel not found', { status: 404 });
}
---

<AdminLayout title={`${hotel.name} | Admin`} activeNav="hotels">
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
    <a href="/admin/hotels" class="hover:text-teal-600">Hotels</a>
    <span>›</span>
    <span class="text-slate-900 font-medium">{hotel.name}</span>
  </nav>

  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Hotel info -->
    <div class="lg:col-span-2 space-y-6">
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <!-- Hotel image -->
        {hotel.thumbnail_url && (
          <div class="aspect-video bg-slate-100 overflow-hidden">
            <img src={hotel.thumbnail_url} alt={hotel.name} class="w-full h-full object-cover" />
          </div>
        )}
        <div class="p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-xl font-bold text-slate-900">{hotel.name}</h2>
              {hotel.name_ja && <p class="text-slate-500 text-sm mt-0.5">{hotel.name_ja}</p>}
              <p class="text-slate-500 mt-1 flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                {hotel.city}, {hotel.country}
              </p>
            </div>
            <div class="flex items-center gap-2">
              {hotel.is_active ? (
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-medium bg-green-50 text-green-700">
                  <span class="w-2 h-2 rounded-full bg-green-500"></span>Active
                </span>
              ) : (
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-medium bg-slate-100 text-slate-500">
                  <span class="w-2 h-2 rounded-full bg-slate-400"></span>Inactive
                </span>
              )}
            </div>
          </div>

          <div class="mt-4 grid grid-cols-2 gap-3">
            <div class="bg-slate-50 rounded-lg p-3">
              <p class="text-xs text-slate-500 font-medium uppercase tracking-wide">Property Type</p>
              <p class="text-slate-900 font-medium mt-0.5 capitalize">{hotel.property_type || '—'}</p>
            </div>
            <div class="bg-slate-50 rounded-lg p-3">
              <p class="text-xs text-slate-500 font-medium uppercase tracking-wide">Slug</p>
              <p class="text-slate-900 font-mono text-sm mt-0.5">{hotel.slug}</p>
            </div>
            <div class="bg-slate-50 rounded-lg p-3">
              <p class="text-xs text-slate-500 font-medium uppercase tracking-wide">Plans</p>
              <p class="text-slate-900 font-bold text-lg mt-0.5">{hotel.plan_count}</p>
            </div>
            <div class="bg-slate-50 rounded-lg p-3">
              <p class="text-xs text-slate-500 font-medium uppercase tracking-wide">Total Bookings</p>
              <p class="text-slate-900 font-bold text-lg mt-0.5">{hotel.booking_count}</p>
            </div>
          </div>

          {hotel.description && (
            <div class="mt-4">
              <h3 class="text-sm font-medium text-slate-700 mb-1">Description</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{hotel.description}</p>
            </div>
          )}
        </div>
      </div>

      <!-- Plans -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-200 flex items-center justify-between">
          <h3 class="font-semibold text-slate-900">Plans ({plans.length})</h3>
        </div>
        {plans.length === 0 ? (
          <p class="px-5 py-8 text-center text-slate-400 text-sm">No plans yet</p>
        ) : (
          <div class="divide-y divide-slate-100">
            {plans.map((plan) => (
              <div class="px-5 py-4 flex items-center justify-between">
                <div>
                  <p class="font-medium text-slate-900 text-sm">{plan.name}</p>
                  <p class="text-xs text-slate-500 mt-0.5 capitalize">{plan.plan_type} · {plan.duration_hours}h</p>
                </div>
                <div class="text-right">
                  <p class="font-bold text-slate-900">${plan.price_usd}</p>
                  <p class="text-xs text-slate-400">{plan.is_active ? 'Active' : 'Inactive'}</p>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Recent bookings -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-200">
          <h3 class="font-semibold text-slate-900">Recent Bookings ({bookings.length})</h3>
        </div>
        {bookings.length === 0 ? (
          <p class="px-5 py-8 text-center text-slate-400 text-sm">No bookings yet</p>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50">
                  <th class="text-left px-4 py-3 font-medium text-slate-600">Guest</th>
                  <th class="text-left px-4 py-3 font-medium text-slate-600">Plan</th>
                  <th class="text-left px-4 py-3 font-medium text-slate-600">Check-in</th>
                  <th class="text-right px-4 py-3 font-medium text-slate-600">Amount</th>
                  <th class="text-center px-4 py-3 font-medium text-slate-600">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {bookings.map((b) => (
                  <tr>
                    <td class="px-4 py-3 text-slate-700">{b.guest_name || b.guest_email || '—'}</td>
                    <td class="px-4 py-3 text-slate-500">{b.plan_name || '—'}</td>
                    <td class="px-4 py-3 text-slate-500">{b.checkin_date || '—'}</td>
                    <td class="px-4 py-3 text-right font-medium">${b.total_price || '0'}</td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${
                        b.status === 'confirmed' ? 'bg-green-50 text-green-700' :
                        b.status === 'pending' ? 'bg-amber-50 text-amber-700' :
                        'bg-slate-100 text-slate-500'
                      }`}>{b.status}</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-4">
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5">
        <h3 class="font-semibold text-slate-900 mb-3">Actions</h3>
        <div class="space-y-2">
          <a href={`/hotel/${hotel.slug}`} target="_blank"
            class="flex items-center gap-2 w-full px-3 py-2 text-sm bg-teal-50 text-teal-700 rounded-lg hover:bg-teal-100 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            View Public Page
          </a>
          <a href={`/admin/hotels/${hotel.id}/edit`} class="flex items-center gap-2 w-full px-3 py-2 text-sm bg-indigo-50 text-indigo-700 rounded-lg hover:bg-indigo-100 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            Edit Hotel Info
          </a>
          {hotel.phone && (
            <button id="call-hotel-btn" data-phone={hotel.phone} data-hotel-id={hotel.id} data-hotel-name={hotel.name}
              class="flex items-center gap-2 w-full px-3 py-2 text-sm bg-teal-50 text-teal-700 rounded-lg hover:bg-teal-100 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/></svg>
              📞 今すぐ発信 ({hotel.phone})
            </button>
          )}
          <div id="call-result" class="hidden text-xs p-2 rounded-lg"></div>
          <button class={`flex items-center gap-2 w-full px-3 py-2 text-sm rounded-lg transition-colors ${
            hotel.is_active
              ? 'bg-red-50 text-red-700 hover:bg-red-100'
              : 'bg-green-50 text-green-700 hover:bg-green-100'
          }`}>
            {hotel.is_active ? '⏸ Deactivate' : '▶ Activate'}
          </button>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5">
        <h3 class="font-semibold text-slate-900 mb-3">Info</h3>
        <dl class="space-y-2 text-sm">
          <div class="flex justify-between">
            <dt class="text-slate-500">ID</dt>
            <dd class="font-mono text-slate-700">#{hotel.id}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-slate-500">Created</dt>
            <dd class="text-slate-700">{hotel.created_at ? new Date(hotel.created_at).toLocaleDateString() : '—'}</dd>
          </div>
          {hotel.phone && (
            <div class="flex justify-between">
              <dt class="text-slate-500">Phone</dt>
              <dd class="text-slate-700">{hotel.phone}</dd>
            </div>
          )}
          {hotel.website && (
            <div class="flex justify-between gap-2">
              <dt class="text-slate-500">Website</dt>
              <dd><a href={hotel.website} target="_blank" class="text-teal-600 hover:underline text-xs truncate max-w-32">{hotel.website}</a></dd>
            </div>
          )}
        </dl>
      </div>
    </div>
  </div>
</AdminLayout>

<script is:inline>
document.getElementById('call-hotel-btn')?.addEventListener('click', async function() {
  const btn = this;
  const result = document.getElementById('call-result');
  btn.disabled = true;
  btn.textContent = '発信中...';
  try {
    const res = await fetch('/api/admin/call', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action: 'dial',
        to_number: btn.dataset.phone,
        hotel_id: parseInt(btn.dataset.hotelId),
        hotel_name: btn.dataset.hotelName,
        note: 'Admin manual call from hotel detail page',
      }),
    });
    const data = await res.json();
    result.className = `block text-xs p-2 rounded-lg ${res.ok ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700'}`;
    result.textContent = res.ok ? `✅ 発信成功！SID: ${data.call_sid || '—'}` : `❌ ${data.error}`;
  } catch(e) {
    result.className = 'block text-xs p-2 rounded-lg bg-red-50 text-red-700';
    result.textContent = `❌ エラー: ${e.message}`;
  } finally {
    btn.disabled = false;
    btn.textContent = '📞 今すぐ発信 (' + btn.dataset.phone + ')';
  }
});
</script>
