---
import AdminLayout from '../../../../layouts/AdminLayout.astro';

const { id } = Astro.params;
const db = (Astro.locals as any).runtime?.env?.DB;

let hotel: any = null;
let plans: any[] = [];
let error = '';

if (!db) {
  error = 'Database not available';
} else {
  hotel = await db.prepare('SELECT * FROM hotels WHERE id = ?').bind(id).first();
  if (!hotel) error = 'Hotel not found';
  if (hotel) {
    const plansResult = await db.prepare('SELECT * FROM plans WHERE hotel_id = ? ORDER BY price_usd ASC').bind(id).all();
    plans = plansResult?.results || [];
  }
}

const currentAmenities: string[] = hotel ? (() => { try { return JSON.parse(hotel.amenities || '[]'); } catch { return []; } })() : [];

const COMMON_AMENITIES = [
  'Free Wi-Fi','Parking on Premises','Air Conditioner (Cooling)','Air Conditioner (Heating)',
  'Swimming Pool','Gym','Spa','Breakfast','Restaurant','Bar','Room Service','Concierge',
  'Shower','Bath','Hot Tub','Hair Dryer','TV','Refrigerator','Electric pot','Microwave',
  'Coffee Machine','Towels','Shampoo','Luggage Storage','Desk','Meeting Room','Printer',
  'Balcony','Garden','Beach Access','Airport Transfer',
];

const PLAN_TYPES = ['daycation','for_couple','for_work','luxury','personal_time','transit','overnight','early_check_in'];

// 30-minute interval time options
const TIME_OPTIONS: string[] = [];
for (let h = 0; h < 24; h++) {
  TIME_OPTIONS.push(`${h}:00`);
  TIME_OPTIONS.push(`${h}:30`);
}
---

<AdminLayout title={hotel ? `Edit: ${hotel.name}` : 'Edit Hotel'} activeNav="hotels">
  <div class="max-w-3xl mx-auto px-4 py-8">

    <!-- Header -->
    <div class="flex items-center gap-3 mb-6">
      <a href={`/admin/hotels/${id}`} class="text-gray-400 hover:text-gray-600 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
      </a>
      <div>
        <h1 class="text-xl font-bold text-slate-900">Edit Hotel Info</h1>
        {hotel && <p class="text-sm text-slate-500">{hotel.name}</p>}
      </div>
    </div>

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 mb-6">{error}</div>
    )}

    {hotel && (
      <form id="edit-hotel-form" class="space-y-6">
        <input type="hidden" name="id" value={hotel.id} />

        <!-- Top action bar -->
        <div>
          <div id="form-success-top" class="hidden bg-green-50 border border-green-200 text-green-700 text-sm rounded-lg px-4 py-3 mb-3"></div>
          <div id="form-error-top" class="hidden bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3 mb-3"></div>
          <div class="flex gap-3">
            <button type="button" class="save-btn flex-1 bg-teal-600 hover:bg-teal-700 text-white font-semibold py-2.5 rounded-lg transition-colors text-sm">
              Save Changes
            </button>
            <a href={`/admin/hotels/${id}`} class="px-5 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-colors">
              Cancel
            </a>
          </div>
        </div>

        <!-- Basic Info -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
          <h2 class="text-sm font-semibold text-teal-700 uppercase tracking-wide">Basic Information</h2>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Name (EN) <span class="text-red-500">*</span></label>
              <input name="name" type="text" required value={hotel.name || ''}
                class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Name (JA)</label>
              <input name="name_ja" type="text" value={hotel.name_ja || ''}
                class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Slug</label>
            <input name="slug" type="text" value={hotel.slug || ''}
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm font-mono focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none" />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Property Type</label>
            <select name="property_type"
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none bg-white">
              {['hotel','villa','resort','hostel','apartment','guest_house','bnb','ryokan','boutique_hotel','cottage','entire_home','private_room','shared_room'].map(t => (
                <option value={t} selected={hotel.property_type === t}>{t.replace('_', ' ')}</option>
              ))}
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Thumbnail</label>
            <div class="flex gap-2 mb-2">
              <input name="thumbnail_url" id="thumbnail-url-input" type="text" value={hotel.thumbnail_url || ''}
                placeholder="https://..." class="flex-1 px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none" />
              <label for="thumbnail-upload" class="cursor-pointer flex items-center gap-1.5 px-3 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm rounded-lg transition-colors whitespace-nowrap">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                Upload
              </label>
              <input id="thumbnail-upload" type="file" accept="image/*" class="hidden" />
            </div>
            <div id="thumbnail-preview" class={hotel.thumbnail_url ? '' : 'hidden'}>
              <img id="thumbnail-img" src={hotel.thumbnail_url || ''} alt="thumbnail" class="h-24 w-40 object-cover rounded-lg border" />
            </div>
            <span id="thumbnail-status" class="text-xs text-gray-500"></span>
          </div>
        </div>

        <!-- Gallery Images -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
          <h2 class="text-sm font-semibold text-teal-700 uppercase tracking-wide">Gallery Images</h2>
          <p class="text-xs text-gray-500">Drag and drop to reorder. The first image will be shown as the main photo.</p>

          <!-- Upload button -->
          <div class="flex items-center gap-3">
            <label for="img-upload" class="cursor-pointer flex items-center gap-2 px-4 py-2 bg-teal-600 hover:bg-teal-700 text-white text-sm font-medium rounded-lg transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
              Upload Images
            </label>
            <input id="img-upload" type="file" accept="image/*" multiple class="hidden" />
            <span id="upload-status" class="text-sm text-gray-500"></span>
          </div>

          <!-- Image grid (drag-sortable) -->
          <div id="gallery-grid" class="grid grid-cols-3 sm:grid-cols-4 gap-3 min-h-[80px]">
            <!-- JS will populate this -->
          </div>
          <p id="gallery-empty" class="text-sm text-gray-400 text-center py-4 hidden">No images yet.</p>
        </div>

        <!-- Description -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
          <h2 class="text-sm font-semibold text-teal-700 uppercase tracking-wide">Description</h2>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Description (EN)</label>
            <textarea name="description" rows={4}
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none resize-y"
            >{hotel.description || ''}</textarea>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Description (JA)</label>
            <textarea name="description_ja" rows={4}
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none resize-y"
            >{hotel.description_ja || ''}</textarea>
          </div>
          <div id="cancellation">
            <label class="block text-sm font-medium text-slate-700 mb-1">Cancellation Policy</label>
            <textarea name="cancellation_policy" rows={3} placeholder="e.g. Free cancellation up to 24 hours before check-in. No refund after that."
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none resize-y"
            >{hotel.cancellation_policy || ''}</textarea>
          </div>
        </div>

        <!-- Location -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
          <h2 class="text-sm font-semibold text-teal-700 uppercase tracking-wide">Location</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">City</label>
              <input name="city" type="text" value={hotel.city || ''}
                class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Country</label>
              <input name="country" type="text" value={hotel.country || ''}
                class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Address</label>
            <input name="address" type="text" value={hotel.address || ''}
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none" />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Latitude</label>
              <input name="latitude" type="number" step="any" value={hotel.latitude ?? ''}
                class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm font-mono focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Longitude</label>
              <input name="longitude" type="number" step="any" value={hotel.longitude ?? ''}
                class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm font-mono focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none" />
            </div>
          </div>
        </div>

        <!-- Contact -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
          <h2 class="text-sm font-semibold text-teal-700 uppercase tracking-wide">Contact</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
              <input name="email" type="email" value={hotel.email || ''}
                class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Phone</label>
              <input name="phone" type="tel" value={hotel.phone || ''}
                class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none" />
            </div>
          </div>
        </div>

        <!-- System -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
          <h2 class="text-sm font-semibold text-teal-700 uppercase tracking-wide">System Settings</h2>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">iCal URL</label>
            <input name="ical_url" type="text" value={hotel.ical_url || ''}
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm font-mono focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none" />
          </div>
          <div class="flex items-center gap-3">
            <input type="checkbox" name="auto_call_enabled" id="auto_call_enabled" value="1"
              checked={!!hotel.auto_call_enabled}
              class="w-4 h-4 text-teal-600 rounded border-gray-300 focus:ring-teal-500" />
            <label for="auto_call_enabled" class="text-sm font-medium text-slate-700">Auto-call enabled</label>
          </div>
        </div>

        <!-- Amenities -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
          <h2 class="text-sm font-semibold text-teal-700 uppercase tracking-wide">Amenities</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
            {COMMON_AMENITIES.map(a => (
              <label class="flex items-center gap-2 text-sm text-slate-700 cursor-pointer">
                <input type="checkbox" name="amenities" value={a} checked={currentAmenities.includes(a)}
                  class="w-4 h-4 text-teal-600 rounded border-gray-300 focus:ring-teal-500" />
                {a}
              </label>
            ))}
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Custom amenities <span class="text-gray-400">(comma-separated)</span></label>
            <input id="custom-amenities" type="text"
              value={currentAmenities.filter(a => !COMMON_AMENITIES.includes(a)).join(', ')}
              placeholder="e.g. Sauna, Rooftop Terrace"
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none" />
          </div>
        </div>

        <!-- Bottom Actions -->
        <div>
          <div id="form-success-bottom" class="hidden bg-green-50 border border-green-200 text-green-700 text-sm rounded-lg px-4 py-3 mb-3"></div>
          <div id="form-error-bottom" class="hidden bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3 mb-3"></div>
          <div class="flex gap-3">
            <button type="button" class="save-btn flex-1 bg-teal-600 hover:bg-teal-700 text-white font-semibold py-2.5 rounded-lg transition-colors text-sm">
              Save Changes
            </button>
            <a href={`/admin/hotels/${id}`} class="px-5 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-colors">
              Cancel
            </a>
          </div>
        </div>
      </form>

      <!-- Plans Section (separate from main form) -->
      <div class="mt-8 bg-white rounded-xl border border-gray-200 p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-teal-700 uppercase tracking-wide">Plans</h2>
          <button id="add-plan-btn" class="text-sm bg-teal-600 hover:bg-teal-700 text-white px-3 py-1.5 rounded-lg transition-colors">
            + Add Plan
          </button>
        </div>

        <!-- Add Plan Form (hidden by default) -->
        <div id="add-plan-form" class="hidden mb-6 p-4 bg-gray-50 rounded-lg border border-gray-200 space-y-3">
          <h3 class="text-sm font-semibold text-slate-700">New Plan</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Name (EN) *</label>
              <input id="new-name" type="text" placeholder="Plan name"
                class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" />
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Name (JA)</label>
              <input id="new-name-ja" type="text" placeholder="プラン名"
                class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" />
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Price (USD) *</label>
              <input id="new-price" type="number" step="0.01" min="0" placeholder="0.00"
                class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" />
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Plan Type</label>
              <select id="new-plan-type" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none bg-white">
                {PLAN_TYPES.map(t => <option value={t}>{t.replace('_',' ')}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Check-in</label>
              <input id="new-checkin" type="text" list="time-options" placeholder="10:00"
                class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" />
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Check-out</label>
              <input id="new-checkout" type="text" list="time-options" placeholder="18:00"
                class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" />
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Max Guests</label>
              <input id="new-guests" type="number" min="1" value="2"
                class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Description</label>
            <textarea id="new-desc" rows={2} placeholder="Plan description..."
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none resize-y"></textarea>
          </div>
          <div id="add-plan-error" class="hidden text-red-600 text-xs"></div>
          <div class="flex gap-2">
            <button id="save-plan-btn" class="bg-teal-600 hover:bg-teal-700 text-white text-sm px-4 py-2 rounded-lg transition-colors">Save Plan</button>
            <button id="cancel-plan-btn" class="text-gray-600 text-sm px-4 py-2 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">Cancel</button>
          </div>
        </div>

        <!-- Plans List -->
        <div id="plans-list" class="space-y-2">
          {plans.length === 0 && (
            <p class="text-sm text-gray-400 text-center py-4">No plans yet.</p>
          )}
          {plans.map((plan: any) => (
            <div class="plan-row flex items-start gap-3 p-3 rounded-lg border border-gray-100 hover:border-gray-200 transition-colors" data-plan-id={plan.id}>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="font-medium text-sm text-slate-900 plan-name">{plan.name}</span>
                  <span class={`text-xs px-2 py-0.5 rounded-full ${plan.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>
                    {plan.is_active ? 'Active' : 'Inactive'}
                  </span>
                  <span class="text-xs bg-teal-50 text-teal-700 px-2 py-0.5 rounded-full">{plan.plan_type}</span>
                </div>
                <div class="text-xs text-gray-500 mt-0.5">
                  ${plan.price_usd} · {plan.check_in_time}–{plan.check_out_time} · max {plan.max_guests} guests
                </div>
              </div>
              <div class="flex gap-1 flex-shrink-0">
                <button class="edit-plan-btn text-xs px-2 py-1 bg-indigo-50 text-indigo-700 rounded hover:bg-indigo-100 transition-colors">Edit</button>
                <button class="toggle-plan-btn text-xs px-2 py-1 rounded transition-colors"
                  class:list={[plan.is_active ? 'bg-red-50 text-red-600 hover:bg-red-100' : 'bg-green-50 text-green-700 hover:bg-green-100']}>
                  {plan.is_active ? 'Deactivate' : 'Activate'}
                </button>
                <button class="delete-plan-btn text-xs px-2 py-1 bg-red-50 text-red-600 rounded hover:bg-red-100 transition-colors">Delete</button>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Time datalist (shared) -->
      <datalist id="time-options">
        {TIME_OPTIONS.map(t => <option value={t} />)}
      </datalist>

      <!-- Edit Plan Modal -->
      <div id="edit-plan-modal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-xl w-full max-w-lg p-6 space-y-4">
          <h3 class="text-base font-semibold text-slate-900">Edit Plan</h3>
          <input type="hidden" id="edit-plan-id" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Name (EN) *</label>
              <input id="edit-plan-name" type="text" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" />
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Name (JA)</label>
              <input id="edit-plan-name-ja" type="text" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" />
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Price (USD)</label>
              <input id="edit-plan-price" type="number" step="0.01" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" />
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Plan Type</label>
              <select id="edit-plan-type" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none bg-white">
                {PLAN_TYPES.map(t => <option value={t}>{t.replace('_',' ')}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Check-in</label>
              <input id="edit-plan-checkin" type="text" list="time-options" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" />
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Check-out</label>
              <input id="edit-plan-checkout" type="text" list="time-options" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" />
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Max Guests</label>
              <input id="edit-plan-guests" type="number" min="1" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Description</label>
            <textarea id="edit-plan-desc" rows={2} class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none resize-y"></textarea>
          </div>
          <div id="edit-plan-error" class="hidden text-red-600 text-xs"></div>
          <div class="flex gap-2">
            <button id="update-plan-btn" class="bg-teal-600 hover:bg-teal-700 text-white text-sm px-4 py-2 rounded-lg transition-colors">Update</button>
            <button id="close-modal-btn" class="text-gray-600 text-sm px-4 py-2 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">Cancel</button>
          </div>
        </div>
      </div>
    )}
  </div>
</AdminLayout>

<script is:inline define:vars={{ hotelId: id }}>
// ── Hotel Info Save ──
async function saveHotel() {
  const btns = document.querySelectorAll('.save-btn');
  const errEls = [document.getElementById('form-error-top'), document.getElementById('form-error-bottom')];
  const successEls = [document.getElementById('form-success-top'), document.getElementById('form-success-bottom')];
  errEls.forEach(el => el && (el.className = 'hidden'));
  successEls.forEach(el => el && (el.className = 'hidden'));
  btns.forEach(b => { b.disabled = true; b.textContent = 'Saving...'; });

  const form = document.getElementById('edit-hotel-form');
  const body = { id: parseInt(form.id.value) };
  const fields = ['name','name_ja','slug','description','description_ja','cancellation_policy','city','country',
    'address','thumbnail_url','property_type','email','phone','ical_url'];
  for (const f of fields) { if (form[f]) body[f] = form[f].value; }
  if (form.latitude?.value !== '') body.latitude = parseFloat(form.latitude.value);
  if (form.longitude?.value !== '') body.longitude = parseFloat(form.longitude.value);
  body.auto_call_enabled = form.auto_call_enabled?.checked ? 1 : 0;

  // Collect amenities
  const checked = [...document.querySelectorAll('input[name="amenities"]:checked')].map(el => el.value);
  const custom = document.getElementById('custom-amenities').value.split(',').map(s => s.trim()).filter(Boolean);
  body.amenities = JSON.stringify([...new Set([...checked, ...custom])]);

  try {
    const res = await fetch('/api/admin/hotels', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    const data = await res.json();
    if (res.ok && data.success) {
      const msg = '✅ Page Updated Successfully';
      successEls.forEach(el => {
        if (!el) return;
        el.className = 'block bg-green-50 border border-green-200 text-green-700 text-sm rounded-lg px-4 py-3';
        el.textContent = msg;
      });
    } else {
      const msg = data.error || 'Failed to save changes.';
      errEls.forEach(el => {
        if (!el) return;
        el.className = 'block bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3';
        el.textContent = msg;
      });
    }
  } catch {
    const msg = 'Connection error. Please try again.';
    errEls.forEach(el => {
      if (!el) return;
      el.className = 'block bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3';
      el.textContent = msg;
    });
  } finally { btns.forEach(b => { b.disabled = false; b.textContent = 'Save Changes'; }); }
}

document.querySelectorAll('.save-btn').forEach(btn => btn.addEventListener('click', saveHotel));

const HOTEL_ID = parseInt(hotelId);

// ── Thumbnail Upload ──
document.getElementById('thumbnail-upload')?.addEventListener('change', async function() {
  const file = this.files?.[0];
  if (!file) return;
  const statusEl = document.getElementById('thumbnail-status');
  statusEl.textContent = 'Uploading...';
  const fd = new FormData();
  fd.append('hotel_id', HOTEL_ID);
  fd.append('file', file);
  try {
    const res = await fetch('/api/admin/hotel-images', { method: 'POST', body: fd });
    const data = await res.json();
    if (data.success) {
      const input = document.getElementById('thumbnail-url-input');
      input.value = data.image_url;
      const preview = document.getElementById('thumbnail-preview');
      const img = document.getElementById('thumbnail-img');
      img.src = data.image_url;
      preview.classList.remove('hidden');
      statusEl.textContent = '✅ Uploaded';
    } else {
      statusEl.textContent = `Error: ${data.error}`;
    }
  } catch { statusEl.textContent = 'Connection error'; }
  this.value = '';
});

// Update thumbnail preview on URL input change
document.getElementById('thumbnail-url-input')?.addEventListener('input', function() {
  const img = document.getElementById('thumbnail-img');
  const preview = document.getElementById('thumbnail-preview');
  if (this.value) { img.src = this.value; preview.classList.remove('hidden'); }
  else { preview.classList.add('hidden'); }
});

// ── Gallery Images ──
(function() {
  const grid = document.getElementById('gallery-grid');
  const emptyMsg = document.getElementById('gallery-empty');
  const statusEl = document.getElementById('upload-status');
  let images = []; // {id, image_url, sort_order}
  let dragSrcId = null;

  async function loadImages() {
    const res = await fetch(`/api/admin/hotel-images?hotel_id=${HOTEL_ID}`);
    const data = await res.json();
    images = data.images || [];
    renderGrid();
  }

  function renderGrid() {
    grid.innerHTML = '';
    if (!images.length) { emptyMsg.classList.remove('hidden'); return; }
    emptyMsg.classList.add('hidden');
    images.forEach(img => {
      const div = document.createElement('div');
      div.className = 'relative group rounded-lg overflow-hidden border-2 border-transparent hover:border-teal-400 transition-all cursor-grab aspect-square bg-gray-100';
      div.draggable = true;
      div.dataset.id = img.id;
      div.innerHTML = `
        <img src="${img.image_url}" alt="" class="w-full h-full object-cover pointer-events-none" />
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-all flex items-center justify-center opacity-0 group-hover:opacity-100">
          <button class="delete-img-btn bg-red-500 text-white rounded-full w-7 h-7 flex items-center justify-center text-sm hover:bg-red-600" data-id="${img.id}">✕</button>
        </div>
        <div class="absolute top-1 left-1 bg-black/50 text-white text-xs rounded px-1 order-badge"></div>
      `;
      // Drag events
      div.addEventListener('dragstart', e => { dragSrcId = img.id; div.classList.add('opacity-50'); e.dataTransfer.effectAllowed = 'move'; });
      div.addEventListener('dragend', () => { div.classList.remove('opacity-50'); });
      div.addEventListener('dragover', e => { e.preventDefault(); e.dataTransfer.dropEffect = 'move'; div.classList.add('border-teal-400'); });
      div.addEventListener('dragleave', () => div.classList.remove('border-teal-400'));
      div.addEventListener('drop', async e => {
        e.preventDefault(); div.classList.remove('border-teal-400');
        if (dragSrcId === img.id) return;
        // Swap positions
        const srcIdx = images.findIndex(i => i.id === dragSrcId);
        const dstIdx = images.findIndex(i => i.id === img.id);
        if (srcIdx < 0 || dstIdx < 0) return;
        const [moved] = images.splice(srcIdx, 1);
        images.splice(dstIdx, 0, moved);
        images.forEach((im, idx) => im.sort_order = idx);
        renderGrid();
        // Save order
        await fetch('/api/admin/hotel-images', { method: 'PUT', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ images: images.map(i => ({id:i.id, sort_order:i.sort_order})) }) });
      });
      // Delete
      div.querySelector('.delete-img-btn').addEventListener('click', async () => {
        if (!confirm('Delete this image?')) return;
        await fetch(`/api/admin/hotel-images?id=${img.id}`, { method: 'DELETE' });
        images = images.filter(i => i.id !== img.id);
        images.forEach((im, idx) => im.sort_order = idx);
        renderGrid();
      });
      grid.appendChild(div);
    });
    // Update order badges
    grid.querySelectorAll('.order-badge').forEach((badge, idx) => { badge.textContent = idx === 0 ? 'Main' : `${idx+1}`; });
  }

  // File upload
  document.getElementById('img-upload').addEventListener('change', async function() {
    const files = [...this.files];
    if (!files.length) return;
    statusEl.textContent = `Uploading... (0/${files.length})`;
    let done = 0;
    for (const file of files) {
      const fd = new FormData();
      fd.append('hotel_id', HOTEL_ID);
      fd.append('file', file);
      try {
        const res = await fetch('/api/admin/hotel-images', { method: 'POST', body: fd });
        const data = await res.json();
        if (data.success) {
          images.push({ id: data.id, image_url: data.image_url, sort_order: data.sort_order });
          done++;
          statusEl.textContent = `Uploading... (${done}/${files.length})`;
        } else {
          statusEl.textContent = `Error: ${data.error}`;
        }
      } catch { statusEl.textContent = 'Connection error'; }
    }
    renderGrid();
    statusEl.textContent = done > 0 ? `✅ ${done} image(s) uploaded` : '';
    this.value = '';
  });

  loadImages();
})();

// ── Plans ──

// Add plan toggle
document.getElementById('add-plan-btn')?.addEventListener('click', () => {
  document.getElementById('add-plan-form').classList.toggle('hidden');
});
document.getElementById('cancel-plan-btn')?.addEventListener('click', () => {
  document.getElementById('add-plan-form').classList.add('hidden');
});

// Save new plan
document.getElementById('save-plan-btn')?.addEventListener('click', async () => {
  const errEl = document.getElementById('add-plan-error');
  errEl.className = 'hidden';
  const name = document.getElementById('new-name').value.trim();
  if (!name) { errEl.textContent = 'Name is required'; errEl.className = 'block text-red-600 text-xs'; return; }
  const body = {
    hotel_id: HOTEL_ID,
    name,
    name_ja: document.getElementById('new-name-ja').value || null,
    price_usd: parseFloat(document.getElementById('new-price').value) || 0,
    plan_type: document.getElementById('new-plan-type').value,
    check_in_time: document.getElementById('new-checkin').value,
    check_out_time: document.getElementById('new-checkout').value,
    max_guests: parseInt(document.getElementById('new-guests').value) || 2,
    description: document.getElementById('new-desc').value,
  };
  const res = await fetch('/api/admin/plans', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
  const data = await res.json();
  if (data.success) { window.location.reload(); } else { errEl.textContent = data.error || 'Error'; errEl.className = 'block text-red-600 text-xs'; }
});

// Plan row actions (event delegation)
document.getElementById('plans-list')?.addEventListener('click', async function(e) {
  const btn = e.target.closest('button');
  if (!btn) return;
  const row = btn.closest('.plan-row');
  const planId = parseInt(row?.dataset.planId);

  if (btn.classList.contains('delete-plan-btn')) {
    if (!confirm('Delete this plan?')) return;
    const res = await fetch(`/api/admin/plans?id=${planId}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) row.remove(); else alert(data.error);
  }

  if (btn.classList.contains('toggle-plan-btn')) {
    const isActive = btn.textContent.trim() === 'Deactivate' ? 0 : 1;
    const res = await fetch('/api/admin/plans', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: planId, is_active: isActive }) });
    const data = await res.json();
    if (data.success) window.location.reload(); else alert(data.error);
  }

  if (btn.classList.contains('edit-plan-btn')) {
    // Populate modal from row data
    const nameEl = row.querySelector('.plan-name');
    document.getElementById('edit-plan-id').value = planId;
    document.getElementById('edit-plan-name').value = nameEl?.textContent || '';
    // Fetch full plan data
    const res = await fetch(`/api/admin/plans?hotel_id=${HOTEL_ID}`);
    const data = await res.json();
    const plan = (data.plans || []).find(p => p.id === planId);
    if (plan) {
      document.getElementById('edit-plan-name').value = plan.name || '';
      document.getElementById('edit-plan-name-ja').value = plan.name_ja || '';
      document.getElementById('edit-plan-price').value = plan.price_usd || '';
      document.getElementById('edit-plan-type').value = plan.plan_type || 'daycation';
      document.getElementById('edit-plan-checkin').value = plan.check_in_time || '';
      document.getElementById('edit-plan-checkout').value = plan.check_out_time || '';
      document.getElementById('edit-plan-guests').value = plan.max_guests || 2;
      document.getElementById('edit-plan-desc').value = plan.description || '';

    }
    document.getElementById('edit-plan-modal').classList.remove('hidden');
  }
});

// Close modal
document.getElementById('close-modal-btn')?.addEventListener('click', () => {
  document.getElementById('edit-plan-modal').classList.add('hidden');
});
document.getElementById('edit-plan-modal')?.addEventListener('click', function(e) {
  if (e.target === this) this.classList.add('hidden');
});

// Update plan
document.getElementById('update-plan-btn')?.addEventListener('click', async () => {
  const errEl = document.getElementById('edit-plan-error');
  errEl.className = 'hidden';
  const body = {
    id: parseInt(document.getElementById('edit-plan-id').value),
    name: document.getElementById('edit-plan-name').value.trim(),
    name_ja: document.getElementById('edit-plan-name-ja').value || null,
    price_usd: parseFloat(document.getElementById('edit-plan-price').value) || 0,
    plan_type: document.getElementById('edit-plan-type').value,
    check_in_time: document.getElementById('edit-plan-checkin').value,
    check_out_time: document.getElementById('edit-plan-checkout').value,
    max_guests: parseInt(document.getElementById('edit-plan-guests').value) || 2,
    description: document.getElementById('edit-plan-desc').value,
  };
  if (!body.name) { errEl.textContent = 'Name is required'; errEl.className = 'block text-red-600 text-xs'; return; }
  const res = await fetch('/api/admin/plans', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
  const data = await res.json();
  if (data.success) window.location.reload(); else { errEl.textContent = data.error || 'Error'; errEl.className = 'block text-red-600 text-xs'; }
});
</script>
