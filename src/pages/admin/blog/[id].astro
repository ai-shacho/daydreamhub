---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../../lib/adminAuth';

const runtime = (Astro.locals as any).runtime;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || 'dev-secret';
const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect('/admin/login');

const { id } = Astro.params;
let post: any = null;
let error = '';
let success = false;

if (!id) return new Response('Not found', { status: 404 });

// Handle POST (save)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const title = formData.get('title') as string;
    const title_ja = formData.get('title_ja') as string;
    const slug = formData.get('slug') as string;
    const excerpt = formData.get('excerpt') as string;
    const city = formData.get('city') as string;
    let thumbnail_url = formData.get('thumbnail_url') as string;
    
    // Handle thumbnail_file if present (takes priority over thumbnail_url)
    const thumbnailFile = formData.get('thumbnail_file') as File;
    if (thumbnailFile && thumbnailFile.size > 0) {
      thumbnail_url = formData.get('thumbnail_file_url') as string;
    }
    
    const content = formData.get('content') as string;
    const content_ja = formData.get('content_ja') as string;
    const published_at_raw = formData.get('published_at') as string;
    const published_at = published_at_raw ? published_at_raw.replace('T', ' ') + ':00' : null;

    if (db) {
      const result = await db.prepare(`
        UPDATE blog_posts
        SET title = ?, title_ja = ?, slug = ?, excerpt = ?, city = ?,
            thumbnail_url = ?, content = ?, content_ja = ?, published_at = ?
        WHERE id = ?
      `).bind(title, title_ja, slug, excerpt, city, thumbnail_url, content, content_ja, published_at, id).run();

      if (result.meta.changes === 0) {
        error = 'Blog post not found or no changes made';
      } else {
        success = true;
      }
    } else {
      error = 'Database not available';
    }
  } catch (e: any) {
    error = e.message || 'Failed to save';
  }
}

// Load post
if (db) {
  try {
    post = await db.prepare(
      `SELECT id, title, title_ja, slug, excerpt, city, thumbnail_url, content, content_ja, published_at FROM blog_posts WHERE id = ?`
    ).bind(id).first();
  } catch (e: any) {
    error = e.message || 'Failed to load post';
  }
}

if (!post) return new Response('Blog post not found', { status: 404 });

// Format published_at for datetime-local input (YYYY-MM-DDTHH:MM)
const publishedAtValue = post.published_at ? post.published_at.slice(0, 16).replace(' ', 'T') : '';

// Escape content for safe embedding in JS
const contentEscaped = JSON.stringify(post.content || '');
const contentJaEscaped = JSON.stringify(post.content_ja || '');
---

<AdminLayout title={`Edit: ${post.title || 'Blog Post'}`} activeNav="blog">
  <!-- Jodit Editor CSS -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jodit/3.24.6/jodit.min.css" />

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
    <a href="/admin/blog" class="hover:text-teal-600">Blog Posts</a>
    <span>›</span>
    <span class="text-slate-900 font-medium">Edit #{post.id}</span>
  </nav>

  {success && (
    <div id="success-msg" class="bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-lg mb-4 text-sm font-medium">
      ✅ 保存しました / Saved successfully
    </div>
  )}

  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>
  )}

  <form method="POST" id="blog-form" class="space-y-6">
    <!-- Basic Info -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
      <h2 class="text-base font-semibold text-slate-900 mb-4">Basic Info</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">
            Title (English) <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            name="title"
            value={post.title || ''}
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
            placeholder="English title"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">
            Title (Japanese)
          </label>
          <input
            type="text"
            name="title_ja"
            value={post.title_ja || ''}
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
            placeholder="日本語タイトル"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Slug</label>
          <input
            type="text"
            name="slug"
            value={post.slug || ''}
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
            placeholder="url-slug"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">City</label>
          <input
            type="text"
            name="city"
            value={post.city || ''}
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
            placeholder="Tokyo"
          />
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-slate-700 mb-1">Thumbnail Image</label>
          <div id="upload-area" class="border-2 border-dashed border-slate-300 rounded-lg p-6 text-center cursor-pointer hover:border-teal-500 hover:bg-teal-50 transition-colors" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)">
            <input
              type="file"
              name="thumbnail_file"
              id="thumbnail_file"
              accept="image/jpeg,image/png,image/webp,image/gif"
              class="hidden"
            />
            <div id="upload-prompt" class="text-slate-500">
              <p class="text-sm font-medium mb-1">📁 クリックまたはドラッグ&ドロップ</p>
              <p class="text-xs text-slate-400">PNG, JPG, WebP, GIF (最大5MB)</p>
            </div>
            <div id="upload-spinner" class="hidden">
              <p class="text-sm font-medium text-teal-600">アップロード中...</p>
            </div>
          </div>
          <input type="hidden" name="thumbnail_url" id="thumbnail_url" value={post.thumbnail_url || ''} />
          <input type="hidden" name="thumbnail_file_url" id="thumbnail_file_url" />
        </div>
        <div id="thumb-preview-container" class="md:col-span-2 {post.thumbnail_url ? '' : 'hidden'}">
          <div class="relative inline-block">
            <img id="thumb-preview" src={post.thumbnail_url || ''} alt="Thumbnail preview" class="h-48 object-cover rounded-lg border border-slate-200" />
            <button
              type="button"
              id="remove-thumbnail"
              class="absolute top-2 right-2 bg-red-500 text-white rounded-full p-1 hover:bg-red-600 transition-colors"
              onclick="removeThumbnail()"
            >
              ✕
            </button>
          </div>
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-slate-700 mb-1">Excerpt</label>
          <textarea
            name="excerpt"
            rows="3"
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent resize-y"
            placeholder="Short description..."
          >{post.excerpt || ''}</textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Published At</label>
          <input
            type="datetime-local"
            name="published_at"
            value={publishedAtValue}
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
          />
          <p class="text-xs text-slate-400 mt-1">Leave blank to keep as draft</p>
        </div>
        <div class="flex items-end">
          <a
            href={`/blog/${post.slug}`}
            target="_blank"
            class="inline-flex items-center gap-1 px-3 py-2 text-sm text-teal-600 border border-teal-200 rounded-lg hover:bg-teal-50 transition-colors"
          >
            👁 Preview
          </a>
        </div>
      </div>
    </div>

    <!-- Content Editors -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
      <h2 class="text-base font-semibold text-slate-900 mb-2">Content (English)</h2>
      <p class="text-xs text-slate-400 mb-3">ビジュアルエディタで編集できます。HTMLの直接編集も可能です。</p>
      <!-- Hidden input for form submission -->
      <input type="hidden" name="content" id="content-hidden" />
      <!-- Jodit editor target -->
      <div id="editor-en" class="min-h-[400px]"></div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
      <h2 class="text-base font-semibold text-slate-900 mb-2">Content (Japanese)</h2>
      <p class="text-xs text-slate-400 mb-3">日本語コンテンツをビジュアルエディタで編集できます。</p>
      <input type="hidden" name="content_ja" id="content-ja-hidden" />
      <div id="editor-ja" class="min-h-[400px]"></div>
    </div>

    <!-- Actions -->
    <div class="flex items-center justify-between sticky bottom-4 bg-white border border-slate-200 rounded-xl shadow-md px-6 py-4">
      <a href="/admin/blog" class="px-4 py-2 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors">
        ← 一覧に戻る
      </a>
      <div class="flex items-center gap-3">
        <span id="save-status" class="text-sm text-slate-400"></span>
        <button
          type="submit"
          id="save-btn"
          class="px-6 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors flex items-center gap-2"
        >
          💾 保存する
        </button>
      </div>
    </div>
  </form>
</AdminLayout>

<!-- Jodit Editor JS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jodit/3.24.6/jodit.min.js"></script>

<script define:vars={{ contentEscaped, contentJaEscaped }}>
  // Wait for Jodit to load
  window.addEventListener('DOMContentLoaded', () => {
    const Jodit = window.Jodit;
    if (!Jodit) {
      console.error('Jodit not loaded');
      return;
    }

    const commonConfig = {
      height: 500,
      language: 'en',
      allowResizeY: true,
      allowResizeX: false,
      showCharsCounter: false,
      showWordsCounter: false,
      showXPathInStatusbar: false,
      askBeforePasteHTML: false,
      askBeforePasteFromWord: false,
      defaultActionOnPaste: 'insert_as_html',
      buttons: [
        'bold', 'italic', 'underline', 'strikethrough', '|',
        'ul', 'ol', '|',
        'outdent', 'indent', '|',
        'font', 'fontsize', 'brush', '|',
        'paragraph', '|',
        'image', 'link', '|',
        'align', '|',
        'undo', 'redo', '|',
        'hr', 'table', '|',
        'source'
      ],
      uploader: {
        url: '/api/admin/upload-image',
        insertImageAsBase64URI: false,
        format: 'json',
        method: 'POST',
        process: function (resp) {
          if (resp.success && resp.imageUrl) {
            return { files: [resp.imageUrl], isImages: [true], baseurl: '' };
          }
          return resp;
        },
      },
      cleanHTML: {
        denyTags: false,
        allowTags: false,
        removeEmptyElements: false,
      },
      processPasteHTML: true,
      enter: 'p',
    };

    // Initialize English editor
    const editorEn = Jodit.make('#editor-en', commonConfig);
    editorEn.value = JSON.parse(contentEscaped);

    // Initialize Japanese editor
    const editorJa = Jodit.make('#editor-ja', commonConfig);
    editorJa.value = JSON.parse(contentJaEscaped);

    // On form submit, copy editor values to hidden inputs
    const form = document.getElementById('blog-form');
    const saveBtn = document.getElementById('save-btn');
    const saveStatus = document.getElementById('save-status');

    form.addEventListener('submit', (e) => {
      document.getElementById('content-hidden').value = editorEn.value;
      document.getElementById('content-ja-hidden').value = editorJa.value;
      saveBtn.disabled = true;
      saveBtn.textContent = '保存中...';
    });

    // Auto-hide success message
    const successMsg = document.getElementById('success-msg');
    if (successMsg) {
      setTimeout(() => {
        successMsg.style.opacity = '0';
        successMsg.style.transition = 'opacity 0.5s';
        setTimeout(() => successMsg.remove(), 500);
      }, 3000);
    }

    // Thumbnail file upload handling
    const fileInput = document.getElementById('thumbnail_file');
    const uploadArea = document.getElementById('upload-area');
    const thumbPreview = document.getElementById('thumb-preview');
    const thumbContainer = document.getElementById('thumb-preview-container');
    const uploadPrompt = document.getElementById('upload-prompt');
    const uploadSpinner = document.getElementById('upload-spinner');
    const thumbUrlInput = document.getElementById('thumbnail_url');
    const thumbFileUrlInput = document.getElementById('thumbnail_file_url');

    // Click to upload
    uploadArea.addEventListener('click', () => fileInput.click());
    
    // File change event
    fileInput.addEventListener('change', async (e) => {
      const file = e.target.files?.[0];
      if (file) {
        await uploadThumbnailFile(file);
      }
    });

    // Drag and drop handlers
    window.handleDragOver = (e) => {
      e.preventDefault();
      uploadArea.classList.add('border-teal-500', 'bg-teal-50');
    };

    window.handleDragLeave = (e) => {
      e.preventDefault();
      uploadArea.classList.remove('border-teal-500', 'bg-teal-50');
    };

    window.handleDrop = (e) => {
      e.preventDefault();
      uploadArea.classList.remove('border-teal-500', 'bg-teal-50');
      const files = e.dataTransfer?.files;
      if (files && files.length > 0) {
        const file = files[0];
        if (file.type.startsWith('image/')) {
          fileInput.files = files;
          uploadThumbnailFile(file);
        } else {
          alert('画像ファイルをドラッグしてください / Please drag an image file');
        }
      }
    };

    // Upload function
    window.uploadThumbnailFile = async (file) => {
      uploadPrompt.classList.add('hidden');
      uploadSpinner.classList.remove('hidden');

      const formData = new FormData();
      formData.append('image', file);

      try {
        const response = await fetch('/api/admin/upload-image', {
          method: 'POST',
          body: formData,
        });

        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.error || 'Upload failed');
        }

        const result = await response.json();
        if (result.success) {
          thumbUrlInput.value = result.imageUrl;
          thumbFileUrlInput.value = result.imageUrl;
          thumbPreview.src = result.imageUrl;
          thumbContainer.classList.remove('hidden');
          uploadPrompt.classList.add('hidden');
          uploadSpinner.classList.add('hidden');
        }
      } catch (error) {
        alert('画像アップロードエラー / Image upload error: ' + (error instanceof Error ? error.message : 'Unknown'));
        uploadPrompt.classList.remove('hidden');
        uploadSpinner.classList.add('hidden');
      }
    };

    window.removeThumbnail = () => {
      fileInput.value = '';
      thumbUrlInput.value = '';
      thumbFileUrlInput.value = '';
      thumbContainer.classList.add('hidden');
      uploadPrompt.classList.remove('hidden');
      uploadSpinner.classList.add('hidden');
    };
  });
</script>
