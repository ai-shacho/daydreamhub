---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect("/admin/login");

const url = new URL(Astro.request.url);
const publishedFilter = url.searchParams.get("published") || "";
const cityFilter = url.searchParams.get("city") || "";
const search = url.searchParams.get("search") || "";

let posts: any[] = [];
let cities: string[] = [];
let error = "";

if (db) {
  try {
    // Get distinct cities for filter
    const cityResult = await db.prepare("SELECT DISTINCT city FROM blog_posts WHERE city IS NOT NULL AND city != '' ORDER BY city").all();
    cities = (cityResult?.results || []).map((r: any) => r.city);

    let query = `SELECT id, title, title_ja, slug, city, thumbnail_url, published_at FROM blog_posts WHERE 1=1`;
    const binds: any[] = [];

    if (publishedFilter === "1") {
      query += " AND published_at IS NOT NULL";
    } else if (publishedFilter === "0") {
      query += " AND published_at IS NULL";
    }
    if (cityFilter) {
      query += " AND city = ?";
      binds.push(cityFilter);
    }
    if (search) {
      query += " AND (title LIKE ? OR title_ja LIKE ? OR slug LIKE ?)";
      binds.push(`%${search}%`, `%${search}%`, `%${search}%`);
    }

    query += " ORDER BY published_at DESC LIMIT 200";
    const result = await db.prepare(query).bind(...binds).all();
    posts = result?.results || [];
  } catch (e: any) {
    error = e.message || "Failed to load blog posts";
  }
}
---

<AdminLayout title="Blog Posts" activeNav="blog">
  <!-- Header with New Blog Button -->
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Blog Posts</h1>
    <a
      href="/admin/blog/new"
      class="px-4 py-2 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 transition-colors flex items-center gap-2"
    >
      ✏️ New Blog Post
    </a>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <form method="GET" action="/admin/blog" class="flex flex-wrap items-end gap-4">
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Search</label>
        <input type="text" name="search" value={search} placeholder="Title or slug..." class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent" />
      </div>
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Published</label>
        <select name="published" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white">
          <option value="">All</option>
          <option value="1" selected={publishedFilter === "1"}>Published</option>
          <option value="0" selected={publishedFilter === "0"}>Draft</option>
        </select>
      </div>
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">City</label>
        <select name="city" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white">
          <option value="">All Cities</option>
          {cities.map((c) => (
            <option value={c} selected={c === cityFilter}>{c}</option>
          ))}
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">
          Filter
        </button>
        <a href="/admin/blog" class="px-4 py-2 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors">
          Reset
        </a>
      </div>
    </form>
  </div>

  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>
  )}

  <p class="text-sm text-slate-500 mb-4">{posts.length} post{posts.length !== 1 ? "s" : ""} found</p>

  <!-- Blog Posts Table -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-medium text-slate-600">ID</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Title</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">City</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Status</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Published At</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Slug</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {posts.length === 0 ? (
            <tr>
              <td colspan="7" class="px-4 py-12 text-center text-slate-400">No blog posts found</td>
            </tr>
          ) : posts.map((p: any) => (
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-4 py-3 font-mono text-slate-500">#{p.id}</td>
              <td class="px-4 py-3">
                <div class="font-medium text-slate-900 max-w-[300px] truncate">{p.title || "-"}</div>
                {p.title_ja && <div class="text-xs text-slate-400 max-w-[300px] truncate">{p.title_ja}</div>}
                <div class="text-xs text-slate-400 font-mono">/{p.slug}</div>
              </td>
              <td class="px-4 py-3 text-slate-600">{p.city || "-"}</td>
              <td class="px-4 py-3 text-center">
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                  p.published_at ? "bg-emerald-100 text-emerald-700" : "bg-amber-100 text-amber-700"
                }`}>
                  {p.published_at ? "Published" : "Draft"}
                </span>
              </td>
              <td class="px-4 py-3 text-slate-500 text-xs">{p.published_at?.slice(0, 16) || "-"}</td>
              <td class="px-4 py-3 text-slate-500 text-xs font-mono">/{p.slug}</td>
              <td class="px-4 py-3 text-center">
                <div class="flex items-center justify-center gap-2">
                  <a
                    href={`/admin/blog/${p.id}`}
                    class="px-3 py-1 text-xs font-medium rounded border text-blue-700 bg-blue-50 border-blue-200 hover:bg-blue-100 transition-colors"
                  >
                    Edit
                  </a>
                  <button
                    class="publish-toggle-btn px-3 py-1 text-xs font-medium rounded border transition-colors"
                    data-id={p.id}
                    data-published={p.published_at ? "1" : "0"}
                    class:list={[
                      p.published_at
                        ? "text-amber-700 bg-amber-50 border-amber-200 hover:bg-amber-100"
                        : "text-emerald-700 bg-emerald-50 border-emerald-200 hover:bg-emerald-100"
                    ]}
                  >
                    {p.published_at ? "Unpublish" : "Publish"}
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  document.querySelectorAll('.publish-toggle-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = Number(btn.getAttribute('data-id'));
      const currentlyPublished = btn.getAttribute('data-published') === '1';
      const action = currentlyPublished ? 'unpublish' : 'publish';

      if (!confirm(`Are you sure you want to ${action} post #${id}?`)) return;

      (btn as HTMLButtonElement).disabled = true;
      const origText = btn.textContent;
      btn.textContent = '...';

      try {
        const res = await fetch('/api/admin/blog', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, is_published: currentlyPublished ? 0 : 1 }),
        });

        if (res.ok) {
          location.reload();
        } else {
          const data = await res.json();
          alert('Failed: ' + (data.error || 'Unknown error'));
          btn.textContent = origText;
          (btn as HTMLButtonElement).disabled = false;
        }
      } catch {
        alert('Network error');
        btn.textContent = origText;
        (btn as HTMLButtonElement).disabled = false;
      }
    });
  });
</script>
