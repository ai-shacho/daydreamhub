---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';

const runtime = Astro.locals.runtime as any;
const jwtSecret = runtime?.env?.JWT_SECRET || 'dev-secret';

const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect('/admin/login');
---

<AdminLayout title="Sales Dialer" activeNav="outreach">
  <div class="max-w-7xl mx-auto mt-6 px-4 space-y-6">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="text-xl font-bold text-slate-800">Sales Outreach Dialer</h1>
        <p class="text-xs text-slate-500 mt-1">リスト進行管理 / 順次架電 / 結果フラグ可視化</p>
      </div>
      <div class="flex gap-2">
        <button id="btn-add" class="px-4 py-2 bg-teal-600 text-white text-sm rounded-lg hover:bg-teal-700 font-medium">+ Add Lead</button>
        <button id="btn-import" class="px-4 py-2 bg-slate-600 text-white text-sm rounded-lg hover:bg-slate-700 font-medium">Import CSV</button>
      </div>
    </div>

    <section class="bg-white rounded-xl border border-slate-200 shadow-sm p-4">
      <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
        <h2 class="font-semibold text-slate-800">Uploaded Lists</h2>
        <div class="text-xs text-slate-500">対象リスト: <span id="active-list-label" class="font-semibold text-slate-700">All Leads</span></div>
      </div>
      <div id="list-cards" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
        <div class="text-sm text-slate-400">Loading lists...</div>
      </div>
    </section>

    <section class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 space-y-3">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <h2 class="font-semibold text-slate-800">Dial Controls</h2>
        <div class="flex gap-2">
          <button id="btn-start-auto" class="px-3 py-2 text-sm rounded-lg bg-emerald-600 text-white hover:bg-emerald-700">Start Auto</button>
          <button id="btn-stop-auto" class="px-3 py-2 text-sm rounded-lg bg-slate-100 text-slate-700 hover:bg-slate-200" disabled>Stop Auto</button>
          <button id="btn-call-next" class="px-3 py-2 text-sm rounded-lg bg-blue-600 text-white hover:bg-blue-700">Call Next</button>
        </div>
      </div>
      <p id="dialer-status" class="text-xs text-slate-500">待機中</p>
    </section>

    <section class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 space-y-3">
      <div class="flex items-center justify-between gap-3">
        <h2 class="font-semibold text-slate-800">A/B Script Variants</h2>
        <p class="text-xs text-slate-500">attempt結果をvariant単位で集計</p>
      </div>
      <div id="variant-stats" class="text-xs text-slate-400">Loading variant stats...</div>
    </section>

    <div class="flex gap-1 border-b border-slate-200 text-sm" id="filter-tabs">
      {['all', 'new', 'calling', 'interested', 'appointment_set', 'contact_obtained', 'not_interested', 'declined', 'no_answer', 'voicemail'].map((s) => (
        <button
          class={`filter-tab px-3 py-2 border-b-2 font-medium transition-colors ${s === 'all' ? 'border-teal-500 text-teal-700' : 'border-transparent text-slate-500 hover:text-slate-700'}`}
          data-status={s}
        >
          {s === 'all' ? 'All' : s.replace('_', ' ').replace(/\b\w/g, (c) => c.toUpperCase())}
        </button>
      ))}
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[1300px]">
          <thead class="bg-slate-50 border-b border-slate-200">
            <tr>
              <th class="text-left px-4 py-3 text-slate-600 font-medium">Hotel</th>
              <th class="text-left px-4 py-3 text-slate-600 font-medium">Phone</th>
              <th class="text-left px-4 py-3 text-slate-600 font-medium">Status</th>
              <th class="text-left px-4 py-3 text-slate-600 font-medium">Flags</th>
              <th class="text-left px-4 py-3 text-slate-600 font-medium">Call Time (JST / Local)</th>
              <th class="text-left px-4 py-3 text-slate-600 font-medium">TZ / Attempts / Variant</th>
              <th class="text-left px-4 py-3 text-slate-600 font-medium">Notes</th>
              <th class="text-left px-4 py-3 text-slate-600 font-medium">Updated</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody id="lead-tbody" class="divide-y divide-slate-100">
            <tr><td colspan="9" class="text-center py-8 text-slate-400">Loading…</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="drawer" class="fixed top-0 right-0 h-full w-full max-w-lg bg-white border-l border-slate-200 shadow-2xl transform translate-x-full transition-transform z-50">
    <div class="p-4 border-b border-slate-200 flex items-center justify-between">
      <h3 class="font-semibold text-slate-800">Lead Detail</h3>
      <button id="drawer-close" class="text-slate-500 hover:text-slate-700">✕</button>
    </div>
    <div id="drawer-body" class="p-4 space-y-3 text-sm text-slate-700"></div>
  </div>

  <div id="modal-add" class="hidden fixed inset-0 bg-black/40 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md mx-4 p-6">
      <h2 class="text-lg font-bold text-slate-800 mb-4">Add Lead</h2>
      <form id="form-add" class="space-y-3">
        <input name="hotel_name" required placeholder="Hotel Name" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
        <input name="phone" required placeholder="Phone (+1...)" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
        <input name="country" placeholder="Country" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
        <input name="email" type="email" placeholder="Email" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
        <input name="notes" placeholder="Notes" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
        <div class="flex gap-2 pt-2">
          <button type="submit" class="flex-1 bg-teal-600 text-white py-2 rounded-lg text-sm font-medium hover:bg-teal-700">Add</button>
          <button type="button" id="btn-add-cancel" class="flex-1 bg-slate-100 text-slate-700 py-2 rounded-lg text-sm font-medium hover:bg-slate-200">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <div id="modal-import" class="hidden fixed inset-0 bg-black/40 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl mx-4 p-6">
      <h2 class="text-lg font-bold text-slate-800 mb-2">Import CSV to New List</h2>
      <input id="import-list-name" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm mb-2" placeholder="List name (e.g. Tokyo Hotels Batch A)" />
      <p class="text-xs text-slate-500 mb-3">format: <code class="bg-slate-100 px-1 rounded">hotel_name,phone,country,email,timezone</code>（header付き推奨）</p>
      <input id="csv-file" type="file" accept=".csv,text/csv" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm mb-2" />
      <textarea id="csv-input" rows="8" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm font-mono" placeholder="Fallback: paste CSV text here"></textarea>
      <div class="flex gap-2 mt-3">
        <button id="btn-import-confirm" class="flex-1 bg-teal-600 text-white py-2 rounded-lg text-sm font-medium hover:bg-teal-700">Import</button>
        <button id="btn-import-cancel" class="flex-1 bg-slate-100 text-slate-700 py-2 rounded-lg text-sm font-medium hover:bg-slate-200">Cancel</button>
      </div>
      <p id="import-result" class="text-xs text-slate-500 mt-2 hidden"></p>
    </div>
  </div>
</AdminLayout>

<script>
import { formatDisplayDate } from '../../lib/dateFormat';

const STATUS_COLORS = {
  new: 'bg-slate-100 text-slate-600',
  calling: 'bg-blue-100 text-blue-700',
  interested: 'bg-green-100 text-green-700',
  appointment_set: 'bg-emerald-100 text-emerald-700',
  contact_obtained: 'bg-cyan-100 text-cyan-700',
  declined: 'bg-red-100 text-red-600',
  not_interested: 'bg-red-100 text-red-600',
  no_answer: 'bg-yellow-100 text-yellow-700',
  voicemail: 'bg-violet-100 text-violet-700',
};

let currentFilter = 'all';
let currentListId = 0;
let lists = [];
let leads = [];
let variants = [];
let variantStats = [];
let autoCalling = false;
let autoTimer = null;

async function api(body) {
  const r = await fetch('/api/admin/outreach', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
    credentials: 'include',
  });
  return r.json();
}

async function loadDashboard() {
  const params = new URLSearchParams();
  if (currentFilter !== 'all') params.set('status', currentFilter);
  if (currentListId) params.set('list_id', String(currentListId));
  const r = await fetch(`/api/admin/outreach?${params.toString()}`, { credentials: 'include' });
  const data = await r.json();
  lists = data.lists || [];
  leads = data.leads || [];
  variants = data.variants || [];
  variantStats = data.variant_stats || [];
  renderLists();
  renderVariantStats();
  renderTable();
}

function renderLists() {
  const wrap = document.getElementById('list-cards');
  const label = document.getElementById('active-list-label');
  const active = lists.find((l) => l.id === currentListId);
  label.textContent = active ? active.name : 'All Leads';

  if (!lists.length) {
    wrap.innerHTML = '<div class="text-sm text-slate-400">No upload list yet. Import CSV to create one.</div>';
    return;
  }

  wrap.innerHTML = [
    `<button class="list-card text-left border rounded-xl p-3 ${currentListId === 0 ? 'border-teal-500 bg-teal-50' : 'border-slate-200'}" data-id="0">
      <div class="font-medium text-slate-700">All Leads</div>
      <p class="text-xs text-slate-500 mt-1">全件表示</p>
    </button>`,
    ...lists.map((l) => {
      const total = Number(l.total_rows || 0);
      const done = Number(l.success_count || 0) + Number(l.rejected_count || 0);
      const pct = total ? Math.min(100, Math.round((done / total) * 100)) : 0;
      return `<button class="list-card text-left border rounded-xl p-3 ${currentListId === l.id ? 'border-teal-500 bg-teal-50' : 'border-slate-200'}" data-id="${l.id}">
        <div class="flex items-center justify-between gap-2">
          <div class="font-medium text-slate-700 truncate">${esc(l.name)}</div>
          <span class="text-[10px] px-2 py-0.5 rounded-full bg-slate-100 text-slate-600">${esc(l.status || 'active')}</span>
        </div>
        <p class="text-xs text-slate-500 mt-1">${Number(l.imported_rows || 0)} imported / ${Number(l.duplicate_rows || 0)} dup</p>
        <div class="w-full h-1.5 bg-slate-100 rounded-full mt-2 overflow-hidden"><div class="h-full bg-teal-500" style="width:${pct}%"></div></div>
        <div class="mt-2 text-[11px] text-slate-500">Done ${done}/${total} ・ Calling ${Number(l.calling_count || 0)} ・ Pending ${Number(l.pending_count || 0)}</div>
      </button>`;
    }),
  ].join('');

  wrap.querySelectorAll('.list-card').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      currentListId = Number(e.currentTarget.dataset.id || '0');
      await loadDashboard();
    });
  });
}

function renderVariantStats() {
  const el = document.getElementById('variant-stats');
  if (!el) return;
  if (!variants.length) {
    el.innerHTML = '<div class="text-slate-400">No variants configured.</div>';
    return;
  }
  const statsMap = Object.fromEntries((variantStats || []).map((s) => [String(s.script_variant || ''), s]));
  el.innerHTML = `<div class="grid grid-cols-1 md:grid-cols-2 gap-2">${variants.map((v) => {
    const s = statsMap[v.code] || {};
    const attempts = Number(s.attempts || 0);
    const interested = Number(s.interested || 0);
    const rate = attempts ? Math.round((interested / attempts) * 100) : 0;
    return `<div class="border border-slate-200 rounded-lg p-2 bg-slate-50">
      <div class="font-semibold text-slate-700">${esc(v.code)} - ${esc(v.name || '')} ${Number(v.active) ? '' : '<span class="text-[10px] text-rose-600">(inactive)</span>'}</div>
      <div class="text-slate-500">attempts: ${attempts} / interested: ${interested} / CVR: ${rate}%</div>
    </div>`;
  }).join('')}</div>`;
}

function badgesForLead(lead) {
  const status = String(lead.status || 'new');
  const flags = [];
  if (status === 'interested' || status === 'appointment_set') flags.push('<span class="px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 text-[11px]">アポ獲得</span>');
  if (status === 'contact_obtained') flags.push('<span class="px-2 py-0.5 rounded-full bg-cyan-100 text-cyan-700 text-[11px]">連絡先獲得</span>');
  if (lead.requested_materials) flags.push('<span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 text-[11px]">資料希望</span>');
  if (lead.requested_explanation) flags.push('<span class="px-2 py-0.5 rounded-full bg-indigo-100 text-indigo-700 text-[11px]">説明希望</span>');
  if (lead.needs_recall) flags.push('<span class="px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 text-[11px]">要再架電</span>');
  if (status === 'not_interested' || status === 'declined' || lead.do_not_call) flags.push('<span class="px-2 py-0.5 rounded-full bg-rose-100 text-rose-700 text-[11px]">再架電除外</span>');
  if (!flags.length) flags.push('<span class="px-2 py-0.5 rounded-full bg-slate-100 text-slate-500 text-[11px]">-</span>');
  return flags.join(' ');
}

function formatCallDateTime(raw) {
  if (!raw) return '-';
  const d = new Date(raw.replace(' ', 'T') + 'Z');
  if (Number.isNaN(d.getTime())) return esc(raw);
  return new Intl.DateTimeFormat('en-US', {
    timeZone: 'UTC',
    weekday: 'short',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
  }).format(d);
}

function renderTable() {
  const tbody = document.getElementById('lead-tbody');
  if (!leads.length) {
    tbody.innerHTML = '<tr><td colspan="9" class="text-center py-8 text-slate-400">No leads found.</td></tr>';
    return;
  }

  tbody.innerHTML = leads
    .map((l) => {
      const color = STATUS_COLORS[l.status] || 'bg-slate-100 text-slate-600';
      const statusLabel = String(l.status || 'new').replace('_', ' ');
      return `<tr class="hover:bg-slate-50" data-id="${l.id}">
        <td class="px-4 py-3 font-medium text-slate-800">${esc(l.hotel_name)}</td>
        <td class="px-4 py-3 text-slate-600 font-mono text-xs">${esc(l.phone || '')}</td>
        <td class="px-4 py-3"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium ${color}">${statusLabel}</span></td>
        <td class="px-4 py-3">${badgesForLead(l)}</td>
        <td class="px-4 py-3 text-xs text-slate-600">
          <div>JST: ${formatCallDateTime(l.last_call_started_at_jst)}</div>
          <div class="text-slate-400">${esc(l.last_call_lead_timezone || 'UTC')}: ${formatCallDateTime(l.last_call_started_at_local)}</div>
        </td>
        <td class="px-4 py-3 text-xs text-slate-600">
          <div>${esc(l.timezone || l.last_call_lead_timezone || 'UTC')}</div>
          <div class="text-slate-400">attempts: ${Number(l.total_attempts || 0)} / variant: ${esc(l.assigned_script_variant || l.last_script_variant || '-')}</div>
        </td>
        <td class="px-4 py-3 text-slate-500 text-xs max-w-xs truncate">${esc(l.notes || '')}</td>
        <td class="px-4 py-3 text-slate-400 text-xs">${formatDisplayDate(l.updated_at)}</td>
        <td class="px-4 py-3">
          <div class="flex gap-1 justify-end flex-wrap">
            <button class="btn-call px-2 py-1 bg-teal-600 text-white text-xs rounded hover:bg-teal-700" data-id="${l.id}">Call</button>
            <button class="btn-flag px-2 py-1 bg-emerald-50 text-emerald-700 text-xs rounded hover:bg-emerald-100" data-id="${l.id}" data-status="appointment_set">アポ</button>
            <button class="btn-flag px-2 py-1 bg-cyan-50 text-cyan-700 text-xs rounded hover:bg-cyan-100" data-id="${l.id}" data-status="contact_obtained">連絡先</button>
            <button class="btn-flag px-2 py-1 bg-rose-50 text-rose-700 text-xs rounded hover:bg-rose-100" data-id="${l.id}" data-status="declined">お断り</button>
            <button class="btn-note px-2 py-1 bg-slate-100 text-slate-600 text-xs rounded hover:bg-slate-200" data-id="${l.id}" data-notes="${esc(l.notes || '')}">Note</button>
            <button class="btn-detail px-2 py-1 bg-indigo-100 text-indigo-700 text-xs rounded hover:bg-indigo-200" data-id="${l.id}">Detail</button>
          </div>
        </td>
      </tr>`;
    })
    .join('');

  tbody.querySelectorAll('.btn-call').forEach((btn) => btn.addEventListener('click', async (e) => {
    const id = Number(e.currentTarget.dataset.id);
    const res = await api({ action: 'call_lead', lead_id: id });
    if (res.error) alert(res.error);
    await loadDashboard();
  }));

  tbody.querySelectorAll('.btn-flag').forEach((btn) => btn.addEventListener('click', async (e) => {
    const id = Number(e.currentTarget.dataset.id);
    const status = e.currentTarget.dataset.status;
    const res = await api({ action: 'update_lead', lead_id: id, status });
    if (res.error) alert(res.error);
    await loadDashboard();
  }));

  tbody.querySelectorAll('.btn-note').forEach((btn) => btn.addEventListener('click', async (e) => {
    const id = Number(e.currentTarget.dataset.id);
    const current = e.currentTarget.dataset.notes || '';
    const note = prompt('Notes', current);
    if (note === null) return;
    await api({ action: 'update_lead', lead_id: id, notes: note });
    await loadDashboard();
  }));

  tbody.querySelectorAll('.btn-detail').forEach((btn) => btn.addEventListener('click', async (e) => {
    const id = Number(e.currentTarget.dataset.id);
    const data = await api({ action: 'get_lead_detail', lead_id: id });
    if (data.error) return alert(data.error);
    openDrawer(data.lead, data.call_log);
  }));
}

function openDrawer(lead, callLog) {
  const drawer = document.getElementById('drawer');
  const body = document.getElementById('drawer-body');
  body.innerHTML = `
    <div><div class="text-xs text-slate-500">Hotel</div><div class="font-semibold">${esc(lead.hotel_name || '')}</div></div>
    <div><div class="text-xs text-slate-500">Phone / Email</div><div>${esc(lead.phone || '')} ${lead.email ? ` / ${esc(lead.email)}` : ''}</div></div>
    <div><div class="text-xs text-slate-500">Current Status</div><div>${esc(lead.status || 'new')}</div></div>
    <div><div class="text-xs text-slate-500">Recall / Preference Flags</div><div>needs_recall=${Number(lead.needs_recall || 0)} / materials=${Number(lead.requested_materials || 0)} / explanation=${Number(lead.requested_explanation || 0)} / do_not_call=${Number(lead.do_not_call || 0)}</div></div>
    <div><div class="text-xs text-slate-500">Last Call Time</div><div>JST: ${formatCallDateTime(lead.last_call_started_at_jst)} / ${esc(lead.last_call_lead_timezone || 'UTC')}: ${formatCallDateTime(lead.last_call_started_at_local)}</div></div>
    <div><div class="text-xs text-slate-500">Notes</div><div class="whitespace-pre-wrap">${esc(lead.notes || '-')}</div></div>
    <hr class="my-2" />
    <div class="font-semibold">Latest Call</div>
    ${callLog ? `
      <div class="text-xs text-slate-500">Call Log ID #${callLog.id}</div>
      <div>Status: ${esc(callLog.status || '-')}</div>
      <div>Note: <span class="whitespace-pre-wrap">${esc(callLog.note || '-')}</span></div>
      <div class="text-xs text-slate-500">${formatDisplayDate(callLog.updated_at || callLog.created_at)}</div>
      ${callLog.error_detail ? `<pre class="text-[11px] p-2 rounded bg-slate-50 border overflow-x-auto">${esc(callLog.error_detail)}</pre>` : ''}
    ` : '<div class="text-sm text-slate-400">No call history yet.</div>'}
  `;
  drawer.classList.remove('translate-x-full');
}

function esc(s) {
  return String(s || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

document.getElementById('drawer-close').addEventListener('click', () => {
  document.getElementById('drawer').classList.add('translate-x-full');
});

document.querySelectorAll('.filter-tab').forEach((tab) => {
  tab.addEventListener('click', async (e) => {
    document.querySelectorAll('.filter-tab').forEach((t) => {
      t.classList.remove('border-teal-500', 'text-teal-700');
      t.classList.add('border-transparent', 'text-slate-500');
    });
    const el = e.currentTarget;
    el.classList.add('border-teal-500', 'text-teal-700');
    el.classList.remove('border-transparent', 'text-slate-500');
    currentFilter = el.dataset.status || 'all';
    await loadDashboard();
  });
});

document.getElementById('btn-call-next').addEventListener('click', async () => {
  const res = await api({ action: 'call_next', list_id: currentListId || null });
  const statusEl = document.getElementById('dialer-status');
  if (res.done) {
    statusEl.textContent = '完了: コール可能なホテルがありません';
  } else if (res.error) {
    statusEl.textContent = `Error: ${res.error}`;
  } else {
    statusEl.textContent = `Calling lead #${res.lead_id || '-'}...`;
  }
  await loadDashboard();
});

document.getElementById('btn-start-auto').addEventListener('click', async () => {
  if (autoCalling) return;
  autoCalling = true;
  document.getElementById('btn-start-auto').disabled = true;
  document.getElementById('btn-stop-auto').disabled = false;
  const statusEl = document.getElementById('dialer-status');
  statusEl.textContent = 'Auto dial started (interval 20s)';

  const tick = async () => {
    if (!autoCalling) return;
    const res = await api({ action: 'call_next', list_id: currentListId || null });
    if (res.done || res.error) {
      statusEl.textContent = res.done ? 'Auto dial complete' : `Auto dial error: ${res.error}`;
      stopAuto();
      await loadDashboard();
      return;
    }
    statusEl.textContent = `Auto calling lead #${res.lead_id || '-'} ... next in 20s`;
    await loadDashboard();
    autoTimer = setTimeout(tick, 20000);
  };

  tick();
});

function stopAuto() {
  autoCalling = false;
  if (autoTimer) clearTimeout(autoTimer);
  autoTimer = null;
  document.getElementById('btn-start-auto').disabled = false;
  document.getElementById('btn-stop-auto').disabled = true;
}

document.getElementById('btn-stop-auto').addEventListener('click', () => {
  stopAuto();
  document.getElementById('dialer-status').textContent = 'Auto dial stopped';
});

document.getElementById('btn-add').addEventListener('click', () => {
  document.getElementById('modal-add').classList.remove('hidden');
});
document.getElementById('btn-add-cancel').addEventListener('click', () => {
  document.getElementById('modal-add').classList.add('hidden');
});
document.getElementById('form-add').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const body = { action: 'add_lead', ...Object.fromEntries(fd.entries()), list_id: currentListId || null };
  const res = await api(body);
  if (res.error) return alert(res.error);
  e.target.reset();
  document.getElementById('modal-add').classList.add('hidden');
  await loadDashboard();
});

document.getElementById('btn-import').addEventListener('click', () => {
  document.getElementById('modal-import').classList.remove('hidden');
});
document.getElementById('btn-import-cancel').addEventListener('click', () => {
  document.getElementById('modal-import').classList.add('hidden');
});
document.getElementById('btn-import-confirm').addEventListener('click', async () => {
  const file = document.getElementById('csv-file')?.files?.[0] || null;
  const csv = document.getElementById('csv-input').value.trim();
  if (!file && !csv) return;
  const listName = document.getElementById('import-list-name').value.trim();

  let res;
  if (file) {
    const fd = new FormData();
    fd.append('action', 'import_csv_file');
    fd.append('list_name', listName || '');
    fd.append('file', file);
    const r = await fetch('/api/admin/outreach', { method: 'POST', body: fd, credentials: 'include' });
    res = await r.json();
  } else {
    res = await api({ action: 'import_csv', csv, list_name: listName || null });
  }

  const msg = document.getElementById('import-result');
  msg.classList.remove('hidden');
  if (res.error) {
    msg.textContent = `Error: ${res.error}`;
  } else {
    msg.textContent = `Imported ${res.imported} leads (${res.skipped} duplicate/invalid).`;
    document.getElementById('csv-input').value = '';
    document.getElementById('import-list-name').value = '';
    if (document.getElementById('csv-file')) document.getElementById('csv-file').value = '';
    if (res.list_id) currentListId = Number(res.list_id);
    await loadDashboard();
  }
});

loadDashboard();
</script>
