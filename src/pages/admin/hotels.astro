---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';
import HotelsFilterBar from '../../components/admin/hotels/HotelsFilterBar.astro';
import HotelsHeader from '../../components/admin/hotels/HotelsHeader.astro';
import HotelsTable from '../../components/admin/hotels/HotelsTable.astro';
import AssignOwnerModal from '../../components/admin/hotels/AssignOwnerModal.astro';
import HotelsInteractionsScript from '../../components/admin/hotels/HotelsInteractionsScript.astro';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect("/admin/login");

const url = new URL(Astro.request.url);
const countryFilter = url.searchParams.get("country") || "";
const cityFilter = url.searchParams.get("city") || "";
const statusFilter = url.searchParams.get("status") || "";
const searchQuery = url.searchParams.get("q") || "";
const sortBy = url.searchParams.get("sort") || "name";
const sortOrder = url.searchParams.get("order") || "asc";
const ownerFilter = url.searchParams.get("owner") || "";

let hotels: any[] = [];
let countries: string[] = [];
let cities: string[] = [];
let error = "";

if (db) {
  try {
    const countriesResult = await db.prepare(
      "SELECT DISTINCT country FROM hotels WHERE country IS NOT NULL AND country != '' ORDER BY country"
    ).all();
    countries = (countriesResult?.results || []).map((r: any) => r.country);

    let cityQuery = "SELECT DISTINCT city FROM hotels WHERE city IS NOT NULL AND city != ''";
    const cityBinds: any[] = [];
    if (countryFilter) {
      cityQuery += " AND country = ?";
      cityBinds.push(countryFilter);
    }
    cityQuery += " ORDER BY city";
    const citiesResult = cityBinds.length
      ? await db.prepare(cityQuery).bind(...cityBinds).all()
      : await db.prepare(cityQuery).all();
    cities = (citiesResult?.results || []).map((r: any) => r.city);

    const validSortCols: Record<string, string> = {
      name: "h.name",
      country: "h.country",
      city: "h.city",
      created_at: "h.created_at",
      bookings: "active_bookings",
      plans: "plan_count",
      owner: "h.email",
    };
    const orderCol = validSortCols[sortBy] || "h.name";
    const orderDir = sortOrder === "desc" ? "DESC" : "ASC";

    let query = `
      SELECT h.*,
        (SELECT COUNT(*) FROM plans p WHERE p.hotel_id = h.id) as plan_count,
        (SELECT COUNT(*) FROM bookings b WHERE b.hotel_id = h.id AND b.status IN ('pending', 'confirmed')) as active_bookings,
        u.email as owner_login_email,
        u.name as owner_name
      FROM hotels h
      LEFT JOIN users u ON u.email = h.email AND u.role IN ('owner', 'inactive')
      WHERE 1=1
    `;
    const binds: any[] = [];

    if (searchQuery) {
      const isNumeric = /^\d+$/.test(searchQuery.trim());
      if (isNumeric) {
        query += " AND (h.id = ? OR h.name LIKE ? OR h.name_ja LIKE ?)";
        binds.push(parseInt(searchQuery), `%${searchQuery}%`, `%${searchQuery}%`);
      } else {
        query += " AND (h.name LIKE ? OR h.name_ja LIKE ? OR CAST(h.id AS TEXT) LIKE ?)";
        binds.push(`%${searchQuery}%`, `%${searchQuery}%`, `%${searchQuery}%`);
      }
    }
    if (countryFilter) {
      query += " AND h.country = ?";
      binds.push(countryFilter);
    }
    if (cityFilter) {
      query += " AND h.city = ?";
      binds.push(cityFilter);
    }
    if (statusFilter === "active") {
      query += " AND h.status = 'active'";
    } else if (statusFilter === "demo") {
      query += " AND h.status = 'demo'";
    } else if (statusFilter === "inactive") {
      query += " AND h.status = 'inactive'";
    }
    if (ownerFilter === "assigned") {
      query += " AND h.email IS NOT NULL AND h.email != '' AND h.email IN (SELECT email FROM users WHERE role IN ('owner', 'inactive'))";
    } else if (ownerFilter === "unassigned") {
      query += " AND (h.email IS NULL OR h.email = '' OR h.email NOT IN (SELECT email FROM users WHERE role IN ('owner', 'inactive')))";
    }

    query += ` ORDER BY ${orderCol} ${orderDir}`;

    const result = binds.length
      ? await db.prepare(query).bind(...binds).all()
      : await db.prepare(query).all();
    hotels = result?.results || [];
  } catch (e: any) {
    error = e.message || "Failed to load hotels";
  }
} else {
  error = "Database not available";
}

function sortLink(col: string) {
  const params = new URLSearchParams(url.searchParams);
  if (params.get("sort") === col) {
    params.set("order", sortOrder === "asc" ? "desc" : "asc");
  } else {
    params.set("sort", col);
    params.set("order", "asc");
  }
  return `/admin/hotels?${params.toString()}`;
}

function sortIcon(col: string) {
  if (sortBy !== col) return "↕";
  return sortOrder === "asc" ? "↑" : "↓";
}

const hotelsExportParams = Astro.url.searchParams.toString();
const hotelsExportUrl = hotelsExportParams ? `/api/admin/hotels-export?${hotelsExportParams}` : '/api/admin/hotels-export';
---

<AdminLayout title="Hotels" activeNav="hotels">
  <HotelsFilterBar
    searchQuery={searchQuery}
    countries={countries}
    countryFilter={countryFilter}
    cities={cities}
    cityFilter={cityFilter}
    statusFilter={statusFilter}
    ownerFilter={ownerFilter}
    sortBy={sortBy}
    sortOrder={sortOrder}
  />

  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>
  )}

  <HotelsHeader hotelCount={hotels.length} hotelsExportUrl={hotelsExportUrl} />

  <HotelsTable hotels={hotels} error={error} sortLink={sortLink} sortIcon={sortIcon} />

  <AssignOwnerModal />
</AdminLayout>

<HotelsInteractionsScript />
