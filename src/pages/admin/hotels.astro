---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect("/admin/login");

// Read filter params
const url = new URL(Astro.request.url);
const countryFilter = url.searchParams.get("country") || "";
const cityFilter = url.searchParams.get("city") || "";
const statusFilter = url.searchParams.get("status") || ""; // "active" | "inactive" | ""
const searchQuery = url.searchParams.get("q") || "";
const sortBy = url.searchParams.get("sort") || "name"; // "name" | "country" | "city" | "created_at"
const sortOrder = url.searchParams.get("order") || "asc"; // "asc" | "desc"

const ownerFilter = url.searchParams.get("owner") || ""; // "assigned" | "unassigned" | ""

let hotels: any[] = [];
let countries: string[] = [];
let cities: string[] = [];
let error = "";

// Map of owner email -> owner name for display
let ownerMap: Record<string, string> = {};

if (db) {
  try {
    // Fetch all owner accounts for mapping
    const ownersResult = await db.prepare(
      "SELECT name, email FROM users WHERE role IN ('owner', 'inactive') ORDER BY name"
    ).all();
    for (const o of (ownersResult?.results || []) as any[]) {
      ownerMap[o.email] = o.name;
    }

    // Fetch distinct countries for filter dropdown
    const countriesResult = await db.prepare(
      "SELECT DISTINCT country FROM hotels WHERE country IS NOT NULL AND country != '' ORDER BY country"
    ).all();
    countries = (countriesResult?.results || []).map((r: any) => r.country);

    // Fetch distinct cities (filtered by country if selected)
    let cityQuery = "SELECT DISTINCT city FROM hotels WHERE city IS NOT NULL AND city != ''";
    const cityBinds: any[] = [];
    if (countryFilter) {
      cityQuery += " AND country = ?";
      cityBinds.push(countryFilter);
    }
    cityQuery += " ORDER BY city";
    const citiesResult = cityBinds.length
      ? await db.prepare(cityQuery).bind(...cityBinds).all()
      : await db.prepare(cityQuery).all();
    cities = (citiesResult?.results || []).map((r: any) => r.city);

    // Build main hotels query
    const validSortCols: Record<string, string> = {
      name: "h.name",
      country: "h.country",
      city: "h.city",
      created_at: "h.created_at",
      bookings: "active_bookings",
      plans: "plan_count",
      owner: "h.email",
    };
    const orderCol = validSortCols[sortBy] || "h.name";
    const orderDir = sortOrder === "desc" ? "DESC" : "ASC";

    let query = `
      SELECT h.*,
        (SELECT COUNT(*) FROM plans p WHERE p.hotel_id = h.id) as plan_count,
        (SELECT COUNT(*) FROM bookings b WHERE b.hotel_id = h.id AND b.status IN ('pending', 'confirmed')) as active_bookings
      FROM hotels h
      WHERE 1=1
    `;
    const binds: any[] = [];

    if (searchQuery) {
      const isNumeric = /^\d+$/.test(searchQuery.trim());
      if (isNumeric) {
        query += " AND (h.id = ? OR h.name LIKE ? OR h.name_ja LIKE ?)";
        binds.push(parseInt(searchQuery), `%${searchQuery}%`, `%${searchQuery}%`);
      } else {
        query += " AND (h.name LIKE ? OR h.name_ja LIKE ? OR CAST(h.id AS TEXT) LIKE ?)";
        binds.push(`%${searchQuery}%`, `%${searchQuery}%`, `%${searchQuery}%`);
      }
    }
    if (countryFilter) {
      query += " AND h.country = ?";
      binds.push(countryFilter);
    }
    if (cityFilter) {
      query += " AND h.city = ?";
      binds.push(cityFilter);
    }
    if (statusFilter === "active") {
      query += " AND h.is_active = 1";
    } else if (statusFilter === "inactive") {
      query += " AND h.is_active = 0";
    }
    if (ownerFilter === "assigned") {
      query += " AND h.email IS NOT NULL AND h.email != '' AND h.email IN (SELECT email FROM users WHERE role IN ('owner', 'inactive'))";
    } else if (ownerFilter === "unassigned") {
      query += " AND (h.email IS NULL OR h.email = '' OR h.email NOT IN (SELECT email FROM users WHERE role IN ('owner', 'inactive')))";
    }

    query += ` ORDER BY ${orderCol} ${orderDir}`;

    const result = binds.length
      ? await db.prepare(query).bind(...binds).all()
      : await db.prepare(query).all();
    hotels = result?.results || [];
  } catch (e: any) {
    error = e.message || "Failed to load hotels";
  }
} else {
  error = "Database not available";
}

// Helper: toggle sort order link
function sortLink(col: string) {
  const params = new URLSearchParams(url.searchParams);
  if (params.get("sort") === col) {
    params.set("order", sortOrder === "asc" ? "desc" : "asc");
  } else {
    params.set("sort", col);
    params.set("order", "asc");
  }
  return `/admin/hotels?${params.toString()}`;
}

function sortIcon(col: string) {
  if (sortBy !== col) return "↕";
  return sortOrder === "asc" ? "↑" : "↓";
}
---

<AdminLayout title="Hotels" activeNav="hotels">
  <!-- Filter bar -->
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <form method="GET" action="/admin/hotels" class="flex flex-wrap items-end gap-4">
      <!-- Search -->
      <div class="min-w-[220px] flex-1">
        <label class="block text-xs font-medium text-slate-500 mb-1">Search by Name or ID</label>
        <input
          type="text"
          name="q"
          value={searchQuery}
          placeholder="Hotel name or ID..."
          class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500"
        />
      </div>

      <!-- Country filter -->
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Country</label>
        <select name="country" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white">
          <option value="">All Countries</option>
          {countries.map((c) => (
            <option value={c} selected={c === countryFilter}>{c}</option>
          ))}
        </select>
      </div>

      <!-- City filter -->
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">City</label>
        <select name="city" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white">
          <option value="">All Cities</option>
          {cities.map((c) => (
            <option value={c} selected={c === cityFilter}>{c}</option>
          ))}
        </select>
      </div>

      <!-- Status filter -->
      <div class="min-w-[140px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Status</label>
        <select name="status" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white">
          <option value="" selected={statusFilter === ""}>All Status</option>
          <option value="active" selected={statusFilter === "active"}>Active</option>
          <option value="inactive" selected={statusFilter === "inactive"}>Inactive</option>
        </select>
      </div>

      <!-- Owner filter -->
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Owner</label>
        <select name="owner" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white">
          <option value="" selected={ownerFilter === ""}>All</option>
          <option value="assigned" selected={ownerFilter === "assigned"}>Assigned</option>
          <option value="unassigned" selected={ownerFilter === "unassigned"}>Unassigned</option>
        </select>
      </div>

      <!-- Hidden sort params to preserve on filter submit -->
      <input type="hidden" name="sort" value={sortBy} />
      <input type="hidden" name="order" value={sortOrder} />

      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">
          Filter
        </button>
        <a href="/admin/hotels" class="px-4 py-2 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors">
          Reset
        </a>
      </div>
    </form>
  </div>

  <!-- Result count -->
  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>
  )}

  <div class="flex items-center justify-between mb-3">
    <p class="text-sm text-slate-500">{hotels.length} hotel{hotels.length !== 1 ? "s" : ""} found</p>
    <a href="/admin/hotels/new" class="px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">
      + Add Hotel
    </a>
  </div>

  <!-- Table -->
  {hotels.length === 0 && !error ? (
    <div class="bg-white rounded-xl border border-slate-200 p-12 text-center">
      <p class="text-slate-500">No hotels found matching the filters.</p>
    </div>
  ) : (
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th class="text-left px-4 py-3 font-medium text-slate-600">Thumbnail</th>
              <th class="text-left px-4 py-3 font-medium text-slate-600">
                <a href={sortLink("name")} class="hover:text-teal-600 inline-flex items-center gap-1">
                  Hotel Name <span class="text-xs">{sortIcon("name")}</span>
                </a>
              </th>
              <th class="text-left px-4 py-3 font-medium text-slate-600">
                <a href={sortLink("country")} class="hover:text-teal-600 inline-flex items-center gap-1">
                  Country <span class="text-xs">{sortIcon("country")}</span>
                </a>
              </th>
              <th class="text-left px-4 py-3 font-medium text-slate-600">
                <a href={sortLink("city")} class="hover:text-teal-600 inline-flex items-center gap-1">
                  City <span class="text-xs">{sortIcon("city")}</span>
                </a>
              </th>
              <th class="text-center px-4 py-3 font-medium text-slate-600">
                <a href={sortLink("plans")} class="hover:text-teal-600 inline-flex items-center gap-1">Plans <span class="text-xs">{sortIcon("plans")}</span></a>
              </th>
              <th class="text-center px-4 py-3 font-medium text-slate-600">
                <a href={sortLink("bookings")} class="hover:text-teal-600 inline-flex items-center gap-1">Bookings <span class="text-xs">{sortIcon("bookings")}</span></a>
              </th>
              <th class="text-left px-4 py-3 font-medium text-slate-600">
                <a href={sortLink("owner")} class="hover:text-teal-600 inline-flex items-center gap-1">
                  Owner <span class="text-xs">{sortIcon("owner")}</span>
                </a>
              </th>
              <th class="text-center px-4 py-3 font-medium text-slate-600">Status</th>
              <th class="text-right px-4 py-3 font-medium text-slate-600">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {hotels.map((hotel) => (
              <tr class="hover:bg-slate-50 transition-colors">
                <!-- Thumbnail -->
                <td class="px-4 py-3">
                  {hotel.thumbnail_url ? (
                    <img src={hotel.thumbnail_url} alt={hotel.name} class="w-12 h-9 object-cover rounded-md border border-slate-200" />
                  ) : (
                    <div class="w-12 h-9 bg-slate-100 rounded-md border border-slate-200 flex items-center justify-center text-slate-300 text-xs">
                      🏨
                    </div>
                  )}
                </td>

                <!-- Name -->
                <td class="px-4 py-3">
                  <div class="font-medium text-slate-900">{hotel.name}</div>
                  {hotel.name_ja && <div class="text-xs text-slate-400 mt-0.5">{hotel.name_ja}</div>}
                  <div class="text-xs text-slate-400 mt-0.5">{hotel.property_type || "Hotel"}</div>
                </td>

                <!-- Country -->
                <td class="px-4 py-3 text-slate-600">{hotel.country || "-"}</td>

                <!-- City -->
                <td class="px-4 py-3 text-slate-600">{hotel.city || "-"}</td>

                <!-- Plans -->
                <td class="px-4 py-3 text-center">
                  <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-blue-50 text-blue-700 text-xs font-semibold">
                    {hotel.plan_count}
                  </span>
                </td>

                <!-- Active Bookings -->
                <td class="px-4 py-3 text-center">
                  <span class={`inline-flex items-center justify-center w-7 h-7 rounded-full text-xs font-semibold ${hotel.active_bookings > 0 ? "bg-green-50 text-green-700" : "bg-slate-50 text-slate-500"}`}>
                    {hotel.active_bookings}
                  </span>
                </td>

                <!-- Owner -->
                <td class="px-4 py-3">
                  {hotel.email && ownerMap[hotel.email] ? (
                    <div class="flex items-center gap-2">
                      <div>
                        <div class="text-sm font-medium text-slate-800">{ownerMap[hotel.email]}</div>
                        <div class="text-xs text-slate-400">{hotel.email}</div>
                      </div>
                      <button class="assign-owner-btn flex-shrink-0 text-slate-400 hover:text-teal-600 transition-colors" data-id={hotel.id} data-name={hotel.name} data-email={hotel.email} title="Change Owner">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" /></svg>
                      </button>
                    </div>
                  ) : hotel.email ? (
                    <div class="flex items-center gap-2">
                      <div>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200">
                          No account
                        </span>
                        <div class="text-xs text-slate-400 mt-0.5">{hotel.email}</div>
                      </div>
                      <button class="assign-owner-btn flex-shrink-0 text-amber-500 hover:text-teal-600 transition-colors" data-id={hotel.id} data-name={hotel.name} data-email={hotel.email} title="Assign Owner">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" /></svg>
                      </button>
                    </div>
                  ) : (
                    <button class="assign-owner-btn inline-flex items-center gap-1 px-2 py-1 text-xs font-medium text-red-600 bg-red-50 border border-red-200 rounded hover:bg-teal-50 hover:text-teal-700 hover:border-teal-200 transition-colors" data-id={hotel.id} data-name={hotel.name} data-email="">
                      + Assign Owner
                    </button>
                  )}
                </td>

                <!-- Status -->
                <td class="px-4 py-3 text-center">
                  <button
                    class="toggle-active-btn inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium cursor-pointer transition-colors"
                    data-id={hotel.id}
                    data-active={hotel.is_active ? "1" : "0"}
                    class:list={[hotel.is_active ? "bg-green-50 text-green-700 hover:bg-red-50 hover:text-red-700" : "bg-slate-100 text-slate-500 hover:bg-green-50 hover:text-green-700"]}
                  >
                    <span class={`w-1.5 h-1.5 rounded-full ${hotel.is_active ? "bg-green-500" : "bg-slate-400"}`}></span>
                    {hotel.is_active ? "Active" : "Inactive"}
                  </button>
                </td>

                <!-- Actions -->
                <td class="px-4 py-3 text-right">
                  <div class="flex items-center justify-end gap-1">
                    <a
                      href={`/admin/hotels/${hotel.id}`}
                      class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-indigo-600 bg-indigo-50 border border-indigo-200 rounded-md hover:bg-indigo-100 transition-colors"
                    >
                      Edit
                    </a>
                    <button
                      class="delete-hotel-btn inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-red-600 bg-red-50 border border-red-200 rounded-md hover:bg-red-100 transition-colors"
                      data-id={hotel.id}
                      data-name={hotel.name}
                    >
                      Delete
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <!-- Assign Owner Modal -->
  <div id="assign-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/60" id="assign-backdrop"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-white rounded-xl shadow-xl w-full max-w-md">
        <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between">
          <h2 class="text-lg font-semibold text-slate-900">Assign Owner</h2>
          <button id="assign-close" class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
        </div>
        <div class="p-6 space-y-4">
          <p class="text-sm text-slate-500">Hotel: <strong id="assign-hotel-name"></strong></p>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Search Owner</label>
            <input id="assign-search" type="text" placeholder="Owner name or email..."
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" autocomplete="off" />
            <div id="assign-suggestions" class="border border-slate-200 rounded-lg mt-1 max-h-40 overflow-y-auto hidden"></div>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Owner Email</label>
            <input id="assign-email" type="email" placeholder="owner@example.com"
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 outline-none" />
          </div>
          <div id="assign-error" class="hidden bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-3 py-2"></div>
          <div class="flex gap-3">
            <button id="assign-cancel" class="flex-1 py-2 border border-slate-200 rounded-lg text-sm text-slate-600 hover:bg-slate-50">Cancel</button>
            <button id="assign-save" class="flex-1 py-2 bg-teal-600 text-white rounded-lg text-sm font-medium hover:bg-teal-700">Assign</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // Toggle Active/Inactive
  document.querySelectorAll('.toggle-active-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      const currentActive = btn.getAttribute('data-active') === '1';
      const newStatus = currentActive ? 0 : 1;
      const label = currentActive ? 'deactivate' : 'activate';

      if (!confirm(`Are you sure you want to ${label} this hotel?`)) return;

      try {
        const res = await fetch('/api/admin/hotels', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: Number(id), is_active: newStatus }),
        });

        if (res.ok) {
          location.reload();
        } else {
          const data = await res.json();
          alert('Failed: ' + (data.error || 'Unknown error'));
        }
      } catch {
        alert('Network error');
      }
    });
  });

  // Delete Hotel
  document.querySelectorAll('.delete-hotel-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      const name = btn.getAttribute('data-name');

      if (!confirm(`Are you sure you want to delete "${name}"? This action cannot be undone.`)) return;

      try {
        const res = await fetch(`/api/admin/hotels?id=${id}`, {
          method: 'DELETE',
        });

        if (res.ok) {
          location.reload();
        } else {
          const data = await res.json();
          alert('Failed: ' + (data.error || 'Unknown error'));
        }
      } catch {
        alert('Network error');
      }
    });
  });

  // Assign Owner modal
  const assignModal = document.getElementById('assign-modal')!;
  let assignHotelId: string | null = null;

  function openAssign(id: string, name: string, email: string) {
    assignHotelId = id;
    (document.getElementById('assign-hotel-name') as HTMLElement).textContent = name;
    (document.getElementById('assign-email') as HTMLInputElement).value = email || '';
    (document.getElementById('assign-search') as HTMLInputElement).value = '';
    document.getElementById('assign-suggestions')!.classList.add('hidden');
    document.getElementById('assign-error')!.classList.add('hidden');
    assignModal.classList.remove('hidden');
    (document.getElementById('assign-search') as HTMLInputElement).focus();
  }
  function closeAssign() { assignModal.classList.add('hidden'); }

  // Owner search
  let searchTimer: any = null;
  const searchInput = document.getElementById('assign-search') as HTMLInputElement;
  const suggestions = document.getElementById('assign-suggestions') as HTMLElement;

  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTimer);
    const q = searchInput.value.trim();
    if (q.length < 2) { suggestions.classList.add('hidden'); return; }
    searchTimer = setTimeout(async () => {
      try {
        const res = await fetch(`/api/admin/users?search=${encodeURIComponent(q)}&role=owner&limit=10`);
        const data = await res.json();
        const users = data.users || [];
        if (users.length === 0) {
          suggestions.innerHTML = '<div class="px-3 py-2 text-xs text-slate-400">No owners found</div>';
        } else {
          suggestions.innerHTML = users.map((u: any) =>
            `<div class="owner-suggestion px-3 py-2 hover:bg-teal-50 cursor-pointer text-sm border-b border-slate-100 last:border-0" data-email="${u.email}">
              <span class="font-medium text-slate-800">${u.name}</span>
              <span class="text-xs text-slate-400 ml-2">${u.email}</span>
            </div>`
          ).join('');
          suggestions.querySelectorAll('.owner-suggestion').forEach(el => {
            el.addEventListener('click', () => {
              (document.getElementById('assign-email') as HTMLInputElement).value = el.getAttribute('data-email') || '';
              searchInput.value = el.querySelector('.font-medium')?.textContent || '';
              suggestions.classList.add('hidden');
            });
          });
        }
        suggestions.classList.remove('hidden');
      } catch {}
    }, 300);
  });

  document.querySelectorAll('.assign-owner-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      openAssign(
        btn.getAttribute('data-id') || '',
        btn.getAttribute('data-name') || '',
        btn.getAttribute('data-email') || ''
      );
    });
  });

  document.getElementById('assign-close')?.addEventListener('click', closeAssign);
  document.getElementById('assign-backdrop')?.addEventListener('click', closeAssign);
  document.getElementById('assign-cancel')?.addEventListener('click', closeAssign);

  document.getElementById('assign-save')?.addEventListener('click', async () => {
    if (!assignHotelId) return;
    const email = (document.getElementById('assign-email') as HTMLInputElement).value.trim();
    const errEl = document.getElementById('assign-error')!;
    errEl.classList.add('hidden');

    if (!email) { errEl.textContent = 'Email is required'; errEl.classList.remove('hidden'); return; }

    const btn = document.getElementById('assign-save') as HTMLButtonElement;
    btn.textContent = 'Assigning...'; btn.disabled = true;

    try {
      const res = await fetch(`/api/admin/hotels/${assignHotelId}/assign-owner`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ owner_email: email }),
      });
      const data = await res.json();
      if (res.ok) {
        location.reload();
      } else {
        errEl.textContent = data.error || 'Failed to assign owner';
        errEl.classList.remove('hidden');
      }
    } catch {
      errEl.textContent = 'Network error';
      errEl.classList.remove('hidden');
    }
    btn.textContent = 'Assign'; btn.disabled = false;
  });
</script>
