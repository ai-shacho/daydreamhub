---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect("/admin/login");

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get("status") || "";
const directionFilter = url.searchParams.get("direction") || "";
const search = url.searchParams.get("search") || "";

let messages: any[] = [];
let error = "";

if (db) {
  try {
    let query = `SELECT * FROM messages WHERE 1=1`;
    const binds: any[] = [];

    if (statusFilter) {
      query += " AND status = ?";
      binds.push(statusFilter);
    }
    if (directionFilter) {
      query += " AND direction = ?";
      binds.push(directionFilter);
    }
    if (search) {
      query += " AND (subject LIKE ? OR recipient_email LIKE ? OR sender_email LIKE ?)";
      binds.push(`%${search}%`, `%${search}%`, `%${search}%`);
    }

    query += " ORDER BY created_at DESC LIMIT 200";
    const result = await db.prepare(query).bind(...binds).all();
    messages = result?.results || [];
  } catch (e: any) {
    error = e.message || "Failed to load messages";
  }
}

const statusOptions = ["", "sent", "delivered", "failed", "pending", "queued"];
const directionOptions = ["", "inbound", "outbound"];
const statusColors: Record<string, string> = {
  sent: "bg-emerald-100 text-emerald-700",
  delivered: "bg-blue-100 text-blue-700",
  failed: "bg-red-100 text-red-700",
  pending: "bg-amber-100 text-amber-700",
  queued: "bg-slate-100 text-slate-600",
};
const directionColors: Record<string, string> = {
  inbound: "bg-indigo-100 text-indigo-700",
  outbound: "bg-cyan-100 text-cyan-700",
};
---

<AdminLayout title="Messages" activeNav="messages">
  <!-- Filters -->
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <form method="GET" action="/admin/messages" class="flex flex-wrap items-end gap-4">
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Search</label>
        <input type="text" name="search" value={search} placeholder="Subject, recipient, or sender..." class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent" />
      </div>
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Status</label>
        <select name="status" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white">
          <option value="">All Statuses</option>
          {statusOptions.filter((s) => s).map((s) => (
            <option value={s} selected={s === statusFilter}>{s.charAt(0).toUpperCase() + s.slice(1)}</option>
          ))}
        </select>
      </div>
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Direction</label>
        <select name="direction" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white">
          <option value="">All Directions</option>
          {directionOptions.filter((d) => d).map((d) => (
            <option value={d} selected={d === directionFilter}>{d.charAt(0).toUpperCase() + d.slice(1)}</option>
          ))}
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">
          Filter
        </button>
        <a href="/admin/messages" class="px-4 py-2 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors">
          Reset
        </a>
      </div>
    </form>
  </div>

  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>
  )}

  <p class="text-sm text-slate-500 mb-4">{messages.length} message{messages.length !== 1 ? "s" : ""} found</p>

  <!-- Messages Table -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-medium text-slate-600">ID</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Subject</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Recipient</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Sender</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Direction</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Type</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Status</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {messages.length === 0 ? (
            <tr>
              <td colspan="8" class="px-4 py-12 text-center text-slate-400">No messages found</td>
            </tr>
          ) : messages.map((m: any) => (
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-4 py-3 font-mono text-slate-500">#{m.id}</td>
              <td class="px-4 py-3">
                <div class="font-medium text-slate-900 max-w-[300px] truncate">{m.subject || "-"}</div>
                {m.booking_id && <div class="text-xs text-slate-400">Booking #{m.booking_id}</div>}
              </td>
              <td class="px-4 py-3 text-slate-600">{m.recipient_email || "-"}</td>
              <td class="px-4 py-3 text-slate-600">{m.sender_email || "-"}</td>
              <td class="px-4 py-3 text-center">
                {m.direction && (
                  <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${directionColors[m.direction] || "bg-slate-100 text-slate-600"}`}>
                    {m.direction}
                  </span>
                )}
              </td>
              <td class="px-4 py-3 text-center text-slate-500 text-xs">{m.message_type || "-"}</td>
              <td class="px-4 py-3 text-center">
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColors[m.status] || "bg-slate-100 text-slate-600"}`}>
                  {m.status || "-"}
                </span>
                {m.error_detail && (
                  <div class="text-xs text-red-400 mt-1 max-w-[150px] truncate" title={m.error_detail}>{m.error_detail}</div>
                )}
              </td>
              <td class="px-4 py-3 text-slate-500 text-xs">{m.created_at?.slice(0, 16) || "-"}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
