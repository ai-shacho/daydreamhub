---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../../lib/adminAuth';

const runtime = (Astro.locals as any).runtime;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || 'dev-secret';
const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect('/admin/login');

const { id } = Astro.params;
let booking: any = null;
let callLogs: any[] = [];

if (db && id) {
  try {
    booking = await db.prepare(`
      SELECT b.*,
        h.name as hotel_name, h.slug as hotel_slug, h.phone as hotel_phone,
        h.city, h.country,
        p.name as plan_name, p.plan_type, p.price_usd, p.duration_hours
      FROM bookings b
      LEFT JOIN hotels h ON h.id = b.hotel_id
      LEFT JOIN plans p ON p.id = b.plan_id
      WHERE b.id = ?1
    `).bind(id).first();

    const logsResult = await db.prepare(`
      SELECT * FROM call_logs WHERE booking_id = ?1 ORDER BY created_at DESC
    `).bind(id).all();
    callLogs = logsResult?.results || [];
  } catch (e: any) {
    console.error(e);
  }
}

if (!booking) return new Response('Booking not found', { status: 404 });

const statusColor: Record<string,string> = {
  pending: 'bg-amber-50 text-amber-700',
  confirmed: 'bg-green-50 text-green-700',
  cancelled: 'bg-red-50 text-red-700',
  pending_alternative: 'bg-blue-50 text-blue-700',
  refunded: 'bg-slate-100 text-slate-600',
};
---

<AdminLayout title={`Booking #${booking.id} | Admin`} activeNav="bookings">
  <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
    <a href="/admin/bookings" class="hover:text-teal-600">Bookings</a>
    <span>›</span>
    <span class="text-slate-900 font-medium">#{booking.id}</span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main info -->
    <div class="lg:col-span-2 space-y-5">

      <!-- Booking summary card -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-lg font-bold text-slate-900">Booking #{booking.id}</h2>
          <span class={`inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ${statusColor[booking.status] || 'bg-slate-100 text-slate-600'}`}>
            {booking.status}
          </span>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Guest</p>
            <p class="font-semibold text-slate-900">{booking.guest_name || '—'}</p>
            <p class="text-sm text-slate-500">{booking.guest_email}</p>
            {booking.guest_phone && <p class="text-sm text-slate-500">{booking.guest_phone}</p>}
          </div>
          <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Check-in</p>
            <p class="font-semibold text-slate-900">{booking.check_in_date || '—'}</p>
            <p class="text-sm text-slate-500">{booking.adults} adults{booking.children ? `, ${booking.children} children` : ''}</p>
          </div>
          <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Hotel</p>
            <a href={`/admin/hotels/${booking.hotel_id}`} class="font-semibold text-teal-600 hover:underline">{booking.hotel_name}</a>
            <p class="text-sm text-slate-500">{booking.city}, {booking.country}</p>
          </div>
          <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Plan</p>
            <p class="font-semibold text-slate-900">{booking.plan_name}</p>
            <p class="text-sm text-slate-500">{booking.plan_type} · {booking.duration_hours}h · ${booking.price_usd}</p>
          </div>
          <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Total</p>
            <p class="text-2xl font-bold text-teal-600">${booking.total_price_usd}</p>
          </div>
          <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Payment</p>
            <p class="text-sm font-medium text-slate-700 font-mono">{booking.paypal_order_id || '—'}</p>
            {booking.paypal_capture_id && <p class="text-xs text-slate-400 font-mono">{booking.paypal_capture_id}</p>}
          </div>
        </div>
        {booking.notes && (
          <div class="mt-4 pt-4 border-t border-slate-100">
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Notes</p>
            <p class="text-sm text-slate-700 whitespace-pre-wrap">{booking.notes}</p>
          </div>
        )}
      </div>

      <!-- Call logs -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-200 flex items-center justify-between">
          <h3 class="font-semibold text-slate-900">📞 Call Logs ({callLogs.length})</h3>
          {booking.hotel_phone && (
            <button id="trigger-call" data-hotel-id={booking.hotel_id} data-phone={booking.hotel_phone} data-booking-id={booking.id}
              class="px-3 py-1.5 text-sm bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition-colors flex items-center gap-1">
              📞 Call Hotel Now
            </button>
          )}
        </div>
        {callLogs.length === 0 ? (
          <p class="px-5 py-8 text-center text-slate-400 text-sm">No calls yet</p>
        ) : (
          <div class="divide-y divide-slate-100">
            {callLogs.map(log => (
              <div class="px-5 py-4">
                <div class="flex items-center justify-between mb-2">
                  <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${
                    log.status === 'confirmed' ? 'bg-green-50 text-green-700' :
                    log.status === 'declined' ? 'bg-red-50 text-red-700' :
                    log.status === 'alternative_offered' ? 'bg-blue-50 text-blue-700' :
                    'bg-slate-100 text-slate-600'
                  }`}>{log.status}</span>
                  <span class="text-xs text-slate-400">{log.created_at}</span>
                </div>
                {log.alternative_info && (
                  <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 mb-2">
                    <p class="text-xs font-medium text-blue-700 mb-1">🔄 Alternative offered:</p>
                    <p class="text-sm text-blue-800">{log.alternative_info}</p>
                  </div>
                )}
                {log.transcription && (
                  <details class="mt-2">
                    <summary class="text-xs text-slate-500 cursor-pointer hover:text-teal-600">View transcript</summary>
                    <pre class="mt-2 text-xs text-slate-600 bg-slate-50 p-3 rounded-lg whitespace-pre-wrap font-mono max-h-40 overflow-y-auto">{log.transcription}</pre>
                  </details>
                )}
              </div>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- Sidebar actions -->
    <div class="space-y-4">
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5">
        <h3 class="font-semibold text-slate-900 mb-3">Actions</h3>
        <div class="space-y-2">
          <button onclick={`updateStatus('confirmed')`} class="w-full text-sm px-3 py-2 bg-green-50 text-green-700 rounded-lg hover:bg-green-100 transition-colors text-left">
            ✅ Mark Confirmed
          </button>
          <button onclick={`updateStatus('cancelled')`} class="w-full text-sm px-3 py-2 bg-red-50 text-red-700 rounded-lg hover:bg-red-100 transition-colors text-left">
            ❌ Cancel Booking
          </button>
          <a href={`/hotel/${booking.hotel_slug}`} target="_blank"
            class="flex items-center gap-1 w-full text-sm px-3 py-2 bg-slate-50 text-slate-700 rounded-lg hover:bg-slate-100 transition-colors">
            🔗 View Hotel Page
          </a>
        </div>
        <div id="action-result" class="hidden mt-3 text-xs p-2 rounded-lg"></div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5">
        <h3 class="font-semibold text-slate-900 mb-3">Info</h3>
        <dl class="space-y-2 text-sm">
          <div class="flex justify-between"><dt class="text-slate-500">Booking ID</dt><dd class="font-mono">#{booking.id}</dd></div>
          <div class="flex justify-between"><dt class="text-slate-500">Created</dt><dd class="text-slate-700 text-xs">{booking.created_at?.slice(0,16)}</dd></div>
          <div class="flex justify-between"><dt class="text-slate-500">Hotel ID</dt><dd><a href={`/admin/hotels/${booking.hotel_id}`} class="text-teal-600 hover:underline">#{booking.hotel_id}</a></dd></div>
          <div class="flex justify-between"><dt class="text-slate-500">Plan ID</dt><dd class="font-mono">#{booking.plan_id}</dd></div>
        </dl>
      </div>
    </div>
  </div>
</AdminLayout>

<script is:inline>
async function updateStatus(newStatus) {
  const result = document.getElementById('action-result');
  try {
    const res = await fetch(`/api/admin/bookings`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: parseInt(location.pathname.split('/').pop()), status: newStatus }),
    });
    const data = await res.json();
    result.className = `block mt-3 text-xs p-2 rounded-lg ${res.ok ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700'}`;
    result.textContent = res.ok ? `✅ Status updated to ${newStatus}` : `❌ ${data.error}`;
    if (res.ok) setTimeout(() => location.reload(), 1000);
  } catch(e) {
    result.className = 'block mt-3 text-xs p-2 rounded-lg bg-red-50 text-red-700';
    result.textContent = `❌ ${e.message}`;
  }
}

document.getElementById('trigger-call')?.addEventListener('click', async function() {
  const res = await fetch('/api/admin/call', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      action: 'dial',
      to_number: this.dataset.phone,
      hotel_id: parseInt(this.dataset.hotelId),
      note: `Booking #${this.dataset.bookingId} confirmation call`,
    }),
  });
  const data = await res.json();
  alert(res.ok ? `✅ Call initiated! SID: ${data.call_sid}` : `❌ ${data.error}`);
});
</script>
