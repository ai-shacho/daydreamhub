---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect("/admin/login");

const url = new URL(Astro.request.url);
const approvedFilter = url.searchParams.get("approved") ?? "";
const search = url.searchParams.get("search") || "";

let reviews: any[] = [];
let error = "";

if (db) {
  try {
    let query = `SELECT r.id, r.hotel_id, r.rating, r.content, r.is_approved, r.created_at,
      h.name as hotel_name
      FROM reviews r
      LEFT JOIN hotels h ON h.id = r.hotel_id
      WHERE 1=1`;
    const binds: any[] = [];

    if (approvedFilter !== "") {
      query += " AND r.is_approved = ?";
      binds.push(Number(approvedFilter));
    }
    if (search) {
      query += " AND (r.content LIKE ? OR h.name LIKE ?)";
      binds.push(`%${search}%`, `%${search}%`);
    }

    query += " ORDER BY r.created_at DESC LIMIT 200";
    const result = await db.prepare(query).bind(...binds).all();
    reviews = result?.results || [];
  } catch (e: any) {
    error = e.message || "Failed to load reviews";
  }
}

const approvalColors: Record<string, string> = {
  "1": "bg-emerald-100 text-emerald-700",
  "0": "bg-amber-100 text-amber-700",
};

function renderStars(rating: number): string {
  const full = Math.floor(rating);
  const half = rating % 1 >= 0.5 ? 1 : 0;
  const empty = 5 - full - half;
  return "★".repeat(full) + (half ? "½" : "") + "☆".repeat(empty);
}

function truncate(text: string, len: number): string {
  if (!text) return "-";
  return text.length > len ? text.slice(0, len) + "..." : text;
}
---

<AdminLayout title="Reviews" activeNav="reviews">
  <!-- Filters -->
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <form method="GET" action="/admin/reviews" class="flex flex-wrap items-end gap-4">
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Search</label>
        <input type="text" name="search" value={search} placeholder="Review content or hotel name..." class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent" />
      </div>
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Status</label>
        <select name="approved" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white">
          <option value="">All</option>
          <option value="1" selected={approvedFilter === "1"}>Approved</option>
          <option value="0" selected={approvedFilter === "0"}>Pending</option>
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">
          Filter
        </button>
        <a href="/admin/reviews" class="px-4 py-2 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors">
          Reset
        </a>
      </div>
    </form>
  </div>

  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>
  )}

  <p class="text-sm text-slate-500 mb-4">{reviews.length} review{reviews.length !== 1 ? "s" : ""} found</p>

  <!-- Reviews Table -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-medium text-slate-600">ID</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Hotel</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Rating</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Content</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Status</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Created</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {reviews.length === 0 ? (
            <tr>
              <td colspan="7" class="px-4 py-12 text-center text-slate-400">No reviews found</td>
            </tr>
          ) : reviews.map((r: any) => (
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-4 py-3 font-mono text-slate-500">#{r.id}</td>
              <td class="px-4 py-3 font-medium text-slate-900">{r.hotel_name || "-"}</td>
              <td class="px-4 py-3 text-amber-500 whitespace-nowrap" title={`${r.rating} / 5`}>
                {renderStars(r.rating)}
                <span class="ml-1 text-slate-500 text-xs">{r.rating}</span>
              </td>
              <td class="px-4 py-3 text-slate-600 max-w-[300px]">
                <span title={r.content || ""}>{truncate(r.content, 80)}</span>
              </td>
              <td class="px-4 py-3 text-center">
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${approvalColors[String(r.is_approved)] || "bg-slate-100 text-slate-600"}`}>
                  {r.is_approved ? "Approved" : "Pending"}
                </span>
              </td>
              <td class="px-4 py-3 text-slate-500 text-xs">{r.created_at?.slice(0, 16) || "-"}</td>
              <td class="px-4 py-3 text-center">
                <div class="flex items-center justify-center gap-1">
                  {!r.is_approved && (
                    <button
                      class="review-btn px-2 py-1 text-xs text-emerald-700 bg-emerald-50 border border-emerald-200 rounded hover:bg-emerald-100 transition-colors"
                      data-id={r.id}
                      data-action="approve"
                    >
                      Approve
                    </button>
                  )}
                  {r.is_approved === 1 && (
                    <button
                      class="review-btn px-2 py-1 text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded hover:bg-amber-100 transition-colors"
                      data-id={r.id}
                      data-action="reject"
                    >
                      Reject
                    </button>
                  )}
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  document.querySelectorAll('.review-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = Number(btn.getAttribute('data-id'));
      const action = btn.getAttribute('data-action');
      const actionLabel = action === 'approve' ? 'approve' : 'reject';

      if (!confirm(`Are you sure you want to ${actionLabel} review #${id}?`)) return;

      btn.disabled = true;
      const origText = btn.textContent;
      btn.textContent = '...';

      try {
        const res = await fetch('/api/admin/reviews', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, action }),
        });

        if (res.ok) {
          location.reload();
        } else {
          const data = await res.json();
          alert('Failed: ' + (data.error || 'Unknown error'));
          btn.textContent = origText;
          btn.disabled = false;
        }
      } catch {
        alert('Network error');
        btn.textContent = origText;
        btn.disabled = false;
      }
    });
  });
</script>
