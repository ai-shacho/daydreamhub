---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect("/admin/login");

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get("status") || "";

let editRequests: any[] = [];
let error = "";

if (db) {
  try {
    let query = `SELECT er.*, h.name as hotel_name, u.name as requester_name
    FROM hotel_edit_requests er
    LEFT JOIN hotels h ON er.hotel_id = h.id
    LEFT JOIN users u ON er.requested_by = u.id`;
    const binds: any[] = [];
    if (statusFilter) {
      query += " WHERE er.status = ?";
      binds.push(statusFilter);
    }
    query += " ORDER BY er.created_at DESC LIMIT 100";

    const result = binds.length > 0
      ? await db.prepare(query).bind(...binds).all()
      : await db.prepare(query).all();
    editRequests = result?.results || [];
  } catch (e: any) {
    error = e.message || "Failed to load edit requests";
    editRequests = [];
  }
}

function getChangeSummary(fieldChanges: string) {
  try {
    const changes = JSON.parse(fieldChanges);
    return Object.keys(changes).join(", ");
  } catch {
    return "-";
  }
}
---

<AdminLayout title="Edit Requests" activeNav="edit-requests">
  <!-- Filter -->
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <form method="GET" action="/admin/edit-requests" class="flex flex-wrap items-end gap-4">
      <div class="min-w-[200px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Status</label>
        <select name="status" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white">
          <option value="" selected={statusFilter === ""}>All</option>
          <option value="pending" selected={statusFilter === "pending"}>Pending</option>
          <option value="approved" selected={statusFilter === "approved"}>Approved</option>
          <option value="rejected" selected={statusFilter === "rejected"}>Rejected</option>
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">
          Filter
        </button>
        <a href="/admin/edit-requests" class="px-4 py-2 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors">
          Reset
        </a>
      </div>
    </form>
  </div>

  <!-- Count & Error -->
  <div class="flex items-center justify-between mb-4">
    <p class="text-sm text-slate-500">{editRequests.length} edit request{editRequests.length !== 1 ? "s" : ""} found</p>
  </div>

  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>
  )}

  <!-- Table -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm" id="edit-requests-table">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-medium text-slate-600">ID</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Hotel</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Requested By</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Changes</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Status</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Date</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {editRequests.length === 0 ? (
            <tr>
              <td colspan="7" class="px-4 py-12 text-center text-slate-400">No edit requests found</td>
            </tr>
          ) : editRequests.map((er: any) => (
            <>
              <tr class="hover:bg-slate-50 transition-colors" data-id={er.id}>
                <td class="px-4 py-3 font-mono text-slate-500">#{er.id}</td>
                <td class="px-4 py-3 text-slate-600">{er.hotel_name || `Hotel #${er.hotel_id}`}</td>
                <td class="px-4 py-3 text-slate-600">{er.requester_name || `User #${er.requested_by}`}</td>
                <td class="px-4 py-3 text-slate-600">
                  <button class="detail-toggle text-teal-600 hover:text-teal-800 underline text-xs" data-target={`detail-${er.id}`}>
                    {getChangeSummary(er.field_changes)}
                  </button>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                    er.status === "approved" ? "bg-emerald-100 text-emerald-700" :
                    er.status === "rejected" ? "bg-red-100 text-red-700" :
                    "bg-amber-100 text-amber-700"
                  }`}>
                    {er.status === "approved" ? "Approved" : er.status === "rejected" ? "Rejected" : "Pending"}
                  </span>
                </td>
                <td class="px-4 py-3 text-slate-500 text-xs">{er.created_at?.slice(0, 16)}</td>
                <td class="px-4 py-3 text-center">
                  {er.status === "pending" ? (
                    <div class="flex items-center justify-center gap-1">
                      <button class="approve-btn px-2 py-1 text-xs text-emerald-700 bg-emerald-50 border border-emerald-200 rounded hover:bg-emerald-100 transition-colors" data-id={er.id} title="Approve">
                        Approve
                      </button>
                      <button class="reject-btn px-2 py-1 text-xs text-red-700 bg-red-50 border border-red-200 rounded hover:bg-red-100 transition-colors" data-id={er.id} title="Reject">
                        Reject
                      </button>
                    </div>
                  ) : (
                    <span class="text-xs text-slate-400">
                      {er.admin_note ? `Note: ${er.admin_note}` : "Processed"}
                    </span>
                  )}
                </td>
              </tr>
              <tr id={`detail-${er.id}`} class="hidden bg-slate-50">
                <td colspan="7" class="px-4 py-3">
                  <div class="text-xs text-slate-500 mb-1 font-medium">Field Changes:</div>
                  <div class="bg-white rounded border border-slate-200 p-3 text-sm" data-changes={er.field_changes}>
                    <dl class="space-y-1 changes-list"></dl>
                  </div>
                  {er.admin_note && (
                    <div class="mt-2 text-xs text-slate-500">
                      <span class="font-medium">Admin Note:</span> {er.admin_note}
                    </div>
                  )}
                </td>
              </tr>
            </>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  // Parse and render field changes for detail rows
  document.querySelectorAll('[data-changes]').forEach(function(el) {
    var changesJson = el.getAttribute('data-changes');
    var dl = el.querySelector('.changes-list');
    if (!changesJson || !dl) return;
    try {
      var changes = JSON.parse(changesJson);
      var html = '';
      for (var key in changes) {
        if (changes.hasOwnProperty(key)) {
          var val = changes[key];
          if (typeof val === 'object') val = JSON.stringify(val);
          html += '<div class="flex gap-2 py-1 border-b border-slate-100 last:border-0">';
          html += '<dt class="font-medium text-slate-700 min-w-[140px]">' + key + ':</dt>';
          html += '<dd class="text-slate-600 break-all">' + (val || '<em class="text-slate-400">empty</em>') + '</dd>';
          html += '</div>';
        }
      }
      dl.innerHTML = html || '<p class="text-slate-400 italic">No changes data</p>';
    } catch (e) {
      dl.innerHTML = '<p class="text-red-400 italic">Error parsing changes</p>';
    }
  });

  // Detail toggle
  document.querySelectorAll('.detail-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var targetId = btn.getAttribute('data-target');
      if (!targetId) return;
      var detailRow = document.getElementById(targetId);
      if (detailRow) {
        detailRow.classList.toggle('hidden');
      }
    });
  });

  // Approve button
  document.querySelectorAll('.approve-btn').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var id = Number(btn.getAttribute('data-id'));
      if (!confirm('Approve this edit request? The changes will be applied to the hotel.')) return;

      btn.disabled = true;
      var origText = btn.textContent;
      btn.textContent = '...';

      try {
        var res = await fetch('/api/admin/edit-requests', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: id, action: 'approve' }),
        });

        if (res.ok) {
          var row = btn.closest('tr');
          var badge = row.querySelector('span[class*="rounded-full"]');
          if (badge) {
            badge.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700';
            badge.textContent = 'Approved';
          }
          var actionsCell = btn.closest('td');
          actionsCell.innerHTML = '<span class="text-xs text-slate-400">Processed</span>';
        } else {
          var data = await res.json();
          alert('Failed to approve: ' + (data.error || 'Unknown error'));
          btn.textContent = origText;
          btn.disabled = false;
        }
      } catch (e) {
        alert('Error approving edit request');
        btn.textContent = origText;
        btn.disabled = false;
      }
    });
  });

  // Reject button
  document.querySelectorAll('.reject-btn').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var id = Number(btn.getAttribute('data-id'));
      var adminNote = prompt('Reason for rejection (optional):');
      if (adminNote === null) return;

      btn.disabled = true;
      var origText = btn.textContent;
      btn.textContent = '...';

      try {
        var res = await fetch('/api/admin/edit-requests', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: id, action: 'reject', admin_note: adminNote || '' }),
        });

        if (res.ok) {
          var row = btn.closest('tr');
          var badge = row.querySelector('span[class*="rounded-full"]');
          if (badge) {
            badge.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700';
            badge.textContent = 'Rejected';
          }
          var actionsCell = btn.closest('td');
          actionsCell.innerHTML = '<span class="text-xs text-slate-400">' + (adminNote ? 'Note: ' + adminNote : 'Processed') + '</span>';
        } else {
          var data = await res.json();
          alert('Failed to reject: ' + (data.error || 'Unknown error'));
          btn.textContent = origText;
          btn.disabled = false;
        }
      } catch (e) {
        alert('Error rejecting edit request');
        btn.textContent = origText;
        btn.disabled = false;
      }
    });
  });
</script>
