---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect("/admin/login");

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get("status") || "";
const searchQuery = url.searchParams.get("q") || "";

let applications: any[] = [];
let error = "";

if (db) {
  try {
    let query = `SELECT * FROM owner_applications WHERE 1=1`;
    const binds: any[] = [];
    if (statusFilter) { query += " AND status = ?"; binds.push(statusFilter); }
    if (searchQuery) {
      query += " AND (hotel_name LIKE ? OR contact_name LIKE ? OR contact_email LIKE ? OR booking_email LIKE ?)";
      const like = `%${searchQuery}%`;
      binds.push(like, like, like, like);
    }
    query += " ORDER BY created_at DESC LIMIT 200";
    const result = await db.prepare(query).bind(...binds).all();
    applications = result?.results || [];
  } catch (e: any) {
    error = e.message || "Failed to load applications";
  }
}

const statusColors: Record<string, string> = {
  new: "bg-blue-100 text-blue-700",
  reviewing: "bg-amber-100 text-amber-700",
  approved: "bg-emerald-100 text-emerald-700",
  rejected: "bg-red-100 text-red-600",
};
---

<AdminLayout title="Owner Applications" activeNav="owner-applications">
  {error && <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">{error}</div>}

  <!-- Filter -->
  <div class="bg-white rounded-xl border border-slate-200 p-4 mb-6">
    <form method="get" class="flex flex-wrap items-end gap-3">
      <div class="flex-1 min-w-48">
        <label class="block text-xs font-medium text-slate-500 mb-1">Search</label>
        <input
          type="text"
          name="q"
          value={searchQuery}
          placeholder="Hotel name, email, contact..."
          class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500"
        />
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-500 mb-1">Status</label>
        <select name="status" class="px-3 py-2 border border-slate-200 rounded-lg text-sm">
          <option value="">All</option>
          <option value="new" selected={statusFilter === "new"}>New</option>
          <option value="reviewing" selected={statusFilter === "reviewing"}>Reviewing</option>
          <option value="approved" selected={statusFilter === "approved"}>Approved</option>
          <option value="rejected" selected={statusFilter === "rejected"}>Rejected</option>
        </select>
      </div>
      <button type="submit" class="px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700">Search</button>
      <a href="/admin/owner-applications" class="px-4 py-2 border border-slate-200 text-slate-600 text-sm rounded-lg hover:bg-slate-50">Reset</a>
    </form>
  </div>

  <p class="text-sm text-slate-500 mb-3">{applications.length} applications found</p>

  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">ID</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Hotel Name</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Contact</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Email</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Phone</th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500">Status</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Date</th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {applications.map((a: any) => (
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-4 py-3 text-slate-400 text-xs">#{a.id}</td>
              <td class="px-4 py-3 font-medium text-slate-900">{a.hotel_name}</td>
              <td class="px-4 py-3 text-slate-700">{a.contact_name}</td>
              <td class="px-4 py-3 text-slate-500 text-xs">{a.contact_email}</td>
              <td class="px-4 py-3 text-slate-500 text-xs">{a.contact_phone}</td>
              <td class="px-4 py-3 text-center">
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColors[a.status] || "bg-slate-100 text-slate-600"}`}>
                  {a.status}
                </span>
              </td>
              <td class="px-4 py-3 text-slate-500 text-xs">{a.created_at?.slice(0, 16) || "-"}</td>
              <td class="px-4 py-3 text-center">
                <button
                  class="detail-btn px-2 py-1 text-xs text-slate-600 bg-slate-50 border border-slate-200 rounded hover:bg-slate-100 transition-colors"
                  data-id={a.id}
                  data-app={JSON.stringify(a)}
                >
                  Details
                </button>
              </td>
            </tr>
          ))}
          {applications.length === 0 && (
            <tr><td colspan="8" class="px-4 py-8 text-center text-slate-400">No applications found</td></tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Detail Modal -->
  <div id="detail-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/60" id="detail-backdrop"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
        <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between">
          <h2 class="text-lg font-semibold text-slate-900">Application Details</h2>
          <button id="detail-close" class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
        </div>
        <div class="p-6 space-y-6">
          <!-- Property Info -->
          <div>
            <h3 class="text-sm font-semibold text-slate-500 mb-2">Property Information</h3>
            <div class="grid grid-cols-2 gap-3 text-sm">
              <div><span class="text-slate-400">Hotel Name:</span> <span id="d-hotel-name" class="font-medium text-slate-900"></span></div>
              <div><span class="text-slate-400">Booking Email:</span> <span id="d-booking-email" class="text-slate-700"></span></div>
              <div><span class="text-slate-400">Phone:</span> <span id="d-hotel-phone" class="text-slate-700"></span></div>
              <div><span class="text-slate-400">Company:</span> <span id="d-company" class="text-slate-700"></span></div>
              <div class="col-span-2"><span class="text-slate-400">Website:</span> <span id="d-site-url" class="text-slate-700"></span></div>
            </div>
          </div>

          <!-- Contact Info -->
          <div>
            <h3 class="text-sm font-semibold text-slate-500 mb-2">Contact Person</h3>
            <div class="grid grid-cols-2 gap-3 text-sm">
              <div><span class="text-slate-400">Name:</span> <span id="d-contact-name" class="font-medium text-slate-900"></span></div>
              <div><span class="text-slate-400">Email:</span> <span id="d-contact-email" class="text-slate-700"></span></div>
              <div><span class="text-slate-400">Phone:</span> <span id="d-contact-phone" class="text-slate-700"></span></div>
              <div><span class="text-slate-400">Preferred Method:</span> <span id="d-contact-method" class="text-slate-700"></span></div>
              <div><span class="text-slate-400">Messenger:</span> <span id="d-messenger" class="text-slate-700"></span></div>
              <div><span class="text-slate-400">WhatsApp:</span> <span id="d-whatsapp" class="text-slate-700"></span></div>
              <div><span class="text-slate-400">LINE:</span> <span id="d-line" class="text-slate-700"></span></div>
              <div><span class="text-slate-400">Other SNS:</span> <span id="d-other-sns" class="text-slate-700"></span></div>
            </div>
          </div>

          <!-- Payment Info -->
          <div>
            <h3 class="text-sm font-semibold text-slate-500 mb-2">Payment Information</h3>
            <div class="grid grid-cols-2 gap-3 text-sm">
              <div><span class="text-slate-400">Method:</span> <span id="d-payment-method" class="text-slate-700"></span></div>
              <div><span class="text-slate-400">PayPal:</span> <span id="d-paypal" class="text-slate-700"></span></div>
              <div><span class="text-slate-400">Wise:</span> <span id="d-wise" class="text-slate-700"></span></div>
              <div><span class="text-slate-400">Payoneer:</span> <span id="d-payoneer" class="text-slate-700"></span></div>
              <div class="col-span-2"><span class="text-slate-400">Bank Account:</span> <span id="d-bank" class="text-slate-700 whitespace-pre-wrap"></span></div>
            </div>
          </div>

          <!-- Status Update -->
          <div class="border-t border-slate-200 pt-4">
            <h3 class="text-sm font-semibold text-slate-500 mb-2">Update Status</h3>
            <div class="flex items-end gap-3">
              <div class="flex-1">
                <select id="d-status" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm">
                  <option value="new">New</option>
                  <option value="reviewing">Reviewing</option>
                  <option value="approved">Approved</option>
                  <option value="rejected">Rejected</option>
                </select>
              </div>
              <div class="flex-1">
                <input id="d-note" type="text" placeholder="Note (optional)" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm" />
              </div>
              <button id="d-save" class="px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700">Save</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const modal = document.getElementById('detail-modal')!;
  let currentId: number | null = null;

  function openModal(app: any) {
    currentId = app.id;
    (document.getElementById('d-hotel-name') as HTMLElement).textContent = app.hotel_name || '-';
    (document.getElementById('d-booking-email') as HTMLElement).textContent = app.booking_email || '-';
    (document.getElementById('d-hotel-phone') as HTMLElement).textContent = app.hotel_phone || '-';
    (document.getElementById('d-company') as HTMLElement).textContent = app.management_company || '-';
    (document.getElementById('d-site-url') as HTMLElement).textContent = app.site_url || '-';
    (document.getElementById('d-contact-name') as HTMLElement).textContent = app.contact_name || '-';
    (document.getElementById('d-contact-email') as HTMLElement).textContent = app.contact_email || '-';
    (document.getElementById('d-contact-phone') as HTMLElement).textContent = app.contact_phone || '-';
    (document.getElementById('d-contact-method') as HTMLElement).textContent = app.contact_method || '-';
    (document.getElementById('d-messenger') as HTMLElement).textContent = app.messenger_url || '-';
    (document.getElementById('d-whatsapp') as HTMLElement).textContent = app.whatsapp_url || '-';
    (document.getElementById('d-line') as HTMLElement).textContent = app.line_url || '-';
    (document.getElementById('d-other-sns') as HTMLElement).textContent = app.other_sns_url || '-';
    (document.getElementById('d-payment-method') as HTMLElement).textContent = app.payment_method || '-';
    (document.getElementById('d-paypal') as HTMLElement).textContent = app.paypal_account || '-';
    (document.getElementById('d-wise') as HTMLElement).textContent = app.wise_account || '-';
    (document.getElementById('d-payoneer') as HTMLElement).textContent = app.payoneer_account || '-';
    (document.getElementById('d-bank') as HTMLElement).textContent = app.bank_account || '-';
    (document.getElementById('d-status') as HTMLSelectElement).value = app.status || 'new';
    (document.getElementById('d-note') as HTMLInputElement).value = app.note || '';
    modal.classList.remove('hidden');
  }

  function closeModal() { modal.classList.add('hidden'); }

  document.getElementById('detail-close')?.addEventListener('click', closeModal);
  document.getElementById('detail-backdrop')?.addEventListener('click', closeModal);

  document.querySelectorAll('.detail-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const app = JSON.parse(btn.getAttribute('data-app') || '{}');
      openModal(app);
    });
  });

  document.getElementById('d-save')?.addEventListener('click', async () => {
    if (!currentId) return;
    const status = (document.getElementById('d-status') as HTMLSelectElement).value;
    const note = (document.getElementById('d-note') as HTMLInputElement).value;
    const btn = document.getElementById('d-save') as HTMLButtonElement;
    btn.textContent = 'Saving...'; btn.disabled = true;
    try {
      const res = await fetch('/api/admin/owner-applications', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: currentId, status, note }),
      });
      if (res.ok) location.reload();
      else { const d = await res.json(); alert(d.error || 'Failed'); }
    } catch { alert('Network error'); }
    btn.textContent = 'Save'; btn.disabled = false;
  });
</script>
