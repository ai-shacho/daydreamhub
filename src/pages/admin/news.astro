---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect("/admin/login");

let news: any[] = [];
let error = "";

if (db) {
  try {
    await db.prepare("SELECT id FROM news LIMIT 1").first();
    const result = await db.prepare("SELECT * FROM news ORDER BY published_at DESC, created_at DESC LIMIT 100").all();
    news = result?.results || [];
  } catch {
    try {
      await db.exec(`CREATE TABLE IF NOT EXISTS news (
        id INTEGER PRIMARY KEY AUTOINCREMENT, title TEXT NOT NULL, title_ja TEXT,
        content TEXT, content_ja TEXT, category TEXT DEFAULT 'update',
        published_at TEXT, created_at TEXT DEFAULT (datetime('now'))
      )`);
    } catch (e: any) { error = e.message; }
  }
}

const categoryColors: Record<string, string> = {
  update: "bg-blue-100 text-blue-700",
  blog: "bg-teal-100 text-teal-700",
  policy: "bg-amber-100 text-amber-700",
  feature: "bg-purple-100 text-purple-700",
  maintenance: "bg-slate-100 text-slate-600",
};
---

<AdminLayout title="News / What's New" activeNav="news">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-slate-900">What's New</h1>
    <button id="add-news-btn" class="px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">
      + Add News
    </button>
  </div>

  {error && <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>}

  <p class="text-sm text-slate-500 mb-4">{news.length} item{news.length !== 1 ? "s" : ""}</p>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-medium text-slate-600">ID</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Title</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Category</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Status</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Published</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {news.length === 0 ? (
            <tr><td colspan="6" class="px-4 py-12 text-center text-slate-400">No news items yet</td></tr>
          ) : news.map((n: any) => (
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-4 py-3 font-mono text-slate-500">#{n.id}</td>
              <td class="px-4 py-3">
                <div class="font-medium text-slate-900">{n.title}</div>
                {n.title_ja && <div class="text-xs text-slate-400">{n.title_ja}</div>}
              </td>
              <td class="px-4 py-3 text-center">
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${categoryColors[n.category] || "bg-slate-100 text-slate-600"}`}>{n.category}</span>
              </td>
              <td class="px-4 py-3 text-center">
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${n.published_at ? "bg-emerald-100 text-emerald-700" : "bg-amber-100 text-amber-700"}`}>
                  {n.published_at ? "Published" : "Draft"}
                </span>
              </td>
              <td class="px-4 py-3 text-slate-500 text-xs">{n.published_at?.slice(0, 16) || "-"}</td>
              <td class="px-4 py-3 text-center">
                <div class="flex items-center justify-center gap-1">
                  <button class="edit-news-btn px-2 py-1 text-xs text-indigo-600 bg-indigo-50 border border-indigo-200 rounded hover:bg-indigo-100 transition-colors"
                    data-id={n.id} data-title={n.title} data-title-ja={n.title_ja || ''} data-content={n.content || ''} data-content-ja={n.content_ja || ''} data-category={n.category} data-published-at={n.published_at || ''}>
                    Edit
                  </button>
                  <button class="delete-news-btn px-2 py-1 text-xs text-red-600 bg-red-50 border border-red-200 rounded hover:bg-red-100 transition-colors" data-id={n.id} data-title={n.title}>
                    Delete
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Add/Edit Modal -->
  <div id="news-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50" id="news-modal-backdrop"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-white rounded-xl shadow-xl w-full max-w-lg max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200">
          <h2 id="news-modal-title" class="text-lg font-semibold text-slate-900">Add News</h2>
          <button id="news-modal-close" class="text-slate-400 hover:text-slate-600">&times;</button>
        </div>
        <form id="news-form" class="p-6 space-y-4">
          <input type="hidden" id="news-id" />
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Title (EN) *</label>
            <input id="news-title" type="text" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 outline-none" />
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Title (JA)</label>
            <input id="news-title-ja" type="text" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 outline-none" />
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Content (EN)</label>
            <textarea id="news-content" rows="3" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 outline-none"></textarea>
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Content (JA)</label>
            <textarea id="news-content-ja" rows="3" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 outline-none"></textarea>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-medium text-slate-700 mb-1">Category</label>
              <select id="news-category" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm bg-white focus:ring-2 focus:ring-teal-500 outline-none">
                <option value="update">Update</option>
                <option value="blog">Blog</option>
                <option value="policy">Policy</option>
                <option value="feature">New Feature</option>
                <option value="maintenance">Maintenance</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-700 mb-1">Published At</label>
              <input id="news-published-at" type="datetime-local" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 outline-none" />
            </div>
          </div>
          <div id="news-error" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded px-3 py-2"></div>
          <div class="flex justify-end gap-3 pt-2 border-t border-slate-200">
            <button type="button" id="news-form-cancel" class="px-4 py-2 text-sm text-slate-600 bg-slate-100 rounded-lg hover:bg-slate-200">Cancel</button>
            <button type="submit" id="news-form-submit" class="px-5 py-2 text-sm font-medium text-white bg-teal-600 rounded-lg hover:bg-teal-700">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  var modal = document.getElementById('news-modal');
  var form = document.getElementById('news-form');
  var editMode = false;

  function openModal(data) {
    editMode = !!data;
    document.getElementById('news-modal-title').textContent = editMode ? 'Edit News' : 'Add News';
    document.getElementById('news-id').value = data ? data.id : '';
    document.getElementById('news-title').value = data ? data.title : '';
    document.getElementById('news-title-ja').value = data ? data.titleJa : '';
    document.getElementById('news-content').value = data ? data.content : '';
    document.getElementById('news-content-ja').value = data ? data.contentJa : '';
    document.getElementById('news-category').value = data ? data.category : 'update';
    document.getElementById('news-published-at').value = data ? (data.publishedAt || '').slice(0, 16) : '';
    document.getElementById('news-error').className = 'hidden';
    modal.classList.remove('hidden');
  }

  function closeModal() { modal.classList.add('hidden'); }

  document.getElementById('add-news-btn').addEventListener('click', function() { openModal(null); });
  document.getElementById('news-modal-close').addEventListener('click', closeModal);
  document.getElementById('news-form-cancel').addEventListener('click', closeModal);
  document.getElementById('news-modal-backdrop').addEventListener('click', closeModal);

  document.querySelectorAll('.edit-news-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      openModal({
        id: btn.dataset.id,
        title: btn.dataset.title,
        titleJa: btn.dataset.titleJa,
        content: btn.dataset.content,
        contentJa: btn.dataset.contentJa,
        category: btn.dataset.category,
        publishedAt: btn.dataset.publishedAt,
      });
    });
  });

  document.querySelectorAll('.delete-news-btn').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      if (!confirm('Delete "' + btn.dataset.title + '"?')) return;
      var res = await fetch('/api/admin/news?id=' + btn.dataset.id, { method: 'DELETE' });
      if (res.ok) location.reload();
      else alert('Failed to delete');
    });
  });

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var errEl = document.getElementById('news-error');
    var submitBtn = document.getElementById('news-form-submit');
    errEl.className = 'hidden';
    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving...';

    var payload = {
      title: document.getElementById('news-title').value,
      title_ja: document.getElementById('news-title-ja').value,
      content: document.getElementById('news-content').value,
      content_ja: document.getElementById('news-content-ja').value,
      category: document.getElementById('news-category').value,
      published_at: document.getElementById('news-published-at').value || '',
    };
    if (editMode) payload.id = Number(document.getElementById('news-id').value);

    try {
      var res = await fetch('/api/admin/news', {
        method: editMode ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (res.ok) location.reload();
      else {
        var data = await res.json();
        errEl.textContent = data.error || 'Failed';
        errEl.className = 'text-sm text-red-600 bg-red-50 border border-red-200 rounded px-3 py-2';
      }
    } catch {
      errEl.textContent = 'Network error';
      errEl.className = 'text-sm text-red-600 bg-red-50 border border-red-200 rounded px-3 py-2';
    }
    submitBtn.disabled = false;
    submitBtn.textContent = 'Save';
  });
</script>
