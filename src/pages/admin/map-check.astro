---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || 'dev-secret';

const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect('/admin/login');

let hotels: any[] = [];
if (db) {
  const result = await db.prepare(`
    SELECT h.id, h.name, h.city, h.country, h.latitude, h.longitude,
           h.email as hotel_email, h.coords_verified_at,
           u.name as owner_name, u.email as owner_email
    FROM hotels h
    LEFT JOIN users u ON u.email = h.email AND u.role IN ('owner', 'inactive')
    WHERE h.is_active = 1 AND h.name NOT LIKE '%Test%' AND h.name NOT LIKE '%test%'
    ORDER BY h.name
  `).all();
  hotels = result?.results || [];
}
---

<AdminLayout title="Map Check" activeNav="map-check">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-xl font-bold text-slate-800">Map Coordinate Check</h1>
      <p class="text-sm text-slate-500 mt-1">{hotels.length} hotels · Checks if DB coordinates match hotel name via Google</p>
    </div>
    <div class="flex items-center gap-2">
      <button id="run-btn" class="px-5 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">
        ▶ Run Check
      </button>
      <button id="export-btn" class="hidden px-5 py-2 bg-slate-600 text-white text-sm font-medium rounded-lg hover:bg-slate-700 transition-colors">
        ⬇ Export CSV
      </button>
      <button id="autofix-btn" class="hidden px-5 py-2 bg-amber-500 text-white text-sm font-medium rounded-lg hover:bg-amber-600 transition-colors">
        🔧 Auto-fix Hotel Entries
      </button>
    </div>
  </div>

  <div id="progress-bar-wrap" class="hidden mb-4">
    <div class="flex items-center justify-between text-xs text-slate-500 mb-1">
      <span id="progress-label">Checking...</span>
      <span id="progress-count">0 / {hotels.length}</span>
    </div>
    <div class="w-full bg-slate-200 rounded-full h-2">
      <div id="progress-bar" class="bg-teal-500 h-2 rounded-full transition-all duration-300" style="width:0%"></div>
    </div>
  </div>

  <div id="summary" class="hidden mb-4 grid grid-cols-6 gap-3 text-center">
    <div class="bg-red-50 border border-red-200 rounded-lg p-3">
      <div id="count-mismatch" class="text-2xl font-bold text-red-600">0</div>
      <div class="text-xs text-red-500 mt-1">Mismatch (&gt;500m off)</div>
    </div>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-3">
      <div id="count-issue" class="text-2xl font-bold text-amber-600">0</div>
      <div class="text-xs text-amber-500 mt-1">No coords / Not found</div>
    </div>
    <div class="bg-purple-50 border border-purple-200 rounded-lg p-3">
      <div id="count-location-mismatch" class="text-2xl font-bold text-purple-600">0</div>
      <div class="text-xs text-purple-500 mt-1">City/Country mismatch</div>
    </div>
    <div class="bg-slate-50 border border-slate-200 rounded-lg p-3">
      <div id="count-manual" class="text-2xl font-bold text-slate-500">0</div>
      <div class="text-xs text-slate-500 mt-1">Manual review (room type)</div>
    </div>
    <div class="bg-teal-50 border border-teal-200 rounded-lg p-3">
      <div id="count-verified" class="text-2xl font-bold text-teal-600">0</div>
      <div class="text-xs text-teal-500 mt-1">Verified (manually confirmed)</div>
    </div>
    <div class="bg-green-50 border border-green-200 rounded-lg p-3">
      <div id="count-ok" class="text-2xl font-bold text-green-600">0</div>
      <div class="text-xs text-green-500 mt-1">OK</div>
    </div>
  </div>

  <div id="results" class="space-y-2"></div>
</AdminLayout>

<script define:vars={{ hotels }}>
  const STORAGE_KEY = 'mapCheckResults_v1';
  let running = false;
  let problems = [];
  let counts = { mismatch: 0, issue: 0, locMismatch: 0, manual: 0, verified: 0, ok: 0 };

  function saveResults() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({
        timestamp: Date.now(),
        problems,
        counts,
      }));
    } catch {}
  }

  function loadResults() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      return JSON.parse(raw);
    } catch { return null; }
  }

  function renderFromCache(cache) {
    problems = cache.problems || [];
    counts = cache.counts || { mismatch: 0, issue: 0, locMismatch: 0, manual: 0, verified: 0, ok: 0 };
    if (typeof counts.verified !== 'number') counts.verified = 0;

    document.getElementById('summary').classList.remove('hidden');
    document.getElementById('count-mismatch').textContent = counts.mismatch;
    document.getElementById('count-issue').textContent = counts.issue;
    document.getElementById('count-location-mismatch').textContent = counts.locMismatch;
    document.getElementById('count-manual').textContent = counts.manual;
    document.getElementById('count-verified').textContent = counts.verified;
    document.getElementById('count-ok').textContent = counts.ok;

    const resultsEl = document.getElementById('results');
    resultsEl.innerHTML = '';
    for (const p of problems) renderRow(p);

    const fixable = problems.filter(p => p.is_property && (p.status === 'mismatch' || p.status === 'no_coords'));
    if (fixable.length > 0) {
      const btn = document.getElementById('autofix-btn');
      btn.textContent = `🔧 Auto-fix ${fixable.length} Hotel Entr${fixable.length === 1 ? 'y' : 'ies'}`;
      btn.classList.remove('hidden');
    }

    if (problems.length > 0) document.getElementById('export-btn').classList.remove('hidden');

    const ts = new Date(cache.timestamp).toLocaleString();
    const banner = document.createElement('div');
    banner.className = 'mb-3 text-xs text-slate-500 text-right';
    banner.innerHTML = `Showing cached results from ${ts} · <button id="clear-cache" class="text-teal-600 hover:underline">Clear cache</button>`;
    resultsEl.parentNode.insertBefore(banner, resultsEl);
    document.getElementById('clear-cache').addEventListener('click', () => {
      localStorage.removeItem(STORAGE_KEY);
      location.reload();
    });
  }

  // Show cached results on page load
  const cached = loadResults();
  if (cached) renderFromCache(cached);

  document.getElementById('run-btn').addEventListener('click', async () => {
    if (running) return;
    running = true;
    document.getElementById('run-btn').disabled = true;
    document.getElementById('run-btn').textContent = '⏳ Running...';
    document.getElementById('autofix-btn').classList.add('hidden');
    document.getElementById('progress-bar-wrap').classList.remove('hidden');
    document.getElementById('summary').classList.remove('hidden');
    document.getElementById('results').innerHTML = '';

    let countMismatch = 0, countIssue = 0, countOk = 0, countManual = 0, countLocationMismatch = 0, countVerified = 0;
    problems = [];
    // Remove any cached-results banner from a previous run
    document.querySelectorAll('#clear-cache').forEach((b) => b.parentElement?.remove());

    for (let i = 0; i < hotels.length; i++) {
      const hotel = hotels[i];
      document.getElementById('progress-label').textContent = `Checking: ${hotel.name}`;
      document.getElementById('progress-count').textContent = `${i + 1} / ${hotels.length}`;
      document.getElementById('progress-bar').style.width = `${Math.round((i + 1) / hotels.length * 100)}%`;

      try {
        const res = await fetch(`/api/admin/map-check?id=${hotel.id}`);
        const data = await res.json();

        // If admin has manually verified this hotel's coordinates, treat coordinate-related
        // mismatches as resolved (e.g. Google returns a chain HQ address but DB is correct).
        // "no_coords" still counts as a problem because missing data is always wrong.
        const isVerified = !!data.coords_verified_at;
        const skipDueToVerified = isVerified && (data.status === 'mismatch' || data.status === 'location_mismatch');

        if (data.status === 'ok') {
          countOk++;
        } else if (skipDueToVerified) {
          countVerified++;
        } else if (data.status === 'location_mismatch') {
          countLocationMismatch++;
          problems.push(data);
          renderRow(data);
        } else {
          if (!data.is_property) countManual++;
          else if (data.status === 'mismatch') countMismatch++;
          else countIssue++;
          problems.push(data);
          renderRow(data);
        }
      } catch {
        countIssue++;
        problems.push({ id: hotel.id, name: hotel.name, status: 'error', is_property: false });
        renderRow({ id: hotel.id, name: hotel.name, status: 'error', is_property: false });
      }

      document.getElementById('count-mismatch').textContent = countMismatch;
      document.getElementById('count-issue').textContent = countIssue;
      document.getElementById('count-location-mismatch').textContent = countLocationMismatch;
      document.getElementById('count-manual').textContent = countManual;
      document.getElementById('count-verified').textContent = countVerified;
      document.getElementById('count-ok').textContent = countOk;

      // Incrementally save so progress is kept even if page is navigated away
      counts = { mismatch: countMismatch, issue: countIssue, locMismatch: countLocationMismatch, manual: countManual, verified: countVerified, ok: countOk };
      saveResults();

      // Small delay to avoid rate limiting
      await new Promise(r => setTimeout(r, 200));
    }

    document.getElementById('progress-label').textContent = 'Done';
    document.getElementById('run-btn').textContent = '▶ Run Again';
    document.getElementById('run-btn').disabled = false;
    running = false;

    counts = { mismatch: countMismatch, issue: countIssue, locMismatch: countLocationMismatch, manual: countManual, verified: countVerified, ok: countOk };
    saveResults();

    if (problems.length > 0) document.getElementById('export-btn').classList.remove('hidden');

    // Show auto-fix button if there are fixable property entries
    const fixable = problems.filter(p => p.is_property && (p.status === 'mismatch' || p.status === 'no_coords'));
    if (fixable.length > 0) {
      const btn = document.getElementById('autofix-btn');
      btn.textContent = `🔧 Auto-fix ${fixable.length} Hotel Entr${fixable.length === 1 ? 'y' : 'ies'}`;
      btn.classList.remove('hidden');
    }

    if (problems.length === 0) {
      document.getElementById('results').innerHTML = '<div class="bg-green-50 border border-green-200 rounded-lg p-6 text-center text-green-700 font-medium">✅ All coordinates look correct!</div>';
    }
  });

  document.getElementById('autofix-btn').addEventListener('click', async () => {
    const fixable = problems.filter(p => p.is_property && (p.status === 'mismatch' || p.status === 'no_coords'));
    if (!fixable.length) return;
    if (!confirm(`Update ${fixable.length} hotels' coordinates and addresses with Google Maps data?`)) return;

    const btn = document.getElementById('autofix-btn');
    btn.disabled = true;
    btn.textContent = `⏳ Updating 0 / ${fixable.length}...`;

    let done = 0, failed = 0;
    for (const p of fixable) {
      try {
        const res = await fetch('/api/admin/map-check', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: p.id,
            latitude: p.google_lat,
            longitude: p.google_lng,
            address: p.google_address,
          }),
        });
        if (res.ok) done++;
        else failed++;
      } catch {
        failed++;
      }
      btn.textContent = `⏳ Updating ${done + failed} / ${fixable.length}...`;
    }

    btn.textContent = `✅ Updated ${done}${failed ? ` (${failed} failed)` : ''}`;
    localStorage.removeItem(STORAGE_KEY);
    setTimeout(() => location.reload(), 2000);
  });

  function csvEscape(v) {
    if (v == null) return '';
    return `"${String(v).replace(/"/g, '""')}"`;
  }

  function statusNote(r) {
    if (r.status === 'mismatch') return `${(r.distance_m ?? 0).toLocaleString()}m off from Google`;
    if (r.status === 'no_coords') return 'No coordinates in DB';
    if (r.status === 'not_found') return 'Not found on Google Maps';
    if (r.status === 'location_mismatch') return r.mismatch_field === 'city'
      ? `City mismatch: DB="${r.db_city}" Google="${r.google_city}"`
      : `Country mismatch: DB="${r.db_country}" Google="${r.google_country}"`;
    if (!r.is_property) return 'Room type name — manual review needed';
    return '';
  }

  document.getElementById('export-btn').addEventListener('click', () => {
    const rows = [
      ['ID', 'Hotel Name', 'Owner Name', 'Owner Email', 'Status', 'DB Lat', 'DB Lng', 'Google Lat', 'Google Lng', 'Google Address', 'Distance (m)', 'Google Maps Link', 'Google Maps Detail Page', 'Note'],
      ...problems.map(r => [
        r.id,
        csvEscape(r.name),
        csvEscape(r.owner_name ?? ''),
        csvEscape(r.owner_email ?? ''),
        r.status,
        r.db_lat ?? '',
        r.db_lng ?? '',
        r.google_lat ?? '',
        r.google_lng ?? '',
        csvEscape(r.google_address ?? ''),
        r.distance_m ?? '',
        r.google_lat && r.google_lng ? `"https://www.google.com/maps?q=${r.google_lat},${r.google_lng}"` : '',
        r.google_place_url ? `"${r.google_place_url}"` : '',
        csvEscape(statusNote(r)),
      ]),
    ];
    const csv = '﻿' + rows.map(row => row.join(',')).join('\r\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `map-check-${new Date().toISOString().slice(0, 10)}.csv`;
    a.click();
  });

  function renderRow(data) {
    const el = document.createElement('div');
    const isManual = !data.is_property;
    const colorMap = {
      mismatch: 'border-red-200 bg-red-50',
      no_coords: 'border-amber-200 bg-amber-50',
      not_found: 'border-amber-200 bg-amber-50',
      country_mismatch: 'border-purple-200 bg-purple-50',
      error: 'border-slate-200 bg-slate-50',
    };
    const colors = isManual ? 'border-slate-200 bg-slate-50' : (colorMap[data.status] || 'border-slate-200 bg-slate-50');

    const manualBadge = '<span class="px-2 py-0.5 rounded-full text-xs font-medium bg-slate-200 text-slate-700">Manual review</span>';
    const statusBadges = {
      mismatch: '<span class="px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">Mismatch</span>',
      no_coords: '<span class="px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">No coords</span>',
      not_found: '<span class="px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">Not found</span>',
      location_mismatch: '<span class="px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-700">Location mismatch</span>',
      error: '<span class="px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600">Error</span>',
    };
    const badgeHtml = isManual ? manualBadge : (statusBadges[data.status] || '');

    let detail = '';
    if (data.status === 'mismatch') {
      detail = `
        <div class="mt-2 text-xs text-slate-600 space-y-0.5">
          <div>DB: ${data.db_lat?.toFixed(6)}, ${data.db_lng?.toFixed(6)}</div>
          <div>Google: ${data.google_lat?.toFixed(6)}, ${data.google_lng?.toFixed(6)} — ${data.google_address || ''}</div>
          <div class="text-red-600 font-medium">Distance: ${data.distance_m?.toLocaleString()} m off</div>
        </div>`;
    } else if (data.status === 'no_coords') {
      detail = `<div class="mt-2 text-xs text-slate-600">Google suggests: ${data.google_lat?.toFixed(6)}, ${data.google_lng?.toFixed(6)} — ${data.google_address || ''}</div>`;
    } else if (data.status === 'not_found') {
      detail = `<div class="mt-2 text-xs text-slate-500">Could not find this hotel on Google Maps by name.</div>`;
    } else if (data.status === 'location_mismatch') {
      const field = data.mismatch_field === 'city'
        ? `city: Google returned "${data.google_city}", DB has "${data.db_city || '(none)'}"`
        : `country: Google returned "${data.google_country}", DB has "${data.db_country || '(none)'}"`;
      detail = `<div class="mt-2 text-xs text-purple-700">Skipped — ${field}. Check manually.</div>`;
    }

    const ownerHtml = data.owner_name
      ? `<span class="text-xs text-slate-500">Owner: ${data.owner_name} (${data.owner_email})</span>`
      : `<span class="text-xs text-slate-400">No owner assigned</span>`;

    // Show "Mark as verified" only for coordinate-related issues (mismatch / location_mismatch).
    // Useful when Google returns wrong location (e.g. chain head office) but DB is correct.
    const canVerify = data.status === 'mismatch' || data.status === 'location_mismatch';
    const verifyBtn = canVerify
      ? `<button class="verify-btn text-xs px-2 py-1 rounded bg-teal-600 text-white hover:bg-teal-700 shrink-0" data-id="${data.id}">✅ Mark as verified</button>`
      : '';

    el.innerHTML = `
      <div class="border rounded-lg p-4 ${colors}">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2 flex-wrap">
            ${badgeHtml}
            <a href="/admin/hotels/${data.id}/edit" target="_blank" rel="noopener" class="font-medium text-slate-800 hover:underline">${data.name}</a>
            ${ownerHtml}
          </div>
          <div class="flex items-center gap-2 shrink-0">
            ${verifyBtn}
            <a href="/admin/hotels/${data.id}/edit" target="_blank" rel="noopener" class="text-xs text-teal-600 hover:underline">Edit →</a>
          </div>
        </div>
        ${detail}
      </div>`;

    const verifyButton = el.querySelector('.verify-btn');
    if (verifyButton) {
      verifyButton.addEventListener('click', async (e) => {
        const btn = e.currentTarget;
        const id = Number(btn.getAttribute('data-id'));
        if (!confirm('Mark this hotel as verified? It will be excluded from future Map Check results until the coordinates are changed.')) return;
        btn.disabled = true;
        btn.textContent = '⏳ Saving...';
        try {
          const res = await fetch('/api/admin/map-check', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, verified: true }),
          });
          if (!res.ok) throw new Error('Request failed');
          // Remove from current problems list + recount verified, then re-render summary.
          problems = problems.filter(p => p.id !== id);
          counts.verified = (counts.verified || 0) + 1;
          if (data.status === 'mismatch') counts.mismatch = Math.max(0, counts.mismatch - 1);
          else if (data.status === 'location_mismatch') counts.locMismatch = Math.max(0, counts.locMismatch - 1);
          document.getElementById('count-mismatch').textContent = counts.mismatch;
          document.getElementById('count-location-mismatch').textContent = counts.locMismatch;
          document.getElementById('count-verified').textContent = counts.verified;
          saveResults();
          el.remove();
        } catch {
          btn.disabled = false;
          btn.textContent = '✅ Mark as verified';
          alert('Failed to mark as verified. Please try again.');
        }
      });
    }

    document.getElementById('results').appendChild(el);
  }
</script>
