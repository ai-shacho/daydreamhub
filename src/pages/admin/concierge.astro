---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect("/admin/login");

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get("status") || "";
const search = url.searchParams.get("search") || "";
const dateFrom = url.searchParams.get("from") || "";
const dateTo = url.searchParams.get("to") || "";
const [fromY, fromM, fromD] = dateFrom ? dateFrom.split('-') : ['', '', ''];
const [toY, toM, toD] = dateTo ? dateTo.split('-') : ['', '', ''];
const months = [
  { val: '01', label: 'Jan' }, { val: '02', label: 'Feb' }, { val: '03', label: 'Mar' },
  { val: '04', label: 'Apr' }, { val: '05', label: 'May' }, { val: '06', label: 'Jun' },
  { val: '07', label: 'Jul' }, { val: '08', label: 'Aug' }, { val: '09', label: 'Sep' },
  { val: '10', label: 'Oct' }, { val: '11', label: 'Nov' }, { val: '12', label: 'Dec' },
];
const curYear = new Date().getFullYear();
const years = [curYear - 1, curYear, curYear + 1];
const days = Array.from({ length: 31 }, (_, i) => String(i + 1).padStart(2, '0'));

let groups: any[] = [];
let stats = { total: 0, calling: 0, success: 0, allFailed: 0, refunded: 0, revenue: 0 };
let error = "";

if (db) {
  try {
    const [totalRes, callingRes, successRes, failedRes, refundedRes, revenueRes] = await Promise.all([
      db.prepare("SELECT COUNT(*) as c FROM concierge_call_groups").first(),
      db.prepare("SELECT COUNT(*) as c FROM concierge_call_groups WHERE status = 'calling'").first(),
      db.prepare("SELECT COUNT(*) as c FROM concierge_call_groups WHERE status = 'success'").first(),
      db.prepare("SELECT COUNT(*) as c FROM concierge_call_groups WHERE status = 'all_failed'").first(),
      db.prepare("SELECT COUNT(*) as c FROM concierge_call_groups WHERE refund_status = 'refunded'").first(),
      db.prepare("SELECT COUNT(*) as c FROM concierge_call_groups WHERE payment_status = 'paid'").first(),
    ]);
    stats.total = totalRes?.c ?? 0;
    stats.calling = callingRes?.c ?? 0;
    stats.success = successRes?.c ?? 0;
    stats.allFailed = failedRes?.c ?? 0;
    stats.refunded = refundedRes?.c ?? 0;
    stats.revenue = (revenueRes?.c ?? 0) * 7;

    let query = `SELECT g.*,
    (SELECT COUNT(*) FROM concierge_calls WHERE call_group_id = g.id) as call_count,
    (SELECT GROUP_CONCAT(hotel_name, ' / ') FROM concierge_calls WHERE call_group_id = g.id ORDER BY call_order) as hotel_names
    FROM concierge_call_groups g WHERE 1=1`;
    const binds: any[] = [];

    if (statusFilter) {
      query += " AND g.status = ?";
      binds.push(statusFilter);
    }
    if (search) {
      query += " AND (g.guest_name LIKE ? OR g.guest_email LIKE ? OR g.session_id LIKE ?)";
      binds.push(`%${search}%`, `%${search}%`, `%${search}%`);
    }
    if (dateFrom) {
      query += " AND g.created_at >= ?";
      binds.push(dateFrom);
    }
    if (dateTo) {
      query += " AND g.created_at <= ? || ' 23:59:59'";
      binds.push(dateTo);
    }

    query += " ORDER BY g.created_at DESC LIMIT 100";
    const result = await db.prepare(query).bind(...binds).all();
    groups = result?.results || [];
  } catch (e: any) {
    error = e.message || "Failed to load concierge data";
  }
}

const statusOptions = ["", "pending", "calling", "success", "all_failed"];
const statusLabels: Record<string, string> = {
  "": "All Statuses",
  pending: "Pending Payment",
  calling: "Calling",
  success: "Success",
  all_failed: "All Failed",
};
const statusColors: Record<string, string> = {
  pending: "bg-slate-100 text-slate-600",
  calling: "bg-blue-100 text-blue-700",
  success: "bg-emerald-100 text-emerald-700",
  all_failed: "bg-red-100 text-red-700",
};
const paymentColors: Record<string, string> = {
  required: "bg-amber-100 text-amber-700",
  paid: "bg-green-100 text-green-700",
};
const refundColors: Record<string, string> = {
  refunded: "bg-purple-100 text-purple-700",
  refund_failed: "bg-red-100 text-red-700",
};
---

<AdminLayout title="Concierge" activeNav="concierge">
  <!-- Stats Cards -->
  <div class="grid grid-cols-2 lg:grid-cols-6 gap-3 mb-6">
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <p class="text-xs font-medium text-slate-500 uppercase">Total</p>
      <p class="text-2xl font-bold text-slate-900 mt-1">{stats.total}</p>
    </div>
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <p class="text-xs font-medium text-blue-500 uppercase">Calling</p>
      <p class="text-2xl font-bold text-blue-700 mt-1">{stats.calling}</p>
    </div>
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <p class="text-xs font-medium text-emerald-500 uppercase">Success</p>
      <p class="text-2xl font-bold text-emerald-700 mt-1">{stats.success}</p>
    </div>
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <p class="text-xs font-medium text-red-500 uppercase">Failed</p>
      <p class="text-2xl font-bold text-red-700 mt-1">{stats.allFailed}</p>
    </div>
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <p class="text-xs font-medium text-purple-500 uppercase">Refunded</p>
      <p class="text-2xl font-bold text-purple-700 mt-1">{stats.refunded}</p>
    </div>
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <p class="text-xs font-medium text-amber-500 uppercase">Revenue</p>
      <p class="text-2xl font-bold text-amber-700 mt-1">${stats.revenue}</p>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <form method="GET" action="/admin/concierge" class="flex flex-wrap items-end gap-4">
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Search</label>
        <input type="text" name="search" value={search} placeholder="Guest name, email, or session ID..." class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent" />
      </div>
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Status</label>
        <select name="status" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white">
          {statusOptions.map((s) => (
            <option value={s} selected={s === statusFilter}>{statusLabels[s]}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-500 mb-1">From</label>
        <div class="flex gap-1">
          <select id="ac-from-y" class="px-2 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white">
            <option value="">YYYY</option>
            {years.map(y => <option value={y} selected={fromY === String(y)}>{y}</option>)}
          </select>
          <select id="ac-from-m" class="px-2 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white">
            <option value="">MM</option>
            {months.map(m => <option value={m.val} selected={fromM === m.val}>{m.label}</option>)}
          </select>
          <select id="ac-from-d" class="px-2 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white">
            <option value="">DD</option>
            {days.map(d => <option value={d} selected={fromD === d}>{d}</option>)}
          </select>
        </div>
        <input type="hidden" id="ac-from-hidden" name="from" value={dateFrom} />
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-500 mb-1">To</label>
        <div class="flex gap-1">
          <select id="ac-to-y" class="px-2 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white">
            <option value="">YYYY</option>
            {years.map(y => <option value={y} selected={toY === String(y)}>{y}</option>)}
          </select>
          <select id="ac-to-m" class="px-2 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white">
            <option value="">MM</option>
            {months.map(m => <option value={m.val} selected={toM === m.val}>{m.label}</option>)}
          </select>
          <select id="ac-to-d" class="px-2 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white">
            <option value="">DD</option>
            {days.map(d => <option value={d} selected={toD === d}>{d}</option>)}
          </select>
        </div>
        <input type="hidden" id="ac-to-hidden" name="to" value={dateTo} />
      </div>
      <button type="submit" class="px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">
        Filter
      </button>
      <a href="/admin/concierge" class="px-4 py-2 text-slate-600 text-sm font-medium border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">
        Reset
      </a>
    </form>
  </div>

  <!-- Error -->
  {error && (
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-sm text-red-700">{error}</div>
  )}

  <!-- Call Groups Table -->
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-200">
      <h3 class="text-base font-semibold text-slate-900">Call Groups ({groups.length})</h3>
    </div>

    {groups.length > 0 ? (
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-slate-50 text-left">
              <th class="px-4 py-3 font-medium text-slate-500 text-xs uppercase tracking-wide">ID</th>
              <th class="px-4 py-3 font-medium text-slate-500 text-xs uppercase tracking-wide">Guest</th>
              <th class="px-4 py-3 font-medium text-slate-500 text-xs uppercase tracking-wide">Hotels</th>
              <th class="px-4 py-3 font-medium text-slate-500 text-xs uppercase tracking-wide">Progress</th>
              <th class="px-4 py-3 font-medium text-slate-500 text-xs uppercase tracking-wide">Status</th>
              <th class="px-4 py-3 font-medium text-slate-500 text-xs uppercase tracking-wide">Payment</th>
              <th class="px-4 py-3 font-medium text-slate-500 text-xs uppercase tracking-wide">Refund</th>
              <th class="px-4 py-3 font-medium text-slate-500 text-xs uppercase tracking-wide">Date</th>
              <th class="px-4 py-3 font-medium text-slate-500 text-xs uppercase tracking-wide">Detail</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {groups.map((g: any) => (
              <>
                <tr class="hover:bg-slate-50 transition-colors group-row" data-group-id={g.id}>
                  <td class="px-4 py-3 text-slate-600 font-mono text-xs">#{g.id}</td>
                  <td class="px-4 py-3">
                    <div class="text-slate-900 font-medium text-xs">{g.guest_name || "-"}</div>
                    <div class="text-slate-400 text-xs truncate max-w-[180px]">{g.guest_email || "-"}</div>
                  </td>
                  <td class="px-4 py-3">
                    <div class="text-slate-700 text-xs max-w-[250px] truncate" title={g.hotel_names || ""}>
                      {g.hotel_names || "-"}
                    </div>
                  </td>
                  <td class="px-4 py-3 text-slate-600 text-xs font-mono">
                    {g.current_order}/{g.total_calls}
                  </td>
                  <td class="px-4 py-3">
                    <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusColors[g.status] || "bg-slate-100 text-slate-700"}`}>
                      {g.status === "all_failed" ? "Failed" : g.status}
                    </span>
                  </td>
                  <td class="px-4 py-3">
                    <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${paymentColors[g.payment_status] || "bg-slate-100 text-slate-600"}`}>
                      {g.payment_status === "paid" ? "$7 Paid" : g.payment_status}
                    </span>
                  </td>
                  <td class="px-4 py-3">
                    {g.refund_status ? (
                      <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${refundColors[g.refund_status] || "bg-slate-100 text-slate-600"}`}>
                        {g.refund_status}
                      </span>
                    ) : (
                      <span class="text-slate-300 text-xs">-</span>
                    )}
                  </td>
                  <td class="px-4 py-3 text-slate-500 text-xs whitespace-nowrap">
                    {g.created_at
                      ? new Date(g.created_at + "Z").toLocaleString("ja-JP", {
                          timeZone: "Asia/Tokyo",
                          month: "2-digit",
                          day: "2-digit",
                          hour: "2-digit",
                          minute: "2-digit",
                        })
                      : "-"}
                  </td>
                  <td class="px-4 py-3">
                    <button class="detail-toggle text-teal-600 hover:text-teal-800 text-xs font-medium" data-group-id={g.id}>
                      Show
                    </button>
                  </td>
                </tr>
                <tr class="detail-row hidden" id={`detail-${g.id}`}>
                  <td colspan="9" class="px-4 py-0">
                    <div class="py-3 bg-slate-50 rounded-lg my-2 px-4">
                      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-3 text-xs">
                        <div>
                          <span class="text-slate-500">Session:</span>
                          <span class="text-slate-700 font-mono ml-1">{g.session_id?.slice(0, 20)}...</span>
                        </div>
                        <div>
                          <span class="text-slate-500">PayPal Order:</span>
                          <span class="text-slate-700 font-mono ml-1">{g.paypal_order_id || "-"}</span>
                        </div>
                        <div>
                          <span class="text-slate-500">Capture ID:</span>
                          <span class="text-slate-700 font-mono ml-1">{g.paypal_capture_id || "-"}</span>
                        </div>
                        <div>
                          <span class="text-slate-500">Refund ID:</span>
                          <span class="text-slate-700 font-mono ml-1">{g.refund_id || "-"}</span>
                        </div>
                      </div>

                      {g.request_details && (() => {
                        try {
                          const d = JSON.parse(g.request_details);
                          return (
                            <div class="text-xs text-slate-600 mb-3">
                              <span class="text-slate-500">Request:</span> {d.date} {d.check_in}-{d.check_out} | {d.guests} guest(s) | {d.language}
                            </div>
                          );
                        } catch {
                          return null;
                        }
                      })()}

                      <div class="text-xs text-slate-500 font-medium mb-2">Individual Calls:</div>
                      <div class="calls-container" data-group-id={g.id}>
                        <span class="text-xs text-slate-400">Loading...</span>
                      </div>

                      <div class="mt-4">
                        <button class="chat-log-toggle text-xs font-medium text-teal-600 hover:text-teal-800" data-session-id={g.session_id}>
                          Show Chat Log
                        </button>
                        <div class="chat-log-container hidden mt-2" data-session-id={g.session_id}>
                          <span class="text-xs text-slate-400">Loading...</span>
                        </div>
                      </div>
                    </div>
                  </td>
                </tr>
              </>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="px-5 py-12 text-center">
        <svg class="w-12 h-12 text-slate-300 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 0 1-.825-.242m9.345-8.334a2.126 2.126 0 0 0-.476-.095 48.64 48.64 0 0 0-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0 0 11.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
        </svg>
        <p class="text-sm text-slate-500">No concierge call groups yet.</p>
      </div>
    )}
  </div>

  <!-- AI Call Script Section -->
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden mt-6">
    <div class="px-5 py-4 border-b border-slate-200 flex items-center justify-between">
      <h3 class="text-base font-semibold text-slate-900">AI Call Script (Telnyx)</h3>
      <div class="flex gap-2">
        <button id="btn-check-assistant" class="px-3 py-1.5 text-xs font-medium border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">
          Check Current
        </button>
        <button id="btn-update-default" class="px-3 py-1.5 text-xs font-medium bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition-colors">
          Push Script to Telnyx
        </button>
      </div>
    </div>
    <div id="script-status" class="px-5 py-3 hidden">
      <div id="script-status-msg" class="text-sm"></div>
    </div>
    <div class="p-4">
      <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-2">Call Script (English / Multilingual)</h4>
      <pre id="script-default" class="text-xs text-slate-700 bg-slate-50 rounded-lg p-3 max-h-[400px] overflow-y-auto whitespace-pre-wrap font-mono leading-relaxed">Loading...</pre>
    </div>
    <div id="current-assistant" class="hidden px-5 py-3 border-t border-slate-200">
      <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-2">Current Telnyx Assistant</h4>
      <pre id="current-assistant-data" class="text-xs text-slate-600 bg-slate-50 rounded-lg p-3 max-h-[200px] overflow-y-auto whitespace-pre-wrap font-mono"></pre>
    </div>
  </div>
</AdminLayout>

<script>
  // Date selects → hidden input
  function syncConcDate(prefix) {
    var y = document.getElementById('ac-' + prefix + '-y').value;
    var m = document.getElementById('ac-' + prefix + '-m').value;
    var d = document.getElementById('ac-' + prefix + '-d').value;
    document.getElementById('ac-' + prefix + '-hidden').value = (y && m && d) ? y + '-' + m + '-' + d : '';
  }
  ['from', 'to'].forEach(function(p) {
    ['y', 'm', 'd'].forEach(function(part) {
      document.getElementById('ac-' + p + '-' + part)?.addEventListener('change', function() { syncConcDate(p); });
    });
  });

  // Detail toggle for call groups
  document.querySelectorAll('.detail-toggle').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const groupId = btn.getAttribute('data-group-id');
      if (!groupId) return;
      const detailRow = document.getElementById(`detail-${groupId}`);
      if (!detailRow) return;

      const isHidden = detailRow.classList.contains('hidden');
      detailRow.classList.toggle('hidden');

      if (isHidden) {
        // Load calls for this group
        const callsContainer = detailRow.querySelector(`.calls-container[data-group-id="${groupId}"]`);
        if (callsContainer && callsContainer.innerHTML.includes('Loading')) {
          try {
            const res = await fetch(`/api/admin/concierge?group_id=${groupId}`);
            if (res.ok) {
              const data = await res.json();
              const calls = data.calls || [];
              if (calls.length === 0) {
                callsContainer.innerHTML = '<span class="text-xs text-slate-400">No calls found</span>';
              } else {
                let html = '<div class="space-y-2">';
                calls.forEach((c: any) => {
                  const statusColor = c.status === 'success' ? 'bg-emerald-100 text-emerald-700' :
                                      c.status === 'failed' ? 'bg-red-100 text-red-700' :
                                      c.status === 'calling' ? 'bg-blue-100 text-blue-700' :
                                      'bg-slate-100 text-slate-600';
                  html += `<div class="flex items-center gap-3 text-xs bg-white rounded border border-slate-200 px-3 py-2">
                    <span class="font-mono text-slate-400">#${c.call_order}</span>
                    <span class="text-slate-700 font-medium">${c.hotel_name || '-'}</span>
                    <span class="text-slate-500">${c.hotel_phone || '-'}</span>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusColor}">${c.status}</span>
                    <span class="text-slate-400">${c.telnyx_call_id ? 'Call: ' + c.telnyx_call_id.slice(0, 12) + '...' : ''}</span>
                  </div>`;
                });
                html += '</div>';
                callsContainer.innerHTML = html;
              }
            } else {
              callsContainer.innerHTML = '<span class="text-xs text-red-400">Failed to load calls</span>';
            }
          } catch {
            callsContainer.innerHTML = '<span class="text-xs text-red-400">Network error</span>';
          }
        }
      }
    });
  });

  // Chat log toggle
  document.querySelectorAll('.chat-log-toggle').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const sessionId = btn.getAttribute('data-session-id');
      if (!sessionId) return;
      const container = document.querySelector(`.chat-log-container[data-session-id="${sessionId}"]`) as HTMLElement;
      if (!container) return;

      const isHidden = container.classList.contains('hidden');
      container.classList.toggle('hidden');

      if (isHidden && container.innerHTML.includes('Loading')) {
        try {
          const res = await fetch(`/api/admin/concierge?session_id=${sessionId}&type=messages`);
          if (res.ok) {
            const data = await res.json();
            const messages = data.messages || [];
            if (messages.length === 0) {
              container.innerHTML = '<span class="text-xs text-slate-400">No chat messages</span>';
            } else {
              let html = '<div class="space-y-1 max-h-[300px] overflow-y-auto bg-white rounded border border-slate-200 p-3">';
              messages.forEach((m: any) => {
                const isUser = m.role === 'user';
                html += `<div class="text-xs ${isUser ? 'text-blue-700' : 'text-slate-600'}">
                  <span class="font-medium">${m.role}:</span> ${m.content}
                </div>`;
              });
              html += '</div>';
              container.innerHTML = html;
            }
          } else {
            container.innerHTML = '<span class="text-xs text-red-400">Failed to load chat log</span>';
          }
        } catch {
          container.innerHTML = '<span class="text-xs text-red-400">Network error</span>';
        }
      }
    });
  });

  // Load call script
  async function loadScript() {
    const scriptEl = document.getElementById('script-default');
    if (!scriptEl) return;
    try {
      const res = await fetch('/api/admin/concierge?type=script');
      if (res.ok) {
        const data = await res.json();
        scriptEl.textContent = data.script || 'No script found';
      } else {
        scriptEl.textContent = 'Failed to load script';
      }
    } catch {
      scriptEl.textContent = 'Network error loading script';
    }
  }
  loadScript();

  // Check current Telnyx assistant
  document.getElementById('btn-check-assistant')?.addEventListener('click', async () => {
    const statusEl = document.getElementById('script-status');
    const msgEl = document.getElementById('script-status-msg');
    const dataEl = document.getElementById('current-assistant-data');
    const containerEl = document.getElementById('current-assistant');

    if (statusEl) statusEl.classList.remove('hidden');
    if (msgEl) msgEl.textContent = 'Checking...';

    try {
      const res = await fetch('/api/admin/concierge?type=assistant');
      if (res.ok) {
        const data = await res.json();
        if (msgEl) msgEl.innerHTML = '<span class="text-emerald-600">Assistant loaded successfully</span>';
        if (dataEl) dataEl.textContent = JSON.stringify(data, null, 2);
        if (containerEl) containerEl.classList.remove('hidden');
      } else {
        if (msgEl) msgEl.innerHTML = '<span class="text-red-600">Failed to load assistant</span>';
      }
    } catch {
      if (msgEl) msgEl.innerHTML = '<span class="text-red-600">Network error</span>';
    }
  });

  // Push script to Telnyx
  document.getElementById('btn-update-default')?.addEventListener('click', async () => {
    if (!confirm('Push the current call script to Telnyx?')) return;

    const statusEl = document.getElementById('script-status');
    const msgEl = document.getElementById('script-status-msg');

    if (statusEl) statusEl.classList.remove('hidden');
    if (msgEl) msgEl.textContent = 'Updating...';

    try {
      const res = await fetch('/api/admin/concierge', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'update_script' }),
      });

      if (res.ok) {
        if (msgEl) msgEl.innerHTML = '<span class="text-emerald-600">Script pushed to Telnyx successfully</span>';
      } else {
        const data = await res.json();
        if (msgEl) msgEl.innerHTML = `<span class="text-red-600">Failed: ${data.error || 'Unknown error'}</span>`;
      }
    } catch {
      if (msgEl) msgEl.innerHTML = '<span class="text-red-600">Network error</span>';
    }
  });
</script>
