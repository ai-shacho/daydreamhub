---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';

const runtime = (Astro.locals as any).runtime;
const db = runtime?.env?.DB;
const env = runtime?.env;
const jwtSecret = env?.JWT_SECRET || 'dev-secret';
const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect('/admin/login');

// Config status
const cfg = {
  apiKey: env?.TELNYX_API_KEY ? true : false,
  fromNumber: env?.TELNYX_FROM_NUMBER || '',
  assistantId: env?.TELNYX_AI_ASSISTANT_ID || '',
  texmlAppId: env?.TELNYX_TEXML_APP_ID || '',
  anthropicKey: env?.ANTHROPIC_API_KEY ? true : false,
};

// Recent call logs
let callLogs: any[] = [];
let hotels: any[] = [];
if (db) {
  try {
    const logsResult = await db.prepare(`
      SELECT cl.*, h.name as hotel_name, h.phone as hotel_phone
      FROM call_logs cl
      LEFT JOIN hotels h ON h.id = cl.hotel_id
      ORDER BY cl.created_at DESC LIMIT 30
    `).all();
    callLogs = logsResult?.results || [];

    const hotelsResult = await db.prepare(
      `SELECT id, name, phone, city, country FROM hotels WHERE is_active = 1 AND phone IS NOT NULL AND phone != '' ORDER BY name LIMIT 200`
    ).all();
    hotels = hotelsResult?.results || [];
  } catch {}
}

const statusColor: Record<string, string> = {
  calling: 'bg-blue-100 text-blue-700',
  confirmed: 'bg-green-100 text-green-700',
  no_answer: 'bg-amber-100 text-amber-700',
  failed: 'bg-red-100 text-red-700',
  declined: 'bg-red-100 text-red-700',
  queued: 'bg-slate-100 text-slate-600',
};
---

<AdminLayout title="Telnyx Phone" activeNav="telnyx">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-semibold text-slate-900">📞 Telnyx Phone Management</h2>
      <p class="text-sm text-slate-500 mt-1">AI電話発信・通話ログ管理</p>
    </div>
  </div>

  <!-- Config status -->
  <div class="bg-white rounded-xl border border-slate-200 p-5 mb-6">
    <h3 class="font-semibold text-slate-800 mb-3">⚙️ 環境変数ステータス</h3>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
      {[
        { label: 'TELNYX_API_KEY', ok: cfg.apiKey },
        { label: 'TELNYX_FROM_NUMBER', ok: !!cfg.fromNumber, val: cfg.fromNumber },
        { label: 'TELNYX_AI_ASSISTANT_ID', ok: !!cfg.assistantId },
        { label: 'TELNYX_TEXML_APP_ID', ok: !!cfg.texmlAppId },
        { label: 'ANTHROPIC_API_KEY', ok: cfg.anthropicKey },
      ].map(item => (
        <div class={`rounded-lg p-3 text-xs font-medium ${item.ok ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-600'}`}>
          <span class="text-base">{item.ok ? '✅' : '❌'}</span><br/>
          <span class="font-mono">{item.label}</span>
          {item.val && <div class="mt-0.5 text-slate-500 font-mono">{item.val}</div>}
        </div>
      ))}
    </div>
    {(!cfg.apiKey || !cfg.fromNumber || !cfg.texmlAppId) && (
      <div class="mt-3 bg-amber-50 border border-amber-200 rounded-lg p-3 text-sm text-amber-800">
        ⚠️ 未設定の環境変数があります。<strong>Cloudflare Pages → Settings → Environment variables</strong> で設定してください。
      </div>
    )}
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Manual dial panel -->
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h3 class="font-semibold text-slate-800 mb-4">📲 手動発信</h3>
      <form id="dial-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">ホテル選択（任意）</label>
          <select id="hotel-select" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-teal-400 focus:outline-none">
            <option value="">— ホテルを選択 —</option>
            {hotels.map(h => (
              <option value={h.id} data-phone={h.phone} data-name={h.name}>
                {h.name} ({h.city}) — {h.phone}
              </option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">電話番号 *</label>
          <input id="to-number" type="tel" placeholder="+81312345678" required
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-teal-400 focus:outline-none font-mono" />
          <p class="text-xs text-slate-400 mt-1">国際形式（例: +81312345678）</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">メモ（任意）</label>
          <input id="call-note" type="text" placeholder="用件・備考"
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-teal-400 focus:outline-none" />
        </div>
        <button type="submit" id="dial-btn"
          class="w-full bg-teal-600 hover:bg-teal-700 disabled:bg-slate-300 text-white font-medium py-2.5 rounded-lg transition-colors flex items-center justify-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
          </svg>
          発信する
        </button>
      </form>
      <!-- Result -->
      <div id="dial-result" class="hidden mt-4 p-3 rounded-lg text-sm"></div>
    </div>

    <!-- Live call status -->
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-semibold text-slate-800">📊 通話ステータス</h3>
        <button id="refresh-logs" class="text-sm text-teal-600 hover:text-teal-700 font-medium flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          更新
        </button>
      </div>
      <div id="call-stats" class="grid grid-cols-3 gap-3 mb-4">
        <div class="bg-blue-50 rounded-lg p-3 text-center">
          <p class="text-xl font-bold text-blue-700">{callLogs.filter(l => l.status === 'calling').length}</p>
          <p class="text-xs text-blue-600 font-medium">発信中</p>
        </div>
        <div class="bg-green-50 rounded-lg p-3 text-center">
          <p class="text-xl font-bold text-green-700">{callLogs.filter(l => l.status === 'confirmed').length}</p>
          <p class="text-xs text-green-600 font-medium">確認済み</p>
        </div>
        <div class="bg-slate-50 rounded-lg p-3 text-center">
          <p class="text-xl font-bold text-slate-700">{callLogs.length}</p>
          <p class="text-xs text-slate-600 font-medium">合計</p>
        </div>
      </div>
      <!-- Log list -->
      <div id="log-list" class="space-y-2 max-h-72 overflow-y-auto">
        {callLogs.length === 0 ? (
          <p class="text-center text-slate-400 text-sm py-8">通話ログなし</p>
        ) : callLogs.map(log => (
          <div class="flex items-center justify-between py-2 border-b border-slate-100 last:border-0">
            <div class="min-w-0">
              <p class="text-sm font-medium text-slate-800 truncate">{log.hotel_name || log.to_number}</p>
              <p class="text-xs text-slate-400">{log.to_number} · {log.created_at?.slice(0, 16)}</p>
            </div>
            <span class={`ml-2 flex-shrink-0 inline-block px-2 py-0.5 rounded-full text-xs font-medium ${statusColor[log.status] || 'bg-slate-100 text-slate-600'}`}>
              {log.status}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Full logs table -->
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden mt-6">
    <div class="px-5 py-4 border-b border-slate-200 flex items-center justify-between">
      <h3 class="font-semibold text-slate-900">通話ログ一覧</h3>
      <a href="/admin/call-logs" class="text-sm text-teal-600 hover:text-teal-700">詳細ページ →</a>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-medium text-slate-600">ホテル</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">電話番号</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">方向</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">ステータス</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">メモ</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">日時</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {callLogs.length === 0 ? (
            <tr>
              <td colspan="6" class="px-4 py-12 text-center text-slate-400">通話ログなし</td>
            </tr>
          ) : callLogs.map(log => (
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-4 py-3 font-medium text-slate-800">{log.hotel_name || '—'}</td>
              <td class="px-4 py-3 font-mono text-slate-600 text-xs">{log.to_number}</td>
              <td class="px-4 py-3 text-center">
                <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${
                  log.direction === 'outbound' ? 'bg-teal-50 text-teal-700' : 'bg-purple-50 text-purple-700'
                }`}>
                  {log.direction === 'outbound' ? '↗ 発信' : '↙ 着信'}
                </span>
              </td>
              <td class="px-4 py-3 text-center">
                <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${statusColor[log.status] || 'bg-slate-100 text-slate-600'}`}>
                  {log.status}
                </span>
              </td>
              <td class="px-4 py-3 text-slate-500 text-xs max-w-xs truncate">{log.note || '—'}</td>
              <td class="px-4 py-3 text-slate-400 text-xs">{log.created_at?.slice(0, 16)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script is:inline>
// Hotel select auto-fills phone
document.getElementById('hotel-select')?.addEventListener('change', function() {
  const opt = this.options[this.selectedIndex];
  const phone = opt?.getAttribute('data-phone') || '';
  document.getElementById('to-number').value = phone;
});

// Dial form submit
document.getElementById('dial-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('dial-btn');
  const result = document.getElementById('dial-result');
  const hotelSelect = document.getElementById('hotel-select');
  const hotelId = hotelSelect?.value || null;
  const hotelName = hotelSelect?.options[hotelSelect.selectedIndex]?.getAttribute('data-name') || '';
  const toNumber = document.getElementById('to-number').value.trim();
  const note = document.getElementById('call-note').value.trim();

  if (!toNumber) return;

  btn.disabled = true;
  btn.textContent = '発信中...';
  result.className = 'hidden mt-4 p-3 rounded-lg text-sm';

  try {
    const res = await fetch('/api/admin/call', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'dial', to_number: toNumber, hotel_id: hotelId ? parseInt(hotelId) : null, hotel_name: hotelName, note }),
    });
    const data = await res.json();
    if (res.ok && data.success) {
      result.className = 'block mt-4 p-3 rounded-lg text-sm bg-green-50 text-green-700 border border-green-200';
      result.textContent = `✅ 発信成功！Call SID: ${data.call_sid || '—'}`;
      setTimeout(() => location.reload(), 3000);
    } else {
      result.className = 'block mt-4 p-3 rounded-lg text-sm bg-red-50 text-red-700 border border-red-200';
      result.textContent = `❌ エラー: ${data.error || JSON.stringify(data)}`;
    }
  } catch (e) {
    result.className = 'block mt-4 p-3 rounded-lg text-sm bg-red-50 text-red-700 border border-red-200';
    result.textContent = `❌ 通信エラー: ${e.message}`;
  } finally {
    btn.disabled = false;
    btn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/></svg> 発信する`;
  }
});

// Refresh logs
document.getElementById('refresh-logs')?.addEventListener('click', () => location.reload());
</script>
