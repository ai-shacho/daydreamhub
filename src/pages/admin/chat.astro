---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect("/admin/login");

const url = new URL(Astro.request.url);
const selectedSession = url.searchParams.get("session_id") || "";

let sessions: any[] = [];
let messages: any[] = [];
let totalSessions = 0;
let error = "";

if (db) {
  try {
    // Get all sessions with message count
    const sessionsRes = await db.prepare(`
      SELECT s.id, s.locale, s.created_at, s.updated_at,
        COUNT(m.id) as message_count,
        MAX(m.created_at) as last_message_at,
        (SELECT m2.content FROM concierge_messages m2 WHERE m2.session_id = s.id ORDER BY m2.created_at DESC LIMIT 1) as last_message
      FROM concierge_sessions s
      LEFT JOIN concierge_messages m ON m.session_id = s.id
      GROUP BY s.id
      ORDER BY MAX(m.created_at) DESC NULLS LAST, s.created_at DESC
      LIMIT 100
    `).all();
    sessions = sessionsRes?.results || [];
    totalSessions = sessions.length;

    // If a session is selected, load its messages
    if (selectedSession) {
      const msgsRes = await db.prepare(`
        SELECT id, session_id, role, content, message_type, image_key, created_at
        FROM concierge_messages
        WHERE session_id = ?
        ORDER BY created_at ASC
      `).bind(selectedSession).all();
      messages = msgsRes?.results || [];
    }
  } catch (e: any) {
    error = e.message || "Failed to load chat history";
  }
}
---

<AdminLayout title="Chat History" activeNav="chat">
  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>
  )}

  <div class="flex gap-6 h-[calc(100vh-10rem)]">
    <!-- Sessions sidebar -->
    <div class="w-80 flex-shrink-0 bg-white rounded-xl border border-slate-200 flex flex-col overflow-hidden">
      <div class="p-4 border-b border-slate-200">
        <h2 class="font-semibold text-slate-900">Chat Sessions</h2>
        <p class="text-xs text-slate-500 mt-0.5">Total: {totalSessions}</p>
      </div>
      <div class="flex-1 overflow-y-auto divide-y divide-slate-100">
        {sessions.length === 0 ? (
          <p class="p-6 text-sm text-slate-400 text-center">No sessions found</p>
        ) : sessions.map((s: any) => (
          <a
            href={`/admin/chat?session_id=${s.id}`}
            class={`block px-4 py-3 hover:bg-slate-50 transition-colors ${selectedSession === s.id ? "bg-teal-50 border-l-2 border-teal-500" : ""}`}
          >
            <div class="flex items-center justify-between mb-1">
              <span class="font-mono text-xs text-slate-500 truncate max-w-[140px]">{s.id}</span>
              <span class="text-xs text-slate-400 ml-2 flex-shrink-0">
                {s.locale ? (
                  <span class="px-1.5 py-0.5 bg-slate-100 rounded text-slate-600">{s.locale}</span>
                ) : ""}
              </span>
            </div>
            <p class="text-xs text-slate-600 truncate mb-1">{s.last_message || "(no messages)"}</p>
            <div class="flex items-center justify-between">
              <span class="text-xs text-slate-400">{s.message_count} msgs</span>
              <span class="text-xs text-slate-400">{(s.last_message_at || s.created_at)?.slice(0, 10) || ""}</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Message view -->
    <div class="flex-1 bg-white rounded-xl border border-slate-200 flex flex-col overflow-hidden">
      {!selectedSession ? (
        <div class="flex-1 flex items-center justify-center">
          <div class="text-center text-slate-400">
            <svg class="w-12 h-12 mx-auto mb-3 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
            </svg>
            <p class="text-sm">Select a session to view messages</p>
          </div>
        </div>
      ) : (
        <>
          <div class="p-4 border-b border-slate-200">
            <h3 class="font-semibold text-slate-900 font-mono text-sm">{selectedSession}</h3>
            <p class="text-xs text-slate-500">{messages.length} messages</p>
          </div>
          <div class="flex-1 overflow-y-auto p-4 space-y-3">
            {messages.length === 0 ? (
              <p class="text-sm text-slate-400 text-center py-8">No messages in this session</p>
            ) : messages.map((m: any) => (
              <div class={`flex ${m.role === "user" ? "justify-end" : "justify-start"}`}>
                <div class={`max-w-[75%] rounded-xl px-4 py-2.5 text-sm ${
                  m.role === "user"
                    ? "bg-teal-600 text-white rounded-br-sm"
                    : "bg-slate-100 text-slate-800 rounded-bl-sm"
                }`}>
                  <div class="text-xs font-medium mb-1 opacity-70">
                    {m.role === "user" ? "User" : "AI"} · {m.created_at?.slice(11, 16) || ""}
                  </div>
                  <p class="whitespace-pre-wrap break-words">{m.content}</p>
                  {m.image_key && (
                    <p class="text-xs mt-1 opacity-60">📎 Image: {m.image_key}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </>
      )}
    </div>
  </div>
</AdminLayout>
