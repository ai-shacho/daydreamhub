---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyAdmin } from '../../lib/adminAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const admin = await verifyAdmin(Astro.request, jwtSecret);
if (!admin) return Astro.redirect("/admin/login");

let stats = { totalHotels: 0, totalBookings: 0, pendingBookings: 0, revenue: 0, totalCities: 0, blogPosts: 0 };
let recentBookings: any[] = [];
let error = "";

if (db) {
  try {
    const [hotelsRes, bookingsRes, pendingRes, revenueRes, recentRes, citiesRes, blogRes] = await Promise.all([
      db.prepare("SELECT COUNT(*) as c FROM hotels").first(),
      db.prepare("SELECT COUNT(*) as c FROM bookings").first(),
      db.prepare("SELECT COUNT(*) as c FROM bookings WHERE status = 'pending'").first(),
      db.prepare("SELECT COALESCE(SUM(total_price_usd), 0) as total FROM bookings WHERE status IN ('confirmed', 'completed')").first(),
      db.prepare(`SELECT b.*, h.name as hotel_name, p.name as plan_name
        FROM bookings b
        LEFT JOIN hotels h ON h.id = b.hotel_id
        LEFT JOIN plans p ON p.id = b.plan_id
        ORDER BY b.created_at DESC LIMIT 10`).all(),
      db.prepare("SELECT COUNT(*) as c FROM cities").first(),
      db.prepare("SELECT COUNT(*) as c FROM blog_posts").first(),
    ]);
    stats.totalHotels = hotelsRes?.c ?? 0;
    stats.totalBookings = bookingsRes?.c ?? 0;
    stats.pendingBookings = pendingRes?.c ?? 0;
    stats.revenue = revenueRes?.total ?? 0;
    stats.totalCities = citiesRes?.c ?? 0;
    stats.blogPosts = blogRes?.c ?? 0;
    recentBookings = recentRes?.results || [];
  } catch (e: any) {
    error = e.message || "Failed to load dashboard data";
  }
}

const statusColors: Record<string, string> = {
  pending: "bg-amber-100 text-amber-700",
  confirmed: "bg-emerald-100 text-emerald-700",
  completed: "bg-blue-100 text-blue-700",
  cancelled: "bg-red-100 text-red-700",
};
---

<AdminLayout title="Dashboard" activeNav="dashboard">
  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">{error}</div>
  )}

  <!-- Welcome -->
  <div class="mb-6">
    <h2 class="text-2xl font-bold text-slate-900">Welcome back, {admin.name || "Admin"}</h2>
    <p class="text-slate-500 text-sm mt-1">Here is an overview of your DayDreamHub platform.</p>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Total Hotels</p>
          <p class="text-3xl font-bold text-slate-900 mt-1">{stats.totalHotels}</p>
        </div>
        <div class="w-10 h-10 bg-teal-50 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Total Bookings</p>
          <p class="text-3xl font-bold text-slate-900 mt-1">{stats.totalBookings}</p>
        </div>
        <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Pending Bookings</p>
          <p class="text-3xl font-bold text-amber-600 mt-1">{stats.pendingBookings}</p>
        </div>
        <div class="w-10 h-10 bg-amber-50 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Revenue (USD)</p>
          <p class="text-3xl font-bold text-emerald-600 mt-1">${stats.revenue.toLocaleString()}</p>
        </div>
        <div class="w-10 h-10 bg-emerald-50 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Total Cities</p>
          <p class="text-3xl font-bold text-slate-900 mt-1">{stats.totalCities}</p>
        </div>
        <div class="w-10 h-10 bg-indigo-50 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Blog Posts</p>
          <p class="text-3xl font-bold text-slate-900 mt-1">{stats.blogPosts}</p>
        </div>
        <div class="w-10 h-10 bg-rose-50 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="mb-8">
    <h3 class="text-sm font-semibold text-slate-600 uppercase tracking-wide mb-3">Quick Actions</h3>
    <div class="flex flex-wrap gap-3">
      <a href="/admin/hotels" class="inline-flex items-center gap-2 px-4 py-2.5 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75" />
        </svg>
        Hotels
      </a>
      <a href="/admin/hotels/new" class="inline-flex items-center gap-2 px-4 py-2.5 bg-[#45A2C1] text-white text-sm font-medium rounded-lg hover:bg-[#3a8fab] transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        新規ホテル追加 / Add New Hotel
      </a>
      <a href="/admin/bookings" class="inline-flex items-center gap-2 px-4 py-2.5 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25" />
        </svg>
        Bookings
      </a>
      <a href="/admin/blog" class="inline-flex items-center gap-2 px-4 py-2.5 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25" />
        </svg>
        Blog
      </a>
      <a href="/admin/cities" class="inline-flex items-center gap-2 px-4 py-2.5 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
        </svg>
        Cities
      </a>
    </div>
  </div>

  <!-- Recent Bookings -->
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-200 flex items-center justify-between">
      <h3 class="text-base font-semibold text-slate-900">Recent Bookings</h3>
      <a href="/admin/bookings" class="text-sm text-teal-600 hover:text-teal-700 font-medium">View All</a>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-medium text-slate-600">ID</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Guest</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Hotel</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Plan</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Check-in</th>
            <th class="text-right px-4 py-3 font-medium text-slate-600">Price</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Status</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Created</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {recentBookings.length === 0 ? (
            <tr>
              <td colspan="8" class="px-4 py-12 text-center text-slate-400">No bookings yet</td>
            </tr>
          ) : recentBookings.map((b: any) => (
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-4 py-3 font-mono text-slate-500">#{b.id}</td>
              <td class="px-4 py-3">
                <div class="font-medium text-slate-900">{b.guest_name || "-"}</div>
                <div class="text-xs text-slate-400">{b.guest_email || ""}</div>
              </td>
              <td class="px-4 py-3 text-slate-600">{b.hotel_name || "-"}</td>
              <td class="px-4 py-3 text-slate-600">{b.plan_name || "-"}</td>
              <td class="px-4 py-3 text-slate-600">{b.check_in_date || "-"}</td>
              <td class="px-4 py-3 text-right font-mono text-slate-900">${b.total_price_usd != null ? Number(b.total_price_usd).toFixed(2) : "-"}</td>
              <td class="px-4 py-3 text-center">
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColors[b.status] || "bg-slate-100 text-slate-600"}`}>
                  {b.status}
                </span>
              </td>
              <td class="px-4 py-3 text-slate-500 text-xs">{b.created_at?.slice(0, 16) || "-"}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
