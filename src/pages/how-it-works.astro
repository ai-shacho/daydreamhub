---
import Layout from '../layouts/Layout.astro';

const env = (Astro.locals as any).runtime?.env;
const DB = env?.DB;
let totalHotels = 270, totalCities = 60, totalCountries = 25;
try {
  if (DB) {
    const h = await DB.prepare("SELECT COUNT(*) as c FROM hotels WHERE is_active = 1").first();
    totalHotels = h?.c || totalHotels;
    const ci = await DB.prepare("SELECT COUNT(DISTINCT city) as c FROM hotels WHERE is_active = 1").first();
    totalCities = ci?.c || totalCities;
    const co = await DB.prepare("SELECT COUNT(DISTINCT country) as c FROM hotels WHERE is_active = 1").first();
    totalCountries = co?.c || totalCountries;
  }
} catch (e) {}
---

<Layout title="How DaydreamHub Works — Day-Use Hotel Booking">

  <!-- Hero -->
  <section class="bg-gradient-to-br from-teal-900 via-teal-800 to-teal-700 text-white py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <span class="inline-block bg-amber-400 text-gray-900 text-xs font-bold px-3 py-1 rounded-full mb-4 uppercase tracking-wider">What is DaydreamHub?</span>
      <h1 class="text-4xl md:text-5xl font-bold mb-5 leading-tight">
        The world's first platform<br class="hidden md:block"/>dedicated to <span class="text-amber-400">day-use hotel</span> bookings
      </h1>
      <p class="text-teal-100 text-lg md:text-xl max-w-2xl mx-auto mb-8">
        Book a hotel room for just a few hours<br class="hidden md:block"/> — for layovers, work, rest, or a romantic escape.<br/>
        At half the price of a regular overnight stay.
      </p>
      <div class="flex flex-wrap justify-center gap-6 text-center">
        <div><p class="text-3xl font-bold text-amber-400">{totalHotels}+</p><p class="text-teal-200 text-sm">Hotels</p></div>
        <div class="w-px bg-white/20"></div>
        <div><p class="text-3xl font-bold text-amber-400">{totalCities}+</p><p class="text-teal-200 text-sm">Cities</p></div>
        <div class="w-px bg-white/20"></div>
        <div><p class="text-3xl font-bold text-amber-400">{totalCountries}+</p><p class="text-teal-200 text-sm">Countries</p></div>
        <div class="w-px bg-white/20"></div>
        <div><p class="text-3xl font-bold text-amber-400">From 1hr</p><p class="text-teal-200 text-sm">Short stays available</p></div>
      </div>
    </div>
  </section>

  <!-- What is Day Use -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-gray-800 text-center mb-4">What is a Day-Use Hotel?</h2>
      <p class="text-gray-500 text-center max-w-2xl mx-auto mb-12">A day-use hotel lets you book a room for a few hours — no overnight stay required. Perfect for after checkout, before arrival, or any time you need a comfortable private space.</p>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { img: 'https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=600&q=80', title: 'Airport Layover', desc: 'Use a hotel near the airport for a shower or nap between flights. Far more comfortable than a lounge.' },
          { img: 'https://images.unsplash.com/photo-1497366216548-37526070297c?w=600&q=80', title: 'Work & Meetings', desc: 'Use a hotel room as a quiet office or meeting space. Full Wi-Fi, privacy, and focus.' },
          { img: 'https://images.unsplash.com/photo-1529543544282-ea669407fca3?w=600&q=80', title: 'Couples & Romance', desc: 'Enjoy a few hours at a hotel for a lunch date or anniversary. Affordable and intimate.' },
          { img: 'https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=600&q=80', title: 'Sightseeing Break', desc: 'Drop off luggage and explore. Come back to freshen up with a shower during your tour.' },
          { img: 'https://images.unsplash.com/photo-1455587734955-081b22074882?w=600&q=80', title: 'Late Night / Early Morning', desc: 'Need a rest after an early checkout or night bus? Day-use has you covered.' },
          { img: 'https://images.unsplash.com/photo-1476703993599-0035a21b17a9?w=600&q=80', title: 'Families', desc: 'A quiet space for children to nap or for nursing during a long day of sightseeing.' },
        ].map(u => (
          <div class="group rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-300 bg-white">
            <div class="relative h-48 overflow-hidden">
              <img
                src={u.img}
                alt={u.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
              <h3 class="absolute bottom-3 left-4 text-white font-bold text-lg drop-shadow">{u.title}</h3>
            </div>
            <div class="p-5">
              <p class="text-gray-500 text-sm leading-relaxed">{u.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 bg-teal-50">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-gray-800 text-center mb-3">How It Works</h2>
      <p class="text-gray-500 text-center mb-12">3 simple steps to book</p>
      <div class="relative">
        <div class="hidden md:block absolute top-10 left-[calc(16.67%)] right-[calc(16.67%)] h-0.5 bg-teal-200"></div>
        <div class="grid md:grid-cols-3 gap-8">
          {[
            { step: '01', icon: '🔍', title: 'Enter your city & time', desc: 'Type your destination, date, check-in/out time, and number of guests into the AI chat. Any city worldwide.' },
            { step: '02', icon: '🤖', title: 'AI finds the best hotel', desc: 'DaydreamHub-listed hotels are shown first. For unlisted areas, the AI searches Google Maps for real hotels.' },
            { step: '03', icon: '✅', title: 'Book & confirm', desc: 'Listed hotels: instant online booking. Unlisted hotels: AI calls ahead to confirm availability (flat $7 fee).' },
          ].map(s => (
            <div class="text-center relative">
              <div class="w-20 h-20 bg-teal-600 rounded-full flex items-center justify-center text-3xl mx-auto mb-4 relative z-10 shadow-lg">
                {s.icon}
              </div>
              <div class="absolute top-0 right-0 bg-amber-400 text-gray-900 text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center">{s.step}</div>
              <h3 class="font-bold text-gray-800 text-lg mb-2">{s.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Two Services -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-gray-800 text-center mb-3">Two Ways to Book</h2>
      <p class="text-gray-500 text-center mb-10">The method depends on whether the hotel is listed on DaydreamHub</p>
      <div class="grid md:grid-cols-2 gap-6">

        <!-- Direct Booking -->
        <div class="border-2 border-teal-500 rounded-2xl overflow-hidden relative">
          <div class="absolute top-0 right-0 bg-teal-500 text-white text-xs font-bold px-3 py-1 rounded-bl-lg z-10">Free</div>
          <div class="relative h-44 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800&q=80" alt="Listed Hotels" class="w-full h-full object-cover" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <h3 class="absolute bottom-4 left-6 text-xl font-bold text-white">Listed Hotels — Book Directly</h3>
          </div>
          <div class="p-8">
            <p class="text-gray-500 text-sm mb-4 leading-relaxed">Send a booking request to hotels partnered with DaydreamHub. Pay upfront — fully refunded if the hotel doesn't confirm. <strong class="text-teal-600">No service fee whatsoever.</strong></p>
            <ul class="space-y-2 text-sm text-gray-600">
              {['✅ Zero platform fee', '✅ Request-based booking', '✅ Full refund if request is declined', '✅ Secure online payment', '✅ Automatic confirmation email', '✅ 60+ cities worldwide'].map(i => (
                <li>{i}</li>
              ))}
            </ul>
            <div class="mt-6">
              <a href="/search" class="inline-block bg-teal-600 hover:bg-teal-500 text-white font-bold px-6 py-2.5 rounded-lg text-sm transition-colors">Search Hotels →</a>
            </div>
          </div>
        </div>

        <!-- AI Phone Booking -->
        <div class="border-2 border-blue-400 rounded-2xl overflow-hidden relative">
          <div class="absolute top-0 right-0 bg-blue-500 text-white text-xs font-bold px-3 py-1 rounded-bl-lg z-10">$7</div>
          <div class="relative h-44 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1593642533144-3d62aa4783ec?w=800&q=80" alt="AI Phone Booking" class="w-full h-full object-cover" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <h3 class="absolute bottom-4 left-6 text-xl font-bold text-white">Unlisted Hotels — AI Phone Booking</h3>
          </div>
          <div class="p-8">
            <p class="text-gray-500 text-sm mb-4 leading-relaxed">Even if a hotel isn't on DDH, our AI will call on your behalf to check day-use availability. Works anywhere in the world.</p>
            <ul class="space-y-2 text-sm text-gray-600">
              {['AI calls up to 3 hotels', 'Works anywhere in the world', 'Flat $7 fee (covers 1–3 calls)', 'Full refund if all attempts fail', 'Any hotel listed on Google Maps'].map(i => (
                <li>✓ {i}</li>
              ))}
            </ul>
            <div class="mt-6">
              <a href="/concierge" class="inline-block bg-blue-600 hover:bg-blue-500 text-white font-bold px-6 py-2.5 rounded-lg text-sm transition-colors">Ask the AI →</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold text-gray-800 mb-3">Pricing</h2>
      <p class="text-gray-500 mb-10">Simple and transparent</p>
      <div class="grid md:grid-cols-3 gap-4 text-sm">
        {[
          { label: 'Booking a listed hotel', price: 'Free', desc: 'No platform fee charged', color: 'bg-teal-50 border-teal-200' },
          { label: 'AI phone service (up to 3 calls)', price: '$7', desc: 'For unlisted hotel availability checks', color: 'bg-blue-50 border-blue-200' },
          { label: 'Money-back guarantee', price: '100%', desc: 'If all calls fail', color: 'bg-amber-50 border-amber-200' },
        ].map(p => (
          <div class={`${p.color} border rounded-2xl p-6`}>
            <p class="text-gray-600 text-xs font-medium mb-2">{p.label}</p>
            <p class="text-4xl font-bold text-gray-800 mb-1">{p.price}</p>
            <p class="text-gray-500 text-xs">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-gray-800 text-center mb-10">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'What does "day-use" mean?', a: 'Day-use means booking a hotel room for a few hours without staying overnight. For example, a plan from 10:00 to 18:00 lets you use the room for 8 hours.' },
          { q: 'What is the minimum booking duration?', a: 'It depends on the hotel and plan, but options range from 1-hour short stays to 8-hour or half-day plans. Just ask the AI for your preferred time.' },
          { q: 'Can I book hotels not listed on DaydreamHub?', a: 'Yes! With our AI Phone Service ($7), we can call any hotel listed on Google Maps anywhere in the world to check day-use availability on your behalf.' },
          { q: 'When is the $7 AI phone fee charged?', a: 'Payment is collected via PayPal when you confirm the request — before the AI makes any calls. If all attempts fail, you receive a full refund.' },
          { q: 'Can I cancel my booking?', a: 'Cancellation policies vary by hotel. Please refer to the details on your booking confirmation screen or email.' },
          { q: 'How do I list my hotel on DaydreamHub?', a: 'Visit our "For Hotel Owners" page to apply. Listing is completely free.', link: '/for-hotel-owner' },
        ].map((item, i) => (
          <details class="border border-gray-200 rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer font-medium text-gray-800 flex justify-between items-center hover:bg-gray-50 rounded-xl list-none">
              {item.q}
              <span class="text-teal-500 text-xl group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="px-6 pb-4 text-gray-500 text-sm leading-relaxed">
              {item.a}
              {item.link && <a href={item.link} class="text-teal-600 underline ml-1">Learn more</a>}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-teal-700 to-teal-600 text-white text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-4">Ready to book your next stay?</h2>
      <p class="text-teal-100 mb-8">Our AI instantly searches day-use hotels across {totalCities}+ cities worldwide</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/search" class="bg-amber-400 hover:bg-amber-300 text-gray-900 font-bold px-8 py-3 rounded-xl text-base transition-colors">
          🔍 Search Hotels
        </a>
        <a href="/how-it-works#faq" class="bg-white/20 hover:bg-white/30 text-white font-bold px-8 py-3 rounded-xl text-base transition-colors border border-white/30">
          FAQ
        </a>
      </div>
    </div>
  </section>

</Layout>
