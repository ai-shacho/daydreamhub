---
import Layout from '../../layouts/Layout.astro';
import { getLocale, t, localePath } from '../../lib/i18n';

const locale = getLocale(Astro.url);
---

<Layout title={t("auth.reset_password", locale)}>
  <div class="min-h-[80vh] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <div class="bg-white rounded-2xl shadow-lg p-8">
        <!-- Header -->
        <div class="text-center mb-8">
          <a href={localePath("/", locale)} class="inline-flex items-center gap-2 text-2xl font-bold text-teal-700 mb-2">
            <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none">
              <circle cx="16" cy="16" r="14" fill="#f59e0b"/>
              <path d="M10 20 Q16 10 22 20" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round"/>
              <circle cx="16" cy="13" r="3" fill="white"/>
            </svg>
            DayDreamHub
          </a>
          <h1 class="text-2xl font-bold text-slate-900 mt-4">{t("auth.reset_password", locale)}</h1>
          <p class="text-sm text-slate-500 mt-2">{t("auth.reset_description", locale)}</p>
        </div>

        <!-- Success message (hidden by default) -->
        <div id="reset-success" class="hidden bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-lg mb-4 text-sm"></div>

        <!-- Error message (hidden by default) -->
        <div id="reset-error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm"></div>

        <!-- Reset Password Form -->
        <form id="reset-form" class="space-y-5">
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1">{t("auth.email", locale)}</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder={t("auth.email_placeholder", locale)}
              class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
            />
          </div>

          <button
            type="submit"
            class="w-full px-4 py-2.5 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors focus:outline-none focus:ring-2 focus:ring-teal-500 focus:ring-offset-2"
          >
            {t("auth.send_reset_link", locale)}
          </button>
        </form>

        <!-- Links -->
        <div class="mt-6 text-center">
          <a href={localePath("/auth/login", locale)} class="text-sm text-teal-600 hover:text-teal-700 font-medium transition-colors">
            {t("auth.back_to_login", locale)}
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('reset-form') as HTMLFormElement;
  const errorEl = document.getElementById('reset-error') as HTMLDivElement;
  const successEl = document.getElementById('reset-success') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');
    successEl.classList.add('hidden');

    const email = (document.getElementById('email') as HTMLInputElement).value;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const origText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = '...';

    try {
      const res = await fetch('/api/admin/auth', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'reset-password', email }),
      });

      if (res.ok) {
        successEl.textContent = 'If an account with that email exists, a reset link has been sent.';
        successEl.classList.remove('hidden');
        form.reset();
      } else {
        const data = await res.json();
        errorEl.textContent = data.error || 'Failed to send reset link. Please try again.';
        errorEl.classList.remove('hidden');
      }
    } catch {
      errorEl.textContent = 'Network error. Please try again.';
      errorEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = origText;
    }
  });
</script>
