---
import Layout from '../../layouts/Layout.astro';
import { getLocale, t, localePath } from '../../lib/i18n';

const locale = getLocale(Astro.url);
---

<Layout title={t("auth.register", locale)}>
  <div class="min-h-[80vh] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <div class="bg-white rounded-2xl shadow-lg p-8">
        <!-- Header -->
        <div class="text-center mb-8">
          <a href={localePath("/", locale)} class="inline-flex items-center gap-2 text-2xl font-bold text-teal-700 mb-2">
            <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none">
              <circle cx="16" cy="16" r="14" fill="#f59e0b"/>
              <path d="M10 20 Q16 10 22 20" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round"/>
              <circle cx="16" cy="13" r="3" fill="white"/>
            </svg>
            DayDreamHub
          </a>
          <h1 class="text-2xl font-bold text-slate-900 mt-4">{t("auth.register", locale)}</h1>
        </div>

        <!-- Error message (hidden by default) -->
        <div id="register-error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm"></div>

        <!-- Registration Form -->
        <form id="register-form" class="space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700 mb-1">{t("auth.name", locale)}</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder={t("auth.name_placeholder", locale)}
              class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1">{t("auth.email", locale)}</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder={t("auth.email_placeholder", locale)}
              class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-slate-700 mb-1">{t("auth.password", locale)}</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minlength="8"
              placeholder={t("auth.password_placeholder", locale)}
              class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
            />
            <p class="text-xs text-slate-400 mt-1">{t("auth.password_min_chars", locale)}</p>
          </div>

          <div>
            <label for="confirm-password" class="block text-sm font-medium text-slate-700 mb-1">{t("auth.confirm_password", locale)}</label>
            <input
              type="password"
              id="confirm-password"
              name="confirm_password"
              required
              minlength="8"
              placeholder={t("auth.confirm_password_placeholder", locale)}
              class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
            />
          </div>

          <button
            type="submit"
            class="w-full px-4 py-2.5 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors focus:outline-none focus:ring-2 focus:ring-teal-500 focus:ring-offset-2"
          >
            {t("auth.register_button", locale)}
          </button>
        </form>

        <!-- Links -->
        <div class="mt-6 text-center">
          <p class="text-sm text-slate-500">
            {locale === "ja" ? "既にアカウントをお持ちですか？" : "Already have an account?"}
            <a href={localePath("/auth/login", locale)} class="text-teal-600 hover:text-teal-700 font-medium ml-1">
              {t("auth.login", locale)}
            </a>
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('register-form') as HTMLFormElement;
  const errorEl = document.getElementById('register-error') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');

    const name = (document.getElementById('name') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const confirmPassword = (document.getElementById('confirm-password') as HTMLInputElement).value;

    if (password !== confirmPassword) {
      errorEl.textContent = 'Passwords do not match.';
      errorEl.classList.remove('hidden');
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const origText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = '...';

    try {
      const res = await fetch('/api/admin/auth', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'register', name, email, password }),
      });

      const data = await res.json();

      if (res.ok) {
        window.location.href = '/auth/login?registered=1';
      } else {
        errorEl.textContent = data.error || 'Registration failed. Please try again.';
        errorEl.classList.remove('hidden');
      }
    } catch {
      errorEl.textContent = 'Network error. Please try again.';
      errorEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = origText;
    }
  });
</script>
