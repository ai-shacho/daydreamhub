---
import Layout from '../../layouts/Layout.astro';
import { getLocale, t, localePath } from '../../lib/i18n';

const locale = getLocale(Astro.url);
const orderId = Astro.url.searchParams.get('order') || '';
const paymentStatus = Astro.url.searchParams.get('payment_status') || '';
---

<Layout title={`${t('booking.confirmation_title', locale)} | ${t('site.name', locale)}`} description={t('booking.confirmation_message', locale)}>

  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-16 text-center" data-order-id={orderId} data-payment-status={paymentStatus}>
    <!-- State: Payment Under Review (PayPal PENDING) -->
    <div id="state-payment-review" class="hidden">
      <div class="mb-8">
        <div class="w-20 h-20 mx-auto bg-amber-100 rounded-full flex items-center justify-center animate-pulse">
          <svg class="w-10 h-10 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </div>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 mb-4">{t('booking.payment_review_title', locale)}</h1>
      <p class="text-gray-600 text-lg mb-4 max-w-md mx-auto">{t('booking.payment_review_message', locale)}</p>
      <p class="text-gray-400 text-sm max-w-md mx-auto">{t('booking.payment_review_note', locale)}</p>
      {orderId && (
        <div class="bg-amber-50 border border-amber-200 rounded-xl px-6 py-4 mt-8 inline-block">
          <p class="text-sm text-amber-600 mb-1">{t('booking.payment_review_order', locale)}</p>
          <p class="text-base font-mono font-semibold text-amber-800">{orderId}</p>
        </div>
      )}
    </div>

    <!-- State: Pending -->
    <div id="state-pending" class="hidden">
      <div class="mb-8">
        <div class="w-20 h-20 mx-auto bg-blue-100 rounded-full flex items-center justify-center animate-pulse">
          <svg class="w-10 h-10 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
        </div>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 mb-4">{t('booking.pending_title', locale)}</h1>
      <p class="text-gray-600 text-lg mb-4">{t('booking.pending_message', locale)}</p>
      <p class="text-gray-400 text-sm">{t('booking.pending_eta', locale)}</p>
      <p class="text-gray-400 text-sm mt-2">{t('booking.pending_check_email', locale)}</p>
    </div>

    <!-- State: Confirmed -->
    <div id="state-confirmed" class="hidden">
      <div class="mb-8">
        <div class="w-20 h-20 mx-auto bg-green-100 rounded-full flex items-center justify-center">
          <svg class="w-10 h-10 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
        </div>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 mb-4">{t('booking.confirmation_title', locale)}</h1>
      <p class="text-gray-600 text-lg mb-4 max-w-md mx-auto">{t('booking.confirmation_message', locale)}</p>
      <div class="text-sm text-gray-500 mb-6 space-y-1 max-w-md mx-auto">
        <p>📧 A confirmation email has been sent to your inbox.</p>
        <p>🏨 Please proceed directly to the hotel during check-in hours.</p>
        <p>❓ Questions? Contact us at <a href="mailto:contact@daydreamhub.com" class="text-teal-600 hover:underline">contact@daydreamhub.com</a></p>
      </div>

<!-- Booking Details Card -->
      <div id="booking-details-card" class="hidden mt-4 bg-white border border-gray-200 rounded-2xl p-6 text-left max-w-md mx-auto">
        <h3 class="font-semibold text-slate-800 mb-4 text-sm uppercase tracking-wide text-center">Booking Details</h3>
        <dl class="space-y-3 text-sm">
          <div class="flex justify-between">
            <dt class="text-gray-500">Hotel</dt>
            <dd id="detail-hotel" class="font-medium text-slate-800 text-right max-w-[180px]">—</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-500">Plan</dt>
            <dd id="detail-plan" class="font-medium text-slate-800 text-right max-w-[180px]">—</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-500">Check-in Date</dt>
            <dd id="detail-checkin" class="font-medium text-slate-800">—</dd>
          </div>
          <div class="flex justify-between border-t pt-3 mt-3">
            <dt class="text-gray-700 font-semibold">Total Paid</dt>
            <dd id="detail-price" class="font-bold text-teal-700">—</dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- State: Alt Choice -->
    <div id="state-alt-choice" class="hidden">
      <div class="mb-8">
        <div class="w-20 h-20 mx-auto bg-amber-100 rounded-full flex items-center justify-center">
          <svg class="w-10 h-10 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
          </svg>
        </div>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 mb-4">{t('booking.alt_hotels_unavailable_title', locale)}</h1>
      <p class="text-gray-600 text-lg mb-6">{t('booking.alt_hotels_unavailable_message', locale)}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <button id="btn-retry-more" class="px-8 py-3 bg-teal-700 text-white font-medium rounded-lg hover:bg-teal-800 transition-colors">
          {t('booking.alt_try_more', locale)}
        </button>
        <button id="btn-refund" class="px-8 py-3 bg-gray-200 text-gray-800 font-medium rounded-lg hover:bg-gray-300 transition-colors">
          {t('booking.alt_refund', locale)}
        </button>
      </div>
      <p class="text-gray-400 text-sm mt-4">{t('booking.alt_deadline', locale)}</p>
    </div>

    <!-- State: Cancelled / Refunded -->
    <div id="state-cancelled" class="hidden">
      <div class="mb-8">
        <div class="w-20 h-20 mx-auto bg-red-100 rounded-full flex items-center justify-center">
          <svg class="w-10 h-10 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </div>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 mb-4">{t('booking.cancelled_title', locale)}</h1>
      <p class="text-gray-600 text-lg mb-8 max-w-md mx-auto">{t('booking.cancelled_message', locale)}</p>
    </div>

    <!-- Order ID (always visible when present) -->
    {orderId && (
      <div class="bg-gray-50 border border-gray-200 rounded-xl px-6 py-4 mb-8 inline-block">
        <p class="text-sm text-gray-500 mb-1">{t('booking.order_id', locale)}</p>
        <p class="text-lg font-mono font-semibold text-gray-800">{orderId}</p>
      </div>
    )}

    <!-- Back to Home Button -->
    <div>
      <a href={localePath('/', locale)} class="inline-flex items-center px-8 py-3 bg-[#45A2C1] text-white font-medium rounded-lg hover:bg-[#3891AE] transition-colors duration-200">
        <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
        </svg>
        {t('booking.back_home', locale)}
      </a>
    </div>
  </div>

  <script>
    import { initConfirmationStatus } from '../../lib/confirmationStatus';
    initConfirmationStatus();
  </script>

</Layout>
