---
import Layout from '../../layouts/Layout.astro';
import PayPalButton from '../../components/PayPalButton.astro';
import { getLocale, t, localePath } from '../../lib/i18n';

const locale = getLocale(Astro.url);
const { planId } = Astro.params;
const planIdNum = parseInt(planId || '0');
const isTestMode = Astro.url.searchParams.get('test_pay') === '1';

// Auth check: redirect to login if not authenticated
async function verifyJWT(token: string, secret: string): Promise<Record<string, any> | null> {
  try {
    const parts = token.split('.');
    if (parts.length !== 3) return null;
    const [header, body, signature] = parts;
    const key = await crypto.subtle.importKey(
      'raw', new TextEncoder().encode(secret),
      { name: 'HMAC', hash: 'SHA-256' }, false, ['verify']
    );
    const sigBytes = Uint8Array.from(
      atob(signature.replace(/-/g, '+').replace(/_/g, '/')), c => c.charCodeAt(0)
    );
    const valid = await crypto.subtle.verify('HMAC', key, sigBytes, new TextEncoder().encode(`${header}.${body}`));
    if (!valid) return null;
    const payload = JSON.parse(atob(body));
    if (payload.exp && payload.exp < Math.floor(Date.now() / 1000)) return null;
    return payload;
  } catch { return null; }
}
{
  const env = (Astro.locals as any).runtime?.env;
  const jwtSecret = env?.JWT_SECRET || 'ddh-secret-2025';
  const cookieHeader = Astro.request.headers.get('cookie') || '';
  const tokenMatch = cookieHeader.match(/ddh_token=([^;]+)/);
  const authPayload = tokenMatch ? await verifyJWT(tokenMatch[1], jwtSecret) : null;
  if (!authPayload) {
    return Astro.redirect(`/login?redirect=/booking/${planId}`);
  }
}

let plan: any = null;
let dbAvailable = false;
let paypalClientId = '';

try {
  const runtime = (Astro.locals as any).runtime;
  const db = runtime?.env?.DB;
  paypalClientId = runtime?.env?.PAYPAL_CLIENT_ID || '';
  if (db) {
    dbAvailable = true;
    plan = await db.prepare(
      "SELECT p.*, p.cancellation_hours, h.name as hotel_name, h.name_ja as hotel_name_ja, h.slug as hotel_slug, h.city, h.country, h.cancellation_policy as hotel_cancellation_policy FROM plans p JOIN hotels h ON h.id = p.hotel_id WHERE p.id = ?"
    ).bind(planIdNum).first();
  }
} catch (e) {
  dbAvailable = false;
}

if (!dbAvailable) {
  const samplePlans = [
    { id: 1, name: "4-Hour Workspace", name_ja: "4時間ワークスペース", price_usd: 25, check_in_time: "09:00", check_out_time: "13:00", plan_type: "day-use", max_guests: 1, duration_hours: 4, hotel_name: "The Work Loft Bangkok", hotel_name_ja: "ザ ワークロフト バンコク", hotel_slug: "work-loft-bangkok", city: "Bangkok", country: "Thailand" },
    { id: 2, name: "Full Day Office", name_ja: "1日オフィス", price_usd: 45, check_in_time: "09:00", check_out_time: "18:00", plan_type: "day-use", max_guests: 2, duration_hours: 9, hotel_name: "The Work Loft Bangkok", hotel_name_ja: "ザ ワークロフト バンコク", hotel_slug: "work-loft-bangkok", city: "Bangkok", country: "Thailand" },
    { id: 6, name: "6-Hour Layover", name_ja: "6時間レイオーバー", price_usd: 40, check_in_time: "00:00", check_out_time: "06:00", plan_type: "day-use", max_guests: 2, duration_hours: 6, hotel_name: "Airport Transit Hotel", hotel_name_ja: "エアポート トランジットホテル", hotel_slug: "airport-transit-hotel", city: "Singapore", country: "Singapore" },
    { id: 10, name: "Romantic Half Day", name_ja: "ロマンチック半日", price_usd: 80, check_in_time: "12:00", check_out_time: "18:00", plan_type: "day-use", max_guests: 2, duration_hours: 6, hotel_name: "Romance Suite Bali", hotel_name_ja: "ロマンス スイート バリ", hotel_slug: "romance-suite-bali", city: "Bali", country: "Indonesia" },
    { id: 14, name: "Luxury Day Pass", name_ja: "ラグジュアリーデイパス", price_usd: 150, check_in_time: "10:00", check_out_time: "18:00", plan_type: "day-use", max_guests: 2, duration_hours: 8, hotel_name: "The Ritz-Carlton KL", hotel_name_ja: "ザ・リッツカールトン KL", hotel_slug: "ritz-carlton-kl", city: "Kuala Lumpur", country: "Malaysia" },
    { id: 18, name: "Beach & Pool Day", name_ja: "ビーチ＆プールデイ", price_usd: 55, check_in_time: "09:00", check_out_time: "17:00", plan_type: "day-use", max_guests: 4, duration_hours: 8, hotel_name: "Daycation Paradise", hotel_name_ja: "デイケーション パラダイス", hotel_slug: "daycation-paradise", city: "Bali", country: "Indonesia" },
  ];
  plan = samplePlans.find((p) => p.id === planIdNum) || null;
  paypalClientId = 'sandbox';
}

if (!plan) {
  Astro.response.status = 404;
}



const displayPlanName = plan ? (locale === 'ja' && plan.name_ja ? plan.name_ja : plan.name) : '';
const displayHotelName = plan ? (locale === 'ja' && plan.hotel_name_ja ? plan.hotel_name_ja : plan.hotel_name) : '';
const timeSlot = plan?.check_in_time && plan?.check_out_time ? `${plan.check_in_time} - ${plan.check_out_time}` : '';
const today = new Date().toISOString().split('T')[0];
const dateParam = Astro.url.searchParams.get('date') || today;
const todayParts = today.split('-');
const bookingMonths = [
  { val: '01', label: 'Jan' }, { val: '02', label: 'Feb' }, { val: '03', label: 'Mar' },
  { val: '04', label: 'Apr' }, { val: '05', label: 'May' }, { val: '06', label: 'Jun' },
  { val: '07', label: 'Jul' }, { val: '08', label: 'Aug' }, { val: '09', label: 'Sep' },
  { val: '10', label: 'Oct' }, { val: '11', label: 'Nov' }, { val: '12', label: 'Dec' },
];
const bookingCurYear = new Date().getFullYear();
const bookingYears = [bookingCurYear, bookingCurYear + 1, bookingCurYear + 2];
const bookingDays = Array.from({ length: 31 }, (_, i) => String(i + 1).padStart(2, '0'));
const maxGuests = plan?.max_guests || 10;
const adultOptions = Array.from({ length: maxGuests }, (_, i) => i + 1);       // 1〜maxGuests
const guestOptions = Array.from({ length: maxGuests + 1 }, (_, i) => i);       // 0〜maxGuests

const planTypeColors: Record<string, string> = {
  'day-use': 'bg-blue-100 text-blue-700',
  'overnight': 'bg-indigo-100 text-indigo-700',
  'hourly': 'bg-green-100 text-green-700',
};
const planTypeClass = plan ? (planTypeColors[plan.plan_type || ''] || 'bg-gray-100 text-gray-700') : '';
---

