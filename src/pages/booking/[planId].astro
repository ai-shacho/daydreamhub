                  return (
                    <div class="bg-green-50 border border-green-200 rounded-lg px-3 py-2.5 text-xs text-green-700">
                      ✅ Free cancellation up to {plan.cancellation_hours ?? 24}h before check-in
                    </div>
                  );
                }
              })()}
            </div>
            <div class="border-t border-gray-200 my-4"></div>
            <div class="flex items-center justify-between mb-2">
              <p class="text-base font-semibold text-gray-800">{t('booking.total', locale)}</p>
              <p class="text-2xl font-bold text-[#45A2C1]">
                ${plan.price_usd} <span class="text-sm font-normal text-gray-500">{t('hotel.usd', locale)}</span>
              </p>
            </div>
            <!-- Approval-based booking notice -->
            <div class="flex items-start gap-3 p-3 bg-amber-50 border border-amber-200 rounded-lg text-sm text-amber-800 mb-3">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
              </svg>
              <div>
                <p class="font-medium">{locale === 'ja' ? '予約承認制について' : 'Approval-based Booking'}</p>
                <p class="mt-0.5 text-xs text-amber-700">
                  {locale === 'ja'
                    ? 'ご予約はホテルによる承認制です。お支払いは予約時にお預かりしますが、承認されなかった場合は全額返金いたします。'
                    : 'Bookings are subject to hotel approval. Payment is collected at the time of booking, but you will receive a full refund if your request is not approved.'}
                </p>
              </div>
            </div>
            <PayPalButton planId={plan.id} priceUsd={plan.price_usd} clientId={paypalClientId} testMode={isTestMode} hotelSlug={plan.hotel_slug} />
          </div>
        </div>
      </div>
    </div>
  ) : (
    <!-- 404: Plan Not Found -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-20 text-center">
      <svg class="w-20 h-20 mx-auto text-gray-300 mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
      </svg>
      <h1 class="text-2xl font-bold text-gray-700 mb-3">
        {t('booking.plan_not_found', locale)}
      </h1>
      <p class="text-gray-500 mb-8 max-w-md mx-auto">
        {t('booking.plan_not_found_desc', locale)}
      </p>
      <a href={localePath('/', locale)} class="inline-flex items-center px-6 py-3 bg-[#45A2C1] text-white font-medium rounded-lg hover:bg-[#3891AE] transition-colors">
        {t('hotel.back_home', locale)}
      </a>
    </div>
  )}

</Layout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script is:inline>
  (function() {
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/flatpickr';
    s.onload = function() {
      var today = new Date();
      today.setHours(0,0,0,0);
      flatpickr('#check_in_date', {
        dateFormat: 'Y-m-d',   // 実際の input value は YYYY-MM-DD（API送信用）
        altInput: true,         // 表示用の別インプットを生成
        altFormat: 'Y-m-d',    // ユーザーには YYYY-MM-DD で表示
        minDate: today,
        disableMobile: true,
        locale: { firstDayOfWeek: 0 }
      });
    };
    document.head.appendChild(s);
  })();
</script>
<script define:vars={{ maxGuests }}>
  // Phone: combine country code + local number into hidden #guest_phone
  (function() {
    var sel = document.getElementById('phone_code') as HTMLSelectElement;
    var manual = document.getElementById('phone_code_manual') as HTMLInputElement;

    // "Other" toggle
    if (sel && manual) {
      sel.addEventListener('change', function() {
        if (sel.value === 'other') {
          manual.classList.remove('hidden');
          manual.focus();
          sel.classList.add('hidden');
        }
        syncPhone();
      });
      manual.addEventListener('blur', function() {
        if (!manual.value.trim()) {
          manual.classList.add('hidden');
          sel.classList.remove('hidden');
          sel.value = '+1';
        }
      });
      manual.addEventListener('input', syncPhone);
    }

    function syncPhone() {
      var code = '';
      if (sel && sel.classList.contains('hidden') && manual) {
        code = manual.value.trim();
      } else {
        code = sel?.value || '';
      }
      var local = (document.getElementById('phone_local') as HTMLInputElement)?.value.trim() || '';
      // strip "-CA" suffix (Canada shares +1)
      var dialCode = code.replace(/-[A-Z]+$/, '');
      var hidden = document.getElementById('guest_phone') as HTMLInputElement;
      if (hidden) hidden.value = local ? dialCode + local : '';
    }
    document.getElementById('phone_local')?.addEventListener('input', syncPhone);
    syncPhone();
  })();

  // date input — value is already in YYYY-MM-DD format, no sync needed

  // Max guests: show error immediately
  if (maxGuests > 0) {
    var guestSelIds = ['adults', 'children', 'infants'];

    function checkGuestTotal() {
      var total = 0;
      guestSelIds.forEach(function(id) {
        total += parseInt(document.getElementById(id)?.value || '0') || 0;
      });
      var errEl = document.getElementById('guests-error');
      var over = total > maxGuests;

      if (errEl) {
        errEl.style.display = over ? 'flex' : 'none';
      }

      // Highlight selects in red when over
      guestSelIds.forEach(function(id) {
        var el = document.getElementById(id);
        if (!el) return;
        if (over) {
          el.style.borderColor = '#ef4444';
          el.style.boxShadow = '0 0 0 2px rgba(239,68,68,0.2)';
        } else {
          el.style.borderColor = '';
          el.style.boxShadow = '';
        }
      });

      return !over;
    }

    guestSelIds.forEach(function(id) {
      var el = document.getElementById(id);
      el?.addEventListener('change', checkGuestTotal);
      el?.addEventListener('input', checkGuestTotal);  // for mobile
    });

    document.querySelector('form')?.addEventListener('submit', function(e) {
      if (!checkGuestTotal()) {
        e.preventDefault();
        document.getElementById('guests-error')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }, true);
  }
</script>
