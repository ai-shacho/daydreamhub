    {city:"Ho Chi Minh City",country:"Vietnam"},{city:"Hanoi",country:"Vietnam"},{city:"Da Nang",country:"Vietnam"},
    {city:"Phnom Penh",country:"Cambodia"},{city:"Siem Reap",country:"Cambodia"},
    {city:"Vientiane",country:"Laos"},{city:"Luang Prabang",country:"Laos"},
    {city:"Yangon",country:"Myanmar"},{city:"Colombo",country:"Sri Lanka"},
    {city:"Mumbai",country:"India"},{city:"Delhi",country:"India"},{city:"Bangalore",country:"India"},
    {city:"Chennai",country:"India"},{city:"Kolkata",country:"India"},{city:"Hyderabad",country:"India"},
    {city:"Goa",country:"India"},{city:"Jaipur",country:"India"},{city:"Agra",country:"India"},
    {city:"Karachi",country:"Pakistan"},{city:"Lahore",country:"Pakistan"},{city:"Islamabad",country:"Pakistan"},
    {city:"Dhaka",country:"Bangladesh"},{city:"Kathmandu",country:"Nepal"},
    {city:"Islamabad",country:"Pakistan"},{city:"Colombo",country:"Sri Lanka"},
    // Middle East
    {city:"Dubai",country:"UAE"},{city:"Abu Dhabi",country:"UAE"},{city:"Sharjah",country:"UAE"},
    {city:"Doha",country:"Qatar"},{city:"Riyadh",country:"Saudi Arabia"},{city:"Jeddah",country:"Saudi Arabia"},
    {city:"Mecca",country:"Saudi Arabia"},{city:"Medina",country:"Saudi Arabia"},
    {city:"Kuwait City",country:"Kuwait"},{city:"Manama",country:"Bahrain"},
    {city:"Muscat",country:"Oman"},{city:"Beirut",country:"Lebanon"},{city:"Amman",country:"Jordan"},
    {city:"Tel Aviv",country:"Israel"},{city:"Jerusalem",country:"Israel"},
    {city:"Cairo",country:"Egypt"},{city:"Alexandria",country:"Egypt"},
    // Oceania
    {city:"Sydney",country:"Australia"},{city:"Melbourne",country:"Australia"},{city:"Brisbane",country:"Australia"},
    {city:"Perth",country:"Australia"},{city:"Adelaide",country:"Australia"},{city:"Gold Coast",country:"Australia"},
    {city:"Auckland",country:"New Zealand"},{city:"Wellington",country:"New Zealand"},{city:"Queenstown",country:"New Zealand"},
    {city:"Nadi",country:"Fiji"},
    // Africa
    {city:"Cape Town",country:"South Africa"},{city:"Johannesburg",country:"South Africa"},{city:"Durban",country:"South Africa"},
    {city:"Nairobi",country:"Kenya"},{city:"Lagos",country:"Nigeria"},{city:"Accra",country:"Ghana"},
    {city:"Casablanca",country:"Morocco"},{city:"Marrakech",country:"Morocco"},{city:"Tunis",country:"Tunisia"},
    {city:"Addis Ababa",country:"Ethiopia"},{city:"Dar es Salaam",country:"Tanzania"},
    // South America
    {city:"São Paulo",country:"Brazil"},{city:"Rio de Janeiro",country:"Brazil"},{city:"Brasília",country:"Brazil"},
    {city:"Buenos Aires",country:"Argentina"},{city:"Santiago",country:"Chile"},
    {city:"Lima",country:"Peru"},{city:"Bogotá",country:"Colombia"},{city:"Medellín",country:"Colombia"},
    {city:"Caracas",country:"Venezuela"},{city:"Montevideo",country:"Uruguay"},
    {city:"Quito",country:"Ecuador"},{city:"La Paz",country:"Bolivia"},
  ];

  // DBの自社登録都市（優先表示）
  var dbCities = (allCities || []).map(function(c) {
    return { city: c.city, country: c.country, inDB: true };
  });
  var dbCityKeys = new Set(dbCities.map(function(c){ return c.city.toLowerCase(); }));

  // マージ: DB都市優先 + 世界都市（重複除外）
  var worldExtras = WORLD_CITIES.filter(function(c) {
    return !dbCityKeys.has(c.city.toLowerCase());
  }).map(function(c) { return { city: c.city, country: c.country, inDB: false }; });

  var cities = dbCities.concat(worldExtras);

  var input = document.getElementById('location-input');
  var list  = document.getElementById('location-suggestions');
  if (!input || !list) return;

  var activeIdx = -1;

  function normalize(s) {
    return (s || '').toLowerCase().replace(/\s+/g, ' ').trim();
  }

  function highlight(text, q) {
    if (!q) return text;
    var re = new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
    return text.replace(re, '<strong class="text-teal-600">$1</strong>');
  }

  function render(items, q) {
    activeIdx = -1;
    if (!items.length) {
      list.classList.add('hidden');
      list.innerHTML = '';
      return;
    }
    list.innerHTML = items.map(function(c, i) {
      var badge = c.inDB
        ? '<span class="text-[10px] bg-teal-100 text-teal-700 px-1.5 py-0.5 rounded font-semibold ml-1.5 flex-shrink-0">DDH</span>'
        : '';
      return '<li class="px-4 py-2.5 cursor-pointer hover:bg-teal-50 text-gray-800 flex justify-between items-center suggestion-item" data-city="' + c.city + '" data-idx="' + i + '">' +
             '<span class="font-medium flex items-center">' + highlight(c.city, q) + badge + '</span>' +
             '<span class="text-gray-400 text-xs ml-2 flex-shrink-0">' + c.country + '</span>' +
             '</li>';
    }).join('');
    list.classList.remove('hidden');
  }

  function setActive(idx, items) {
    var lis = list.querySelectorAll('.suggestion-item');
    lis.forEach(function(li, i) {
      li.classList.toggle('bg-teal-50', i === idx);
    });
    if (lis[idx]) {
      input.value = lis[idx].dataset.city;
    }
  }

  function getMatches(q) {
    if (!q) {
      // 未入力時はDB登録都市を優先表示
      var dbTop = cities.filter(function(c){ return c.inDB; }).slice(0, 8);
      return dbTop.length >= 8 ? dbTop : dbTop.concat(cities.filter(function(c){ return !c.inDB; }).slice(0, 8 - dbTop.length));
    }
    var nq = normalize(q);
    var prefixDB = [], prefixWorld = [], containsDB = [], containsWorld = [];
    cities.forEach(function(c) {
      var nc = normalize(c.city), nco = normalize(c.country);
      var isPrefix = nc.startsWith(nq) || nco.startsWith(nq);
      var isContains = !isPrefix && (nc.includes(nq) || nco.includes(nq));
      if (isPrefix) { c.inDB ? prefixDB.push(c) : prefixWorld.push(c); }
      else if (isContains) { c.inDB ? containsDB.push(c) : containsWorld.push(c); }
    });
    // DB優先: prefix(DB) → prefix(world) → contains(DB) → contains(world)
    return prefixDB.concat(prefixWorld).concat(containsDB).concat(containsWorld).slice(0, 10);
  }

  input.addEventListener('input', function() {
    var q = this.value.trim();
    var matches = getMatches(q);
    render(matches, normalize(q));
  });

  input.addEventListener('focus', function() {
    var q = this.value.trim();
    render(getMatches(q), normalize(q));
  });

  input.addEventListener('keydown', function(e) {
    var lis = list.querySelectorAll('.suggestion-item');
    if (!lis.length) return;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIdx = Math.min(activeIdx + 1, lis.length - 1);
      setActive(activeIdx, lis);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIdx = Math.max(activeIdx - 1, 0);
      setActive(activeIdx, lis);
    } else if (e.key === 'Enter' && activeIdx >= 0) {
      e.preventDefault();
      input.value = lis[activeIdx].dataset.city;
      list.classList.add('hidden');
      activeIdx = -1;
    } else if (e.key === 'Escape') {
      list.classList.add('hidden');
    }
  });

  list.addEventListener('mousedown', function(e) {
    var li = e.target.closest('.suggestion-item');
    if (!li) return;
    e.preventDefault();
    input.value = li.dataset.city;
    list.classList.add('hidden');
  });

  document.addEventListener('click', function(e) {
    if (!document.getElementById('location-wrapper').contains(e.target)) {
      list.classList.add('hidden');
    }
  });
})();
</script>

