  window._heroSubmitCallBook = async function() {
    var name = document.getElementById('call-guest-name')?.value?.trim();
    var email = document.getElementById('call-guest-email')?.value?.trim();
    var date = document.getElementById('call-checkin-date')?.value;
    var checkinTime = document.getElementById('call-checkin-time')?.value || '10:00';
    var checkoutTime = document.getElementById('call-checkout-time')?.value || '18:00';
    if (!name || !email || !date) {
      alert('Please fill in name, email, and date');
      return;
    }
    var selectedHotels = window._heroSelectedHotels || [];
    if (selectedHotels.length === 0) {
      alert('No hotels selected.');
      return;
    }
    var submitBtn = event?.target;
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Processing...'; }

    try {
      var sessionId = window._heroSessionId || ('hero-' + Date.now());

      // Step 1: call_group作成
      var res = await fetch('/api/concierge/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          session_id: sessionId,
          message: '__create_call_group_direct',
          locale: document.documentElement.lang || 'en',
          _call_group: {
            hotels: selectedHotels.map(function(h) {
              return { hotel_name: h.name, hotel_phone: h.phone, hotel_source: 'external' };
            }),
            guest_name: name, guest_email: email, check_in_date: date,
            check_in_time: checkinTime, check_out_time: checkoutTime
          }
        })
      });
      var data = await res.json();
      if (data.error) { addMsg('❌ Error: ' + data.error, 'assistant'); if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = '💳 Pay $7 via PayPal → AI Booking'; } return; }

      var groupId = data.group_id;
      var paypalOrderId = data.paypal_order_id;

      if (!groupId || !paypalOrderId) {
        addMsg('❌ Failed to create booking request.', 'assistant');
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = '💳 Pay $7 via PayPal → AI Booking'; }
        return;
      }

      // Step 2: PayPal JS SDKでページ内決済
      var paypalContainer = document.getElementById('call-paypal-container');
      if (!paypalContainer) {
        // コンテナを動的に挿入
        paypalContainer = document.createElement('div');
        paypalContainer.id = 'call-paypal-container';
        paypalContainer.style.marginTop = '8px';
        submitBtn?.parentNode?.insertBefore(paypalContainer, submitBtn);
        submitBtn.style.display = 'none';
      }

      // PayPal SDKをロード（未ロードの場合）
      var loadPayPalSDK = function(clientId) {
        return new Promise(function(resolve, reject) {
          if (window.paypal) { resolve(window.paypal); return; }
          var script = document.createElement('script');
          script.src = 'https://www.paypal.com/sdk/js?client-id=' + clientId + '&currency=USD&intent=capture&locale=en_US';
          script.onload = function() { resolve(window.paypal); };
          script.onerror = reject;
          document.head.appendChild(script);
        });
      };

      // PayPal client IDをAPIから取得
      var configRes = await fetch('/api/concierge/pay', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'config' })
      });
      var configData = await configRes.json();
      var clientId = configData.client_id || '';

      if (!clientId) {
        addMsg('❌ PayPal configuration error.', 'assistant');
        if (submitBtn) { submitBtn.disabled = false; submitBtn.style.display = ''; submitBtn.textContent = '💳 Pay $7 via PayPal → AI Booking'; }
        return;
      }

      await loadPayPalSDK(clientId);

      window.paypal.Buttons({
        createOrder: function() { return paypalOrderId; },
        onApprove: async function(ppData) {
          paypalContainer.innerHTML = '<p style="color:#4ade80;font-size:12px;text-align:center;">Processing payment...</p>';
          // Step 3: capture
          var capRes = await fetch('/api/concierge/pay', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              action: 'capture',
              order_id: ppData.orderID,
              group_id: groupId,
              session_id: sessionId,
              guest_name: name,
              guest_email: email
            })
          });
          var capData = await capRes.json();
          if (capData.status === 'paid') {
            paypalContainer.innerHTML = '';
            // Step 4: 電話発信
            var callRes = await fetch('/api/concierge/chat', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                session_id: sessionId,
                message: '__confirm_group_payment:' + groupId,
                locale: document.documentElement.lang || 'en',
                guest_name: name,
                guest_email: email
              })
            });
            var callData = await callRes.json();
            var hotelListText = selectedHotels.map(function(h, i){ return (i+1) + '. ' + h.name; }).join('\n');
            addMsg('✅ Payment confirmed! Our AI will call the following hotel' + (selectedHotels.length > 1 ? 's in order' : '') + ':\n\n' + hotelListText + '\n\n👤 ' + name + '\n📅 ' + date + ' ' + checkinTime + '–' + checkoutTime, 'assistant');
            // 発信開始 → 1件目の通話状態ポーリングを開始
            var firstCallId = callData?.metadata?.call_id;
            if (firstCallId) {
              window._startCallPolling(firstCallId, sessionId, document.documentElement.lang || 'en');
            }
          } else {
            paypalContainer.innerHTML = '';
            addMsg('❌ Payment failed. Please try again.', 'assistant');
            if (submitBtn) { submitBtn.disabled = false; submitBtn.style.display = ''; submitBtn.textContent = '💳 Pay $7 via PayPal → AI Booking'; }
          }
        },
        onCancel: function() {
          paypalContainer.innerHTML = '';
          if (submitBtn) { submitBtn.disabled = false; submitBtn.style.display = ''; submitBtn.textContent = '💳 Pay $7 via PayPal → AI Booking'; }
          addMsg('Payment cancelled.', 'assistant');
        },
        onError: function(err) {
          paypalContainer.innerHTML = '';
          if (submitBtn) { submitBtn.disabled = false; submitBtn.style.display = ''; submitBtn.textContent = '💳 Pay $7 via PayPal → AI Booking'; }
          addMsg('❌ PayPal error. Please try again.', 'assistant');
        }
      }).render('#call-paypal-container');

      if (submitBtn) submitBtn.textContent = 'Complete payment above ↑';

    } catch(e) {
      addMsg('❌ Network error. Please try again.', 'assistant');
      if (submitBtn) { submitBtn.disabled = false; submitBtn.style.display = ''; submitBtn.textContent = '💳 Pay $7 via PayPal → AI Booking'; }
    }
  };

