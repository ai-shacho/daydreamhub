---
import Layout from '../layouts/Layout.astro';
import ChatWidget from '../components/ChatWidget.astro';

const env = (Astro.locals as any).runtime?.env;
const DB = env?.DB;

// Speciality tab filter from URL
const activeSpeciality = Astro.url.searchParams.get('speciality') || '';

// Speciality definitions
const specialities = [
  { value: '', label: 'All Types' },
  { value: 'daycation', label: 'Daycation' },
  { value: 'for_couple', label: 'For Couple' },
  { value: 'for_work', label: 'For Work' },
  { value: 'luxury', label: 'Luxury' },
  { value: 'personal_time', label: 'Personal Time' },
  { value: 'transit_use', label: 'Transit Use' },
  { value: 'workspace', label: 'Workspace' },
];

// Category sections to display
const categoryDefs = [
  { planType: 'workspace', title: 'Workspace', subtitle: 'Coworking spaces & hot desks', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
  { planType: 'for_couple', title: 'Romantic Hotels', subtitle: 'Perfect for couples', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { planType: 'luxury', title: 'Luxury Hotels', subtitle: 'Premium day-use experiences', icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z' },
  { planType: 'personal_time', title: 'Rest Hotels', subtitle: 'Relax and recharge', icon: 'M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z' },
  { planType: 'daycation', title: 'Daycation', subtitle: 'Day trips and experiences', icon: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z' },
];

// Fetch data from DB
let heroHotels: any[] = [];
let categoryHotels: Record<string, any[]> = {};
let allCities: any[] = [];
let totalHotels = 0;
let totalPlans = 0;
let recentBlogs: any[] = [];
let mapHotels: any[] = [];

try {
  if (DB) {
    // Fetch hotels for speciality tab (top section)
    if (activeSpeciality) {
      const result = await DB.prepare(
        `SELECT DISTINCT h.id, h.name, h.slug, h.city, h.country, h.property_type, h.thumbnail_url, h.rating,
                MIN(p.price_usd) as min_price
         FROM hotels h
         JOIN plans p ON p.hotel_id = h.id AND p.plan_type = ?1
         WHERE h.is_active = 1
         GROUP BY h.id
         ORDER BY h.rating DESC
         LIMIT 12`
      ).bind(activeSpeciality).all();
      heroHotels = result?.results ?? [];
    } else {
      const result = await DB.prepare(
        `SELECT h.id, h.name, h.slug, h.city, h.country, h.property_type, h.thumbnail_url, h.rating,
                MIN(p.price_usd) as min_price
         FROM hotels h LEFT JOIN plans p ON p.hotel_id = h.id
         WHERE h.is_active = 1
         GROUP BY h.id
         ORDER BY h.rating DESC
         LIMIT 12`
      ).all();
      heroHotels = result?.results ?? [];
    }

    // Fetch hotels per category
    for (const cat of categoryDefs) {
      const result = await DB.prepare(
        `SELECT DISTINCT h.id, h.name, h.slug, h.city, h.country, h.property_type, h.thumbnail_url, h.rating,
                MIN(p.price_usd) as min_price
         FROM hotels h
         JOIN plans p ON p.hotel_id = h.id AND p.plan_type = ?1
         WHERE h.is_active = 1
         GROUP BY h.id
         ORDER BY h.rating DESC
         LIMIT 6`
      ).bind(cat.planType).all();
      categoryHotels[cat.planType] = result?.results ?? [];
    }

    // Get city counts for "Search by City" (all cities for region grouping)
    const cityResult = await DB.prepare(
      `SELECT city, country, COUNT(*) as hotel_count
       FROM hotels WHERE city != '' AND is_active = 1
       GROUP BY city ORDER BY hotel_count DESC LIMIT 60`
    ).all();
    allCities = cityResult?.results ?? [];

    // Stats
    const statsH = await DB.prepare("SELECT COUNT(*) as c FROM hotels WHERE is_active = 1").first();
    totalHotels = statsH?.c || 0;
    const statsP = await DB.prepare("SELECT COUNT(*) as c FROM plans WHERE is_active = 1").first();
    totalPlans = statsP?.c || 0;

    // Recent blog posts
    const blogResult = await DB.prepare(
      `SELECT id, title, slug, excerpt, thumbnail_url, city, published_at
       FROM blog_posts ORDER BY published_at DESC LIMIT 3`
    ).all();
    recentBlogs = blogResult?.results ?? [];

    // Map hotels (with lat/lng)
    const mapResult = await DB.prepare(
      `SELECT id, name, slug, city, country, latitude, longitude, thumbnail_url,
              MIN(p.price_usd) as min_price
       FROM hotels h LEFT JOIN plans p ON p.hotel_id = h.id
       WHERE h.is_active = 1 AND h.latitude IS NOT NULL AND h.longitude IS NOT NULL
       GROUP BY h.id LIMIT 100`
    ).all();
    mapHotels = mapResult?.results ?? [];
  }
} catch (e) {
  console.error('Index DB error:', e);
}

// City images (unsplash fallbacks)
const cityImages: Record<string, string> = {
  'Bangkok': 'photo-1508009603885-50cf7c579365',
  'Tokyo': 'photo-1540959733332-eab4deabeeaf',
  'Bali': 'photo-1537996194471-e657df975ab4',
  'Singapore': 'photo-1525625293386-3f8f99389edd',
  'Dubai': 'photo-1512453979798-5ea266f8880c',
  'London': 'photo-1513635269975-59663e0ac1ad',
  'Seoul': 'photo-1534274988757-a28bf68a75c0',
  'Kuala Lumpur': 'photo-1596422846543-75c6fc197f07',
  'Jakarta': 'photo-1555899434-94d1368aa7af',
  'Osaka': 'photo-1590559899731-a382839e5549',
  'Kyoto': 'photo-1493976040374-85c8e12f0c0e',
  'Ho Chi Minh City': 'photo-1583417319070-4a69db38a482',
};

function getHotelImage(hotel: any): string {
  if (hotel.thumbnail_url) return hotel.thumbnail_url;
  return 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=600&q=80';
}

function getCityImage(city: string): string {
  const key = cityImages[city];
  if (key) return `https://images.unsplash.com/${key}?w=400&q=80`;
  return 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=400&q=80';
}

// Speciality card data for "Search by Speciality" section
const specialityCards = [
  { value: 'daycation', label: 'Daycation', desc: 'Day trips & experiences', color: 'bg-amber-50 text-amber-700 border-amber-200', iconPath: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z' },
  { value: 'for_couple', label: 'For Couple', desc: 'Romantic getaways', color: 'bg-pink-50 text-pink-700 border-pink-200', iconPath: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { value: 'for_work', label: 'For Work', desc: 'Remote work spaces', color: 'bg-blue-50 text-blue-700 border-blue-200', iconPath: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
  { value: 'luxury', label: 'Luxury', desc: 'Premium experiences', color: 'bg-purple-50 text-purple-700 border-purple-200', iconPath: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z' },
  { value: 'personal_time', label: 'Personal Time', desc: 'Rest & relaxation', color: 'bg-green-50 text-green-700 border-green-200', iconPath: 'M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z' },
  { value: 'transit_use', label: 'Transit Use', desc: 'Airport & station stays', color: 'bg-sky-50 text-sky-700 border-sky-200', iconPath: 'M12 19l9 2-9-18-9 18 9-2zm0 0v-8' },
  { value: 'workspace', label: 'Workspace', desc: 'Coworking & meeting rooms', color: 'bg-teal-50 text-teal-700 border-teal-200', iconPath: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
];

// Room types for "Search by Room Type"
const roomTypes = [
  { label: 'Hotel', value: 'Hotel', img: 'photo-1566073771259-6a8506099945' },
  { label: 'Villa', value: 'Villa', img: 'photo-1600596542815-ffad4c1539a9' },
  { label: 'Resort', value: 'Resort', img: 'photo-1520250497591-112f2f40a3f4' },
  { label: 'Hostel', value: 'Hostel', img: 'photo-1555854877-bab0e564b8d5' },
  { label: 'Apartment', value: 'Apartment', img: 'photo-1522708323590-d24dbb6b0267' },
  { label: 'Boutique Hotel', value: 'Boutique Hotel', img: 'photo-1551882547-ff40c63fe5fa' },
];

// Region mapping (country → region)
const countryRegion: Record<string, string> = {
  // Asia
  'Thailand': 'Asia', 'Japan': 'Asia', 'Indonesia': 'Asia', 'Malaysia': 'Asia',
  'Singapore': 'Asia', 'Vietnam': 'Asia', 'Philippines': 'Asia', 'Cambodia': 'Asia',
  'Myanmar': 'Asia', 'Laos': 'Asia', 'South Korea': 'Asia', 'China': 'Asia',
  'Hong Kong': 'Asia', 'Taiwan': 'Asia', 'Sri Lanka': 'Asia', 'Nepal': 'Asia',
  'Bangladesh': 'Asia', 'India': 'Asia', 'Maldives': 'Asia',
  // Middle East
  'UAE': 'Middle East', 'Qatar': 'Middle East', 'Bahrain': 'Middle East',
  'Saudi Arabia': 'Middle East', 'Kuwait': 'Middle East', 'Oman': 'Middle East',
  'Jordan': 'Middle East', 'Lebanon': 'Middle East', 'Israel': 'Middle East',
  'Turkey': 'Middle East', 'Iran': 'Middle East', 'Iraq': 'Middle East',
  // Europe
  'United Kingdom': 'Europe', 'Germany': 'Europe', 'France': 'Europe',
  'Netherlands': 'Europe', 'Spain': 'Europe', 'Italy': 'Europe', 'Portugal': 'Europe',
  'Belgium': 'Europe', 'Switzerland': 'Europe', 'Austria': 'Europe',
  'Sweden': 'Europe', 'Norway': 'Europe', 'Denmark': 'Europe', 'Finland': 'Europe',
  'Poland': 'Europe', 'Czech Republic': 'Europe', 'Hungary': 'Europe',
  'Romania': 'Europe', 'Bulgaria': 'Europe', 'Serbia': 'Europe', 'Croatia': 'Europe',
  'Georgia': 'Europe', 'Ukraine': 'Europe', 'Russia': 'Europe',
  // Africa
  'Nigeria': 'Africa', 'Kenya': 'Africa', 'Ghana': 'Africa', 'South Africa': 'Africa',
  'Tanzania': 'Africa', 'Ethiopia': 'Africa', 'Uganda': 'Africa', 'Rwanda': 'Africa',
  'Senegal': 'Africa', 'Egypt': 'Africa', 'Morocco': 'Africa', 'Tunisia': 'Africa',
  // Oceania
  'Australia': 'Oceania', 'New Zealand': 'Oceania', 'Fiji': 'Oceania',
  // Americas
  'United States': 'Americas', 'Canada': 'Americas', 'Mexico': 'Americas',
  'Brazil': 'Americas', 'Argentina': 'Americas', 'Colombia': 'Americas',
  // Central Asia
  'Uzbekistan': 'Central Asia', 'Kazakhstan': 'Central Asia', 'Kyrgyzstan': 'Central Asia',
  'Tajikistan': 'Central Asia', 'Turkmenistan': 'Central Asia', 'Afghanistan': 'Central Asia',
  'Mongolia': 'Central Asia',
  // South Asia
  'Pakistan': 'South Asia', 'Bhutan': 'South Asia',
  // Country abbreviations
  'UK': 'Europe', 'USA': 'Americas', 'US': 'Americas',
  // Europe (additional)
  'Armenia': 'Europe', 'Azerbaijan': 'Europe', 'Albania': 'Europe',
  'Bosnia and Herzegovina': 'Europe', 'North Macedonia': 'Europe',
  'Moldova': 'Europe', 'Belarus': 'Europe', 'Estonia': 'Europe',
  'Latvia': 'Europe', 'Lithuania': 'Europe', 'Slovenia': 'Europe',
  'Slovakia': 'Europe', 'Luxembourg': 'Europe', 'Malta': 'Europe',
  'Iceland': 'Europe', 'Ireland': 'Europe', 'Greece': 'Europe',
  // Americas (additional)
  'Ecuador': 'Americas', 'Peru': 'Americas', 'Chile': 'Americas',
  'Bolivia': 'Americas', 'Venezuela': 'Americas', 'Uruguay': 'Americas',
  'Paraguay': 'Americas', 'Panama': 'Americas', 'Costa Rica': 'Americas',
  'Guatemala': 'Americas', 'Honduras': 'Americas', 'El Salvador': 'Americas',
  'Nicaragua': 'Americas', 'Cuba': 'Americas', 'Jamaica': 'Americas',
  'Dominican Republic': 'Americas', 'Trinidad and Tobago': 'Americas',
};

const regionOrder = ['Asia', 'Middle East', 'Europe', 'Africa', 'Oceania', 'Americas', 'Central Asia', 'South Asia'];

// City-level overrides for edge cases (empty country, etc.)
const cityRegionOverride: Record<string, string> = {
  'Goris': 'Europe', // Armenia
};

// Group cities by region (fallback: check if country name appears in city name)
const citiesByRegion: Record<string, any[]> = {};
for (const city of allCities) {
  let region = cityRegionOverride[city.city] || countryRegion[city.country];
  // Fallback: scan all country keys to see if city string contains a known country
  if (!region) {
    for (const [country, r] of Object.entries(countryRegion)) {
      if (city.city?.includes(country) || city.country?.includes(country)) {
        region = r;
        break;
      }
    }
  }
  region = region || 'Other';
  if (!citiesByRegion[region]) citiesByRegion[region] = [];
  citiesByRegion[region].push(city);
}
// Sort each region's cities: group by country (alphabetical), then by hotel_count desc within country
for (const region of Object.keys(citiesByRegion)) {
  citiesByRegion[region].sort((a: any, b: any) => {
    const cmp = (a.country || '').localeCompare(b.country || '');
    if (cmp !== 0) return cmp;
    return b.hotel_count - a.hotel_count;
  });
}
const availableRegions = regionOrder.filter(r => citiesByRegion[r]?.length > 0);
if (citiesByRegion['Other']?.length) availableRegions.push('Other');

// Unique city count
const uniqueCityCount = new Set(allCities.map((c: any) => c.city)).size || 85;
---

<Layout title="DayDreamHub - Hotels by the Hour, Worldwide">

  <!-- Hero Section -->
  <section class="relative min-h-[600px] md:min-h-[700px] flex items-center overflow-hidden">
    <div id="hero-slide-0" class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000 opacity-100" style="background-image:url('https://images.unsplash.com/photo-1566073771259-6a8506099945?w=1600&q=80')"></div>
    <div id="hero-slide-1" class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000 opacity-0" style="background-image:url('https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=1600&q=80')"></div>
    <div id="hero-slide-2" class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000 opacity-0" style="background-image:url('https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=1600&q=80')"></div>
    <div class="absolute inset-0 bg-teal-900/80"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 py-16 w-full">
      <div class="text-center text-white mb-8">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-4">Hotels by the Hour. {uniqueCityCount}+ Cities Worldwide.</h1>
        <p class="text-lg md:text-xl text-teal-100 max-w-3xl mx-auto mb-6">The day-use hotel booking platform - find short-stay plans for work, rest, or transit.</p>
        <div class="flex flex-wrap justify-center gap-3 mb-8">
          <span class="bg-white/15 backdrop-blur-sm border border-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full">From 1 hour</span>
          <span class="bg-white/15 backdrop-blur-sm border border-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full">Half the overnight price</span>
          <span class="bg-white/15 backdrop-blur-sm border border-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full">AI instant search</span>
        </div>
      </div>

      <!-- Search Form -->
      <div class="max-w-4xl mx-auto">
        <form action="/search" method="get" class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-4">
          <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
            <div>
              <label class="block text-xs text-teal-100 mb-1 font-medium">Location</label>
              <input type="text" name="location" placeholder="City or country..." class="w-full rounded-lg px-3 py-2.5 text-sm bg-white text-gray-800 focus:outline-none focus:ring-2 focus:ring-amber-400" />
            </div>
            <div>
              <label class="block text-xs text-teal-100 mb-1 font-medium">Check-in</label>
              <input type="text" name="checkin" id="checkin-input" placeholder="MM / DD / YYYY" class="w-full rounded-lg px-3 py-2.5 text-sm bg-white text-gray-800 focus:outline-none focus:ring-2 focus:ring-amber-400" onfocus="this.type='date';this.placeholder=''" onblur="if(!this.value){this.type='text';this.placeholder='MM / DD / YYYY'}" />
            </div>
            <div>
              <label class="block text-xs text-teal-100 mb-1 font-medium">Speciality</label>
              <select name="speciality" class="w-full rounded-lg px-3 py-2.5 text-sm bg-white text-gray-800 focus:outline-none focus:ring-2 focus:ring-amber-400">
                <option value="">All Types</option>
                {specialities.filter(s => s.value).map(s => (
                  <option value={s.value}>{s.label}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-xs text-teal-100 mb-1 font-medium">Guests</label>
              <select name="guests" class="w-full rounded-lg px-3 py-2.5 text-sm bg-white text-gray-800 focus:outline-none focus:ring-2 focus:ring-amber-400">
                {[1, 2, 3, 4].map(n => (
                  <option value={n}>{n} {n === 1 ? 'guest' : 'guests'}</option>
                ))}
              </select>
            </div>
            <div class="flex items-end">
              <button type="submit" class="w-full bg-amber-500 hover:bg-amber-400 text-gray-900 font-semibold px-6 py-2.5 rounded-lg transition-colors text-sm">Search</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-teal-700 text-white py-6">
    <div class="max-w-5xl mx-auto px-4 grid grid-cols-3 text-center divide-x divide-teal-600">
      <div>
        <div class="text-2xl md:text-3xl font-bold">{totalHotels || '350'}+</div>
        <div class="text-xs md:text-sm text-teal-100 mt-1">Day-Use Hotels</div>
      </div>
      <div>
        <div class="text-2xl md:text-3xl font-bold">{uniqueCityCount}+</div>
        <div class="text-xs md:text-sm text-teal-100 mt-1">Cities</div>
      </div>
      <div>
        <div class="text-2xl md:text-3xl font-bold">{totalPlans || '1200'}+</div>
        <div class="text-xs md:text-sm text-teal-100 mt-1">Short-Stay Plans</div>
      </div>
    </div>
  </section>

  <!-- Speciality Tabs -->
  <section class="py-10 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-800 mb-5">Browse by Speciality</h2>

      <!-- Tab buttons -->
      <div class="flex gap-2 overflow-x-auto pb-3 -mx-4 px-4 scrollbar-hide mb-6">
        {specialities.map(s => (
          <a
            href={s.value ? `/?speciality=${s.value}` : '/'}
            class:list={[
              "flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium border transition-colors",
              activeSpeciality === s.value
                ? "bg-teal-700 text-white border-teal-700"
                : "bg-gray-50 text-gray-700 border-gray-200 hover:bg-teal-50 hover:border-teal-300"
            ]}
          >
            {s.label}
          </a>
        ))}
      </div>

      <!-- Hotels grid -->
      {heroHotels.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
          {heroHotels.map((hotel: any) => (
            <a href={`/hotel/${hotel.slug}`} class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow border border-gray-100">
              <div class="aspect-[4/3] overflow-hidden bg-gray-100">
                <img src={getHotelImage(hotel)} alt={hotel.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              </div>
              <div class="p-4">
                <h3 class="font-semibold text-gray-800 text-sm leading-snug line-clamp-2 group-hover:text-teal-700 transition-colors">{hotel.name}</h3>
                <p class="text-xs text-gray-500 mt-1 flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  {hotel.city}, {hotel.country}
                </p>
                <div class="flex items-center justify-between mt-3 pt-2 border-t border-gray-100">
                  {hotel.min_price != null ? (
                    <div>
                      <span class="text-xs text-gray-400">from</span>
                      <span class="text-lg font-bold text-teal-700 ml-1">${hotel.min_price}</span>
                    </div>
                  ) : (
                    <span class="text-xs text-gray-400">Price on request</span>
                  )}
                  {hotel.property_type && (
                    <span class="text-[10px] bg-teal-50 text-teal-700 px-2 py-0.5 rounded-full">{hotel.property_type}</span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="py-12 text-center text-gray-400">
          <p>No hotels found for this speciality.</p>
        </div>
      )}

      <div class="text-center mt-6">
        <a href={activeSpeciality ? `/search?speciality=${activeSpeciality}` : '/search'} class="inline-flex items-center gap-2 text-teal-700 hover:text-teal-800 font-semibold text-sm">
          View all
