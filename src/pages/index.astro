  <script is:inline define:vars={{ mapHotels }}>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof window === 'undefined') return;
      var mapEl = document.getElementById('homepage-map');
      if (!mapEl) return;

      // Load Leaflet dynamically
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
      document.head.appendChild(link);

      var script = document.createElement('script');
      script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      script.onload = function() {
        mapEl.innerHTML = '';
        var map = L.map('homepage-map', { scrollWheelZoom: false }).setView([13.75, 100.5], 3);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        (mapHotels || []).forEach(function(h) {
          if (!h.latitude || !h.longitude) return;
          var marker = L.circleMarker([h.latitude, h.longitude], {
            radius: 7,
            fillColor: '#0d9488',
            color: '#fff',
            weight: 2,
            opacity: 1,
            fillOpacity: 0.9
          }).addTo(map);
          marker.bindPopup(
            '<a href="/hotel/' + h.slug + '" class="font-semibold text-teal-700">' + h.name + '</a>' +
            '<br><span class="text-xs text-gray-500">' + h.city + ', ' + h.country + '</span>' +
            (h.min_price ? '<br><span class="text-xs font-bold">from $' + h.min_price + '</span>' : '')
          );
        });
      };
      document.head.appendChild(script);
    });
  </script>

