<!-- Hero AI Chatbot -->
<script is:inline>
(function() {
  var sessionId = 'hero_' + Math.random().toString(36).slice(2, 11);
  var pendingImageKey = null;
  var isSending = false;

  var messagesEl = document.getElementById('hero-chat-messages');
  var inputEl    = document.getElementById('hero-chat-input');
  var sendBtn    = document.getElementById('hero-chat-send');
  var uploadEl   = document.getElementById('hero-flight-upload');
  var uploadStatus = document.getElementById('hero-upload-status');
  var uploadName   = document.getElementById('hero-upload-name');

  if (!messagesEl || !inputEl || !sendBtn) return;

  // --- helpers ---
  function getFormContext() {
    var checkin  = document.getElementById('checkin-fp')?.value || '';
    var ciTime   = document.querySelector('select[name="checkin_time"]')?.value || '';
    var coTime   = document.querySelector('select[name="checkout_time"]')?.value || '';
    var guests   = document.querySelector('select[name="guests"]')?.value || '1';
    var budget   = document.querySelector('select[name="budget"]')?.value || '';
    var parts = [];
    if (checkin)  parts.push('Date: ' + checkin);
    if (ciTime)   parts.push('Check-in: ' + ciTime);
    if (coTime)   parts.push('Check-out: ' + coTime);
    if (guests)   parts.push('Guests: ' + guests);
    if (budget)   parts.push('Budget: ' + budget);
    return parts.length ? '[' + parts.join(', ') + '] ' : '';
  }

  function showMessages() {
    messagesEl.classList.remove('hidden');
  }

  // Parse hotel slugs from text (e.g. /hotel/some-slug)
  function extractHotelSlugs(text) {
    var slugs = [];
    var re = /\/hotel\/([\w-]+)/g;
    var m;
    while ((m = re.exec(text)) !== null) {
      if (!slugs.includes(m[1])) slugs.push(m[1]);
    }
    return slugs;
  }

  // Render text with hotel links converted to clickable cards
  function renderMsgContent(text) {
    // XSS対策: HTMLエスケープ（リンク変換前に実施）
    var html = text
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');

    // Markdown: ### 見出し
    html = html.replace(/^### (.+)$/gm, '<strong class="block text-amber-300 text-sm mt-2">$1</strong>');
    html = html.replace(/^## (.+)$/gm, '<strong class="block text-amber-200 text-sm mt-2 mb-1">$1</strong>');
    html = html.replace(/^# (.+)$/gm, '<strong class="block text-white text-base mt-2 mb-1">$1</strong>');

    // Markdown: **太字**
    html = html.replace(/\*\*([^*\n]+)\*\*/g, '<strong>$1</strong>');
    // Markdown: *斜体*
    html = html.replace(/\*([^*\n]+)\*/g, '<em>$1</em>');

    // Markdown: --- 区切り線
    html = html.replace(/^---+$/gm, '<hr class="border-white/20 my-2"/>');

    // Markdown: - リスト項目
    html = html.replace(/^[-•]\s+(.+)$/gm, '<span class="flex gap-1.5"><span class="text-amber-400 flex-shrink-0">•</span><span>$1</span></span>');

    // Hotel links: [text](http.../hotel/slug...)
    html = html.replace(/\[([^\]]+)\]\((https?:\/\/[^)]*?\/hotel\/([\w-]+)[^)]*)\)/g,
      '<a href="/hotel/$3" target="_blank" class="underline text-amber-300 hover:text-amber-200">$1</a>');
    // Hotel links: [text](/hotel/slug)
    html = html.replace(/\[([^\]]+)\]\((\/hotel\/([\w-]+))\)/g,
      '<a href="/hotel/$3" target="_blank" class="underline text-amber-300 hover:text-amber-200">$1</a>');
    // Bare /hotel/slug
    html = html.replace(/(\/hotel\/([\w-]+))/g,
      '<a href="$1" target="_blank" class="underline text-amber-300 hover:text-amber-200">$1</a>');

    // 通常リンク [text](url)
    html = html.replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g,
      '<a href="$2" target="_blank" class="underline text-amber-300 hover:text-amber-200">$1</a>');

    return html;
  }

  // 外部ホテル情報をテキストから抽出
  // 📞 電話番号を持つ行をすべて外部ホテルとして扱う（/hotel/slugがない場合）
  function extractExternalHotels(text) {
    var hotels = [];
    var lines = text.split('\n');
    lines.forEach(function(line) {
      // 📞または電話番号パターンを含む行を探す
      var phoneMatch = line.match(/📞\s*([\+\d][\d\s\-\(\)\.]{6,20})/);
      if (!phoneMatch) return;
      var phone = phoneMatch[1].trim();
      // ホテル名を抽出: **名前** または行頭の数字. 名前
      var nameParts = line.match(/\*\*(.*?)\*\*/);
      if (!nameParts) nameParts = line.match(/^\s*\d+\.\s+(.+?)(?:\s*[|｜]|\s*📍|\s*📞)/);
      if (!nameParts) nameParts = line.match(/^\s*[-•]\s+(.+?)(?:\s*[|｜]|\s*📍|\s*📞)/);
      var name = nameParts ? nameParts[1].replace(/\*\*/g, '').trim() : '';
      if (!name || name.length < 2) return;
      // /hotel/slug がある行（自社ホテル）は除外
      if (line.indexOf('/hotel/') !== -1) return;
      hotels.push({ name: name, phone: phone });
    });
    return hotels;
  }

  function addMsg(text, role) {
    showMessages();
    var wrap = document.createElement('div');
    wrap.className = 'flex gap-2' + (role === 'user' ? ' flex-row-reverse' : '');
    if (role === 'assistant') {
      var slugs = extractHotelSlugs(text);
      var externalHotels = extractExternalHotels(text);

      // 自社ホテル: Book Now ボタン（無料）
      var bookBtns = slugs.map(function(slug) {
        return '<button onclick="window._heroBookNow(\'' + slug + '\', this)" ' +
          'class="flex items-center gap-1.5 bg-amber-500 hover:bg-amber-400 text-gray-900 text-xs font-bold px-3 py-1.5 rounded-lg transition-colors">' +
          '🏨 Book Now — ' + slug.replace(/-/g, ' ').replace(/\b\w/g, function(c){ return c.toUpperCase(); }).slice(0,30) +
          '</button>';
      }).join('');

      // 外部ホテル: Call to Book ボタン（$7）
      var callBtns = externalHotels.map(function(h) {
        var safePhone = h.phone.replace(/'/g, '');
        var safeName = h.name.replace(/'/g, '').slice(0, 40);
        return '<button onclick="window._heroCallBook(\'' + safeName + '\',\'' + safePhone + '\', this)" ' +
          'class="flex items-center gap-1.5 bg-blue-500 hover:bg-blue-400 text-white text-xs font-bold px-3 py-1.5 rounded-lg transition-colors">' +
          '📞 Call to Book (+$7) — ' + h.name.slice(0, 28) +
          '</button>';
      }).join('');

      var allBtns = bookBtns + callBtns;
      wrap.innerHTML =
        '<div class="w-6 h-6 bg-white/20 rounded-full flex-shrink-0 flex items-center justify-center text-white text-[10px] font-bold mt-0.5">AI</div>' +
        '<div class="bg-white/20 text-white rounded-xl rounded-tl-none px-3 py-2.5 text-sm max-w-[85%] shadow border border-white/10">' +
          '<div class="whitespace-pre-wrap leading-relaxed">' + renderMsgContent(text) + '</div>' +
          (allBtns ? '<div class="flex flex-wrap gap-2 mt-2.5">' + allBtns + '</div>' : '') +
        '</div>';
    } else {
      wrap.innerHTML =
        '<div class="bg-amber-500 text-gray-900 rounded-xl rounded-tr-none px-3 py-2 text-sm max-w-[85%] font-medium">' + text + '</div>';
    }
    messagesEl.appendChild(wrap);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  // ===== Call Status Polling =====
  window._startCallPolling = function(callId, sid, loc) {
    var maxAttempts = 36; // 最大3分（5秒×36回）
    var attempt = 0;
    var waitEl = document.createElement('div');
    waitEl.id = 'call-polling-' + callId;
    waitEl.className = 'flex gap-2';
    waitEl.innerHTML =
      '<div class="w-6 h-6 bg-white/20 rounded-full flex-shrink-0 flex items-center justify-center text-white text-[10px] font-bold mt-0.5">AI</div>' +
      '<div class="bg-white/20 text-white/80 rounded-xl rounded-tl-none px-3 py-2 text-sm border border-white/10">' +
        '<span class="inline-block w-2 h-2 rounded-full bg-amber-400 animate-pulse mr-2"></span>' +
        '📞 AIがホテルに電話中... / Calling hotel...' +
      '</div>';
    messagesEl.appendChild(waitEl);
    messagesEl.scrollTop = messagesEl.scrollHeight;

    var timer = setInterval(async function() {
      attempt++;
      if (attempt > maxAttempts) {
        clearInterval(timer);
        waitEl.remove();
        addMsg('⏱️ 電話の結果を取得できませんでした。しばらく後に確認してください。 / Call timed out.', 'assistant');
        return;
      }
      try {
        var r = await fetch('/api/concierge/chat', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({session_id: sid, message: '__check_call_status:' + callId, locale: loc || 'en'})
        });
        var d = await r.json();
        var status = d.metadata?.call_status || d.metadata?.status;
        if (status === 'calling' || status === 'pending') return; // まだ通話中
        // 完了・失敗・その他
        clearInterval(timer);
        waitEl.remove();
        if (d.response) addMsg(d.response, 'assistant');

        // 全件失敗 → 返金通知
        if (status === 'failed' && d.metadata?.failed_count >= 1) {
          setTimeout(function(){
            addMsg(
              '💸 **全ホテルへの電話が繋がりませんでした。**\n\n' +
              '$7の料金は自動的に全額返金されます（PayPal処理に2〜5営業日）。\n\n' +
              '別の日時や別の都市で再度お試しください。',
              'assistant'
            );
          }, 1000);
        }
      } catch(e) { /* retry */ }
    }, 5000); // 5秒ごとにポーリング
  };

  // ===== External Hotel Call Booking Flow ($7) =====
  window._heroCallBook = async function(hotelName, hotelPhone, btn) {
    btn.disabled = true;
    btn.textContent = 'Loading...';

    // フォームをチャットに表示
    var messagesEl = document.getElementById('hero-chat-messages');
    var formDiv = document.createElement('div');
    formDiv.className = 'flex gap-2';
    // 今日の日付をデフォルト値に
    var today = new Date().toISOString().split('T')[0];
    var safeName = hotelName.replace(/'/g, '&#39;');
    var safePhone = hotelPhone.replace(/'/g, '');
    formDiv.innerHTML =
      '<div class="w-6 h-6 bg-white/20 rounded-full flex-shrink-0 flex items-center justify-center text-white text-[10px] font-bold mt-0.5">AI</div>' +
      '<div class="bg-gray-900/80 border border-white/20 text-white rounded-xl rounded-tl-none px-4 py-3 text-sm max-w-[92%] w-full" id="call-booking-form">' +
        '<p class="font-bold text-base mb-1">📞 AI電話予約代行</p>' +
        '<p class="text-amber-300 text-xs font-medium mb-3">🏨 ' + safeName + '</p>' +
        '<p class="text-white/70 text-xs mb-3">AIがホテルに電話して空き状況を確認します。<br>サービス料 <strong class="text-amber-400">$7</strong>（全件不成立時は全額返金）</p>' +
        '<div class="space-y-2">' +
          '<div>' +
            '<label class="text-xs text-white/60 block mb-1">お名前 / Your Name</label>' +
            '<input id="call-guest-name" type="text" placeholder="Taro Yamada" class="w-full bg-white/10 text-white placeholder-white/30 rounded-lg px-3 py-2 text-sm border border-white/20 focus:border-amber-400 focus:outline-none" />' +
          '</div>' +
          '<div>' +
            '<label class="text-xs text-white/60 block mb-1">メール / Email</label>' +
            '<input id="call-guest-email" type="email" placeholder="your@email.com" class="w-full bg-white/10 text-white placeholder-white/30 rounded-lg px-3 py-2 text-sm border border-white/20 focus:border-amber-400 focus:outline-none" />' +
          '</div>' +
          '<div class="grid grid-cols-2 gap-2">' +
            '<div>' +
              '<label class="text-xs text-white/60 block mb-1">📅 チェックイン日</label>' +
              '<input id="call-checkin-date" type="date" value="' + today + '" class="w-full bg-white/10 text-white rounded-lg px-3 py-2 text-sm border border-white/20 focus:border-amber-400 focus:outline-none" />' +
            '</div>' +
            '<div>' +
              '<label class="text-xs text-white/60 block mb-1">🕐 チェックイン時間</label>' +
              '<select id="call-checkin-time" class="w-full bg-white/10 text-white rounded-lg px-3 py-2 text-sm border border-white/20 focus:border-amber-400 focus:outline-none">' +
                ['08:00','09:00','10:00','11:00','12:00','13:00','14:00','15:00','16:00','17:00','18:00'].map(function(t){ return '<option value="' + t + '"' + (t==='10:00'?' selected':'') + '>' + t + '</option>'; }).join('') +
              '</select>' +
            '</div>' +
          '</div>' +
          '<div>' +
            '<label class="text-xs text-white/60 block mb-1">🕔 チェックアウト時間</label>' +
            '<select id="call-checkout-time" class="w-full bg-white/10 text-white rounded-lg px-3 py-2 text-sm border border-white/20 focus:border-amber-400 focus:outline-none">' +
              ['10:00','11:00','12:00','13:00','14:00','15:00','16:00','17:00','18:00','19:00','20:00','21:00','22:00'].map(function(t){ return '<option value="' + t + '"' + (t==='18:00'?' selected':'') + '>' + t + '</option>'; }).join('') +
            '</select>' +
          '</div>' +
        '</div>' +
        '<button onclick="window._heroSubmitCallBook(\'' + safeName + '\',\'' + safePhone + '\')" ' +
          'class="mt-3 w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-2.5 rounded-lg text-sm transition-colors flex items-center justify-center gap-2">' +
          '💳 PayPalで$7支払い → AI電話予約へ進む' +
        '</button>' +
        '<button onclick="document.getElementById(\'call-booking-form\').closest(\'.flex\').remove()" ' +
          'class="mt-2 w-full text-white/40 hover:text-white/70 text-xs py-1 transition-colors">キャンセル / Cancel</button>' +
      '</div>';
    messagesEl.appendChild(formDiv);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    btn.textContent = '📞 Call to Book (+$7)';
    btn.disabled = false;
  };

  window._heroSubmitCallBook = async function(hotelName, hotelPhone) {
    var name = document.getElementById('call-guest-name')?.value?.trim();
    var email = document.getElementById('call-guest-email')?.value?.trim();
    var date = document.getElementById('call-checkin-date')?.value;
    var checkinTime = document.getElementById('call-checkin-time')?.value || '10:00';
    var checkoutTime = document.getElementById('call-checkout-time')?.value || '18:00';
    if (!name || !email || !date) {
      alert('お名前・メール・日付を入力してください / Please fill in name, email, and date');
      return;
    }
    var submitBtn = event?.target;
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = '処理中...'; }

    try {
      // セッションIDを取得
      var sessionId = window._heroSessionId || ('hero-' + Date.now());
      // call_groupを作成（外部ホテル1件）
      var res = await fetch('/api/concierge/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          session_id: sessionId,
          message: '__create_call_group_direct',
          locale: document.documentElement.lang || 'en',
          _call_group: {
            hotels: [{ hotel_name: hotelName, hotel_phone: hotelPhone, hotel_source: 'external' }],
            guest_name: name, guest_email: email, check_in_date: date,
            check_in_time: checkinTime, check_out_time: checkoutTime
          }
        })
      });
      var data = await res.json();
      if (data.paypal_url) {
        window.open(data.paypal_url, '_blank');
        addMsg('✅ PayPalページを開きました。支払い完了後、AIがホテルに電話します。\n\n📞 ' + hotelName + '\n👤 ' + name + '\n📅 ' + date, 'assistant');
      // PayPal完了後にポーリング開始を案内
      setTimeout(function(){
        addMsg('💡 支払い完了後、このチャットに「電話済み」と入力すると結果を確認できます。または自動で結果が届きます。', 'assistant');
      }, 2000);
      } else if (data.error) {
        addMsg('❌ エラー: ' + data.error, 'assistant');
      } else {
        addMsg(data.response || '予約リクエストを受け付けました。', 'assistant');
      }
    } catch(e) {
      addMsg('❌ 通信エラーが発生しました。もう一度お試しください。', 'assistant');
    }
  };

  // ===== Inline Booking Flow =====
  window._heroBookNow = async function(slug, btn) {
    btn.disabled = true;
    btn.textContent = 'Loading...';

    try {
      var res = await fetch('/api/hotels/' + slug + '/plans');
      var data = await res.json();
      if (!data.hotel || !data.plans || data.plans.length === 0) {
        btn.textContent = '❌ No plans available';
        return;
      }
      showBookingForm(data.hotel, data.plans, btn);
    } catch(e) {
      btn.textContent = '❌ Error loading plans';
    }
  };

  function showBookingForm(hotel, plans, btn) {
    // Remove any existing form
    var existing = document.getElementById('hero-booking-form');
    if (existing) existing.remove();

    var planOptions = plans.map(function(p) {
      return '<option value="' + p.id + '">' +
        p.name + ' — $' + p.price_usd +
        (p.check_in_time ? ' (' + p.check_in_time + '–' + p.check_out_time + ')' : '') +
        '</option>';
    }).join('');

    var formEl = document.createElement('div');
    formEl.id = 'hero-booking-form';
    formEl.className = 'flex gap-2 mt-2';
    formEl.innerHTML =
      '<div class="w-6 h-6 flex-shrink-0"></div>' +
      '<div class="bg-white rounded-xl p-4 text-gray-800 text-sm max-w-[90%] w-full shadow-lg">' +
        '<div class="flex items-center justify-between mb-3">' +
          '<p class="font-bold text-gray-900 text-sm">📋 ' + hotel.name + '</p>' +
          '<button onclick="document.getElementById(\'hero-booking-form\').remove()" class="text-gray-400 hover:text-gray-600 text-lg leading-none">&times;</button>' +
        '</div>' +
        '<div class="space-y-2">' +
          '<div>' +
            '<label class="text-xs text-gray-500 font-medium">Plan *</label>' +
            '<select id="hbf-plan" class="w-full mt-0.5 border border-gray-200 rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-teal-500">' +
            planOptions +
            '</select>' +
          '</div>' +
          '<div class="grid grid-cols-2 gap-2">' +
            '<div>' +
              '<label class="text-xs text-gray-500 font-medium">Name *</label>' +
              '<input id="hbf-name" type="text" placeholder="John Doe" class="w-full mt-0.5 border border-gray-200 rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-teal-500" />' +
            '</div>' +
            '<div>' +
              '<label class="text-xs text-gray-500 font-medium">Email *</label>' +
              '<input id="hbf-email" type="email" placeholder="you@email.com" class="w-full mt-0.5 border border-gray-200 rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-teal-500" />' +
            '</div>' +
          '</div>' +
          '<div class="grid grid-cols-3 gap-2">' +
            '<div>' +
              '<label class="text-xs text-gray-500 font-medium">Check-in Date *</label>' +
              '<input id="hbf-date" type="date" class="w-full mt-0.5 border border-gray-200 rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-teal-500" />' +
            '</div>' +
            '<div>' +
              '<label class="text-xs text-gray-500 font-medium">Adults</label>' +
              '<input id="hbf-adults" type="number" value="1" min="1" max="10" class="w-full mt-0.5 border border-gray-200 rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-teal-500" />' +
            '</div>' +
            '<div>' +
              '<label class="text-xs text-gray-500 font-medium">Children</label>' +
              '<input id="hbf-children" type="number" value="0" min="0" max="10" class="w-full mt-0.5 border border-gray-200 rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-teal-500" />' +
            '</div>' +
          '</div>' +
          '<div id="hbf-error" class="hidden text-xs text-red-500 font-medium"></div>' +
          '<button id="hbf-submit" onclick="window._heroSubmitBooking()" ' +
            'class="w-full mt-1 bg-teal-600 hover:bg-teal-700 text-white font-semibold py-2 rounded-lg text-xs transition-colors">' +
            'Confirm Booking' +
          '</button>' +
        '</div>' +
      '</div>';

    messagesEl.appendChild(formEl);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    btn.textContent = '✅ Form opened below';
  }

  window._heroSubmitBooking = async function() {
    var planId   = document.getElementById('hbf-plan')?.value;
    var name     = document.getElementById('hbf-name')?.value.trim();
    var email    = document.getElementById('hbf-email')?.value.trim();
    var date     = document.getElementById('hbf-date')?.value;
    var adults   = parseInt(document.getElementById('hbf-adults')?.value || '1');
    var children = parseInt(document.getElementById('hbf-children')?.value || '0');
    var errEl    = document.getElementById('hbf-error');
    var submitBtn = document.getElementById('hbf-submit');

    if (!planId || !name || !email || !date) {
      errEl.textContent = '⚠️ Please fill in all required fields.';
      errEl.classList.remove('hidden');
      return;
    }
    errEl.classList.add('hidden');
    submitBtn.textContent = 'Processing...';
    submitBtn.disabled = true;

    try {
      var res = await fetch('/api/bookings/direct', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ plan_id: parseInt(planId), guest_name: name, guest_email: email, check_in_date: date, adults: adults, children: children }),
      });
      var data = await res.json();
      if (data.success) {
        // Remove form, show success message
        document.getElementById('hero-booking-form')?.remove();
        addMsg('✅ Booking confirmed!\n\n🏨 ' + data.hotel_name + '\n📋 ' + data.plan_name + '\n📅 ' + date + '\n💰 $' + data.total + ' USD\n\nConfirmation has been sent to ' + email + '.', 'assistant');
      } else {
        errEl.textContent = '❌ ' + (data.error || 'Booking failed. Please try again.');
        errEl.classList.remove('hidden');
        submitBtn.textContent = 'Confirm Booking';
        submitBtn.disabled = false;
      }
    } catch(e) {
      errEl.textContent = '❌ Connection error. Please try again.';
      errEl.classList.remove('hidden');
      submitBtn.textContent = 'Confirm Booking';
      submitBtn.disabled = false;
    }
  };

  function addTyping() {
    var el = document.createElement('div');
    el.id = 'hero-typing';
    el.className = 'flex gap-2';
    el.innerHTML =
      '<div class="w-6 h-6 bg-white/20 rounded-full flex-shrink-0 flex items-center justify-center text-white text-[10px] font-bold mt-0.5">AI</div>' +
      '<div class="bg-white/15 text-white rounded-xl rounded-tl-none px-3 py-2 text-sm flex items-center gap-1">' +
        '<span class="w-1.5 h-1.5 bg-white/60 rounded-full animate-bounce" style="animation-delay:0ms"></span>' +
        '<span class="w-1.5 h-1.5 bg-white/60 rounded-full animate-bounce" style="animation-delay:150ms"></span>' +
        '<span class="w-1.5 h-1.5 bg-white/60 rounded-full animate-bounce" style="animation-delay:300ms"></span>' +
      '</div>';
    messagesEl.appendChild(el);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function removeTyping() {
    var el = document.getElementById('hero-typing');
    if (el) el.remove();
  }

  // --- send message ---
  async function sendMessage() {
    var text = inputEl.value.trim();
    if (!text || isSending) return;

    isSending = true;
    sendBtn.disabled = true;
    inputEl.value = '';

    var ctx = getFormContext();
    var fullMsg = ctx + text;
    addMsg(text, 'user');
    addTyping();

    try {
      var body = { session_id: sessionId, message: fullMsg, locale: 'en' };
      if (pendingImageKey) { body.image_key = pendingImageKey; pendingImageKey = null; }

      var res = await fetch('/api/concierge/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      var data = await res.json();
      removeTyping();
      addMsg(data.response || data.reply || data.message || 'Sorry, something went wrong.', 'assistant');

      // 電話発信中なら自動ポーリング開始
      if (data.message_type === 'call_status' && data.metadata?.call_status === 'calling') {
        var callId = data.metadata.call_id;
        window._startCallPolling(callId, sessionId, 'en');
      }

      // Clear upload badge
      uploadName.classList.add('hidden');
      uploadStatus.classList.add('hidden');
    } catch (e) {
      removeTyping();
      addMsg('Connection error. Please try again.', 'assistant');
    } finally {
      isSending = false;
      sendBtn.disabled = false;
      inputEl.focus();
    }
  }

  sendBtn.addEventListener('click', sendMessage);
  inputEl.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') { e.preventDefault(); sendMessage(); }
  });

  // グローバル関数として登録（onclick属性から呼び出し）
  window._heroAskAI = function() {
    var location = document.getElementById('location-input') ? document.getElementById('location-input').value.trim() : '';
    var date     = document.getElementById('checkin-fp') ? document.getElementById('checkin-fp').value.trim() : '';
    var ciTime   = document.querySelector('select[name="checkin_time"]') ? document.querySelector('select[name="checkin_time"]').value : '10:00';
    var coTime   = document.querySelector('select[name="checkout_time"]') ? document.querySelector('select[name="checkout_time"]').value : '18:00';
    var guestsEl = document.querySelector('select[name="guests"]');
    var guests   = guestsEl ? guestsEl.value : '1';
    var budgetEl = document.querySelector('select[name="budget"]');
    var budget   = budgetEl ? budgetEl.value : '';
    var specEl   = document.querySelector('select[name="speciality"]');
    var spec     = specEl ? specEl.value : '';

    if (!location) {
      var li = document.getElementById('location-input');
      if (li) li.focus();
      showMessages();
      addMsg('Please enter a city or location first! 📍', 'assistant');
      return;
    }

    var parts = ['Please recommend 3 day-use hotels in ' + location];
    if (date) parts.push('for ' + date);
    if (ciTime && coTime) parts.push('from ' + ciTime + ' to ' + coTime);
    if (guests) parts.push('for ' + guests + ' guest' + (parseInt(guests) > 1 ? 's' : ''));
    if (budget) parts.push('with ' + budget + ' budget');
    if (spec) parts.push('(' + spec + ')');
    parts.push('. Show the top 3 options with price, time slot, and booking link.');

    var autoMsg = parts.join(' ');
    inputEl.value = autoMsg;

    var wrapper = document.getElementById('ai-chat-wrapper');
    if (wrapper) wrapper.scrollIntoView({ behavior: 'smooth', block: 'center' });

    setTimeout(function() { sendMessage(); }, 400);
  };

  // --- airport shortcuts → fill input ---
  document.querySelectorAll('[data-airport]').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      inputEl.value = btn.dataset.airport;
      inputEl.focus();
    });
  });

  // --- flight photo upload ---
  uploadEl.addEventListener('change', async function() {
    var file = uploadEl.files[0];
    if (!file) return;

    uploadStatus.textContent = 'Uploading...';
    uploadStatus.classList.remove('hidden');
    uploadName.classList.add('hidden');

    var form = new FormData();
    form.append('image', file);
    form.append('session_id', sessionId);

    try {
      var res = await fetch('/api/concierge/upload', { method: 'POST', body: form });
      var data = await res.json();
      if (data.image_key || data.key) {
        pendingImageKey = data.image_key || data.key;
        uploadStatus.classList.add('hidden');
        uploadName.textContent = '📎 ' + file.name;
        uploadName.classList.remove('hidden');
        inputEl.placeholder = 'Photo attached! Now type your destination or "find hotels near this airport"...';
        inputEl.focus();
      } else {
        uploadStatus.textContent = data.error || 'Upload failed';
      }
    } catch (e) {
      uploadStatus.textContent = 'Upload error';
    }
  });
})();
</script>

