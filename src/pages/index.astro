---
import Layout from '../layouts/Layout.astro';
import ChatWidget from '../components/ChatWidget.astro';

const env = (Astro.locals as any).runtime?.env;
const DB = env?.DB;

// Speciality tab filter from URL
const activeSpeciality = Astro.url.searchParams.get('speciality') || '';

// Speciality definitions
const specialities = [
  { value: '', label: 'All Types' },
  { value: 'daycation', label: 'Daycation' },
  { value: 'for_couple', label: 'For Couple' },
  { value: 'for_work', label: 'For Work' },
  { value: 'luxury', label: 'Luxury' },
  { value: 'personal_time', label: 'Personal Time' },
  { value: 'transit_use', label: 'Transit Use' },
  { value: 'workspace', label: 'Workspace' },
];

// Category sections to display
const categoryDefs = [
  { planType: 'daycation',    title: 'Daycation',       subtitle: 'Day trips & leisure',          icon: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z' },
  { planType: 'for_couple',   title: 'Romantic Hotels', subtitle: 'Perfect for couples',           icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { planType: 'workspace',    title: 'Workspace',       subtitle: 'Coworking spaces & hot desks',  icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
  { planType: 'transit_use',  title: 'Transit & Airport', subtitle: 'Layover & airport hotels',   icon: 'M12 19l9 2-9-18-9 18 9-2zm0 0v-8' },
  { planType: 'personal_time',title: 'Rest & Relax',    subtitle: 'Unwind and recharge',           icon: 'M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z' },
  { planType: 'luxury',       title: 'Luxury',          subtitle: 'Premium day-use experiences',   icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z' },
  { planType: 'early_check-in', title: 'Early Check-in', subtitle: 'Arrive early, settle in fast', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
];

// Fetch data from DB
let heroHotels: any[] = [];
let categoryHotels: Record<string, any[]> = {};
let allCities: any[] = [];
let totalHotels = 0;
let totalPlans = 0;
let recentBlogs: any[] = [];
let whatsNewItems: any[] = [];
let mapHotels: any[] = [];
let popularPlans: any[] = [];
let hotelPlanTypes: Record<number, string[]> = {};

try {
  if (DB) {
    // 全クエリを並列実行（順次awaitを廃止）
    const heroQuery = activeSpeciality
      ? DB.prepare(
          `SELECT DISTINCT h.id, h.name, h.slug, h.city, h.country, h.property_type, h.thumbnail_url, h.rating,
                  MIN(p.price_usd) as min_price
           FROM hotels h
           JOIN plans p ON p.hotel_id = h.id AND p.plan_type = ?1
           WHERE h.is_active = 1
           GROUP BY h.id
           ORDER BY h.rating DESC
           LIMIT 12`
        ).bind(activeSpeciality).all().catch(() => ({ results: [] }))
      : DB.prepare(
          `SELECT h.id, h.name, h.slug, h.city, h.country, h.property_type, h.thumbnail_url, h.rating,
                  MIN(p.price_usd) as min_price
           FROM hotels h LEFT JOIN plans p ON p.hotel_id = h.id
           WHERE h.is_active = 1
           GROUP BY h.id
           ORDER BY h.rating DESC
           LIMIT 12`
        ).all().catch(() => ({ results: [] }));

    const categoryQueries = categoryDefs.map(cat =>
      DB.prepare(
        `SELECT DISTINCT h.id, h.name, h.slug, h.city, h.country, h.property_type, h.thumbnail_url, h.rating,
                MIN(p.price_usd) as min_price
         FROM hotels h
         LEFT JOIN plans p ON p.hotel_id = h.id AND p.is_active = 1
         WHERE h.is_active = 1
           AND (h.categories LIKE '%"' || ?1 || '"%' OR EXISTS (SELECT 1 FROM plans p2 WHERE p2.hotel_id = h.id AND p2.plan_type = ?1))
         GROUP BY h.id
         ORDER BY h.rating DESC
         LIMIT 12`
      ).bind(cat.planType).all().catch(() => ({ results: [] }))
    );

    const [heroResult, cityResult, statsH, statsP, blogResult, mapResult, ...categoryResults] =
      await Promise.all([
        heroQuery,
        DB.prepare(
          `SELECT city, country, COUNT(*) as hotel_count
           FROM hotels WHERE city != '' AND is_active = 1
           GROUP BY city ORDER BY hotel_count DESC LIMIT 60`
        ).all().catch(() => ({ results: [] })),
        DB.prepare("SELECT COUNT(*) as c FROM hotels WHERE is_active = 1").first().catch(() => ({ c: 0 })),
        DB.prepare("SELECT COUNT(*) as c FROM plans WHERE is_active = 1").first().catch(() => ({ c: 0 })),
        DB.prepare(
          `SELECT id, title, slug, excerpt, thumbnail_url, city, published_at
           FROM blog_posts ORDER BY published_at DESC LIMIT 3`
        ).all().catch(() => ({ results: [] })),
        DB.prepare(
          `SELECT id, name, slug, city, country, latitude, longitude, thumbnail_url,
                  MIN(p.price_usd) as min_price
           FROM hotels h LEFT JOIN plans p ON p.hotel_id = h.id
           WHERE h.is_active = 1 AND h.latitude IS NOT NULL AND h.longitude IS NOT NULL
           GROUP BY h.id LIMIT 100`
        ).all().catch(() => ({ results: [] })),
        ...categoryQueries,
      ]);

    heroHotels = heroResult?.results ?? [];
    allCities = cityResult?.results ?? [];
    totalHotels = statsH?.c || 0;
    totalPlans = statsP?.c || 0;
    recentBlogs = blogResult?.results ?? [];
    mapHotels = mapResult?.results ?? [];

    // What's New: newsテーブル + ブログを統合
    try {
      const newsResult = await DB.prepare(
        "SELECT title, content, category, published_at FROM news WHERE published_at IS NOT NULL AND category != 'blog' ORDER BY published_at DESC LIMIT 5"
      ).all();
      const newsItems = (newsResult?.results || []).map((n: any) => ({
        title: n.title, content: n.content, category: n.category, published_at: n.published_at, link: null,
      }));
      const blogNewsItems = recentBlogs.slice(0, 5).map((b: any) => ({
        title: b.title, content: b.excerpt, category: 'blog', published_at: b.published_at, link: `/blog/${b.slug}`,
      }));
      whatsNewItems = [...newsItems, ...blogNewsItems]
        .sort((a, b) => new Date(b.published_at).getTime() - new Date(a.published_at).getTime())
        .slice(0, 5);
    } catch {
      whatsNewItems = recentBlogs.slice(0, 5).map((b: any) => ({
        title: b.title, content: b.excerpt, category: 'blog', published_at: b.published_at, link: `/blog/${b.slug}`,
      }));
    }

    categoryDefs.forEach((cat, i) => {
      categoryHotels[cat.planType] = categoryResults[i]?.results?.slice(0, 8) ?? [];
    });
  }
} catch (e) {
  console.error('Index DB error:', e);
}

// Popular Day-Use Plans — separate try block
try {
  const DB2 = (Astro.locals as any).runtime?.env?.DB;
  if (DB2) {
    const popularResult = await DB2.prepare(
      `SELECT p.id as plan_id, p.name as plan_name, p.price_usd, p.check_in_time, p.check_out_time, p.plan_type,
              h.id as hotel_id, h.name as hotel_name, h.slug, h.city, h.country, h.thumbnail_url, h.property_type
       FROM plans p
       JOIN hotels h ON h.id = p.hotel_id
       WHERE h.is_active = 1
       ORDER BY p.price_usd ASC
       LIMIT 9`
    ).all();
    popularPlans = popularResult?.results ?? [];
  }
} catch (e2) {
  console.error('Popular plans error:', e2);
}

// Plan types per hotel — separate try block
try {
  const DB3 = (Astro.locals as any).runtime?.env?.DB;
  if (DB3 && heroHotels.length > 0) {
    const allHotelIds = [
      ...heroHotels.map((h: any) => h.id),
      ...Object.values(categoryHotels).flat().map((h: any) => h.id),
    ].filter((id, i, arr) => id != null && arr.indexOf(id) === i).slice(0, 50);

    if (allHotelIds.length > 0) {
      const placeholders = allHotelIds.map(() => '?').join(',');
      const ptResult = await DB3.prepare(
        `SELECT hotel_id, plan_type FROM plans WHERE hotel_id IN (${placeholders}) AND plan_type IS NOT NULL GROUP BY hotel_id, plan_type`
      ).bind(...allHotelIds).all();
      for (const row of ptResult?.results ?? []) {
        if (!hotelPlanTypes[row.hotel_id]) hotelPlanTypes[row.hotel_id] = [];
        if (row.plan_type && !hotelPlanTypes[row.hotel_id].includes(row.plan_type)) {
          hotelPlanTypes[row.hotel_id].push(row.plan_type);
        }
      }
    }
  }
} catch (e3) {
  console.error('Plan types error:', e3);
}

