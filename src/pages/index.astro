  return 'https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?w=600&q=80&fm=webp';
}

// Speciality card data for "Search by Speciality" section
const specialityCards = [
  { value: 'daycation',    label: 'Daycation',     desc: 'Day trips & experiences',    img: 'https://images.unsplash.com/photo-1571896349842-33c89424de2d?w=600&h=400&fit=crop&fm=webp' },
