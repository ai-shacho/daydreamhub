---
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Wishlist - DayDreamHub" description="Your saved day-use hotels on DayDreamHub.">

  <section class="py-8 min-h-[70vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">

      <!-- Page Title -->
      <div class="mb-8 flex items-center justify-between">
        <h1 class="text-2xl font-bold text-slate-900">My Wishlist</h1>
        <span id="wishlist-count" class="text-sm text-gray-500 hidden"></span>
      </div>

      <!-- Loading state -->
      <div id="wishlist-loading" class="text-center py-20">
        <div class="w-8 h-8 border-2 border-teal-500 border-t-transparent rounded-full animate-spin mx-auto"></div>
      </div>

      <!-- Empty state -->
      <div id="wishlist-empty" class="hidden text-center py-20">
        <svg class="w-20 h-20 mx-auto text-slate-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
        </svg>
        <h2 class="text-xl font-semibold text-slate-600 mb-2">No saved hotels yet</h2>
        <p class="text-gray-400 mb-6">Tap the heart icon on any hotel to save it here.</p>
        <a href="/search" class="inline-block bg-teal-700 hover:bg-teal-800 text-white font-bold px-6 py-2.5 rounded-lg transition-colors">
          Browse Hotels
        </a>
      </div>

      <!-- Hotel grid -->
      <div id="wishlist-grid" class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"></div>

    </div>
  </section>

</Layout>

<script is:inline>
(function() {
  var STORAGE_KEY = 'ddh_wishlist';

  function getSlugs() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    } catch(e) { return []; }
  }

  function renderHotelCard(hotel) {
    var minPriceHtml = hotel.min_price
      ? '<p class="text-[#45A2C1] font-bold text-lg mb-2">From $' + hotel.min_price + ' USD</p>'
      : '';
    return '<div class="bg-white rounded-lg shadow overflow-hidden hover:shadow-lg transition-shadow relative">' +
      '<a href="/hotel/' + hotel.slug + '">' +
        '<div class="w-full aspect-[4/3] overflow-hidden">' +
          '<img src="' + (hotel.thumbnail_url || '/images/placeholder-hotel.jpg') + '" alt="' + hotel.name + '" loading="lazy" class="w-full h-full object-cover" />' +
        '</div>' +
      '</a>' +
      '<button class="wishlist-remove-btn absolute top-2 right-2 w-8 h-8 flex items-center justify-center bg-white/90 rounded-full shadow text-red-500 hover:text-red-600 transition-colors" data-slug="' + hotel.slug + '" title="Remove from wishlist">' +
        '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>' +
      '</button>' +
      '<div class="p-4">' +
        '<h3 class="text-gray-900 font-semibold text-base mb-1 line-clamp-2">' +
          '<a href="/hotel/' + hotel.slug + '" class="hover:text-[#45A2C1] transition-colors">' + hotel.name + '</a>' +
        '</h3>' +
        minPriceHtml +
        '<div class="flex flex-wrap gap-1">' +
          '<span class="text-xs text-gray-500 bg-gray-100 rounded px-2 py-0.5">' + hotel.city + '</span>' +
          '<span class="text-xs text-gray-500 bg-gray-100 rounded px-2 py-0.5">' + hotel.country + '</span>' +
        '</div>' +
      '</div>' +
    '</div>';
  }

  function init() {
    var slugs = getSlugs();
    var loading = document.getElementById('wishlist-loading');
    var empty = document.getElementById('wishlist-empty');
    var grid = document.getElementById('wishlist-grid');
    var countEl = document.getElementById('wishlist-count');

    if (slugs.length === 0) {
      loading.classList.add('hidden');
      empty.classList.remove('hidden');
      return;
    }

    fetch('/api/wishlist-hotels?slugs=' + slugs.join(','))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var hotels = data.hotels || [];
        loading.classList.add('hidden');
        if (hotels.length === 0) {
          empty.classList.remove('hidden');
          return;
        }
        countEl.textContent = hotels.length + ' saved hotel' + (hotels.length !== 1 ? 's' : '');
        countEl.classList.remove('hidden');
        grid.innerHTML = hotels.map(renderHotelCard).join('');
        grid.classList.remove('hidden');

        // Remove buttons
        grid.querySelectorAll('.wishlist-remove-btn').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.preventDefault();
            var slug = btn.getAttribute('data-slug');
            var newSlugs = getSlugs().filter(function(s) { return s !== slug; });
            localStorage.setItem(STORAGE_KEY, JSON.stringify(newSlugs));
            // Remove card from DOM
            btn.closest('.bg-white').remove();
            var remaining = grid.querySelectorAll('.bg-white').length;
            if (remaining === 0) {
              grid.classList.add('hidden');
              empty.classList.remove('hidden');
              countEl.classList.add('hidden');
            } else {
              countEl.textContent = remaining + ' saved hotel' + (remaining !== 1 ? 's' : '');
            }
            // Sync heart buttons if on the same page
            if (window.updateWishlistBtn) window.updateWishlistBtn(slug, false);
          });
        });
      })
      .catch(function() {
        loading.classList.add('hidden');
        empty.classList.remove('hidden');
      });
  }

  // DOMContentLoaded may already have fired (inline scripts run late)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
