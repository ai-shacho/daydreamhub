---
import Layout from '../layouts/Layout.astro';
import { getAirportCoords, haversineKm, nearestAirport } from '../lib/airports';

// Get D1 database binding
const DB = (Astro.locals as any).runtime?.env?.DB;

// Read URL params
const url = Astro.url;
const location = url.searchParams.get('location') || '';
const speciality = url.searchParams.get('speciality') || '';
const propertyType = url.searchParams.get('propertyType') || '';
const country = url.searchParams.get('country') || '';
const ratingMin = url.searchParams.get('rating') || '';
const amenityFilter = url.searchParams.get('amenity') || '';
const cityFilter = url.searchParams.get('city') || '';
const sortBy = url.searchParams.get('sort') || 'default'; // default | price_asc | price_desc | airport_distance | rating_desc
const checkinParam = url.searchParams.get('checkin') || '';
const page = Math.max(1, parseInt(url.searchParams.get('page') || '1'));
const perPage = 12;
const offset = (page - 1) * perPage;

// Build query
let whereClauses: string[] = [];
let params: any[] = [];

if (location) {
  whereClauses.push("(h.city LIKE ?1 OR h.country LIKE ?1 OR h.name LIKE ?1)");
  params.push(`%${location}%`);
}
if (speciality) {
  const paramIdx = params.length + 1;
  whereClauses.push(`EXISTS (SELECT 1 FROM plans p2 WHERE p2.hotel_id = h.id AND p2.plan_type = ?${paramIdx})`);
  params.push(speciality);
}
if (propertyType) {
  const paramIdx = params.length + 1;
  whereClauses.push(`h.property_type = ?${paramIdx}`);
  params.push(propertyType);
}
if (country) {
  const paramIdx = params.length + 1;
  whereClauses.push(`h.country = ?${paramIdx}`);
  params.push(country);
}
if (cityFilter) {
  const paramIdx = params.length + 1;
  whereClauses.push(`h.city = ?${paramIdx}`);
  params.push(cityFilter);
}
if (ratingMin) {
  const paramIdx = params.length + 1;
  whereClauses.push(`h.rating >= ?${paramIdx}`);
  params.push(parseFloat(ratingMin));
}
if (amenityFilter) {
  const paramIdx = params.length + 1;
  whereClauses.push(`EXISTS (SELECT 1 FROM hotel_amenities ha2 JOIN amenities a2 ON a2.id = ha2.amenity_id WHERE ha2.hotel_id = h.id AND a2.name = ?${paramIdx})`);
  params.push(amenityFilter);
}

const whereSQL = whereClauses.length > 0 ? 'WHERE ' + whereClauses.join(' AND ') : '';

let hotels: any[] = [];
let totalCount = 0;
let allCountries: string[] = [];
let allPropertyTypes: string[] = [];
let allAmenities: string[] = [];
let allCities: string[] = [];

if (DB) {
  try {
    // Count query
    const countResult = await DB.prepare(
      `SELECT COUNT(DISTINCT h.id) as total FROM hotels h ${whereSQL}`
    ).bind(...params).first();
    totalCount = countResult?.total || 0;

    // Main query
    const isAirportSort = sortBy === 'airport_distance';
    const orderSQL = sortBy === 'price_asc'
      ? 'ORDER BY min_price ASC NULLS LAST'
      : sortBy === 'price_desc'
        ? 'ORDER BY min_price DESC NULLS LAST'
        : sortBy === 'rating_desc'
          ? 'ORDER BY h.rating DESC NULLS LAST'
          : 'ORDER BY h.rating DESC NULLS LAST, min_price ASC NULLS LAST';

    let fetchLimit = perPage;
    let fetchOffset = offset;
    if (isAirportSort) {
      // Fetch all matching hotels to sort by distance in JS
      fetchLimit = 9999;
      fetchOffset = 0;
    }
    const limitIdx = params.length + 1;
    const offsetIdx = params.length + 2;
    const result = await DB.prepare(
      `SELECT h.*, MIN(p.price_usd) as min_price
       FROM hotels h
       LEFT JOIN plans p ON p.hotel_id = h.id
       ${whereSQL}
       GROUP BY h.id
       ${isAirportSort ? 'ORDER BY h.id DESC' : orderSQL}
       LIMIT ?${limitIdx} OFFSET ?${offsetIdx}`
    ).bind(...params, fetchLimit, fetchOffset).all();
    let allResults: any[] = result?.results || [];

    // Inline airport list & nearest-airport calc (avoid module bundling issues)
    const _airports = [
      // Southeast Asia
      { code:'BKK', lat:13.6811, lng:100.7472 }, { code:'DMK', lat:13.9126, lng:100.6067 },
      { code:'DPS', lat:-8.7482, lng:115.1671 }, { code:'CGK', lat:-6.1256, lng:106.6559 },
      { code:'KUL', lat:2.7456, lng:101.7072 },  { code:'SIN', lat:1.3644, lng:103.9915 },
      { code:'MNL', lat:14.5086, lng:121.0194 }, { code:'CEB', lat:10.3075, lng:123.9792 },
      { code:'SGN', lat:10.8188, lng:106.6520 }, { code:'HAN', lat:21.2187, lng:105.8072 },
      { code:'DAD', lat:16.0439, lng:108.1993 }, { code:'HKT', lat:8.1132, lng:98.3161 },
      { code:'USM', lat:9.5479, lng:100.0623 },  { code:'PNH', lat:11.5466, lng:104.8440 },
      { code:'RGN', lat:16.9073, lng:96.1332 },
      // East Asia
      { code:'HND', lat:35.5494, lng:139.7798 }, { code:'NRT', lat:35.7720, lng:140.3929 },
      { code:'KIX', lat:34.4347, lng:135.2440 }, { code:'ICN', lat:37.4691, lng:126.4510 },
      { code:'PEK', lat:40.0799, lng:116.6031 }, { code:'PVG', lat:31.1443, lng:121.8083 },
      { code:'HKG', lat:22.3080, lng:113.9185 }, { code:'TPE', lat:25.0777, lng:121.2328 },
      // South Asia
      { code:'BOM', lat:19.0896, lng:72.8656 },  { code:'DEL', lat:28.5562, lng:77.1000 },
      { code:'CMB', lat:7.1806, lng:79.8841 },   { code:'CCU', lat:22.6547, lng:88.4467 },
      { code:'MAA', lat:12.9941, lng:80.1709 },
      // Middle East
      { code:'DXB', lat:25.2528, lng:55.3644 },  { code:'AUH', lat:24.4330, lng:54.6511 },
      { code:'DOH', lat:25.2731, lng:51.6081 },  { code:'BAH', lat:26.2708, lng:50.6336 },
      { code:'KWI', lat:29.2267, lng:47.9689 },  { code:'MCT', lat:23.5933, lng:58.2844 },
      { code:'AMM', lat:31.7226, lng:35.9932 },  { code:'BEY', lat:33.8209, lng:35.4884 },
      // Africa
      { code:'NBO', lat:-1.3192, lng:36.9275 },  { code:'CAI', lat:30.1219, lng:31.4056 },
      { code:'JNB', lat:-26.1392, lng:28.2460 }, { code:'CPT', lat:-33.9648, lng:18.6017 },
      { code:'LOS', lat:6.5774, lng:3.3215 },    { code:'ABV', lat:9.0068, lng:7.2632 },
      { code:'ACC', lat:5.6052, lng:-0.1668 },   { code:'DKR', lat:14.7397, lng:-17.4902 },
      { code:'CMN', lat:33.3675, lng:-7.5900 },  { code:'TUN', lat:36.8510, lng:10.2272 },
      { code:'ADD', lat:8.9779, lng:38.7993 },   { code:'DAR', lat:-6.8781, lng:39.2026 },
      // Europe
      { code:'LHR', lat:51.4775, lng:-0.4614 },  { code:'CDG', lat:49.0097, lng:2.5479 },
      { code:'AMS', lat:52.3086, lng:4.7639 },   { code:'FRA', lat:50.0379, lng:8.5622 },
      { code:'MAD', lat:40.4936, lng:-3.5668 },  { code:'FCO', lat:41.8003, lng:12.2389 },
      { code:'IST', lat:41.2753, lng:28.7519 },  { code:'VIE', lat:48.1103, lng:16.5697 },
      { code:'ZRH', lat:47.4647, lng:8.5492 },   { code:'BHX', lat:52.4539, lng:-1.7480 },
      // Americas
      { code:'JFK', lat:40.6413, lng:-73.7781 }, { code:'LAX', lat:33.9425, lng:-118.4081 },
      { code:'ORD', lat:41.9742, lng:-87.9073 }, { code:'MIA', lat:25.7959, lng:-80.2870 },
      { code:'YYZ', lat:43.6777, lng:-79.6248 }, { code:'YYC', lat:51.1315, lng:-114.0105 },
      { code:'GRU', lat:-23.4356, lng:-46.4731 },{ code:'BOG', lat:4.7016, lng:-74.1469 },
      { code:'MEX', lat:19.4363, lng:-99.0721 }, { code:'LIM', lat:-12.0219, lng:-77.1143 },
      // Oceania
      { code:'SYD', lat:-33.9399, lng:151.1753 },{ code:'MEL', lat:-37.6690, lng:144.8410 },
      { code:'BNE', lat:-27.3842, lng:153.1175 },{ code:'AKL', lat:-37.0082, lng:174.7850 },
      { code:'PER', lat:-31.9403, lng:115.9669 },
    ];
    function _hvKm(la1: number, lo1: number, la2: number, lo2: number): number {
      const R = 6371, p = Math.PI / 180;
      const dLa = (la2 - la1) * p;
      const dLo = (lo2 - lo1) * p;
      const sLa = Math.sin(dLa / 2);
      const sLo = Math.sin(dLo / 2);
      const a = sLa * sLa + Math.cos(la1 * p) * Math.cos(la2 * p) * sLo * sLo;
      const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
      return R * c;
    }
    function _nearestAp(lat: number, lng: number) {
      let best: {code:string;km:number}|null = null;
      for (const ap of _airports) {
        const km = _hvKm(lat, lng, ap.lat, ap.lng);
        if (!best || km < best.km) best = {code:ap.code, km};
      }
      return best;
    }

    // Always compute nearest airport for each hotel from coordinates
    allResults = allResults.map((h: any) => {
      if (h.latitude == null || h.longitude == null) return { ...h, _airport_km: null, _airport_code: null };
      const ap = _nearestAp(Number(h.latitude), Number(h.longitude));
      return { ...h, _airport_km: ap?.km ?? null, _airport_code: ap?.code ?? null };
    });

    if (isAirportSort) {
      // Sort by airport distance
      const targetCity = cityFilter || location;
      let airportCoords = getAirportCoords(targetCity);
      if (!airportCoords && allResults.length > 0) {
        airportCoords = getAirportCoords(allResults[0].city);
      }
      if (airportCoords) {
        const [aLat, aLng] = airportCoords;
        allResults = allResults
          .map((h: any) => ({
            ...h,
            _airport_km: (h.latitude != null && h.longitude != null)
              ? haversineKm(h.latitude, h.longitude, aLat, aLng)
              : 99999,
          }))
          .sort((a: any, b: any) => a._airport_km - b._airport_km);
      }
    }

    hotels = isAirportSort ? allResults.slice(offset, offset + perPage) : allResults;

    // Get filter options
    const countriesResult = await DB.prepare(
      "SELECT DISTINCT country FROM hotels WHERE country != '' ORDER BY country"
    ).all();
    allCountries = (countriesResult?.results || []).map((r: any) => r.country);

    const ptResult = await DB.prepare(
      "SELECT DISTINCT property_type FROM hotels WHERE property_type != '' ORDER BY property_type"
    ).all();
    allPropertyTypes = (ptResult?.results || []).map((r: any) => r.property_type);

    const cityResult = await DB.prepare(
      "SELECT DISTINCT city FROM hotels WHERE city != '' ORDER BY city"
    ).all();
    allCities = (cityResult?.results || []).map((r: any) => r.city);

    const amenResult = await DB.prepare(
      "SELECT DISTINCT name FROM amenities ORDER BY name"
    ).all();
    allAmenities = (amenResult?.results || []).map((r: any) => r.name);
  } catch (e) {
    console.error('DB query error:', e);
  }
}

// Fixed property types — matches "Search by Room Type" on the top page
const fallbackPropertyTypes = ['Hotel', 'Villa', 'Resort', 'Apartment', 'Clinic', 'Spa', 'Wellness', 'Coworking Space', 'Cafe & Lounge', 'Hostel'];
allPropertyTypes = fallbackPropertyTypes;

const totalPages = Math.ceil(totalCount / perPage);

// Build pagination items (numbers and ellipsis strings) for the template
const paginationItems: (number | string)[] = Array.from({ length: totalPages }, (_, i) => i + 1)
  .filter(p => p === 1 || p === totalPages || Math.abs(p - page) <= 2)
  .reduce((acc: (number | string)[], p, idx, arr) => {
    if (idx > 0 && typeof arr[idx - 1] === 'number' && (p as number) - (arr[idx - 1] as number) > 1) {
      acc.push('...');
    }
    acc.push(p);
    return acc;
  }, []);

// Speciality options
const specialities = [
  { value: '', label: 'All Specialities' },
  { value: 'rest', label: 'Rest & Relaxation' },
  { value: 'work', label: 'Remote Work' },
  { value: 'personal_time', label: 'Personal Time' },
  { value: 'party', label: 'Party & Events' },
  { value: 'stay', label: 'Day Stay' },
];

// Country region groups for optgroup
const regionGroups = [
  {
    label: 'Southeast Asia',
    countries: ['Thailand', 'Malaysia', 'Indonesia', 'Vietnam', 'Philippines', 'Laos', 'Sri Lanka'],
  },
  {
    label: 'East Asia',
    countries: ['Japan'],
  },
  {
    label: 'Middle East',
    countries: ['UAE', 'Qatar', 'Bahrain', 'Oman', 'Egypt'],
  },
  {
    label: 'Africa',
    countries: ['Kenya', 'Rwanda', 'Nigeria', 'South Africa', 'Tanzania'],
  },
  {
    label: 'Europe',
    countries: ['UK', 'Netherlands', 'France', 'Czech Republic', 'Portugal', 'Italy', 'Spain', 'Finland', 'Bulgaria', 'Serbia', 'Georgia', 'Russia'],
  },
  {
    label: 'Americas',
    countries: ['Canada', 'USA', 'Colombia', 'Mexico', 'Ecuador', 'Peru'],
  },
  {
    label: 'Other',
    countries: ['Australia', 'New Zealand', 'India', 'Pakistan', 'Bhutan', 'Mongolia', 'Kazakhstan', 'Uzbekistan'],
  },
];

// Assign countries to their groups, leftover to Other
// Case-insensitive matching: DB may store "japan" while region list has "Japan"
function getGroupedCountries(available: string[]) {
  // Normalize: map lowercase → canonical display name (first seen wins)
  const normalizeMap = new Map<string, string>();
  for (const c of available) {
    if (c) normalizeMap.set(c.toLowerCase(), c.charAt(0).toUpperCase() + c.slice(1));
  }
  const availableLower = new Set(normalizeMap.keys());

  const assignedLower = new Set<string>();
  const groups: { label: string; countries: string[] }[] = [];

  for (const rg of regionGroups) {
    // Match region list entries case-insensitively against available DB countries
    const matched = rg.countries
      .filter(c => availableLower.has(c.toLowerCase()))
      .map(c => {
        const key = c.toLowerCase();
        assignedLower.add(key);
        // Use DB's capitalized version if available, else fall back to region list entry
        return normalizeMap.get(key) || c;
      });
    if (matched.length > 0) {
      groups.push({ label: rg.label, countries: matched });
    }
  }

  const other = [...normalizeMap.values()].filter(c => !assignedLower.has(c.toLowerCase()));
  if (other.length > 0) {
    const existingOther = groups.find(g => g.label === 'Other');
    if (existingOther) {
      existingOther.countries.push(...other);
    } else {
      groups.push({ label: 'Other', countries: other.sort() });
    }
  }

  return groups;
}

const groupedCountries = getGroupedCountries(allCountries);

// City region groups for optgroup
const cityRegionGroups = [
  { label: 'Japan', cities: ['Tokyo', 'Osaka', 'Kyoto', 'Nagoya', 'Fukuoka', 'Sapporo', 'Yokohama', 'Kobe', 'Nara', 'Hiroshima', 'Okinawa'] },
  { label: 'Thailand', cities: ['Bangkok', 'Pattaya', 'Phuket', 'Chiang Mai', 'Krabi', 'Hua Hin', 'Koh Samui'] },
  { label: 'Malaysia', cities: ['Kuala Lumpur', 'Penang', 'Johor Bahru', 'Langkawi', 'Malacca'] },
  { label: 'Indonesia', cities: ['Jakarta', 'Bali', 'Bandung', 'Surabaya', 'Yogyakarta'] },
  { label: 'Vietnam', cities: ['Ho Chi Minh City', 'Hanoi', 'Da Nang', 'Hoi An', 'Nha Trang'] },
  { label: 'South Korea', cities: ['Seoul', 'Busan', 'Jeju', 'Incheon'] },
  { label: 'Singapore', cities: ['Singapore'] },
  { label: 'UAE', cities: ['Dubai', 'Abu Dhabi'] },
  { label: 'UK', cities: ['London', 'Manchester', 'Edinburgh', 'Birmingham'] },
  { label: 'USA', cities: ['New York', 'Los Angeles', 'San Francisco', 'Miami', 'Las Vegas', 'Chicago'] },
];

function getGroupedCities(available: string[]) {
  const assigned = new Set<string>();
  const groups: { label: string; cities: string[] }[] = [];
  for (const rg of cityRegionGroups) {
    const matched = rg.cities.filter(c => available.includes(c));
    matched.forEach(c => assigned.add(c));
    if (matched.length > 0) {
      groups.push({ label: rg.label, cities: matched });
    }
  }
  const other = available.filter(c => !assigned.has(c) && c);
  if (other.length > 0) {
    groups.push({ label: 'Other Cities', cities: other });
  }
  return groups;
}

const groupedCities = getGroupedCities(allCities);

// Helper: build URL with updated params
function buildUrl(overrides: Record<string, string>) {
  const p = new URLSearchParams(url.searchParams);
  for (const [k, v] of Object.entries(overrides)) {
    if (v) p.set(k, v);
    else p.delete(k);
  }
  return `/search?${p.toString()}`;
}
---

<Layout title="Search Hotels - DayDreamHub" description="Find day-use hotels worldwide. Filter by location, property type, and more.">

  <!-- Search Bar -->
  <section class="bg-teal-700 pb-6">
    <div class="max-w-7xl mx-auto px-4">
      <form method="get" action="/search" class="bg-white rounded-xl shadow-lg p-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
          <!-- Location -->
          <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">Location</label>
            <div class="relative">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <input
                type="text"
                name="location"
                value={location}
                placeholder="City or country..."
                class="w-full pl-9 pr-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
              />
            </div>
          </div>

          <!-- Check-in -->
          <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">Check-in</label>
            <input
              type="text"
              name="checkin"
              id="search-checkin-fp"
              placeholder="MM / DD / YYYY"
              autocomplete="off"
              class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
            />
          </div>

          <!-- Speciality -->
          <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">Speciality</label>
            <select
              name="speciality"
              class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white"
            >
              {specialities.map(s => (
                <option value={s.value} selected={speciality === s.value}>{s.label}</option>
              ))}
            </select>
          </div>

          <!-- Guests -->
          <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">Guests</label>
            <select
              name="guests"
              class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white"
            >
              <option value="">Any</option>
              <option value="1">1 Guest</option>
              <option value="2">2 Guests</option>
              <option value="3">3 Guests</option>
              <option value="4">4 Guests</option>
              <option value="5">5+ Guests</option>
            </select>
          </div>

          <!-- Search button -->
          <div class="flex items-end">
            <button
              type="submit"
              class="w-full bg-amber-500 hover:bg-amber-400 text-gray-900 font-semibold py-2.5 px-6 rounded-lg transition-colors text-sm"
            >
              Search
            </button>
          </div>
        </div>
      </form>
    </div>
  </section>

  <!-- Results section -->
  <section class="max-w-7xl mx-auto px-4 py-6">

    <!-- Mobile filter toggle -->
    <div class="lg:hidden mb-4">
      <button id="filter-toggle-btn" class="flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-200 rounded-lg text-sm font-medium text-gray-700 shadow-sm w-full justify-between">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
          Filters
          {(propertyType || country || cityFilter || amenityFilter || ratingMin) && (
            <span class="bg-teal-600 text-white text-xs rounded-full px-1.5 py-0.5">Active</span>
          )}
        </span>
        <svg id="filter-toggle-icon" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
    </div>

    <div class="flex flex-col lg:flex-row gap-6">

      <!-- Sidebar filters -->
      <aside id="filter-sidebar" class="w-full lg:w-[280px] shrink-0 hidden lg:block">
        <div class="lg:sticky lg:top-20 space-y-5">
          <form method="get" action="/search" id="filter-form">
            <!-- Carry search bar values -->
            {location && <input type="hidden" name="location" value={location} />}
            {speciality && <input type="hidden" name="speciality" value={speciality} />}

            <!-- Property Type -->
            <div class="bg-white rounded-xl shadow-sm p-4">
              <h3 class="font-semibold text-sm text-gray-800 mb-3">Property Type</h3>
              <div class="space-y-2">
                {allPropertyTypes.map(pt => (
                  <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer hover:text-gray-900">
                    <input
                      type="radio"
                      name="propertyType"
                      value={pt}
                      checked={propertyType === pt}
                      class="w-4 h-4 text-teal-600 border-gray-300 focus:ring-teal-500"
                      onchange="this.form.submit()"
                    />
                    {pt}
                  </label>
                ))}
                {propertyType && (
                  <a href={buildUrl({ propertyType: '' })} class="inline-block text-xs text-teal-600 hover:text-teal-800 mt-1">Clear filter</a>
                )}
              </div>
            </div>

            <!-- Rating -->
            <div class="bg-white rounded-xl shadow-sm p-4">
              <h3 class="font-semibold text-sm text-gray-800 mb-3">Rating</h3>
              <div class="space-y-2">
                {[
                  { value: '4.5', label: '4.5+' },
                  { value: '4', label: '4.0+' },
                  { value: '3.5', label: '3.5+' },
                  { value: '3', label: '3.0+' },
                ].map(r => (
                  <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer hover:text-gray-900">
                    <input
                      type="radio"
                      name="rating"
                      value={r.value}
                      checked={ratingMin === r.value}
                      class="w-4 h-4 text-teal-600 border-gray-300 focus:ring-teal-500"
                      onchange="this.form.submit()"
                    />
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                      {r.label}
                    </span>
                  </label>
                ))}
                {ratingMin && (
                  <a href={buildUrl({ rating: '' })} class="inline-block text-xs text-teal-600 hover:text-teal-800 mt-1">Clear filter</a>
                )}
              </div>
            </div>

            <!-- Country (grouped by region) -->
            <div class="bg-white rounded-xl shadow-sm p-4">
              <h3 class="font-semibold text-sm text-gray-800 mb-3">Country</h3>
              <select
                name="country"
                class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white"
                onchange="this.form.submit()"
              >
                <option value="">All Countries</option>
                {allCountries.slice().sort((a, b) => a.localeCompare(b)).map(c => (
                  <option value={c} selected={country === c}>{c.charAt(0).toUpperCase() + c.slice(1)}</option>
                ))}
              </select>
              {country && (
                <a href={buildUrl({ country: '' })} class="inline-block text-xs text-teal-600 hover:text-teal-800 mt-2">Clear filter</a>
              )}
            </div>

            <!-- City -->
            <div class="bg-white rounded-xl shadow-sm p-4">
              <h3 class="font-semibold text-sm text-gray-800 mb-3">City</h3>
              <select
                name="city"
                class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white"
                onchange="this.form.submit()"
              >
                <option value="">All Cities</option>
                {allCities.slice().sort((a, b) => a.localeCompare(b)).map(c => (
                  <option value={c} selected={cityFilter === c}>{c.charAt(0).toUpperCase() + c.slice(1)}</option>
                ))}
              </select>
              {cityFilter && (
                <a href={buildUrl({ city: '' })} class="inline-block text-xs text-teal-600 hover:text-teal-800 mt-2">Clear filter</a>
              )}
            </div>

            <!-- Amenities -->
            {allAmenities.length > 0 && (
              <div class="bg-white rounded-xl shadow-sm p-4">
                <h3 class="font-semibold text-sm text-gray-800 mb-3">Amenities</h3>
                <div class="space-y-2 max-h-48 overflow-y-auto">
                  {allAmenities.slice(0, 15).map(am => (
                    <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer hover:text-gray-900">
                      <input
                        type="radio"
                        name="amenity"
                        value={am}
                        checked={amenityFilter === am}
                        class="w-4 h-4 text-teal-600 border-gray-300 focus:ring-teal-500"
                        onchange="this.form.submit()"
                      />
                      {am}
                    </label>
                  ))}
                </div>
              </div>
            )}
          </form>
        </div>
      </aside>

      <!-- Main results area -->
      <div class="flex-1 min-w-0">
        <!-- Results header -->
        <div class="flex flex-wrap items-center gap-3 mb-2">
          <p class="text-sm text-gray-600 flex-1 min-w-0">
            {totalCount > 0 ? (
              <span>Showing <strong>{offset + 1}</strong>-<strong>{Math.min(offset + perPage, totalCount)}</strong> of <strong>{totalCount}</strong> properties</span>
            ) : (
              <span>No properties found</span>
            )}
            {(location || propertyType || country || cityFilter || amenityFilter || ratingMin) && (
              <a href="/search" class="ml-2 text-teal-600 hover:text-teal-800 text-xs font-medium">Clear all filters</a>
            )}
          </p>

          <!-- Sort selector -->
          <div class="flex items-center gap-2 shrink-0">
            <select
              id="sort-select"
              class="text-sm border border-gray-200 rounded-lg px-3 py-1.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-teal-500 cursor-pointer"
            >
              <option value="default" selected={sortBy === 'default'}>Sort: Recommended</option>
              <option value="price_asc" selected={sortBy === 'price_asc'}>Price: Low to High</option>
              <option value="price_desc" selected={sortBy === 'price_desc'}>Price: High to Low</option>
              <option value="rating_desc" selected={sortBy === 'rating_desc'}>Rating: Highest</option>
              <option value="airport_distance" selected={sortBy === 'airport_distance'}>Distance from Airport</option>
            </select>
          </div>

          <!-- View toggle -->
          <div class="hidden sm:flex items-center gap-1 bg-gray-100 rounded-lg p-1" id="view-toggle">
            <button data-view="grid-3" class="p-1.5 rounded text-gray-500 hover:text-gray-700 bg-white shadow-sm" title="3 columns">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16"><rect x="0" y="0" width="4" height="4" rx="0.5"/><rect x="6" y="0" width="4" height="4" rx="0.5"/><rect x="12" y="0" width="4" height="4" rx="0.5"/><rect x="0" y="6" width="4" height="4" rx="0.5"/><rect x="6" y="6" width="4" height="4" rx="0.5"/><rect x="12" y="6" width="4" height="4" rx="0.5"/></svg>
            </button>
            <button data-view="grid-2" class="p-1.5 rounded text-gray-400 hover:text-gray-700" title="2 columns">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16"><rect x="0" y="0" width="7" height="4" rx="0.5"/><rect x="9" y="0" width="7" height="4" rx="0.5"/><rect x="0" y="6" width="7" height="4" rx="0.5"/><rect x="9" y="6" width="7" height="4" rx="0.5"/></svg>
            </button>
            <button data-view="list" class="p-1.5 rounded text-gray-400 hover:text-gray-700" title="List view">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16"><rect x="0" y="0" width="16" height="3" rx="0.5"/><rect x="0" y="5" width="16" height="3" rx="0.5"/><rect x="0" y="10" width="16" height="3" rx="0.5"/></svg>
            </button>
          </div>
        </div>

        <!-- Search condition summary badges -->
        {(location || checkinParam || cityFilter || country) && (
          <div class="flex flex-wrap gap-2 mb-4">
            {location && (
              <span class="inline-flex items-center gap-1 px-3 py-1 bg-teal-50 text-teal-700 text-xs rounded-full border border-teal-200">
                📍 {location}
              </span>
            )}
            {cityFilter && !location && (
              <span class="inline-flex items-center gap-1 px-3 py-1 bg-teal-50 text-teal-700 text-xs rounded-full border border-teal-200">
                📍 {cityFilter}
              </span>
            )}
            {country && (
              <span class="inline-flex items-center gap-1 px-3 py-1 bg-indigo-50 text-indigo-700 text-xs rounded-full border border-indigo-200">
                🌏 {country}
              </span>
            )}
            {checkinParam && (
              <span class="inline-flex items-center gap-1 px-3 py-1 bg-blue-50 text-blue-700 text-xs rounded-full border border-blue-200">
                📅 {checkinParam}
              </span>
            )}
          </div>
        )}

        <!-- Hotel cards grid -->
        <div id="hotel-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
          {hotels.length > 0 ? (
            hotels.map((hotel: any) => (
              <a href={`/hotel/${hotel.slug}`} class="group bg-white rounded-xl shadow-sm overflow-hidden hover:shadow-md transition-shadow">
                <!-- Image -->
                <div class="aspect-[3/2] bg-gray-100 overflow-hidden relative">
                  {hotel.thumbnail_url ? (
                    <img
                      src={hotel.thumbnail_url}
                      alt={hotel.name}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  ) : (
                    <img
                      src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=600&q=80"
                      alt={hotel.name}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  )}
                  {hotel.property_type && (
                    <span class="absolute top-2 left-2 bg-white/90 backdrop-blur-sm text-xs font-medium text-gray-700 px-2 py-1 rounded-md">
                      {hotel.property_type}
                    </span>
                  )}
                </div>

                <!-- Card body -->
                <div class="p-4">
                  <h3 class="font-semibold text-gray-900 text-sm leading-snug line-clamp-2 group-hover:text-teal-700 transition-colors">
                    {/* Show English name: if name === name_ja (data error), fallback logic */}
                    {hotel.name_ja && hotel.name === hotel.name_ja ? (hotel.name_ja) : hotel.name}
                  </h3>
                  <p class="text-xs text-gray-500 mt-1 flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    {hotel.city}{hotel.country ? `, ${hotel.country}` : ''}
                    {hotel._airport_km != null && hotel._airport_code != null && hotel._airport_km < 500 && (
                      <span class="ml-1 text-gray-400">·</span>
                      <span class="flex items-center gap-0.5 text-gray-400">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                        {hotel._airport_km < 1 ? `${Math.round(hotel._airport_km * 1000)}m` : `${hotel._airport_km.toFixed(1)}km`} from {hotel._airport_code}
                      </span>
                    )}
                  </p>

                  {hotel.rating > 0 && (
                    <div class="flex items-center gap-1 mt-2">
                      <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                      <span class="text-xs font-medium text-gray-700">{hotel.rating.toFixed(1)}</span>
                    </div>
                  )}

                  {hotel.amenity_list && (
                    <div class="flex flex-wrap gap-1 mt-2">
                      {hotel.amenity_list.split(',').slice(0, 3).map((am: string) => (
                        <span class="text-[10px] bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded">{am.trim()}</span>
                      ))}
                    </div>
                  )}

                  <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-100">
                    <div>
                      {hotel.min_price != null ? (
                        <div>
                          <span class="text-xs text-gray-400">from</span>
                          <span class="text-lg font-bold text-teal-700 ml-1" data-usd={hotel.min_price}>${hotel.min_price}</span>
                        </div>
                      ) : (
                        <span class="text-xs text-gray-400">Price on request</span>
                      )}
                    </div>
                    <span class="text-xs font-medium text-amber-600 group-hover:text-amber-500 transition-colors">
                      View Details &rarr;
                    </span>
                  </div>
                </div>
              </a>
            ))
          ) : (
            <div class="col-span-full py-16 text-center">
              <div class="w-20 h-20 mx-auto bg-gray-100 rounded-full flex items-center justify-center mb-6">
                <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-slate-800 mb-2">No hotels found</h3>
              <p class="text-gray-500 mb-8 max-w-sm mx-auto">
                Try adjusting your search — different dates, city, or fewer filters often reveal more options.
              </p>
              <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <a href="/search" class="px-6 py-3 bg-teal-600 hover:bg-teal-700 text-white font-medium rounded-xl transition-colors">
                  Clear Filters
                </a>
                <a href="/" class="px-6 py-3 bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 font-medium rounded-xl transition-colors">
                  Back to Home
                </a>
              </div>
            </div>
          )}
        </div>

        <!-- Pagination -->
        {totalPages > 1 && (
          <nav class="flex items-center justify-center gap-1 mt-8" aria-label="Pagination">
            {page > 1 && (
              <a
                href={buildUrl({ page: String(page - 1) })}
                class="px-3 py-2 text-sm font-medium text-gray-600 bg-white rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors"
              >
                &laquo; Prev
              </a>
            )}

            {paginationItems.map(p =>
                typeof p === 'string' ? (
                  <span class="px-2 py-2 text-sm text-gray-400">...</span>
                ) : (
                  <a
                    href={buildUrl({ page: String(p) })}
                    class:list={[
                      "px-3 py-2 text-sm font-medium rounded-lg border transition-colors",
                      p === page
                        ? "bg-teal-700 text-white border-teal-700"
                        : "text-gray-600 bg-white border-gray-200 hover:bg-gray-50"
                    ]}
                  >
                    {p}
                  </a>
                )
              )
            }

            {page < totalPages && (
              <a
                href={buildUrl({ page: String(page + 1) })}
                class="px-3 py-2 text-sm font-medium text-gray-600 bg-white rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors"
              >
                Next &raquo;
              </a>
            )}
          </nav>
        )}
      </div>

    </div>
  </section>

  <!-- Mobile filter toggle script -->
  <script is:inline>
    (function() {
      var btn = document.getElementById('filter-toggle-btn');
      var sidebar = document.getElementById('filter-sidebar');
      var icon = document.getElementById('filter-toggle-icon');
      if (!btn || !sidebar) return;
      btn.addEventListener('click', function() {
        var hidden = sidebar.classList.toggle('hidden');
        if (icon) {
          icon.style.transform = hidden ? '' : 'rotate(180deg)';
        }
      });
    })();
  </script>

  <!-- Sort select script -->
  <script is:inline>
    (function() {
      var sel = document.getElementById('sort-select');
      if (!sel) return;
      sel.addEventListener('change', function() {
        var p = new URLSearchParams(window.location.search);
        if (sel.value === 'default') { p.delete('sort'); } else { p.set('sort', sel.value); }
        p.delete('page');
        window.location.href = '/search?' + p.toString();
      });
    })();
  </script>

<!-- View toggle script -->
  <script>
    const grid = document.getElementById('hotel-grid');
    const toggle = document.getElementById('view-toggle');
    if (grid && toggle) {
      toggle.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', () => {
          toggle.querySelectorAll('button').forEach(b => {
            b.classList.remove('bg-white', 'shadow-sm', 'text-gray-500');
            b.classList.add('text-gray-400');
          });
          btn.classList.add('bg-white', 'shadow-sm', 'text-gray-500');
          btn.classList.remove('text-gray-400');

          const view = btn.getAttribute('data-view');
          grid.className = 'grid gap-5';
          if (view === 'grid-3') {
            grid.classList.add('grid-cols-1', 'sm:grid-cols-2', 'xl:grid-cols-3');
          } else if (view === 'grid-2') {
            grid.classList.add('grid-cols-1', 'sm:grid-cols-2');
          } else {
            grid.classList.add('grid-cols-1');
          }
        });
      });
    }
  </script>

<!-- Flatpickr: English date picker -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
<script is:inline>
  (function() {
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/flatpickr';
    s.onload = function() {
      if (window.flatpickr) {
        window.flatpickr('#search-checkin-fp', {
          locale: 'en',
          dateFormat: 'm/d/Y',
          disableMobile: true,
          allowInput: true,
        });
      }
    };
    document.head.appendChild(s);
  })();
</script>

</Layout>
