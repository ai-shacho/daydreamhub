---
import OwnerLayout from '../../layouts/OwnerLayout.astro';
import { verifyOwner } from '../../lib/ownerAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const owner = await verifyOwner(Astro.request, jwtSecret);
if (!owner) {
  return Astro.redirect("/login?redirect=/owner/bookings");
}

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get("status") || "";
const hotelFilter = url.searchParams.get("hotel_id") || "";
const dateFrom = url.searchParams.get("from") || "";
const dateTo = url.searchParams.get("to") || "";

// セレクト用に年月日に分解
const [fromY, fromM, fromD] = dateFrom ? dateFrom.split('-') : ['', '', ''];
const [toY, toM, toD] = dateTo ? dateTo.split('-') : ['', '', ''];

const months = [
  { val: '01', label: 'Jan' }, { val: '02', label: 'Feb' }, { val: '03', label: 'Mar' },
  { val: '04', label: 'Apr' }, { val: '05', label: 'May' }, { val: '06', label: 'Jun' },
  { val: '07', label: 'Jul' }, { val: '08', label: 'Aug' }, { val: '09', label: 'Sep' },
  { val: '10', label: 'Oct' }, { val: '11', label: 'Nov' }, { val: '12', label: 'Dec' },
];
const currentYear = new Date().getFullYear();
const years = [currentYear - 1, currentYear, currentYear + 1];
const days = Array.from({ length: 31 }, (_, i) => String(i + 1).padStart(2, '0'));

let bookings: any[] = [];
let ownerHotels: any[] = [];
let error = "";

if (db) {
  try {
    const hotelsRes = await db.prepare(
      "SELECT id, name FROM hotels WHERE email = ? AND is_active = 1 ORDER BY name"
    ).bind(owner.email).all();
    ownerHotels = hotelsRes?.results || [];
    const ownerHotelIds = ownerHotels.map((h: any) => h.id);

    if (ownerHotelIds.length > 0) {
      const placeholders = ownerHotelIds.map(() => "?").join(",");
      let query = `SELECT b.*, h.name as hotel_name, p.name as plan_name
        FROM bookings b
        LEFT JOIN hotels h ON b.hotel_id = h.id
        LEFT JOIN plans p ON b.plan_id = p.id
        WHERE b.hotel_id IN (${placeholders})`;
      const binds: any[] = [...ownerHotelIds];

      if (statusFilter) {
        query += " AND b.status = ?";
        binds.push(statusFilter);
      }
      if (hotelFilter) {
        query += " AND b.hotel_id = ?";
        binds.push(parseInt(hotelFilter));
      }
      if (dateFrom) {
        query += " AND b.check_in_date >= ?";
        binds.push(dateFrom);
      }
      if (dateTo) {
        query += " AND b.check_in_date <= ?";
        binds.push(dateTo);
      }

      query += " ORDER BY b.created_at DESC";
      const result = await db.prepare(query).bind(...binds).all();
      bookings = result?.results || [];
    }
  } catch (e: any) {
    error = e.message || "Failed to load bookings";
  }
}

const statusOptions = ["", "pending", "pending_confirmation", "confirmed", "cancelled"];
const statusLabels: Record<string, string> = {
  "": "All Statuses",
  pending: "Pending",
  pending_confirmation: "Pending Confirmation",
  confirmed: "Confirmed",
  cancelled: "Cancelled"
};
---

<OwnerLayout title="Bookings" activeNav="bookings">
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <form method="GET" action="/owner/bookings" class="flex flex-wrap items-end gap-4">
      <div class="min-w-[180px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Hotel</label>
        <select name="hotel_id" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white">
          <option value="">All My Hotels</option>
          {ownerHotels.map((h: any) => (
            <option value={h.id} selected={String(h.id) === hotelFilter}>{h.name}</option>
          ))}
        </select>
      </div>
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Status</label>
        <select name="status" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white">
          {statusOptions.map((s) => (
            <option value={s} selected={s === statusFilter}>{statusLabels[s]}</option>
          ))}
        </select>
      </div>
      <!-- From date: flatpickr calendar -->
      <div>
        <label class="block text-xs font-medium text-slate-500 mb-1">From</label>
        <input
          type="text"
          id="from-date-picker"
          name="from"
          value={dateFrom}
          placeholder="Select date"
          readonly
          class="px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white w-36 cursor-pointer"
        />
      </div>
      <!-- To date: flatpickr calendar -->
      <div>
        <label class="block text-xs font-medium text-slate-500 mb-1">To</label>
        <input
          type="text"
          id="to-date-picker"
          name="to"
          value={dateTo}
          placeholder="Select date"
          readonly
          class="px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white w-36 cursor-pointer"
        />
      </div>
      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors">
          Filter
        </button>
        <a href="/owner/bookings" class="px-4 py-2 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors">
          Reset
        </a>
        <a href={`/api/owner/bookings?format=csv${statusFilter ? "&status=" + statusFilter : ""}${hotelFilter ? "&hotel_id=" + hotelFilter : ""}${dateFrom ? "&from=" + dateFrom : ""}${dateTo ? "&to=" + dateTo : ""}`} class="px-4 py-2 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 transition-colors inline-flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          CSV
        </a>
      </div>
    </form>
  </div>

  <div class="flex items-center gap-4 mb-4 text-sm">
    <p class="text-slate-500">{bookings.length} booking{bookings.length !== 1 ? "s" : ""} found</p>
    <span class="text-slate-300">|</span>
    <span class="text-amber-600">{bookings.filter((b: any) => b.status === "pending").length} pending</span>
    <span class="text-orange-600">{bookings.filter((b: any) => b.status === "pending_confirmation").length} awaiting confirm</span>
    <span class="text-emerald-600">{bookings.filter((b: any) => b.status === "confirmed").length} confirmed</span>
    <span class="text-red-600">{bookings.filter((b: any) => b.status === "cancelled").length} cancelled</span>
  </div>

  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>
  )}

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm" id="bookings-table">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-medium text-slate-600">ID</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Guest Name</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Hotel</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Plan</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Check-in</th>
            <th class="text-right px-4 py-3 font-medium text-slate-600">Amount (USD)</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Status</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {bookings.length === 0 ? (
            <tr>
              <td colspan="8" class="px-4 py-12 text-center text-slate-400">No bookings found</td>
            </tr>
          ) : bookings.map((b: any) => (
            <>
              <tr class="hover:bg-slate-50 transition-colors booking-row" data-id={b.id}>
                <td class="px-4 py-3 font-mono text-slate-500">#{b.id}</td>
                <td class="px-4 py-3 font-medium text-slate-900">
                  <div>{b.guest_name}</div>
                  <div class="text-xs text-slate-400">{b.guest_email}</div>
                  <div class="text-xs text-slate-500 mt-0.5 flex items-center gap-1">
                    <span>👤 {b.adults || 1}</span>
                    {(b.children > 0) && <span>🧒 {b.children}</span>}
                    {(b.infants > 0) && <span>👶 {b.infants}</span>}
                  </div>
                </td>
                <td class="px-4 py-3 text-slate-600">{b.hotel_name || "-"}</td>
                <td class="px-4 py-3 text-slate-600">{b.plan_name || "-"}</td>
                <td class="px-4 py-3 text-slate-600">{b.check_in_date}</td>
                <td class="px-4 py-3 text-right font-mono">${Number(b.total_price_usd).toFixed(2)}</td>
                <td class="px-4 py-3 text-center">
                  <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                    b.status === "confirmed" ? "bg-emerald-100 text-emerald-700" :
                    b.status === "pending" ? "bg-amber-100 text-amber-700" :
                    b.status === "pending_confirmation" ? "bg-orange-100 text-orange-700" :
                    b.status === "cancelled" ? "bg-red-100 text-red-700" :
                    "bg-slate-100 text-slate-600"
                  }`}>
                    {b.status === "pending_confirmation" ? "Pending Confirm" : b.status}
                  </span>
                </td>
                <td class="px-4 py-3 text-center">
                  <div class="flex items-center justify-center gap-1">
                    <button class="detail-toggle p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded transition-colors" title="View Details" data-id={b.id}>
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                      </svg>
                    </button>
                    {(b.status === "pending" || b.status === "pending_confirmation") && (
                      <button class="confirm-btn px-2 py-1 text-xs text-emerald-700 bg-emerald-50 border border-emerald-200 rounded hover:bg-emerald-100 transition-colors" data-id={b.id} title="Confirm">
                        Confirm
                      </button>
                    )}
                    {(b.status === "pending" || b.status === "pending_confirmation" || b.status === "confirmed") && (
                      <button class="cancel-btn px-2 py-1 text-xs text-red-700 bg-red-50 border border-red-200 rounded hover:bg-red-100 transition-colors" data-id={b.id} title="Cancel">
                        Cancel
                      </button>
                    )}
                    <button class="msg-btn px-2 py-1 text-xs text-blue-700 bg-blue-50 border border-blue-200 rounded hover:bg-blue-100 transition-colors" data-id={b.id} data-guest={b.guest_name} title="Message">
                      💬
                    </button>
                  </div>
                </td>
              </tr>
              <!-- Expanded detail row (hidden by default) -->
              <tr class="detail-row hidden bg-slate-50" data-detail-id={b.id}>
                <td colspan="8" class="px-6 py-4">
                  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
                    <div>
                      <span class="text-slate-400 text-xs block">Email</span>
                      <span class="text-slate-700">{b.guest_email}</span>
                    </div>
                    <div>
                      <span class="text-slate-400 text-xs block">Phone</span>
                      <span class="text-slate-700">{b.guest_phone || "-"}</span>
                    </div>
                    <div>
                      <span class="text-slate-400 text-xs block">Adults / Children / Infants</span>
                      <span class="text-slate-700">{b.adults || 0} / {b.children || 0} / {b.infants || 0}</span>
                    </div>
                    <div>
                      <span class="text-slate-400 text-xs block">PayPal Order ID</span>
                      <span class="text-slate-700 font-mono text-xs">{b.paypal_order_id || "-"}</span>
                    </div>
                    <div>
                      <span class="text-slate-400 text-xs block">Notes</span>
                      <span class="text-slate-700">{b.notes || "-"}</span>
                    </div>
                    <div>
                      <span class="text-slate-400 text-xs block">Created</span>
                      <span class="text-slate-700 text-xs">{b.created_at?.slice(0, 16)}</span>
                    </div>
                  </div>
                </td>
              </tr>
            </>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</OwnerLayout>

<script>
  // Date select → hidden input combiner
  function syncDate(prefix) {
    var y = document.getElementById(prefix + '-y').value;
    var m = document.getElementById(prefix + '-m').value;
    var d = document.getElementById(prefix + '-d').value;
    document.getElementById(prefix + '-hidden').value = (y && m && d) ? y + '-' + m + '-' + d : '';
  }
  ['from', 'to'].forEach(function(p) {
    ['y', 'm', 'd'].forEach(function(part) {
      document.getElementById(p + '-' + part).addEventListener('change', function() { syncDate(p); });
    });
  });

  // Toggle detail rows
  document.querySelectorAll('.detail-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-id');
      const detailRow = document.querySelector(`.detail-row[data-detail-id="${id}"]`);
      if (detailRow) {
        detailRow.classList.toggle('hidden');
        const svg = btn.querySelector('svg');
        if (svg) svg.style.transform = detailRow.classList.contains('hidden') ? '' : 'rotate(180deg)';
      }
    });
  });

  // Confirm booking
  document.querySelectorAll('.confirm-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      if (!confirm(`Confirm booking #${id}?`)) return;

      try {
        const res = await fetch('/api/owner/bookings', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: Number(id), status: 'confirmed' }),
        });

        if (res.ok) {
          location.reload();
        } else {
          alert('Failed to confirm booking');
        }
      } catch {
        alert('Error confirming booking');
      }
    });
  });

  // Cancel booking
  document.querySelectorAll('.cancel-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      if (!confirm(`Cancel booking #${id}? The guest will be notified.`)) return;

      try {
        const res = await fetch('/api/owner/bookings', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: Number(id), status: 'cancelled' }),
        });

        if (res.ok) {
          location.reload();
        } else {
          alert('Failed to cancel booking');
        }
      } catch {
        alert('Error cancelling booking');
      }
    });
  });

  // Message modal
  const msgModal = document.createElement('div');
  msgModal.id = 'owner-msg-modal';
  msgModal.className = 'fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4';
  msgModal.innerHTML = `
    <div class="bg-white rounded-2xl shadow-xl max-w-md w-full p-6">
      <h3 class="text-lg font-bold text-gray-900 mb-1">Message Guest</h3>
      <p class="text-sm text-gray-500 mb-3">Booking #<span id="owner-msg-booking-id"></span> — <span id="owner-msg-guest"></span></p>
      <div id="owner-msg-thread" class="max-h-48 overflow-y-auto mb-3 space-y-2 bg-gray-50 rounded-lg p-3 hidden"></div>
      <textarea id="owner-msg-content" rows="3" placeholder="Type your message..."
        class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-400 outline-none resize-none mb-4"></textarea>
      <div class="flex gap-3">
        <button id="owner-msg-close" class="flex-1 py-2.5 border border-gray-200 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50">Close</button>
        <button id="owner-msg-send" class="flex-1 py-2.5 bg-blue-500 hover:bg-blue-600 text-white rounded-lg text-sm font-bold">Send</button>
      </div>
    </div>`;
  document.body.appendChild(msgModal);

  let currentMsgBookingId = null;

  async function loadOwnerMessages(bookingId) {
    const thread = document.getElementById('owner-msg-thread');
    try {
      const res = await fetch('/api/owner/booking-messages?booking_id=' + bookingId);
      const data = await res.json();
      if (data.messages && data.messages.length > 0) {
        thread.classList.remove('hidden');
        thread.innerHTML = data.messages.map(m => {
          const isHotel = m.sender_type === 'hotel';
          return `<div class="${isHotel ? 'text-right' : 'text-left'}"><span class="inline-block px-3 py-1.5 rounded-xl text-xs max-w-[85%] ${isHotel ? 'bg-blue-500 text-white' : 'bg-white border text-gray-700'}">${m.content}</span><div class="text-xs text-gray-300 mt-0.5">${m.sender_name}</div></div>`;
        }).join('');
        thread.scrollTop = thread.scrollHeight;
      }
    } catch {}
  }

  document.querySelectorAll('.msg-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      currentMsgBookingId = btn.dataset.id;
      document.getElementById('owner-msg-booking-id').textContent = currentMsgBookingId;
      document.getElementById('owner-msg-guest').textContent = btn.dataset.guest;
      document.getElementById('owner-msg-content').value = '';
      document.getElementById('owner-msg-thread').innerHTML = '';
      document.getElementById('owner-msg-thread').classList.add('hidden');
      msgModal.classList.remove('hidden'); msgModal.classList.add('flex');
      await loadOwnerMessages(currentMsgBookingId);
    });
  });

  document.getElementById('owner-msg-close').addEventListener('click', () => { msgModal.classList.add('hidden'); msgModal.classList.remove('flex'); });
  msgModal.addEventListener('click', e => { if (e.target === msgModal) { msgModal.classList.add('hidden'); msgModal.classList.remove('flex'); } });

  document.getElementById('owner-msg-send').addEventListener('click', async () => {
    const content = document.getElementById('owner-msg-content').value.trim();
    if (!content) return;
    const sendBtn = document.getElementById('owner-msg-send');
    sendBtn.textContent = 'Sending...'; sendBtn.disabled = true;
    try {
      const res = await fetch('/api/owner/booking-messages', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ booking_id: Number(currentMsgBookingId), content }) });
      const data = await res.json();
      if (data.success) { document.getElementById('owner-msg-content').value = ''; await loadOwnerMessages(currentMsgBookingId); }
      else { alert(data.error || 'Failed'); }
    } catch { alert('Error'); }
    sendBtn.textContent = 'Send'; sendBtn.disabled = false;
  });
</script>

<!-- flatpickr for date filters -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
<script is:inline>
(function() {
  var fpScript = document.createElement('script');
  fpScript.src = 'https://cdn.jsdelivr.net/npm/flatpickr';
  fpScript.onload = function() {
    if (typeof flatpickr === 'undefined') return;
    flatpickr('#from-date-picker', {
      dateFormat: 'Y-m-d',
      allowInput: false,
      disableMobile: true,
    });
    flatpickr('#to-date-picker', {
      dateFormat: 'Y-m-d',
      allowInput: false,
      disableMobile: true,
    });
  };
  document.head.appendChild(fpScript);
})();
</script>
