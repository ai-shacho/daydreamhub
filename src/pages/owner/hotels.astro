---
import OwnerLayout from '../../layouts/OwnerLayout.astro';
import { verifyOwner } from '../../lib/ownerAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const owner = await verifyOwner(Astro.request, jwtSecret);
if (!owner) {
  return Astro.redirect("/login?redirect=/owner/hotels");
}

let hotels: any[] = [];
let error = "";

if (db) {
  try {
    const result = await db.prepare(
      `SELECT h.*,
        (SELECT COUNT(*) FROM plans p WHERE p.hotel_id = h.id) as plan_count,
        (SELECT COUNT(*) FROM bookings b WHERE b.hotel_id = h.id AND b.status IN ('pending', 'confirmed')) as active_bookings
      FROM hotels h
      WHERE h.email = ?
      ORDER BY h.created_at DESC`
    ).bind(owner.email).all();
    hotels = result?.results || [];
  } catch (e: any) {
    error = e.message || "Failed to load hotels";
  }
} else {
  error = "Database not available";
}
---

<OwnerLayout title="My Hotels" activeNav="hotels">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-xl md:text-2xl font-bold">My Hotels</h1>
    <a href="/owner/hotels/new" class="inline-flex items-center gap-1.5 bg-teal-600 text-white text-sm font-medium py-2 px-4 rounded-full shadow hover:bg-teal-700 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Add New Hotel
    </a>
  </div>

  {error && <p class="text-red-500 text-sm mb-4">{error}</p>}

  {hotels.length === 0 && !error && (
    <div class="text-center py-16 text-slate-400">
      <svg class="w-12 h-12 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
      </svg>
      <p class="text-sm">No hotels yet. Add your first property!</p>
    </div>
  )}

  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
    {hotels.map(hotel => (
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden flex flex-col">
        <div class="relative h-36 bg-slate-100">
          {hotel.thumbnail_url ? (
            <img
              src={hotel.thumbnail_url}
              alt={hotel.name}
              class="w-full h-full object-cover"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-slate-300">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
          )}
          <span class={`absolute top-2 right-2 text-xs font-medium px-2 py-0.5 rounded-full ${hotel.status === 'active' ? 'bg-green-100 text-green-700' : hotel.status === 'demo' ? 'bg-amber-100 text-amber-700' : 'bg-slate-100 text-slate-500'}`}>
            {hotel.status || 'inactive'}
          </span>
        </div>

        <div class="p-4 flex flex-col flex-1">
          <h2 class="font-semibold text-slate-800 text-sm leading-snug mb-0.5 truncate">{hotel.name}</h2>
          <p class="text-xs text-teal-600 capitalize mb-2">{hotel.property_type || hotel.type || '—'}</p>
          <div class="flex gap-4 text-xs text-slate-500 mb-4">
            <span>Plans: <strong class="text-slate-700">{hotel.plan_count}</strong></span>
            <span>Active bookings: <strong class="text-slate-700">{hotel.active_bookings}</strong></span>
          </div>

          <div class="mt-auto flex items-center gap-2">
            <a href={`/owner/hotels/${hotel.id}`} class="flex-1 text-center text-sm font-medium bg-teal-50 text-teal-700 py-1.5 rounded-lg hover:bg-teal-100 transition-colors">
              Edit
            </a>
            <button
              data-hotel-id={hotel.id}
              class="delete-hotel-btn flex-1 text-center text-sm font-medium bg-red-50 text-red-600 py-1.5 rounded-lg hover:bg-red-100 transition-colors"
            >
              Delete
            </button>
          </div>
        </div>
      </div>
    ))}
  </div>
</OwnerLayout>

<script>
  document.addEventListener('click', async function(e) {
    const btn = (e.target as HTMLElement).closest('.delete-hotel-btn');
    if (!btn) return;
    const hotelId = btn.getAttribute('data-hotel-id');
    if (!hotelId) return;
    if (!confirm('本当に削除しますか？')) return;
    const response = await fetch(`/api/owner/hotels/${hotelId}`, {
      method: 'DELETE'
    });
    if (response.ok) {
      window.location.reload();
    } else {
      alert('削除に失敗しました');
    }
  });
</script>
