---
import OwnerLayout from '../../layouts/OwnerLayout.astro';
import { verifyOwner } from '../../lib/ownerAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const owner = await verifyOwner(Astro.request, jwtSecret);
if (!owner) {
  return Astro.redirect("/login?redirect=/owner/hotels");
}

let hotels: any[] = [];
let error = "";

if (db) {
  try {
    const result = await db.prepare(
      `SELECT h.*,
        (SELECT COUNT(*) FROM plans p WHERE p.hotel_id = h.id) as plan_count,
        (SELECT COUNT(*) FROM bookings b WHERE b.hotel_id = h.id AND b.status IN ('pending', 'confirmed')) as active_bookings
      FROM hotels h
      WHERE h.email = ?
      ORDER BY h.created_at DESC`
    ).bind(owner.email).all();
    hotels = result?.results || [];
  } catch (e: any) {
    error = e.message || "Failed to load hotels";
  }
} else {
  error = "Database not available";
}

const propertyTypes = ["Hotel","Villa","Resort","Apartment","Clinic","Spa","Wellness","Coworking Space","Cafe & Lounge","Hostel"];

---

<OwnerLayout title="My Hotels" activeNav="hotels">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-xl md:text-2xl font-bold">My Hotels</h1>
    <a href="/owner/hotels/new" class="inline-block bg-teal-600 text-white py-2 px-4 rounded-full shadow hover:bg-teal-700 transition-all duration-150">Add New Hotel</a>
  </div>

  {error && <p class="text-red-500 text-sm mb-4">{error}</p>}

  <ul class="divide-y divide-slate-200">
    {hotels.map(hotel => (
      <li key={hotel.id} class="flex items-center justify-between py-4">
        <div class="flex items-center gap-4">
          <img src={`/assets/${hotel.image}`} alt="{hotel.name} image" class="w-14 h-14 object-cover rounded-lg" />
          <div>
            <h2 class="text-lg font-semibold text-slate-700">{hotel.name}</h2>
            <p class="text-sm text-teal-600">{hotel.type}</p>
            <p class="text-sm text-slate-500">Plans: {hotel.plan_count} Active bookings: {hotel.active_bookings}</p>
          </div>
        </div>
        <a href={`/owner/hotels/${hotel.id}`} class="text-teal-600 hover:underline">Edit</a>
      </li>
    ))}
  </ul>
</OwnerLayout>