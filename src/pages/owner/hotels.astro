---
import OwnerLayout from '../../layouts/OwnerLayout.astro';
import { verifyOwner } from '../../lib/ownerAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const owner = await verifyOwner(Astro.request, jwtSecret);
if (!owner) {
  return Astro.redirect("/login?redirect=/owner/hotels");
}

let hotels: any[] = [];
let error = "";

if (db) {
  try {
    const result = await db.prepare(
      `SELECT h.*,
        (SELECT COUNT(*) FROM plans p WHERE p.hotel_id = h.id) as plan_count,
        (SELECT COUNT(*) FROM bookings b WHERE b.hotel_id = h.id AND b.status IN ('pending', 'confirmed')) as active_bookings
      FROM hotels h
      WHERE h.email = ?
      ORDER BY h.created_at DESC`
    ).bind(owner.email).all();
    hotels = result?.results || [];
  } catch (e: any) {
    error = e.message || "Failed to load hotels";
  }
} else {
  error = "Database not available";
}

const propertyTypes = ["Hotel","Villa","Resort","Apartment","Clinic","Spa","Wellness","Coworking Space","Cafe & Lounge","Hostel"];

---

<OwnerLayout title="My Hotels" activeNav="hotels">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <p class="text-sm text-slate-500">{hotels.length} hotel{hotels.length !== 1 ? "s" : ""} assigned to your account</p>
    </div>
    <button id="open-add-hotel" class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors shadow-sm">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Add Hotel
    </button>
  </div>

  {error && (
    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">
      {error}
    </div>
  )}

  {hotels.length === 0 && !error ? (
    <div class="bg-white rounded-xl border border-slate-200 p-12 text-center">
      <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
      </svg>
      <h3 class="text-lg font-semibold text-slate-700 mb-2">No hotels yet</h3>
      <p class="text-sm text-slate-500 max-w-md mx-auto mb-6">
        Add your first hotel to get started. It will be reviewed by our admin team before going live.
      </p>
      <button id="open-add-hotel-2" class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Add Your First Hotel
      </button>
    </div>
  ) : (
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th class="text-left px-4 py-3 font-medium text-slate-600">Thumbnail</th>
              <th class="text-left px-4 py-3 font-medium text-slate-600">Hotel Name</th>
              <th class="text-left px-4 py-3 font-medium text-slate-600">City</th>
              <th class="text-center px-4 py-3 font-medium text-slate-600">Plans</th>
              <th class="text-center px-4 py-3 font-medium text-slate-600">Active Bookings</th>
              <th class="text-center px-4 py-3 font-medium text-slate-600">Status</th>
              <th class="text-right px-4 py-3 font-medium text-slate-600">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {hotels.map((hotel: any) => (
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-4 py-3">
                  {hotel.thumbnail_url ? (
                    <img src={hotel.thumbnail_url} alt={hotel.name} class="w-12 h-9 object-cover rounded-md border border-slate-200" />
                  ) : (
                    <div class="w-12 h-9 bg-slate-100 rounded-md border border-slate-200 flex items-center justify-center">
                      <svg class="w-5 h-5 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
                      </svg>
                    </div>
                  )}
                </td>
                <td class="px-4 py-3">
                  <div class="font-medium text-slate-900">{hotel.name}</div>
                  {hotel.name_ja && <div class="text-xs text-slate-400 mt-0.5">{hotel.name_ja}</div>}
                  <div class="text-xs text-slate-400 mt-0.5">{hotel.property_type || "Hotel"}</div>
                </td>
                <td class="px-4 py-3 text-slate-600">
                  <div>{hotel.city}</div>
                  <div class="text-xs text-slate-400">{hotel.country}</div>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-blue-50 text-blue-700 text-xs font-semibold">
                    {hotel.plan_count}
                  </span>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class={`inline-flex items-center justify-center w-7 h-7 rounded-full text-xs font-semibold ${hotel.active_bookings > 0 ? "bg-green-50 text-green-700" : "bg-slate-50 text-slate-500"}`}>
                    {hotel.active_bookings}
                  </span>
                </td>
                <td class="px-4 py-3 text-center">
                  {hotel.is_active ? (
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700">
                      <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                      Active
                    </span>
                  ) : (
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700">
                      <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                      Pending Review
                    </span>
                  )}
                </td>
                <td class="px-4 py-3 text-right">
                  {hotel.is_active ? (
                    <a href={`/owner/hotels/${hotel.id}`} class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-indigo-600 bg-indigo-50 border border-indigo-200 rounded-md hover:bg-indigo-100 transition-colors">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                      </svg>
                      Edit Hotel
                    </a>
                  ) : (
                    <span class="text-xs text-slate-400 italic">Awaiting review</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <!-- Add Hotel Modal -->
  <div id="add-hotel-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/50" id="modal-backdrop"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
      <div class="sticky top-0 bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between rounded-t-2xl">
        <h2 class="text-lg font-semibold text-slate-900">Add New Hotel</h2>
        <button id="close-modal" class="text-slate-400 hover:text-slate-600 transition-colors">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <form id="add-hotel-form" class="p-6 space-y-5">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="sm:col-span-2">
            <label class="block text-sm font-medium text-slate-700 mb-1">Hotel Name <span class="text-red-500">*</span></label>
            <input type="text" name="name" required placeholder="e.g. Grand Ocean Hotel"
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-400 focus:border-transparent outline-none" />
          </div>
          <div class="sm:col-span-2">
            <label class="block text-sm font-medium text-slate-700 mb-1">Hotel Name (Japanese)</label>
            <input type="text" name="name_ja" placeholder="（任意）"
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-400 focus:border-transparent outline-none" />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">City <span class="text-red-500">*</span></label>
            <input type="text" name="city" required placeholder="e.g. Bangkok"
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-400 focus:border-transparent outline-none" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Country <span class="text-red-500">*</span></label>
            <input type="text" name="country" required placeholder="e.g. Thailand"
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-400 focus:border-transparent outline-none" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Address</label>
          <input type="text" name="address" placeholder="Full address"
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-400 focus:border-transparent outline-none" />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Property Type</label>
            <select name="property_type" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-400 focus:border-transparent outline-none bg-white">
              {propertyTypes.map(t => <option value={t}>{t}</option>)}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Phone</label>
            <input type="text" name="phone" placeholder="+66-2-xxx-xxxx"
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-400 focus:border-transparent outline-none" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Description</label>
          <textarea name="description" rows="3" placeholder="Describe your property..."
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-400 focus:border-transparent outline-none resize-none"></textarea>
        </div>

        <div id="form-error" class="hidden p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>
        <div id="form-success" class="hidden p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700"></div>

        <div class="flex gap-3 pt-2">
          <button type="button" id="cancel-btn" class="flex-1 px-4 py-2.5 border border-slate-300 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50 transition-colors">
            Cancel
          </button>
          <button type="submit" id="submit-btn" class="flex-1 px-4 py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors">
            Add Hotel
          </button>
        </div>
      </form>
    </div>
  </div>
</OwnerLayout>

<script is:inline>
function openModal() {
  document.getElementById('add-hotel-modal').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
}
function closeModal() {
  document.getElementById('add-hotel-modal').classList.add('hidden');
  document.body.style.overflow = '';
  document.getElementById('add-hotel-form').reset();
  document.getElementById('form-error').classList.add('hidden');
  document.getElementById('form-success').classList.add('hidden');
}

document.getElementById('open-add-hotel')?.addEventListener('click', openModal);
document.getElementById('open-add-hotel-2')?.addEventListener('click', openModal);
document.getElementById('close-modal')?.addEventListener('click', closeModal);
document.getElementById('cancel-btn')?.addEventListener('click', closeModal);
document.getElementById('modal-backdrop')?.addEventListener('click', closeModal);

document.getElementById('add-hotel-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('submit-btn');
  const errEl = document.getElementById('form-error');
  const successEl = document.getElementById('form-success');
  errEl.classList.add('hidden');
  successEl.classList.add('hidden');
  btn.disabled = true;
  btn.textContent = 'Adding...';

  const form = e.target;
  const data = {
    name: form.name.value,
    name_ja: form.name_ja.value,
    city: form.city.value,
    country: form.country.value,
    address: form.address.value,
    property_type: form.property_type.value,
    phone: form.phone.value,
    description: form.description.value,
  };

  try {
    const res = await fetch('/api/owner/hotels', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    const result = await res.json();
    if (res.ok) {
      successEl.textContent = '✅ Hotel added successfully!';
      successEl.classList.remove('hidden');
      btn.textContent = 'Added!';
      setTimeout(() => {
        closeModal();
        window.location.reload();
      }, 1500);
    } else {
      errEl.textContent = result.error || 'Failed to add hotel.';
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Add Hotel';
    }
  } catch {
    errEl.textContent = 'Connection error. Please try again.';
    errEl.classList.remove('hidden');
    btn.disabled = false;
    btn.textContent = 'Add Hotel';
  }
});
</script>
