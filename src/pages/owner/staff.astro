---
import OwnerLayout from '../../layouts/OwnerLayout.astro';
import { verifyOwner, getOwnerHotelIds, getStaffRole, canManageStaff } from '../../lib/ownerAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const owner = await verifyOwner(Astro.request, jwtSecret);
if (!owner) {
  return Astro.redirect("/login?redirect=/owner/staff");
}

const staffRole = owner.role === 'staff' ? await getStaffRole(db, owner.sub) : null;
if (!canManageStaff(owner, staffRole)) {
  return Astro.redirect("/owner");
}

let ownerHotels: any[] = [];
let staffList: any[] = [];
let error = "";

if (db) {
  try {
    const ownerHotelIds = await getOwnerHotelIds(db, owner);
    if (ownerHotelIds.length > 0) {
      const hotelsPlaceholders = ownerHotelIds.map(() => "?").join(",");

      const hotelsRes = await db.prepare(
        `SELECT id, name FROM hotels WHERE id IN (${hotelsPlaceholders})`
      ).bind(...ownerHotelIds).all();
      ownerHotels = hotelsRes?.results || [];

      const staffRes = await db.prepare(`
        SELECT hs.id, hs.hotel_id, hs.staff_role, hs.created_at, u.id as user_id, u.name, u.email, h.name as hotel_name
        FROM hotel_staff hs
        JOIN users u ON hs.user_id = u.id
        JOIN hotels h ON hs.hotel_id = h.id
        WHERE hs.hotel_id IN (${hotelsPlaceholders})
        ORDER BY hs.created_at DESC
      `).bind(...ownerHotelIds).all();
      staffList = staffRes?.results || [];
    }
  } catch (e: any) {
    error = e.message || "Failed to load staff data";
  }
}
---

<OwnerLayout title="Staff Management" activeNav="staff">
  <!-- Invite Staff -->
  <div class="bg-white rounded-xl border border-slate-200 p-6 mb-6">
    <h3 class="text-lg font-semibold text-slate-900 mb-4">Invite Staff Member</h3>
    <form id="invite-form" class="space-y-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Name</label>
          <input type="text" name="name" required placeholder="Staff member name" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
          <input type="email" name="email" required placeholder="staff@example.com" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Hotels</label>
          <div class="border border-slate-300 rounded-lg p-3 max-h-40 overflow-y-auto space-y-2">
            <label class="flex items-center gap-2 text-sm text-slate-700 cursor-pointer">
              <input type="checkbox" id="select-all-hotels" class="w-4 h-4 text-indigo-600 rounded border-slate-300 focus:ring-indigo-500" />
              <span class="font-medium">All Hotels</span>
            </label>
            <hr class="border-slate-200" />
            {ownerHotels.map((h: any) => (
              <label class="flex items-center gap-2 text-sm text-slate-700 cursor-pointer">
                <input type="checkbox" name="hotel_ids" value={h.id} class="hotel-checkbox w-4 h-4 text-indigo-600 rounded border-slate-300 focus:ring-indigo-500" />
                <span>{h.name}</span>
              </label>
            ))}
          </div>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-2">Permission Level</label>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <label class="flex items-start gap-3 p-3 border border-slate-200 rounded-lg cursor-pointer hover:border-indigo-300 hover:bg-indigo-50 transition-colors has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50">
            <input type="radio" name="staff_role" value="booking_manager" checked class="mt-1 text-indigo-600 focus:ring-indigo-500" />
            <div>
              <p class="text-sm font-semibold text-slate-800">Booking Manager</p>
              <p class="text-xs text-slate-500 mt-0.5">Manage bookings, calendar, messages, and reviews. Cannot edit hotel info, pricing, or invite staff.</p>
            </div>
          </label>
          <label class="flex items-start gap-3 p-3 border border-slate-200 rounded-lg cursor-pointer hover:border-indigo-300 hover:bg-indigo-50 transition-colors has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50">
            <input type="radio" name="staff_role" value="co_owner" class="mt-1 text-indigo-600 focus:ring-indigo-500" />
            <div>
              <p class="text-sm font-semibold text-slate-800">Co-owner</p>
              <p class="text-xs text-slate-500 mt-0.5">Full access — same permissions as the hotel owner, including hotel editing, reports, and staff management.</p>
            </div>
          </label>
        </div>
      </div>
      <div class="flex items-center justify-between">
        <p class="text-xs text-slate-500">Staff will need to log in with the email and a password set by admin.</p>
        <button type="submit" id="invite-btn" class="px-5 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors">
          Invite Staff
        </button>
      </div>
    </form>
    <div id="invite-message" class="mt-3 hidden"></div>
  </div>

  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>
  )}

  <div class="flex items-center justify-between mb-4">
    <p class="text-sm text-slate-500">{staffList.length} staff member{staffList.length !== 1 ? "s" : ""}</p>
  </div>

  <!-- Staff Table -->
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-medium text-slate-600">Name</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Email</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Hotel</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Role</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Added Date</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {staffList.length === 0 ? (
            <tr>
              <td colspan="6" class="px-4 py-12 text-center text-slate-400">
                No staff members yet.
              </td>
            </tr>
          ) : staffList.map((s: any) => (
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-4 py-3">
                <span class="font-medium text-slate-900">{s.name}</span>
              </td>
              <td class="px-4 py-3 text-slate-600">{s.email}</td>
              <td class="px-4 py-3 text-slate-600">{s.hotel_name}</td>
              <td class="px-4 py-3">
                {s.staff_role === 'co_owner' ? (
                  <span class="bg-indigo-100 text-indigo-800 text-xs font-bold px-2 py-1 rounded-full">Co-owner</span>
                ) : (
                  <span class="bg-slate-100 text-slate-700 text-xs font-bold px-2 py-1 rounded-full">Booking Manager</span>
                )}
              </td>
              <td class="px-4 py-3 text-slate-500 text-xs">{s.created_at?.slice(0, 10)}</td>
              <td class="px-4 py-3 text-center">
                <button class="remove-staff-btn px-3 py-1 text-xs font-medium text-red-600 bg-red-50 border border-red-200 rounded-lg hover:bg-red-100 transition-colors" data-staff-id={s.id} data-staff-name={s.name}>
                  Remove
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</OwnerLayout>

<script>
  // Invite form submit
  const inviteForm = document.getElementById('invite-form');
  const inviteMessage = document.getElementById('invite-message');
  const inviteBtn = document.getElementById('invite-btn') as HTMLButtonElement | null;

  // "All Hotels" checkbox toggle
  const selectAll = document.getElementById('select-all-hotels') as HTMLInputElement | null;
  const hotelCheckboxes = document.querySelectorAll('.hotel-checkbox') as NodeListOf<HTMLInputElement>;
  if (selectAll) {
    selectAll.addEventListener('change', () => {
      hotelCheckboxes.forEach(cb => { cb.checked = selectAll.checked; });
    });
    hotelCheckboxes.forEach(cb => {
      cb.addEventListener('change', () => {
        selectAll.checked = Array.from(hotelCheckboxes).every(c => c.checked);
      });
    });
  }

  if (inviteForm) {
    inviteForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(inviteForm as HTMLFormElement);
      const name = formData.get('name');
      const email = formData.get('email');
      const staff_role = formData.get('staff_role') || 'booking_manager';
      const hotelIds = formData.getAll('hotel_ids').map(Number).filter(Boolean);

      if (!name || !email || hotelIds.length === 0) {
        showMessage('Please fill in all fields and select at least one hotel.', 'error');
        return;
      }

      if (inviteBtn) {
        inviteBtn.disabled = true;
        inviteBtn.textContent = 'Inviting...';
      }

      try {
        let successCount = 0;
        let lastError = '';
        for (const hid of hotelIds) {
          const res = await fetch('/api/owner/staff', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, email, hotel_id: hid, staff_role }),
          });
          const data = await res.json();
          if (res.ok && data.success) {
            successCount++;
          } else {
            lastError = data.error || 'Failed to invite staff member.';
          }
        }

        if (successCount > 0) {
          showMessage(`Staff member invited to ${successCount} hotel${successCount > 1 ? 's' : ''} successfully!`, 'success');
          setTimeout(() => window.location.reload(), 1000);
        } else {
          showMessage(lastError || 'Failed to invite staff member.', 'error');
        }
      } catch (err) {
        showMessage('Network error. Please try again.', 'error');
      } finally {
        if (inviteBtn) {
          inviteBtn.disabled = false;
          inviteBtn.textContent = 'Invite Staff';
        }
      }
    });
  }

  // Remove staff buttons
  document.querySelectorAll('.remove-staff-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const staffId = btn.getAttribute('data-staff-id');
      const staffName = btn.getAttribute('data-staff-name');

      if (!confirm(`Are you sure you want to remove ${staffName} from this hotel?`)) {
        return;
      }

      (btn as HTMLButtonElement).disabled = true;
      btn.textContent = 'Removing...';

      try {
        const res = await fetch('/api/owner/staff', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ staff_id: Number(staffId) }),
        });
        const data = await res.json();

        if (res.ok && data.success) {
          window.location.reload();
        } else {
          alert(data.error || 'Failed to remove staff member.');
          (btn as HTMLButtonElement).disabled = false;
          btn.textContent = 'Remove';
        }
      } catch (err) {
        alert('Network error. Please try again.');
        (btn as HTMLButtonElement).disabled = false;
        btn.textContent = 'Remove';
      }
    });
  });

  function showMessage(text: string, type: string) {
    if (!inviteMessage) return;
    inviteMessage.className = 'mt-3 px-4 py-2 rounded-lg text-sm ' +
      (type === 'success'
        ? 'bg-green-50 border border-green-200 text-green-700'
        : 'bg-red-50 border border-red-200 text-red-700');
    inviteMessage.textContent = text;
    inviteMessage.classList.remove('hidden');
  }
</script>
