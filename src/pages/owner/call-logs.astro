---
import OwnerLayout from '../../layouts/OwnerLayout.astro';
import { verifyOwner, getOwnerHotelIds } from '../../lib/ownerAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const owner = await verifyOwner(Astro.request, jwtSecret);
if (!owner) return Astro.redirect("/login?redirect=/owner/call-logs");

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get("status") || "";
const hotelFilter = url.searchParams.get("hotel_id") || "";

let callLogs: any[] = [];
let hotels: any[] = [];
let error = "";

if (db) {
  try {
    const ownerHotelIds = await getOwnerHotelIds(db, owner);
    if (ownerHotelIds.length > 0) {
      const placeholders = ownerHotelIds.map(() => "?").join(",");

      const hotelsResult = await db.prepare(`SELECT id, name FROM hotels WHERE id IN (${placeholders}) ORDER BY name`).bind(...ownerHotelIds).all();
      hotels = hotelsResult?.results || [];

      let query = `SELECT cl.*, h.name as hotel_name, h.phone as hotel_phone,
                        b.guest_name, b.check_in_date, b.status as booking_status
                   FROM call_logs cl
                   LEFT JOIN hotels h ON h.id = cl.hotel_id
                   LEFT JOIN bookings b ON b.id = cl.booking_id
                   WHERE cl.hotel_id IN (${placeholders})`;
      const binds: any[] = [...ownerHotelIds];

      if (statusFilter) {
        query += " AND cl.status = ?";
        binds.push(statusFilter);
      }
      if (hotelFilter) {
        query += " AND cl.hotel_id = ?";
        binds.push(parseInt(hotelFilter));
      }

      query += " ORDER BY cl.created_at DESC LIMIT 100";
      const result = await db.prepare(query).bind(...binds).all();
      callLogs = result?.results || [];
    }
  } catch (e: any) {
    error = e.message || "Failed to load call logs";
  }
}

const statusOptions = ["", "queued", "calling", "amd_detecting", "ivr_detecting", "ivr_navigating", "awaiting_response", "confirmed", "declined", "no_answer", "voicemail", "message_left", "recording_message", "failed"];

const statusColors: Record<string, string> = {
  queued: "bg-slate-100 text-slate-600",
  calling: "bg-blue-100 text-blue-700",
  amd_detecting: "bg-blue-100 text-blue-700",
  ivr_detecting: "bg-cyan-100 text-cyan-700",
  ivr_navigating: "bg-sky-100 text-sky-700",
  ivr_buffer: "bg-sky-100 text-sky-700",
  awaiting_response: "bg-amber-100 text-amber-700",
  confirmed: "bg-emerald-100 text-emerald-700",
  declined: "bg-red-100 text-red-700",
  no_answer: "bg-orange-100 text-orange-700",
  voicemail: "bg-violet-100 text-violet-700",
  message_left: "bg-purple-100 text-purple-700",
  recording_message: "bg-indigo-100 text-indigo-700",
  failed: "bg-red-100 text-red-700"
};
---

<OwnerLayout title="Call Logs" activeNav="call-logs">
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <form method="GET" action="/owner/call-logs" class="flex flex-wrap items-end gap-4">
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Status</label>
        <select name="status" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white">
          <option value="">All Statuses</option>
          {statusOptions.filter((s) => s).map((s) => (
            <option value={s} selected={s === statusFilter}>{s.replace(/_/g, " ")}</option>
          ))}
        </select>
      </div>
      <div class="min-w-[200px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Hotel</label>
        <select name="hotel_id" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white">
          <option value="">All Hotels</option>
          {hotels.map((h: any) => (
            <option value={h.id} selected={String(h.id) === hotelFilter}>{h.name}</option>
          ))}
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">Filter</button>
        <a href="/owner/call-logs" class="px-4 py-2 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors">Reset</a>
      </div>
    </form>
  </div>

  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>
  )}

  <p class="text-sm text-slate-500 mb-4">{callLogs.length} call log{callLogs.length !== 1 ? "s" : ""} found</p>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-medium text-slate-600">Booking</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Hotel</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Guest</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Check-in</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Attempt</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Status</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Time</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {callLogs.length === 0 ? (
            <tr>
              <td colspan="8" class="px-4 py-12 text-center text-slate-400">No call logs found</td>
            </tr>
          ) : callLogs.map((cl: any) => {
            const hasRecording = cl.transcription?.startsWith("recordings/");
            const hasTranscript = cl.transcription && !hasRecording && !cl.transcription.startsWith("telnyx:");
            return (
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-4 py-3 font-mono text-slate-500">#{cl.booking_id}</td>
                <td class="px-4 py-3 text-slate-600">
                  <div>{cl.hotel_name || "-"}</div>
                  <div class="text-xs text-slate-400">{cl.hotel_phone || "No phone"}</div>
                </td>
                <td class="px-4 py-3 font-medium text-slate-900">{cl.guest_name || "-"}</td>
                <td class="px-4 py-3 text-slate-600">{cl.check_in_date || "-"}</td>
                <td class="px-4 py-3 text-center font-mono">{cl.attempt_number}/3</td>
                <td class="px-4 py-3 text-center">
                  <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColors[cl.status] || "bg-slate-100 text-slate-600"}`}>
                    {cl.status?.replace(/_/g, " ")}
                  </span>
                  {cl.result_digit && (
                    <span class="ml-1 text-xs text-slate-400">({cl.result_digit})</span>
                  )}
                </td>
                <td class="px-4 py-3 text-slate-500 text-xs">
                  {cl.started_at ? (
                    <div>{cl.started_at.slice(0, 16)}</div>
                  ) : cl.scheduled_at ? (
                    <div class="text-amber-600">Sched: {cl.scheduled_at.slice(0, 16)}</div>
                  ) : (
                    <div>{cl.created_at?.slice(0, 16) || "-"}</div>
                  )}
                  {cl.ended_at && (
                    <div class="text-slate-400">End: {cl.ended_at.slice(11, 19)}</div>
                  )}
                </td>
                <td class="px-4 py-3 text-center">
                  <div class="flex items-center justify-center gap-1">
                    {hasRecording && (
                      <button class="play-recording-btn p-1.5 text-purple-500 hover:text-purple-700 hover:bg-purple-50 rounded transition-colors" title="Play Recording" data-recording-key={cl.transcription.replace("recordings/", "")} data-id={cl.id}>
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
                        </svg>
                      </button>
                    )}
                    {hasTranscript && (
                      <button class="view-transcript-btn p-1.5 text-slate-400 hover:text-teal-600 hover:bg-teal-50 rounded transition-colors" title="View Transcription" data-transcript={cl.transcription} data-id={cl.id}>
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                        </svg>
                      </button>
                    )}
                    {["failed", "no_answer", "declined"].includes(cl.status) && (
                      <button class="recall-btn p-1.5 text-slate-400 hover:text-teal-600 hover:bg-teal-50 rounded transition-colors" title="Re-call" data-booking-id={cl.booking_id}>
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                        </svg>
                      </button>
                    )}
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Transcript/Recording Modal -->
  <div id="transcript-modal" class="fixed inset-0 z-50 hidden">
    <div class="fixed inset-0 bg-black/50" id="transcript-overlay"></div>
    <div class="fixed inset-0 flex items-center justify-center p-4">
      <div class="bg-white rounded-xl shadow-xl w-full max-w-lg relative">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200">
          <h2 id="modal-title" class="text-lg font-semibold text-slate-900">Call Details</h2>
          <button id="transcript-close" class="p-1 text-slate-400 hover:text-slate-600">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div class="p-6">
          <div id="modal-audio-container" class="hidden mb-4">
            <p class="text-sm text-slate-500 mb-2">Voice Message:</p>
            <audio id="modal-audio" controls class="w-full"></audio>
          </div>
          <pre id="transcript-content" class="whitespace-pre-wrap text-sm text-slate-700 bg-slate-50 rounded-lg p-4 max-h-96 overflow-y-auto hidden"></pre>
        </div>
      </div>
    </div>
  </div>
</OwnerLayout>

<script>
  const modal = document.getElementById('transcript-modal');
  const modalTitle = document.getElementById('modal-title');
  const content = document.getElementById('transcript-content');
  const audioContainer = document.getElementById('modal-audio-container');
  const audioElement = document.getElementById('modal-audio') as HTMLAudioElement | null;

  function openModal() {
    modal?.classList.remove('hidden');
  }
  function closeModal() {
    modal?.classList.add('hidden');
    if (audioElement) audioElement.pause();
  }

  // Play recording buttons
  document.querySelectorAll('.play-recording-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.getAttribute('data-recording-key');
      const id = btn.getAttribute('data-id');
      if (modalTitle) modalTitle.textContent = `Voice Message - Call #${id}`;
      if (audioContainer) audioContainer.classList.remove('hidden');
      if (content) content.classList.add('hidden');
      if (audioElement) {
        audioElement.src = `/api/admin/recordings/${key}`;
        audioElement.load();
      }
      openModal();
    });
  });

  // View transcript buttons
  document.querySelectorAll('.view-transcript-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const transcript = btn.getAttribute('data-transcript');
      const id = btn.getAttribute('data-id');
      if (modalTitle) modalTitle.textContent = `Transcription - Call #${id}`;
      if (audioContainer) audioContainer.classList.add('hidden');
      if (content) {
        content.textContent = transcript || 'No transcription available';
        content.classList.remove('hidden');
      }
      openModal();
    });
  });

  document.getElementById('transcript-close')?.addEventListener('click', closeModal);
  document.getElementById('transcript-overlay')?.addEventListener('click', closeModal);

  // Re-call buttons
  document.querySelectorAll('.recall-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const bookingId = btn.getAttribute('data-booking-id');
      if (!confirm(`Initiate a new call for booking #${bookingId}?`)) return;

      try {
        const res = await fetch('/api/owner/call-logs', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ booking_id: Number(bookingId) }),
        });

        if (res.ok) {
          alert('Call initiated successfully');
          location.reload();
        } else {
          const data = await res.json();
          alert(data.error || 'Failed to initiate call');
        }
      } catch {
        alert('Network error');
      }
    });
  });
</script>
