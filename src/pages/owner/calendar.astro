---
import OwnerLayout from '../../layouts/OwnerLayout.astro';
import { verifyOwner, getOwnerHotelIds } from '../../lib/ownerAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const owner = await verifyOwner(Astro.request, jwtSecret);
if (!owner) return Astro.redirect("/login?redirect=/owner/calendar");

let ownerHotelIds: number[] = [];
let hotels: any[] = [];
let hotelsWithIcal: any[] = [];

if (db) {
  ownerHotelIds = await getOwnerHotelIds(db, owner);
  if (ownerHotelIds.length > 0) {
    const placeholders = ownerHotelIds.map(() => "?").join(",");
    const hotelResult = await db.prepare(
      `SELECT id, name FROM hotels WHERE id IN (${placeholders})`
    ).bind(...ownerHotelIds).all();
    hotels = hotelResult?.results || [];

    const icalResult = await db.prepare(
      `SELECT id, name, ical_url FROM hotels WHERE id IN (${placeholders})`
    ).bind(...ownerHotelIds).all();
    hotelsWithIcal = icalResult?.results || [];
  }
}
---

<OwnerLayout title="Calendar" activeNav="calendar-view">
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <div class="flex flex-wrap items-center gap-4">
      <div class="min-w-[200px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Hotel</label>
        <select id="hotel-filter" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white">
          <option value="">All Hotels</option>
          {hotels.map((h: any) => (
            <option value={h.id}>{h.name}</option>
          ))}
        </select>
      </div>
      <div class="flex items-end gap-2 ml-auto">
        <button id="prev-month" class="px-3 py-2 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
          </svg>
        </button>
        <div id="month-label" class="px-4 py-2 text-sm font-semibold text-slate-700 min-w-[160px] text-center"></div>
        <button id="next-month" class="px-3 py-2 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </button>
        <button id="today-btn" class="px-3 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors">
          Today
        </button>
      </div>
    </div>
  </div>

  <!-- Block Date Controls -->
  <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-4 flex flex-wrap items-center gap-3">
    <div class="text-sm font-medium text-amber-800">📵 Availability Control</div>
    <p class="text-xs text-amber-600 flex-1"><strong>Double-click</strong> (or Shift+click) any date to block/unblock it. Single click shows bookings for that day. Blocked dates won't accept new bookings.</p>
    {hotels.length > 0 && (
      <select id="block-hotel-select" class="text-xs border border-amber-300 rounded-lg px-3 py-1.5 bg-white text-slate-700 focus:outline-none focus:ring-2 focus:ring-amber-400">
        {hotels.map((h: any) => <option value={h.id}>{h.name}</option>)}
      </select>
    )}
    <div class="flex items-center gap-2 text-xs text-slate-500">
      <span class="w-3 h-3 rounded-sm bg-red-200 inline-block border border-red-300"></span>Blocked
      <span class="w-3 h-3 rounded-sm bg-white inline-block border border-slate-300 ml-2"></span>Available
    </div>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden mb-6">
    <!-- Month label above calendar -->
    <div id="calendar-month-heading" class="text-center py-3 border-b border-slate-100 text-lg font-bold text-slate-800 tracking-wide"></div>
    <!-- Day-of-week headers -->
    <div class="grid grid-cols-7 bg-slate-50 border-b border-slate-200">
      <div class="px-2 py-3 text-center text-xs font-semibold text-slate-500 uppercase">Sun</div>
      <div class="px-2 py-3 text-center text-xs font-semibold text-slate-500 uppercase">Mon</div>
      <div class="px-2 py-3 text-center text-xs font-semibold text-slate-500 uppercase">Tue</div>
      <div class="px-2 py-3 text-center text-xs font-semibold text-slate-500 uppercase">Wed</div>
      <div class="px-2 py-3 text-center text-xs font-semibold text-slate-500 uppercase">Thu</div>
      <div class="px-2 py-3 text-center text-xs font-semibold text-slate-500 uppercase">Fri</div>
      <div class="px-2 py-3 text-center text-xs font-semibold text-slate-500 uppercase">Sat</div>
    </div>
    <div id="calendar-grid" class="grid grid-cols-7"></div>
  </div>

  <div id="day-bookings" class="hidden">
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="flex items-center justify-between px-4 py-3 bg-slate-50 border-b border-slate-200">
        <h3 id="day-bookings-title" class="text-sm font-semibold text-slate-700"></h3>
        <button id="close-day-bookings" class="p-1 text-slate-400 hover:text-slate-600">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div id="day-bookings-list" class="divide-y divide-slate-100"></div>
    </div>
  </div>

  {hotelsWithIcal.length > 0 && (
    <div class="mt-6 bg-white rounded-lg shadow p-5">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h3 class="text-sm font-semibold text-slate-800">iCal / External Calendar Sync</h3>
          <p class="text-xs text-slate-400 mt-0.5">Paste your Airbnb, Booking.com, or Google Calendar iCal URL to sync blocked dates.</p>
        </div>
      </div>
      <div class="space-y-4">
        {hotelsWithIcal.map((h: any) => (
          <div class="border border-slate-200 rounded-xl p-4">
            <div class="flex items-center gap-2 mb-3">
              <span class={`w-2 h-2 rounded-full flex-shrink-0 ${h.ical_url ? 'bg-emerald-500' : 'bg-slate-300'}`}></span>
              <span class="font-medium text-slate-700 text-sm">{h.name}</span>
              <span class={`text-xs ml-auto ${h.ical_url ? 'text-emerald-600' : 'text-slate-400'}`}>
                {h.ical_url ? '✓ Connected' : 'Not connected'}
              </span>
            </div>
            <div class="flex gap-2">
              <input
                type="url"
                class="ical-url-input flex-1 px-3 py-2 border border-slate-300 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500 text-slate-700"
                data-hotel-id={h.id}
                value={h.ical_url || ''}
                placeholder="https://www.airbnb.com/calendar/ical/..."
              />
              <button
                class="ical-save-btn px-3 py-2 bg-teal-600 hover:bg-teal-700 text-white text-xs font-semibold rounded-lg transition-colors whitespace-nowrap"
                data-hotel-id={h.id}
              >
                Save
              </button>
            </div>
            <p class="text-xs text-slate-400 mt-1.5">
              Export your DDH calendar: <span class="font-mono text-teal-600 select-all">{Astro.url.origin}/api/ical/{h.slug || h.id}.ics</span>
            </p>
          </div>
        ))}
      </div>
    </div>
  )}

  <script is:inline>
    document.querySelectorAll('.ical-save-btn').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        const hotelId = btn.getAttribute('data-hotel-id');
        const input = document.querySelector('.ical-url-input[data-hotel-id="' + hotelId + '"]');
        if (!input) return;
        const icalUrl = input.value.trim();
        btn.textContent = 'Saving...';
        btn.disabled = true;
        try {
          const res = await fetch('/api/owner/ical', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ hotel_id: Number(hotelId), ical_url: icalUrl || null }),
          });
          const data = await res.json();
          if (data.success) {
            btn.textContent = '✓ Saved';
            btn.classList.remove('bg-teal-600', 'hover:bg-teal-700');
            btn.classList.add('bg-emerald-600');
            setTimeout(function() {
              btn.textContent = 'Save';
              btn.classList.add('bg-teal-600', 'hover:bg-teal-700');
              btn.classList.remove('bg-emerald-600');
              btn.disabled = false;
            }, 2000);
          } else {
            alert(data.error || 'Failed to save');
            btn.textContent = 'Save';
            btn.disabled = false;
          }
        } catch (e) {
          alert('Error saving iCal URL');
          btn.textContent = 'Save';
          btn.disabled = false;
        }
      });
    });
  </script>
</OwnerLayout>

<script>
  const MONTH_NAMES = [
    'January', 'February', 'March', 'April', 'May', 'June',
    'July', 'August', 'September', 'October', 'November', 'December'
  ];

  let currentYear = new Date().getFullYear();
  let currentMonth = new Date().getMonth() + 1; // 1-indexed
  let bookings: any[] = [];
  let selectedDate: string | null = null;

  const calendarGrid = document.getElementById('calendar-grid');
  const monthLabel = document.getElementById('month-label');
  const dayBookings = document.getElementById('day-bookings');
  const dayBookingsTitle = document.getElementById('day-bookings-title');
  const dayBookingsList = document.getElementById('day-bookings-list');
  const hotelFilter = document.getElementById('hotel-filter') as HTMLSelectElement | null;
  const blockHotelSelect = document.getElementById('block-hotel-select') as HTMLSelectElement | null;

  let blockedDates: Set<string> = new Set();

  async function fetchBlockedDates() {
    const hotelId = blockHotelSelect?.value || hotelFilter?.value || '';
    if (!hotelId) return;
    try {
      const res = await fetch(`/api/owner/blocked-dates?hotel_id=${hotelId}&month=${currentYear}-${String(currentMonth).padStart(2, '0')}`);
      const data = await res.json();
      blockedDates = new Set((data.blocked || []).map((b: any) => b.blocked_date));
      renderCalendar();
    } catch {}
  }

  async function toggleBlockDate(dateStr: string) {
    const hotelId = blockHotelSelect?.value || hotelFilter?.value || '';
    if (!hotelId) return;
    const isBlocked = blockedDates.has(dateStr);
    try {
      if (isBlocked) {
        await fetch('/api/owner/blocked-dates', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ hotel_id: Number(hotelId), date: dateStr }) });
        blockedDates.delete(dateStr);
      } else {
        await fetch('/api/owner/blocked-dates', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ hotel_id: Number(hotelId), date: dateStr }) });
        blockedDates.add(dateStr);
      }
      renderCalendar();
    } catch { alert('Failed to update availability'); }
  }

  if (blockHotelSelect) {
    blockHotelSelect.addEventListener('change', fetchBlockedDates);
  }

  // Fetch bookings for the current month
  async function fetchBookings() {
    const hotelId = hotelFilter?.value || '';
    let url = `/api/owner/calendar?year=${currentYear}&month=${currentMonth}`;
    if (hotelId) url += `&hotel_id=${hotelId}`;

    try {
      const res = await fetch(url);
      const data = await res.json();
      bookings = data.bookings || [];
    } catch (err) {
      console.error('Failed to fetch calendar bookings:', err);
      bookings = [];
    }

    renderCalendar();
    fetchBlockedDates();
  }

  // Get bookings for a specific date string (YYYY-MM-DD)
  function getBookingsForDate(dateStr: string) {
    return bookings.filter(b => b.check_in_date === dateStr);
  }

  // Render the calendar grid
  function renderCalendar() {
    if (!calendarGrid || !monthLabel) return;

    // Update month labels
    monthLabel.textContent = `${MONTH_NAMES[currentMonth - 1]} ${currentYear}`;
    const calHeading = document.getElementById('calendar-month-heading');
    if (calHeading) calHeading.textContent = `${MONTH_NAMES[currentMonth - 1]} ${currentYear}`;

    // Calculate first day and total days
    const firstDay = new Date(currentYear, currentMonth - 1, 1).getDay(); // 0=Sun
    const daysInMonth = new Date(currentYear, currentMonth, 0).getDate();

    const today = new Date();
    const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;

    let html = '';

    // Empty cells for days before the 1st
    for (let i = 0; i < firstDay; i++) {
      html += '<div class="bg-slate-50 border border-slate-100 min-h-[80px]"></div>';
    }

    // Day cells
    for (let day = 1; day <= daysInMonth; day++) {
      const dateStr = `${currentYear}-${String(currentMonth).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const dayBookingsArr = getBookingsForDate(dateStr);
      const count = dayBookingsArr.length;
      const isToday = dateStr === todayStr;
      const isSelected = dateStr === selectedDate;

      const isBlocked = blockedDates.has(dateStr);
      let cellClasses = 'border border-slate-100 rounded min-h-[80px] p-2 cursor-pointer transition-colors relative';
      if (isBlocked) cellClasses += ' bg-red-50 hover:bg-red-100';
      else if (isSelected) cellClasses += ' bg-indigo-50 hover:bg-indigo-100';
      else if (isToday) cellClasses += ' bg-white hover:bg-slate-50';
      else cellClasses += ' bg-white hover:bg-slate-50';
      if (isToday) cellClasses += ' ring-2 ring-indigo-500';

      html += `<div class="${cellClasses}" data-date="${dateStr}" data-blocked="${isBlocked ? '1' : '0'}">`;

      // 日付番号は常に表示
      const dayNumColor = isBlocked ? 'text-red-500' : isToday ? 'text-indigo-600 font-bold' : 'text-slate-600';
      html += `<span class="text-xs font-semibold ${dayNumColor}">${day}</span>`;

      if (isBlocked) {
        html += `<div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-20"><span class="text-red-600 text-3xl font-bold">✕</span></div>`;
        html += `<div class="text-[9px] text-red-400 mt-0.5">Blocked</div>`;
      } else {
        if (count > 0) {
          html += `<span class="absolute top-2 right-2 bg-indigo-600 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center font-medium">${count}</span>`;

          // Show first few booking previews
          const previewMax = 2;
          for (let i = 0; i < Math.min(count, previewMax); i++) {
            const b = dayBookingsArr[i];
            const statusColor =
              b.status === 'confirmed' ? 'bg-emerald-100 text-emerald-700 border-emerald-200' :
              b.status === 'pending' ? 'bg-amber-100 text-amber-700 border-amber-200' :
              b.status === 'cancelled' ? 'bg-red-100 text-red-700 border-red-200' :
              'bg-slate-100 text-slate-600 border-slate-200';
            html += `<div class="mt-1 text-[10px] leading-tight truncate px-1 py-0.5 rounded border ${statusColor}">${b.guest_name}</div>`;
          }
          if (count > previewMax) {
            html += `<div class="mt-0.5 text-[10px] text-slate-400">+${count - previewMax} more</div>`;
          }
        }
      } // end else (not blocked)

      html += '</div>';
    }

    // Trailing empty cells to fill the last row
    const totalCells = firstDay + daysInMonth;
    const remainder = totalCells % 7;
    if (remainder > 0) {
      for (let i = 0; i < 7 - remainder; i++) {
        html += '<div class="bg-slate-50 border border-slate-100 min-h-[80px]"></div>';
      }
    }

    calendarGrid.innerHTML = html;

    // Add click handlers to day cells
    calendarGrid.querySelectorAll('[data-date]').forEach(cell => {
      cell.addEventListener('click', async (e) => {
        const date = cell.getAttribute('data-date');
        if (!date) return;
        // Right-click or shift+click = toggle block
        if ((e as MouseEvent).shiftKey) {
          await toggleBlockDate(date);
        } else {
          showDayBookings(date);
        }
      });
      // Double-click = toggle block
      cell.addEventListener('dblclick', async () => {
        const date = cell.getAttribute('data-date');
        if (date) await toggleBlockDate(date);
      });
    });

    // Hide day bookings panel if month changed
    if (dayBookings && selectedDate) {
      const selMonth = parseInt(selectedDate.split('-')[1]);
      const selYear = parseInt(selectedDate.split('-')[0]);
      if (selMonth !== currentMonth || selYear !== currentYear) {
        dayBookings.classList.add('hidden');
        selectedDate = null;
      }
    }
  }

  // Show bookings for a clicked day
  function showDayBookings(dateStr: string) {
    if (!dayBookings || !dayBookingsTitle || !dayBookingsList) return;

    selectedDate = dateStr;
    const dayData = getBookingsForDate(dateStr);

    // Parse the date for display
    const parts = dateStr.split('-');
    const displayDate = `${MONTH_NAMES[parseInt(parts[1]) - 1]} ${parseInt(parts[2])}, ${parts[0]}`;
    dayBookingsTitle.textContent = `Bookings for ${displayDate} (${dayData.length})`;

    if (dayData.length === 0) {
      dayBookingsList.innerHTML = '<div class="px-4 py-8 text-center text-slate-400 text-sm">No bookings for this date</div>';
    } else {
      let html = '';
      dayData.forEach((b: any) => {
        const statusColor =
          b.status === 'confirmed' ? 'bg-emerald-100 text-emerald-700' :
          b.status === 'pending' ? 'bg-amber-100 text-amber-700' :
          b.status === 'cancelled' ? 'bg-red-100 text-red-700' :
          'bg-slate-100 text-slate-600';

        const showConfirm = b.status === 'pending' || b.status === 'pending_confirmation';
        const showCancel = b.status === 'pending' || b.status === 'pending_confirmation' || b.status === 'confirmed';

        html += `
          <div class="px-4 py-3 hover:bg-slate-50 transition-colors">
            <div class="flex items-center justify-between">
              <div>
                <span class="text-sm font-medium text-slate-900">${escapeHtml(b.guest_name)}</span>
                <span class="text-xs text-slate-400 ml-2">#${b.id}</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusColor}">${b.status}</span>
                ${showConfirm ? `<button class="cal-confirm-btn px-2 py-1 text-xs text-emerald-700 bg-emerald-50 border border-emerald-200 rounded hover:bg-emerald-100 transition-colors" data-id="${b.id}">Confirm</button>` : ''}
                ${showCancel ? `<button class="cal-cancel-btn px-2 py-1 text-xs text-red-700 bg-red-50 border border-red-200 rounded hover:bg-red-100 transition-colors" data-id="${b.id}">Cancel</button>` : ''}
              </div>
            </div>
            <div class="mt-1 flex items-center gap-4 text-xs text-slate-500">
              <span>${escapeHtml(b.hotel_name || '-')}</span>
              <span>${escapeHtml(b.plan_name || '-')}</span>
              <span class="font-mono">$${Number(b.total_price_usd).toFixed(2)}</span>
            </div>
          </div>
        `;
      });
      dayBookingsList.innerHTML = html;

      // Attach confirm/cancel handlers
      dayBookingsList.querySelectorAll('.cal-confirm-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.getAttribute('data-id');
          if (!confirm(`Confirm booking #${id}?`)) return;
          (btn as HTMLButtonElement).disabled = true;
          btn.textContent = '...';
          try {
            const res = await fetch('/api/owner/bookings', {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: Number(id), status: 'confirmed' }),
            });
            if (res.ok) { await fetchBookings(); showDayBookings(dateStr); }
            else { alert('Failed to confirm booking'); }
          } catch { alert('Error confirming booking'); }
        });
      });

      dayBookingsList.querySelectorAll('.cal-cancel-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.getAttribute('data-id');
          if (!confirm(`⚠️ Cancel booking #${id}?\n\nThis action cannot be undone.\nA cancellation email will be sent to the guest.`)) return;
          (btn as HTMLButtonElement).disabled = true;
          btn.textContent = '...';
          try {
            const res = await fetch('/api/owner/bookings', {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: Number(id), status: 'cancelled' }),
            });
            if (res.ok) { await fetchBookings(); showDayBookings(dateStr); }
            else { alert('Failed to cancel booking'); }
          } catch { alert('Error cancelling booking'); }
        });
      });
    }

    dayBookings.classList.remove('hidden');

    // Re-render to update selected styling
    renderCalendar();

    // Scroll to the bookings panel
    dayBookings.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function escapeHtml(str: string) {
    if (!str) return '';
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // Navigation handlers
  document.getElementById('prev-month')?.addEventListener('click', () => {
    currentMonth--;
    if (currentMonth < 1) {
      currentMonth = 12;
      currentYear--;
    }
    fetchBookings();
  });

  document.getElementById('next-month')?.addEventListener('click', () => {
    currentMonth++;
    if (currentMonth > 12) {
      currentMonth = 1;
      currentYear++;
    }
    fetchBookings();
  });

  document.getElementById('today-btn')?.addEventListener('click', () => {
    const now = new Date();
    currentYear = now.getFullYear();
    currentMonth = now.getMonth() + 1;
    fetchBookings();
  });

  // Hotel filter change
  hotelFilter?.addEventListener('change', () => {
    fetchBookings();
  });

  // Close day bookings panel
  document.getElementById('close-day-bookings')?.addEventListener('click', () => {
    if (dayBookings) dayBookings.classList.add('hidden');
    selectedDate = null;
    renderCalendar();
  });

  // Initial load
  fetchBookings();
</script>
