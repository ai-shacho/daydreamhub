---
import OwnerLayout from '../../layouts/OwnerLayout.astro';
import { verifyOwner } from '../../lib/ownerAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const owner = await verifyOwner(Astro.request, jwtSecret);
if (!owner) {
  return Astro.redirect("/login?redirect=/owner/reviews");
}

const url = new URL(Astro.request.url);
const hotelFilter = url.searchParams.get("hotel_id") || "";
const ratingFilter = url.searchParams.get("rating") || "";

let reviews: any[] = [];
let ownerHotels: any[] = [];
let avgRating = 0;
let totalReviews = 0;
let error = "";

if (db) {
  try {
    const hotelsRes = await db.prepare(
      "SELECT id, name FROM hotels WHERE email = ? AND is_active = 1 ORDER BY name"
    ).bind(owner.email).all();
    ownerHotels = hotelsRes?.results || [];
    const ownerHotelIds = ownerHotels.map((h: any) => h.id);

    if (ownerHotelIds.length > 0) {
      const placeholders = ownerHotelIds.map(() => "?").join(",");

      const statsRes = await db.prepare(
        `SELECT COUNT(*) as total, COALESCE(AVG(rating), 0) as avg_rating
         FROM reviews WHERE hotel_id IN (${placeholders}) AND is_approved = 1`
      ).bind(...ownerHotelIds).first();
      totalReviews = statsRes?.total ?? 0;
      avgRating = statsRes?.avg_rating ?? 0;

      let query = `SELECT r.*, h.name as hotel_name,
        rr.content as reply_content, rr.created_at as reply_date
        FROM reviews r
        LEFT JOIN hotels h ON r.hotel_id = h.id
        LEFT JOIN review_replies rr ON rr.review_id = r.id
        WHERE r.hotel_id IN (${placeholders})`;
      const binds: any[] = [...ownerHotelIds];

      if (hotelFilter) {
        query += " AND r.hotel_id = ?";
        binds.push(parseInt(hotelFilter));
      }
      if (ratingFilter) {
        query += " AND r.rating = ?";
        binds.push(parseInt(ratingFilter));
      }

      query += " ORDER BY r.created_at DESC";
      const result = await db.prepare(query).bind(...binds).all();
      reviews = result?.results || [];
    }
  } catch (e: any) {
    error = e.message || "Failed to load reviews";
  }
}

function renderStars(rating: number) {
  return Array.from(
    { length: 5 },
    (_, i) => i < rating
      ? '<svg class="w-4 h-4 text-yellow-500 inline" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>'
      : '<svg class="w-4 h-4 text-gray-300 inline" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>'
  ).join("");
}
---

<OwnerLayout title="Reviews" activeNav="reviews">
  <!-- Stats -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Total Reviews</p>
      <p class="text-2xl font-bold text-slate-900 mt-1">{totalReviews}</p>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Average Rating</p>
      <div class="flex items-center gap-2 mt-1">
        <p class="text-2xl font-bold text-slate-900">{Number(avgRating).toFixed(1)}</p>
        <span><Fragment set:html={renderStars(Math.round(Number(avgRating)))} /></span>
      </div>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Hotels Reviewed</p>
      <p class="text-2xl font-bold text-slate-900 mt-1">{ownerHotels.length}</p>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <form method="GET" action="/owner/reviews" class="flex flex-wrap items-end gap-4">
      <div class="min-w-[200px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Hotel</label>
        <select name="hotel_id" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white">
          <option value="">All My Hotels</option>
          {ownerHotels.map((h: any) => (
            <option value={h.id} selected={String(h.id) === hotelFilter}>{h.name}</option>
          ))}
        </select>
      </div>
      <div class="min-w-[140px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Rating</label>
        <select name="rating" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white">
          <option value="">All Ratings</option>
          {[5, 4, 3, 2, 1].map((r) => (
            <option value={r} selected={String(r) === ratingFilter}>{r} Star{r !== 1 ? "s" : ""}</option>
          ))}
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors">
          Filter
        </button>
        <a href="/owner/reviews" class="px-4 py-2 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors">
          Reset
        </a>
      </div>
    </form>
  </div>

  <!-- Count -->
  <div class="flex items-center justify-between mb-4">
    <p class="text-sm text-slate-500">{reviews.length} review{reviews.length !== 1 ? "s" : ""} found</p>
  </div>

  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>
  )}

  <!-- Reviews Table -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-medium text-slate-600">Hotel</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Guest</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Rating</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Title</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600 max-w-[250px]">Comment</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Verified</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Status</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Date</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {reviews.length === 0 ? (
            <tr>
              <td colspan="9" class="px-4 py-12 text-center text-slate-400">
                No reviews found for your hotels.
              </td>
            </tr>
          ) : reviews.map((r: any) => (
            <>
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-4 py-3 text-slate-600">{r.hotel_name || "-"}</td>
                <td class="px-4 py-3">
                  <div class="font-medium text-slate-900">{r.guest_name}</div>
                  <div class="text-xs text-slate-400">{r.guest_email}</div>
                </td>
                <td class="px-4 py-3 text-center">
                  <span><Fragment set:html={renderStars(r.rating)} /></span>
                </td>
                <td class="px-4 py-3 text-slate-600">{r.title || "-"}</td>
                <td class="px-4 py-3 text-slate-600 max-w-[250px] truncate" title={r.comment || ""}>
                  {r.comment ? (r.comment.length > 80 ? r.comment.slice(0, 80) + "..." : r.comment) : "-"}
                </td>
                <td class="px-4 py-3 text-center">
                  {r.is_verified === 1 ? (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
                      Verified
                    </span>
                  ) : (
                    <span class="text-xs text-slate-400">-</span>
                  )}
                </td>
                <td class="px-4 py-3 text-center">
                  <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${r.is_approved === 1 ? "bg-emerald-100 text-emerald-700" : "bg-amber-100 text-amber-700"}`}>
                    {r.is_approved === 1 ? "Approved" : "Pending"}
                  </span>
                </td>
                <td class="px-4 py-3 text-slate-500 text-xs">{r.created_at?.slice(0, 16)}</td>
                <td class="px-4 py-3 text-center">
                  <button class="reply-toggle px-2 py-1 text-xs text-indigo-600 bg-indigo-50 border border-indigo-200 rounded hover:bg-indigo-100 transition-colors" data-id={r.id}>
                    {r.reply_content ? "Edit Reply" : "Reply"}
                  </button>
                </td>
              </tr>
              <!-- Reply row (hidden by default) -->
              <tr class="reply-row hidden bg-indigo-50/50" data-reply-id={r.id}>
                <td colspan="9" class="px-6 py-4">
                  {r.reply_content && (
                    <div class="mb-3">
                      <p class="text-xs font-medium text-indigo-600 mb-1">Your Reply ({r.reply_date?.slice(0, 10)}):</p>
                      <p class="text-sm text-slate-700 bg-white rounded p-3 border border-slate-200">{r.reply_content}</p>
                    </div>
                  )}
                  <div>
                    <label class="text-xs font-medium text-slate-600 mb-1 block">{r.reply_content ? "Update Reply:" : "Write a Reply:"}</label>
                    <textarea class="reply-text w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-y" rows="3" data-review-id={r.id} placeholder="Write your response to this review...">{r.reply_content || ""}</textarea>
                    <button class="submit-reply mt-2 px-4 py-1.5 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors" data-review-id={r.id}>
                      {r.reply_content ? "Update Reply" : "Submit Reply"}
                    </button>
                  </div>
                </td>
              </tr>
            </>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Info note -->
  <div class="mt-4 p-3 bg-indigo-50 border border-indigo-200 rounded-lg">
    <p class="text-xs text-indigo-700">
      Review moderation (approve/reject/delete) is managed by DayDreamHub administrators. If you have concerns about a specific review, please contact support.
    </p>
  </div>
</OwnerLayout>

<script>
  // Toggle reply rows
  document.querySelectorAll('.reply-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-id');
      const row = document.querySelector('.reply-row[data-reply-id="' + id + '"]');
      if (row) row.classList.toggle('hidden');
    });
  });

  // Submit reply
  document.querySelectorAll('.submit-reply').forEach(btn => {
    btn.addEventListener('click', async () => {
      const reviewId = btn.getAttribute('data-review-id');
      const textarea = document.querySelector('.reply-text[data-review-id="' + reviewId + '"]') as HTMLTextAreaElement | null;
      const content = textarea?.value?.trim();
      if (!content) { alert('Please write a reply'); return; }

      try {
        const res = await fetch('/api/owner/review-replies', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ review_id: Number(reviewId), content }),
        });
        if (res.ok) {
          alert('Reply saved successfully');
          location.reload();
        } else {
          const data = await res.json().catch(() => ({}));
          alert(data.error || 'Failed to save reply');
        }
      } catch (e) { alert('Error saving reply'); }
    });
  });
</script>
