---
import OwnerLayout from '../../layouts/OwnerLayout.astro';
import { verifyOwner, getOwnerHotelIds } from '../../lib/ownerAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const owner = await verifyOwner(Astro.request, jwtSecret);
if (!owner) {
  return Astro.redirect("/login?redirect=/owner/messages");
}

const url = new URL(Astro.request.url);
const directionFilter = url.searchParams.get("direction") || "";
const statusFilter = url.searchParams.get("status") || "";
const hotelFilter = url.searchParams.get("hotel_id") || "";

let bookingMessages: any[] = [];
let ownerHotels: any[] = [];
let error = "";

if (db) {
  try {
    const hotelsRes = await db.prepare(
      "SELECT id, name FROM hotels WHERE email = ? AND is_active = 1 ORDER BY name"
    ).bind(owner.email).all();
    ownerHotels = hotelsRes?.results || [];
    const ownerHotelIds = ownerHotels.map((h: any) => h.id);

    if (ownerHotelIds.length > 0) {
      const placeholders = ownerHotelIds.map(() => "?").join(",");
      // Fetch booking messages (guest <-> hotel)
      let query = `SELECT bm.*, b.guest_name, b.guest_email, b.id as booking_id, h.name as hotel_name
        FROM booking_messages bm
        LEFT JOIN bookings b ON bm.booking_id = b.id
        LEFT JOIN hotels h ON b.hotel_id = h.id
        WHERE b.hotel_id IN (${placeholders})`;
      const binds: any[] = [...ownerHotelIds];

      if (directionFilter === "inbound") {
        query += " AND bm.sender_type = 'guest'";
      } else if (directionFilter === "outbound") {
        query += " AND bm.sender_type = 'hotel'";
      }
      if (hotelFilter) {
        query += " AND b.hotel_id = ?";
        binds.push(parseInt(hotelFilter));
      }

      query += " ORDER BY bm.created_at DESC LIMIT 200";
      const result = await db.prepare(query).bind(...binds).all();
      bookingMessages = result?.results || [];
    }
  } catch (e: any) {
    error = e.message || "Failed to load messages";
  }
}

const directionOptions = ["", "inbound", "outbound"];
const directionLabels: Record<string, string> = {
  "": "All",
  inbound: "From Guests",
  outbound: "From Hotel",
};
---

<OwnerLayout title="Messages" activeNav="messages">
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <form method="GET" action="/owner/messages" class="flex flex-wrap items-end gap-4">
      <div class="min-w-[180px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Hotel</label>
        <select name="hotel_id" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white">
          <option value="">All My Hotels</option>
          {ownerHotels.map((h: any) => (
            <option value={h.id} selected={String(h.id) === hotelFilter}>{h.name}</option>
          ))}
        </select>
      </div>
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Direction</label>
        <select name="direction" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white">
          {directionOptions.map((d) => (
            <option value={d} selected={d === directionFilter}>{directionLabels[d]}</option>
          ))}
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors">
          Filter
        </button>
        <a href="/owner/messages" class="px-4 py-2 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors">
          Reset
        </a>
      </div>
    </form>
  </div>

  <div class="flex items-center gap-4 mb-4 text-sm">
    <p class="text-slate-500">{bookingMessages.length} message{bookingMessages.length !== 1 ? "s" : ""} found</p>
    <span class="text-slate-300">|</span>
    <span class="text-blue-600">{bookingMessages.filter((m: any) => m.sender_type === "guest").length} from guests</span>
    <span class="text-indigo-600">{bookingMessages.filter((m: any) => m.sender_type === "hotel").length} from hotel</span>
    <span class="text-amber-600">{bookingMessages.filter((m: any) => m.sender_type === "guest" && !m.is_read).length} unread</span>
  </div>

  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{error}</div>
  )}

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-medium text-slate-600">Booking</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">From</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Message</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Hotel</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Status</th>
            <th class="text-left px-4 py-3 font-medium text-slate-600">Date</th>
            <th class="text-center px-4 py-3 font-medium text-slate-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {bookingMessages.length === 0 ? (
            <tr>
              <td colspan="7" class="px-4 py-12 text-center text-slate-400">No messages found</td>
            </tr>
          ) : bookingMessages.map((m: any) => (
            <tr class:list={["hover:bg-slate-50 transition-colors", m.sender_type === "guest" && !m.is_read ? "bg-blue-50" : ""]}>
              <td class="px-4 py-3 font-mono text-slate-500">
                <a href={`/owner/bookings?search=${m.booking_id}`} class="text-indigo-600 hover:underline">#{m.booking_id}</a>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-2">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${m.sender_type === "guest" ? "bg-blue-100 text-blue-700" : "bg-indigo-100 text-indigo-700"}`}>
                    {m.sender_type === "guest" ? "Guest" : "Hotel"}
                  </span>
                  <span class="text-sm text-slate-700">{m.sender_name}</span>
                </div>
                {m.sender_type === "guest" && m.guest_email && (
                  <div class="text-xs text-slate-400 mt-0.5">{m.guest_email}</div>
                )}
              </td>
              <td class="px-4 py-3 text-slate-700 max-w-[300px]">
                <p class="truncate">{m.content}</p>
              </td>
              <td class="px-4 py-3 text-slate-600 text-sm">{m.hotel_name || "-"}</td>
              <td class="px-4 py-3 text-center">
                {m.sender_type === "guest" ? (
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${m.is_read ? "bg-slate-100 text-slate-500" : "bg-amber-100 text-amber-700"}`}>
                    {m.is_read ? "Read" : "Unread"}
                  </span>
                ) : (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Sent</span>
                )}
              </td>
              <td class="px-4 py-3 text-slate-500 text-xs">{m.created_at?.slice(0, 16) || "-"}</td>
              <td class="px-4 py-3 text-center">
                <button class="reply-btn px-2 py-1 text-xs text-indigo-600 bg-indigo-50 border border-indigo-200 rounded hover:bg-indigo-100 transition-colors"
                  data-booking-id={m.booking_id}
                  data-guest-name={m.guest_name || m.sender_name}
                  data-hotel-name={m.hotel_name}
                >
                  Reply
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
  <!-- Reply Modal -->
  <div id="reply-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50" id="reply-modal-backdrop"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg max-h-[80vh] flex flex-col">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200">
          <div>
            <h2 class="text-lg font-semibold text-slate-900">Message Thread</h2>
            <p class="text-xs text-slate-500">Booking <span id="reply-booking-id" class="font-mono"></span> — <span id="reply-guest-name"></span></p>
          </div>
          <button id="reply-close" class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
        </div>
        <div id="reply-thread" class="flex-1 overflow-y-auto px-6 py-4 space-y-3 bg-slate-50 min-h-[120px]">
          <p class="text-center text-slate-400 text-sm">Loading...</p>
        </div>
        <div class="px-6 py-4 border-t border-slate-200">
          <textarea id="reply-content" rows="2" placeholder="Type your reply..."
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none"></textarea>
          <div class="flex justify-end gap-2 mt-3">
            <button id="reply-cancel" class="px-4 py-2 text-sm text-slate-600 bg-slate-100 rounded-lg hover:bg-slate-200 transition-colors">Close</button>
            <button id="reply-send" class="px-5 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors">Send</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</OwnerLayout>

<script is:inline>
(function() {
  var modal = document.getElementById('reply-modal');
  var thread = document.getElementById('reply-thread');
  var content = document.getElementById('reply-content');
  var bookingIdEl = document.getElementById('reply-booking-id');
  var guestNameEl = document.getElementById('reply-guest-name');
  var currentBookingId = null;

  function openModal(bookingId, guestName, hotelName) {
    currentBookingId = bookingId;
    bookingIdEl.textContent = '#' + bookingId;
    guestNameEl.textContent = guestName || 'Guest';
    content.value = '';
    thread.innerHTML = '<p class="text-center text-slate-400 text-sm">Loading...</p>';
    modal.classList.remove('hidden');
    loadThread(bookingId);
  }

  function closeModal() {
    modal.classList.add('hidden');
    currentBookingId = null;
  }

  async function loadThread(bookingId) {
    try {
      var res = await fetch('/api/owner/booking-messages?booking_id=' + bookingId);
      var data = await res.json();
      var msgs = data.messages || [];
      if (msgs.length === 0) {
        thread.innerHTML = '<p class="text-center text-slate-400 text-sm">No messages yet</p>';
        return;
      }
      var html = '';
      msgs.forEach(function(m) {
        var isHotel = m.sender_type === 'hotel';
        html += '<div class="' + (isHotel ? 'text-right' : 'text-left') + '">' +
          '<div class="inline-block max-w-[85%] px-3 py-2 rounded-xl text-sm ' +
          (isHotel ? 'bg-indigo-500 text-white' : 'bg-white border border-slate-200 text-slate-700') + '">' +
          m.content.replace(/</g, '&lt;') + '</div>' +
          '<div class="text-xs text-slate-400 mt-0.5">' + m.sender_name + ' · ' + (m.created_at || '').slice(0, 16) + '</div></div>';
      });
      thread.innerHTML = html;
      thread.scrollTop = thread.scrollHeight;
    } catch (e) {
      thread.innerHTML = '<p class="text-center text-red-400 text-sm">Failed to load messages</p>';
    }
  }

  // Reply buttons
  document.querySelectorAll('.reply-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      openModal(btn.dataset.bookingId, btn.dataset.guestName, btn.dataset.hotelName);
    });
  });

  // Close
  document.getElementById('reply-close').addEventListener('click', closeModal);
  document.getElementById('reply-cancel').addEventListener('click', closeModal);
  document.getElementById('reply-modal-backdrop').addEventListener('click', closeModal);

  // Send
  document.getElementById('reply-send').addEventListener('click', async function() {
    var msg = content.value.trim();
    if (!msg || !currentBookingId) return;
    var sendBtn = this;
    sendBtn.textContent = 'Sending...';
    sendBtn.disabled = true;
    try {
      var res = await fetch('/api/owner/booking-messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ booking_id: Number(currentBookingId), content: msg })
      });
      var data = await res.json();
      if (data.success) {
        content.value = '';
        await loadThread(currentBookingId);
      } else {
        alert(data.error || 'Failed to send');
      }
    } catch (e) {
      alert('Network error');
    }
    sendBtn.textContent = 'Send';
    sendBtn.disabled = false;
  });
})();
</script>
