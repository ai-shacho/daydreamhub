---
import OwnerLayout from '../../layouts/OwnerLayout.astro';
import { verifyOwner, getOwnerHotelIds, getStaffRole, canAccessReports } from '../../lib/ownerAuth';

const runtime = Astro.locals.runtime as any;
const db = runtime?.env?.DB;
const jwtSecret = runtime?.env?.JWT_SECRET || "dev-secret";

const owner = await verifyOwner(Astro.request, jwtSecret);
if (!owner) {
  return Astro.redirect("/login?redirect=/owner/reports");
}

// Booking managers cannot access reports
const staffRole = owner.role === 'staff' ? await getStaffRole(db, owner.sub) : null;
if (!canAccessReports(owner, staffRole)) {
  return Astro.redirect("/owner");
}

let ownerHotels: any[] = [];
if (db) {
  try {
    const ownerHotelIds = await getOwnerHotelIds(db, owner);
    if (ownerHotelIds.length > 0) {
      const placeholders = ownerHotelIds.map(() => "?").join(",");
      const hotelsRes = await db.prepare(
        `SELECT id, name FROM hotels WHERE id IN (${placeholders}) ORDER BY name`
      ).bind(...ownerHotelIds).all();
      ownerHotels = hotelsRes?.results || [];
    }
  } catch (e) {
    console.error("Reports page DB error:", e);
  }
}
---

<OwnerLayout title="Reports" activeNav="reports">
  <!-- Filters -->
  <div class="bg-white rounded-xl border border-slate-200 p-4 mb-6">
    <div class="flex flex-wrap items-center gap-4">
      <!-- Period Buttons -->
      <div class="flex items-center gap-1">
        <span class="text-xs font-medium text-slate-500 mr-2">Period</span>
        <button data-period="1m" class="period-btn px-3 py-1.5 text-sm font-medium rounded-lg border transition-colors bg-white text-slate-600 border-slate-300 hover:bg-slate-50">
          This Month
        </button>
        <button data-period="3m" class="period-btn px-3 py-1.5 text-sm font-medium rounded-lg border transition-colors bg-indigo-600 text-white border-indigo-600">
          3 Months
        </button>
        <button data-period="6m" class="period-btn px-3 py-1.5 text-sm font-medium rounded-lg border transition-colors bg-white text-slate-600 border-slate-300 hover:bg-slate-50">
          6 Months
        </button>
        <button data-period="1y" class="period-btn px-3 py-1.5 text-sm font-medium rounded-lg border transition-colors bg-white text-slate-600 border-slate-300 hover:bg-slate-50">
          1 Year
        </button>
      </div>
      <!-- CSV Export -->
      <button id="csv-export-btn" class="ml-auto flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-lg border border-slate-300 bg-white text-slate-600 hover:bg-slate-50 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Export CSV
      </button>

      <!-- Hotel Filter -->
      {ownerHotels.length > 1 && (
        <div class="min-w-[200px]">
          <select id="hotel-filter" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white">
            <option value="">All Hotels</option>
            {ownerHotels.map((h: any) => (
              <option value={h.id}>{h.name}</option>
            ))}
          </select>
        </div>
      )}
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center gap-3">
        <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center bg-emerald-100">
          <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Total Revenue</p>
          <p class="text-2xl font-bold text-slate-900 mt-0.5" id="stat-revenue">$0.00</p>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center gap-3">
        <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center bg-blue-100">
          <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
          </svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Total Bookings</p>
          <p class="text-2xl font-bold text-slate-900 mt-0.5" id="stat-bookings">0</p>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center gap-3">
        <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center bg-indigo-100">
          <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
          </svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Avg Booking Value</p>
          <p class="text-2xl font-bold text-slate-900 mt-0.5" id="stat-avg">$0.00</p>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center gap-3">
        <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center bg-amber-100">
          <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
          </svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Month-over-Month</p>
          <p class="text-2xl font-bold text-slate-900 mt-0.5" id="stat-mom">--</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Revenue Chart -->
  <div class="bg-white rounded-xl border border-slate-200 p-6 mb-6">
    <h3 class="text-base font-semibold text-slate-900 mb-4">Monthly Revenue</h3>
    <div style="height: 300px; position: relative;">
      <canvas id="revenue-chart"></canvas>
    </div>
  </div>

  <!-- Plan Breakdown -->
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-200">
      <h3 class="text-base font-semibold text-slate-900">Plan Breakdown (This Month)</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-5 py-3 font-medium text-slate-500 text-xs uppercase tracking-wide">Plan Name</th>
            <th class="text-right px-5 py-3 font-medium text-slate-500 text-xs uppercase tracking-wide">Bookings</th>
            <th class="text-right px-5 py-3 font-medium text-slate-500 text-xs uppercase tracking-wide">Revenue (USD)</th>
          </tr>
        </thead>
        <tbody id="plan-breakdown-body" class="divide-y divide-slate-100">
          <tr>
            <td colspan="3" class="px-5 py-8 text-center text-slate-400 text-sm">Loading...</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</OwnerLayout>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
  let currentPeriod = '3m';
  let currentHotelId = '';
  var lastMonthlyData: any[] = [];
  let revenueChart: any = null;

  function formatCurrency(value: any) {
    return '$' + Number(value || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function updateSummaryCards(monthly: any[]) {
    const totalRevenue = monthly.reduce(function(sum, m) { return sum + Number(m.revenue || 0); }, 0);
    const totalBookings = monthly.reduce(function(sum, m) { return sum + Number(m.confirmed_count || 0); }, 0);
    const avgValue = totalBookings > 0 ? totalRevenue / totalBookings : 0;

    document.getElementById('stat-revenue')!.textContent = formatCurrency(totalRevenue);
    document.getElementById('stat-bookings')!.textContent = String(totalBookings);
    document.getElementById('stat-avg')!.textContent = formatCurrency(avgValue);

    // Month-over-Month change
    var momEl = document.getElementById('stat-mom')!;
    if (monthly.length >= 2) {
      var lastMonth = Number(monthly[monthly.length - 1].revenue || 0);
      var prevMonth = Number(monthly[monthly.length - 2].revenue || 0);
      if (prevMonth > 0) {
        var change = ((lastMonth - prevMonth) / prevMonth) * 100;
        var sign = change >= 0 ? '+' : '';
        momEl.textContent = sign + change.toFixed(1) + '%';
        momEl.className = 'text-2xl font-bold mt-0.5 ' + (change >= 0 ? 'text-emerald-600' : 'text-red-600');
      } else if (lastMonth > 0) {
        momEl.textContent = '+100%';
        momEl.className = 'text-2xl font-bold mt-0.5 text-emerald-600';
      } else {
        momEl.textContent = '0%';
        momEl.className = 'text-2xl font-bold mt-0.5 text-slate-900';
      }
    } else {
      momEl.textContent = '--';
      momEl.className = 'text-2xl font-bold mt-0.5 text-slate-900';
    }
  }

  function renderChart(monthly: any[]) {
    var ctx = (document.getElementById('revenue-chart') as HTMLCanvasElement).getContext('2d')!;
    var labels = monthly.map(function(m) { return m.month; });
    var data = monthly.map(function(m) { return Number(m.revenue || 0); });

    if (revenueChart) {
      revenueChart.destroy();
    }

    revenueChart = new (window as any).Chart(ctx, {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [{
          label: 'Revenue (USD)',
          data: data,
          backgroundColor: 'rgba(99, 102, 241, 0.8)',
          borderColor: 'rgb(99, 102, 241)',
          borderWidth: 1,
          borderRadius: 6,
          maxBarThickness: 60,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(context: any) {
                return 'Revenue: $' + Number(context.parsed.y).toLocaleString('en-US', { minimumFractionDigits: 2 });
              }
            }
          }
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { color: '#64748b', font: { size: 12 } },
          },
          y: {
            beginAtZero: true,
            grid: { color: '#f1f5f9' },
            ticks: {
              color: '#64748b',
              font: { size: 12 },
              callback: function(value: any) { return '$' + value.toLocaleString(); }
            },
          }
        }
      }
    });
  }

  function renderPlanBreakdown(plans: any[]) {
    var tbody = document.getElementById('plan-breakdown-body')!;
    if (!plans || plans.length === 0) {
      tbody.innerHTML = '<tr><td colspan="3" class="px-5 py-8 text-center text-slate-400 text-sm">No bookings this month</td></tr>';
      return;
    }

    var html = '';
    plans.forEach(function(plan) {
      html += '<tr class="hover:bg-slate-50 transition-colors">';
      html += '<td class="px-5 py-3 text-slate-900 font-medium">' + (plan.name || 'Unknown Plan') + '</td>';
      html += '<td class="px-5 py-3 text-right text-slate-600">' + Number(plan.count || 0) + '</td>';
      html += '<td class="px-5 py-3 text-right text-slate-900 font-mono">' + formatCurrency(plan.revenue) + '</td>';
      html += '</tr>';
    });
    tbody.innerHTML = html;
  }

  async function fetchReports() {
    var url = '/api/owner/reports?period=' + encodeURIComponent(currentPeriod);
    if (currentHotelId) {
      url += '&hotel_id=' + encodeURIComponent(currentHotelId);
    }

    try {
      var res = await fetch(url);
      if (!res.ok) throw new Error('Failed to fetch');
      var data = await res.json();

      lastMonthlyData = data.monthly || [];
      updateSummaryCards(lastMonthlyData);
      renderChart(lastMonthlyData);
      renderPlanBreakdown(data.planBreakdown || []);
    } catch (e) {
      console.error('Reports fetch error:', e);
      document.getElementById('stat-revenue')!.textContent = '$0.00';
      document.getElementById('stat-bookings')!.textContent = '0';
      document.getElementById('stat-avg')!.textContent = '$0.00';
      document.getElementById('stat-mom')!.textContent = '--';
      renderPlanBreakdown([]);
    }
  }

  function updatePeriodButtons() {
    document.querySelectorAll('.period-btn').forEach(function(btn) {
      var p = btn.getAttribute('data-period');
      if (p === currentPeriod) {
        btn.className = 'period-btn px-3 py-1.5 text-sm font-medium rounded-lg border transition-colors bg-indigo-600 text-white border-indigo-600';
      } else {
        btn.className = 'period-btn px-3 py-1.5 text-sm font-medium rounded-lg border transition-colors bg-white text-slate-600 border-slate-300 hover:bg-slate-50';
      }
    });
  }

  // Period button click handlers
  document.querySelectorAll('.period-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      currentPeriod = btn.getAttribute('data-period') || '3m';
      updatePeriodButtons();
      fetchReports();
    });
  });

  // Hotel filter change handler
  var hotelFilter = document.getElementById('hotel-filter') as HTMLSelectElement | null;
  if (hotelFilter) {
    hotelFilter.addEventListener('change', function() {
      currentHotelId = hotelFilter!.value;
      fetchReports();
    });
  }

  // CSV Export
  document.getElementById('csv-export-btn')?.addEventListener('click', function() {
    if (!lastMonthlyData || lastMonthlyData.length === 0) {
      alert('No data to export. Please wait for data to load.');
      return;
    }
    var rows = [
      ['Month', 'Total Bookings', 'Confirmed', 'Cancelled', 'Revenue (USD)'],
    ];
    lastMonthlyData.forEach(function(row: any) {
      rows.push([
        row.month || '',
        String(row.booking_count || 0),
        String(row.confirmed_count || 0),
        String(row.cancelled_count || 0),
        Number(row.revenue || 0).toFixed(2),
      ]);
    });
    var csv = rows.map(function(r) {
      return r.map(function(cell) { return '"' + String(cell).replace(/"/g, '""') + '"'; }).join(',');
    }).join('\n');
    var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'daydreamhub-revenue-' + currentPeriod + '-' + new Date().toISOString().slice(0,10) + '.csv';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });

  // Initial load
  fetchReports();
</script>
