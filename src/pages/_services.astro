---
import Layout from '../layouts/Layout.astro';

const title = 'Additional Services | DayDreamHub';
const description = 'Book medical concierge, airport taxi, and tour experiences for your day use stay.';

const serviceCategories = [
  {
    id: 'medical',
    icon: '🏥',
    color: 'teal',
    title: 'Medical Concierge',
    subtitle: 'Healthcare & Wellness Support',
    description: 'Get connected with English-speaking medical professionals, clinic recommendations, and wellness services during your stay.',
    services: [
      { name: 'Clinic Referral', desc: 'Find nearby clinics & hospitals that accommodate visitors', price: 'Free', icon: '🏨' },
      { name: 'Doctor on Call', desc: 'Licensed physician available for in-room consultation', price: 'From $80', icon: '👨‍⚕️' },
      { name: 'Pharmacy Assistance', desc: 'Medication pickup & prescription guidance', price: 'From $15', icon: '💊' },
      { name: 'Dental Emergency', desc: 'Same-day dental clinic coordination', price: 'From $60', icon: '🦷' },
      { name: 'IV Drip Therapy', desc: 'Wellness & recovery IV drip sessions at select spas', price: 'From $120', icon: '💉' },
      { name: 'Health Checkup', desc: 'Comprehensive day-use health screening packages', price: 'From $150', icon: '🩺' },
    ],
    cta: 'Request Medical Support',
    ctaLink: '/concierge?service=medical',
    bgFrom: 'from-teal-50',
    bgTo: 'to-cyan-50',
    border: 'border-teal-200',
    badge: 'bg-teal-100 text-teal-700',
    btn: 'bg-teal-600 hover:bg-teal-700',
    icon2: 'text-teal-600',
  },
  {
    id: 'taxi',
    icon: '🚗',
    color: 'amber',
    title: 'Airport & City Transfer',
    subtitle: 'Transportation Services',
    description: 'Reliable, pre-booked transfers between airports, hotels, and city attractions. English-speaking drivers available.',
    services: [
      { name: 'Airport Pickup', desc: 'Meet & greet at arrival terminal with name board', price: 'From $25', icon: '✈️' },
      { name: 'Airport Drop-off', desc: 'Punctual hotel-to-airport transfer', price: 'From $25', icon: '🛫' },
      { name: 'City Transfer', desc: 'Point-to-point transfer within the city', price: 'From $15', icon: '🏙️' },
      { name: 'Hourly Charter', desc: 'Flexible private car rental by the hour', price: 'From $40/hr', icon: '⏱️' },
      { name: 'Group Shuttle', desc: 'Minivan transfers for groups up to 10', price: 'From $60', icon: '🚐' },
      { name: 'Luxury Sedan', desc: 'Premium vehicle for business or special occasions', price: 'From $80', icon: '🚘' },
    ],
    cta: 'Book a Transfer',
    ctaLink: '/concierge?service=taxi',
    bgFrom: 'from-amber-50',
    bgTo: 'to-orange-50',
    border: 'border-amber-200',
    badge: 'bg-amber-100 text-amber-700',
    btn: 'bg-amber-500 hover:bg-amber-600',
    icon2: 'text-amber-600',
  },
  {
    id: 'tours',
    icon: '🗺️',
    color: 'indigo',
    title: 'Tours & Experiences',
    subtitle: 'Local Experiences & Activities',
    description: 'Discover the city with curated half-day and full-day experiences — from cultural tours to adventure activities.',
    services: [
      { name: 'City Highlights Tour', desc: 'Half-day guided tour of top city landmarks', price: 'From $45', icon: '🏛️' },
      { name: 'Food & Market Tour', desc: 'Local street food and market exploration', price: 'From $35', icon: '🍜' },
      { name: 'Cultural Experience', desc: 'Temple visits, traditional workshops, and ceremonies', price: 'From $50', icon: '⛩️' },
      { name: 'Nature & Adventure', desc: 'Hiking, cycling, or water activities outside the city', price: 'From $60', icon: '🏔️' },
      { name: 'Wellness Day', desc: 'Yoga, meditation, or spa day package', price: 'From $80', icon: '🧘' },
      { name: 'Private Photography', desc: 'Professional photographer for your city exploration', price: 'From $120', icon: '📸' },
    ],
    cta: 'Explore Tours',
    ctaLink: '/concierge?service=tours',
    bgFrom: 'from-indigo-50',
    bgTo: 'to-purple-50',
    border: 'border-indigo-200',
    badge: 'bg-indigo-100 text-indigo-700',
    btn: 'bg-indigo-600 hover:bg-indigo-700',
    icon2: 'text-indigo-600',
  },
];
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-teal-700 via-teal-600 to-cyan-600 text-white py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-teal-200 text-sm font-medium uppercase tracking-wider mb-3">Beyond Day-Use Stays</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Additional Services</h1>
      <p class="text-teal-100 text-lg max-w-2xl mx-auto leading-relaxed">
        Make the most of your visit with our curated services — from medical support and city transfers to guided tours and local experiences.
      </p>
      <div class="flex flex-wrap justify-center gap-3 mt-8">
        {serviceCategories.map(cat => (
          <a href={`#${cat.id}`} class="flex items-center gap-2 bg-white/20 hover:bg-white/30 backdrop-blur-sm border border-white/30 rounded-full px-4 py-2 text-sm font-medium transition-colors">
            <span>{cat.icon}</span>
            <span>{cat.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-gray-50 border-b border-gray-200 py-8 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
        <div class="flex flex-col items-center gap-2">
          <div class="w-10 h-10 bg-teal-100 rounded-full flex items-center justify-center text-xl">1️⃣</div>
          <p class="font-semibold text-gray-800 text-sm">Choose a Service</p>
          <p class="text-gray-500 text-xs">Browse our service categories and select what you need</p>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-10 h-10 bg-teal-100 rounded-full flex items-center justify-center text-xl">2️⃣</div>
          <p class="font-semibold text-gray-800 text-sm">Contact via AI Concierge</p>
          <p class="text-gray-500 text-xs">Our concierge will confirm details and arrange everything</p>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-10 h-10 bg-teal-100 rounded-full flex items-center justify-center text-xl">3️⃣</div>
          <p class="font-semibold text-gray-800 text-sm">Enjoy Your Experience</p>
          <p class="text-gray-500 text-xs">Sit back and relax — we handle all the coordination</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Categories -->
  <div class="max-w-6xl mx-auto px-4 py-12 space-y-16">
    {serviceCategories.map(cat => (
      <section id={cat.id} class="scroll-mt-20">
        <!-- Category header -->
        <div class={`bg-gradient-to-r ${cat.bgFrom} ${cat.bgTo} rounded-2xl p-6 md:p-8 border ${cat.border} mb-6`}>
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div class="flex items-start gap-4">
              <div class="text-4xl">{cat.icon}</div>
              <div>
                <span class={`inline-block text-xs font-semibold px-2 py-0.5 rounded-full mb-2 ${cat.badge}`}>{cat.subtitle}</span>
                <h2 class="text-2xl font-bold text-gray-900">{cat.title}</h2>
                <p class="text-gray-600 mt-1 max-w-xl">{cat.description}</p>
              </div>
            </div>
            <a
              href={cat.ctaLink}
              class={`flex-shrink-0 inline-flex items-center gap-2 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors ${cat.btn}`}
            >
              {cat.cta}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Service cards grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {cat.services.map(svc => (
            <div class="bg-white rounded-xl border border-gray-100 p-4 hover:shadow-md transition-shadow group">
              <div class="flex items-start gap-3">
                <div class="text-2xl flex-shrink-0 mt-0.5">{svc.icon}</div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-semibold text-gray-900 text-sm">{svc.name}</h3>
                  <p class="text-gray-500 text-xs mt-1 leading-relaxed">{svc.desc}</p>
                  <div class="flex items-center justify-between mt-3">
                    <span class={`text-xs font-bold ${cat.icon2}`}>{svc.price}</span>
                    <a
                      href={cat.ctaLink}
                      class="text-xs text-gray-400 hover:text-teal-600 font-medium transition-colors group-hover:text-teal-600"
                    >
                      Enquire →
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>

  <!-- Bottom CTA -->
  <section class="bg-gray-900 text-white py-12 px-4 mt-8">
    <div class="max-w-2xl mx-auto text-center">
      <div class="text-3xl mb-4">🤖</div>
      <h2 class="text-2xl font-bold mb-3">Not sure what you need?</h2>
      <p class="text-gray-400 mb-6">
        Chat with our AI Concierge — available 24/7 to help you plan, book, and coordinate any service during your stay.
      </p>
      <a
        href="/concierge"
        class="inline-flex items-center gap-2 bg-teal-600 hover:bg-teal-500 text-white font-semibold px-6 py-3 rounded-xl transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
        </svg>
        Chat with AI Concierge
      </a>
    </div>
  </section>
</Layout>
