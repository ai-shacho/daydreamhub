---
import Layout from '../../layouts/Layout.astro';

// Auth: verify JWT
async function verifyJWT(token: string, secret: string): Promise<Record<string, any> | null> {
  try {
    const parts = token.split('.');
    if (parts.length !== 3) return null;
    const [header, body, signature] = parts;
    const key = await crypto.subtle.importKey(
      'raw', new TextEncoder().encode(secret),
      { name: 'HMAC', hash: 'SHA-256' }, false, ['verify']
    );
    const sigBytes = Uint8Array.from(
      atob(signature.replace(/-/g, '+').replace(/_/g, '/')), c => c.charCodeAt(0)
    );
    const valid = await crypto.subtle.verify('HMAC', key, sigBytes, new TextEncoder().encode(`${header}.${body}`));
    if (!valid) return null;
    const payload = JSON.parse(atob(body));
    if (payload.exp && payload.exp < Math.floor(Date.now() / 1000)) return null;
    return payload;
  } catch { return null; }
}

const env = (Astro.locals as any).runtime?.env;
const jwtSecret = env?.JWT_SECRET || 'ddh-secret-2025';
const cookieHeader = Astro.request.headers.get('cookie') || '';
const tokenMatch = cookieHeader.match(/ddh_token=([^;]+)/);
const authPayload = tokenMatch ? await verifyJWT(tokenMatch[1], jwtSecret) : null;
const isLoggedIn = !!authPayload;
---

<Layout title="ウィッシュリスト - DayDreamHub" description="DayDreamHubで保存したデイユースホテル一覧。">

  <section class="py-8 min-h-[70vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">

      {isLoggedIn ? (
        <>
          <!-- Page Title -->
          <div class="mb-8 flex items-center justify-between">
            <h1 class="text-2xl font-bold text-slate-900">ウィッシュリスト</h1>
            <span id="wishlist-count" class="text-sm text-gray-500 hidden"></span>
          </div>

          <!-- Loading state -->
          <div id="wishlist-loading" class="text-center py-20">
            <div class="w-8 h-8 border-2 border-teal-500 border-t-transparent rounded-full animate-spin mx-auto"></div>
          </div>

          <!-- Empty state -->
          <div id="wishlist-empty" class="hidden text-center py-20">
            <svg class="w-20 h-20 mx-auto text-slate-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
            </svg>
            <h2 class="text-xl font-semibold text-slate-600 mb-2">保存したホテルはありません</h2>
            <p class="text-gray-400 mb-6">ホテルのハートアイコンをタップして保存できます。</p>
            <a href="/ja/search" class="inline-block bg-teal-700 hover:bg-teal-800 text-white font-bold px-6 py-2.5 rounded-lg transition-colors">
              ホテルを探す
            </a>
          </div>

          <!-- Hotel grid -->
          <div id="wishlist-grid" class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"></div>
        </>
      ) : (
        <!-- Login prompt -->
        <div class="flex flex-col items-center justify-center py-24 text-center">
          <svg class="w-20 h-20 text-slate-300 mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
          </svg>
          <h2 class="text-2xl font-bold text-slate-800 mb-3">お気に入りのホテルを保存しよう</h2>
          <p class="text-gray-500 max-w-md mb-2">
            ウィッシュリストに保存して、どのデバイスからでもアクセスできます。
          </p>
          <p class="text-gray-400 text-sm mb-8">ログインが必要です。</p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/ja/login?redirect=/ja/wishlist" class="inline-block bg-teal-600 hover:bg-teal-700 text-white font-bold px-8 py-3 rounded-lg transition-colors">
              ログインしてウィッシュリストを見る
            </a>
            <a href="/ja/register" class="inline-block border-2 border-teal-600 text-teal-600 hover:bg-teal-50 font-bold px-8 py-3 rounded-lg transition-colors">
              新規アカウント登録
            </a>
          </div>
        </div>
      )}

    </div>
  </section>

</Layout>

{isLoggedIn && (
  <script is:inline>
  (function() {
    var STORAGE_KEY = 'ddh_wishlist';
    var BASE = '/ja';

    function getSlugs() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch(e) { return []; }
    }

    function renderHotelCard(hotel) {
      var minPriceHtml = hotel.min_price
        ? '<p class="text-[#45A2C1] font-bold text-lg mb-2">$' + hotel.min_price + '~</p>' : '';
      return '<div class="bg-white rounded-lg shadow overflow-hidden hover:shadow-lg transition-shadow relative">' +
        '<a href="' + BASE + '/hotel/' + hotel.slug + '">' +
          '<div class="w-full aspect-[4/3] overflow-hidden">' +
            '<img src="' + (hotel.thumbnail_url || '/images/placeholder-hotel.jpg') + '" alt="' + hotel.name + '" loading="lazy" class="w-full h-full object-cover" />' +
          '</div>' +
        '</a>' +
        '<button class="wishlist-remove-btn absolute top-2 right-2 w-8 h-8 flex items-center justify-center bg-white/90 rounded-full shadow text-red-500 hover:text-red-600 transition-colors" data-slug="' + hotel.slug + '" title="ウィッシュリストから削除">' +
          '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>' +
        '</button>' +
        '<div class="p-4">' +
          '<h3 class="text-gray-900 font-semibold text-base mb-1 line-clamp-2">' +
            '<a href="' + BASE + '/hotel/' + hotel.slug + '" class="hover:text-[#45A2C1] transition-colors">' + (hotel.name_ja || hotel.name) + '</a>' +
          '</h3>' +
          minPriceHtml +
          '<div class="flex flex-wrap gap-1">' +
            '<span class="text-xs text-gray-500 bg-gray-100 rounded px-2 py-0.5">' + hotel.city + '</span>' +
            '<span class="text-xs text-gray-500 bg-gray-100 rounded px-2 py-0.5">' + hotel.country + '</span>' +
          '</div>' +
        '</div>' +
      '</div>';
    }

    async function init() {
      var slugs = getSlugs();
      var loading = document.getElementById('wishlist-loading');
      var empty = document.getElementById('wishlist-empty');
      var grid = document.getElementById('wishlist-grid');
      var countEl = document.getElementById('wishlist-count');

      loading.classList.add('hidden');

      if (!slugs.length) {
        empty.classList.remove('hidden');
        return;
      }

      var hotels = [];
      for (var i = 0; i < slugs.length; i++) {
        try {
          var r = await fetch('/api/hotels/' + slugs[i] + '/plans');
          if (r.ok) {
            var d = await r.json();
            if (d.hotel) {
              var prices = (d.plans || []).map(function(p) { return p.price_usd; }).filter(Boolean);
              d.hotel.min_price = prices.length ? Math.min.apply(null, prices) : null;
              hotels.push(d.hotel);
            }
          }
        } catch(e) {}
      }

      if (!hotels.length) {
        empty.classList.remove('hidden');
        return;
      }

      grid.innerHTML = hotels.map(renderHotelCard).join('');
      grid.classList.remove('hidden');
      grid.classList.add('grid');
      countEl.textContent = hotels.length + '件保存済み';
      countEl.classList.remove('hidden');

      grid.addEventListener('click', function(e) {
        var btn = e.target.closest('.wishlist-remove-btn');
        if (!btn) return;
        var slug = btn.getAttribute('data-slug');
        var stored = getSlugs().filter(function(s) { return s !== slug; });
        localStorage.setItem(STORAGE_KEY, JSON.stringify(stored));
        var card = btn.closest('.bg-white');
        if (card) card.remove();
        var remaining = grid.querySelectorAll('.bg-white').length;
        countEl.textContent = remaining + '件保存済み';
        if (!remaining) { grid.classList.add('hidden'); empty.classList.remove('hidden'); countEl.classList.add('hidden'); }
      });
    }

    init();
  })();
  </script>
)}
