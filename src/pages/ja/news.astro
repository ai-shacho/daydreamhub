---
import Layout from '../../layouts/Layout.astro';

const db = (Astro.locals as any).runtime?.env?.DB;
let items: any[] = [];

if (db) {
  let newsItems: any[] = [];
  let blogItems: any[] = [];

  // newsテーブルから取得（blog以外）
  try {
    const newsResult = await db.prepare(
      "SELECT title, title_ja, content, content_ja, category, published_at FROM news WHERE published_at IS NOT NULL AND category != 'blog' ORDER BY published_at DESC LIMIT 50"
    ).all();
    newsItems = (newsResult?.results || []).map((n: any) => ({
      title: n.title_ja || n.title,
      content: n.content_ja || n.content,
      category: n.category,
      published_at: n.published_at,
      type: 'news',
      link: null,
    }));
  } catch {}

  // blog_postsテーブルから取得
  try {
    const blogResult = await db.prepare(
      "SELECT title, title_ja, excerpt, slug, published_at FROM blog_posts WHERE published_at IS NOT NULL ORDER BY published_at DESC LIMIT 50"
    ).all();
    blogItems = (blogResult?.results || []).map((b: any) => ({
      title: b.title_ja || b.title,
      content: b.excerpt,
      category: 'blog',
      published_at: b.published_at,
      type: 'blog',
      link: `/blog/${b.slug}`,
    }));
  } catch {}

  // 統合して日付順にソート
  items = [...newsItems, ...blogItems].sort((a, b) =>
    new Date(b.published_at).getTime() - new Date(a.published_at).getTime()
  );
}

const categoryLabels: Record<string, string> = {
  update: 'お知らせ', blog: 'ブログ', policy: '規約更新', feature: '新機能', maintenance: 'メンテナンス',
};
const categoryColors: Record<string, string> = {
  update: "bg-blue-100 text-blue-700",
  blog: "bg-teal-100 text-teal-700",
  policy: "bg-amber-100 text-amber-700",
  feature: "bg-purple-100 text-purple-700",
  maintenance: "bg-slate-100 text-slate-600",
};

function formatDate(dateStr: string): string {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
}
---

<Layout title="新着情報 - DayDreamHub" description="DayDreamHubの最新のお知らせ、更新情報をお届けします。">
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">新着情報</h1>
    <p class="text-gray-500 mb-8">DayDreamHubの最新のお知らせ、更新情報をお届けします。</p>

    {items.length === 0 ? (
      <div class="text-center py-16 text-gray-400">
        <p class="text-lg">まだお知らせはありません。</p>
      </div>
    ) : (
      <div class="space-y-6">
        {items.map((n: any) => (
          <article class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center gap-3 mb-3">
              <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${categoryColors[n.category] || "bg-slate-100 text-slate-600"}`}>{categoryLabels[n.category] || n.category}</span>
              <time class="text-xs text-gray-400">{formatDate(n.published_at)}</time>
            </div>
            {n.link ? (
              <a href={n.link} class="text-lg font-semibold text-gray-900 hover:text-cyan-600 transition-colors">{n.title}</a>
            ) : (
              <h2 class="text-lg font-semibold text-gray-900">{n.title}</h2>
            )}
            {n.content && (
              <p class="text-sm text-gray-600 leading-relaxed mt-2 whitespace-pre-line">{n.content}</p>
            )}
          </article>
        ))}
      </div>
    )}
  </div>
</Layout>
