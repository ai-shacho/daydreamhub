---
import Layout from '../../layouts/Layout.astro';

const env = (Astro.locals as any).runtime?.env;
const RESEND_API_KEY = env?.RESEND_API_KEY || '';
const ADMIN_EMAIL = env?.ADMIN_EMAIL || 'info@daydreamhub.com';

let success = false;
let error = '';

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const name = (form.get('name') || '').toString().trim();
    const email = (form.get('email') || '').toString().trim();
    const subject = (form.get('subject') || '').toString().trim();
    const message = (form.get('message') || '').toString().trim();
    const category = (form.get('category') || 'general').toString();

    if (!name || !email || !message) {
      error = '必須項目をすべて入力してください。';
    }

    // Save to database
    const db = env?.DB;
    if (!error && db) {
      try {
        await db.prepare(
          'INSERT INTO contact_inquiries (name, email, subject, message, category) VALUES (?, ?, ?, ?, ?)'
        ).bind(name, email, subject, message, category).run();
      } catch (e) {
        console.error('Failed to save contact inquiry:', e);
      }
    }

    if (!error && RESEND_API_KEY) {
      const html = `
<div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto">
  <h2 style="color:#0d9488">新しいお問い合わせ — DaydreamHub (日本語)</h2>
  <table style="border-collapse:collapse;width:100%;margin:16px 0">
    <tr><td style="padding:8px 12px;border:1px solid #ddd;font-weight:bold;background:#f9f9f9;width:30%">カテゴリー</td><td style="padding:8px 12px;border:1px solid #ddd">${category}</td></tr>
    <tr><td style="padding:8px 12px;border:1px solid #ddd;font-weight:bold;background:#f9f9f9">お名前</td><td style="padding:8px 12px;border:1px solid #ddd">${name}</td></tr>
    <tr><td style="padding:8px 12px;border:1px solid #ddd;font-weight:bold;background:#f9f9f9">メール</td><td style="padding:8px 12px;border:1px solid #ddd">${email}</td></tr>
    <tr><td style="padding:8px 12px;border:1px solid #ddd;font-weight:bold;background:#f9f9f9">件名</td><td style="padding:8px 12px;border:1px solid #ddd">${subject || '-'}</td></tr>
    <tr><td style="padding:8px 12px;border:1px solid #ddd;font-weight:bold;background:#f9f9f9">メッセージ</td><td style="padding:8px 12px;border:1px solid #ddd;white-space:pre-wrap">${message}</td></tr>
  </table>
</div>`;
      const res = await fetch('https://api.resend.com/emails', {
        method: 'POST',
        headers: { Authorization: `Bearer ${RESEND_API_KEY}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({
          from: 'DaydreamHub Contact <noreply@daydreamhub.com>',
          to: [ADMIN_EMAIL],
          reply_to: email,
          subject: `[お問い合わせ] ${category} — ${name}: ${subject || message.slice(0, 50)}`,
          html,
        }),
      });
      if (res.ok) {
        success = true;
      } else {
        error = 'メッセージの送信に失敗しました。もう一度お試しください。';
      }
    } else {
      error = 'メールサービスが設定されていません。直接ご連絡ください。';
    }
  } catch (e) {
    error = 'エラーが発生しました。もう一度お試しください。';
  }
}
---

<Layout title="お問い合わせ — DayDreamHub" description="予約に関するご質問・提携のお申し込み・その他のご相談はこちら。">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="text-center mb-10">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">お問い合わせ</h1>
      <p class="text-gray-500 max-w-xl mx-auto">予約に関するご質問、施設掲載のご希望、その他ご相談がございましたらお気軽にどうぞ。</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Left: Contact cards -->
      <div class="space-y-4">
        <a href="/ja/concierge" class="group block rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300">
          <div class="relative h-36 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1677129666186-d29eba893fe3?w=600&q=80" alt="AIコンシェルジュ" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-teal-900/70 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-4">
              <h3 class="font-bold text-white text-base">AIコンシェルジュ</h3>
            </div>
          </div>
          <div class="bg-white border border-gray-100 px-4 py-3">
            <p class="text-sm text-gray-500">ホテル検索・空き確認・おすすめ提案を24時間対応。</p>
            <span class="text-xs font-semibold text-teal-600 mt-2 inline-block">AIに相談する →</span>
          </div>
        </a>

        <a href="/ja/mypage" class="group block rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300">
          <div class="relative h-36 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1617368483303-100123b1d5b6?w=600&q=80" alt="予約状況の確認" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/70 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-4">
              <h3 class="font-bold text-white text-base">予約状況の確認</h3>
            </div>
          </div>
          <div class="bg-white border border-gray-100 px-4 py-3">
            <p class="text-sm text-gray-500">ご予約済みの方はマイページで予約状況をご確認いただけます。</p>
            <span class="text-xs font-semibold text-teal-600 mt-2 inline-block">マイページを見る →</span>
          </div>
        </a>

        <a href="/ja/faq" class="group block rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300">
          <div class="relative h-36 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1768397003975-973cabec2818?w=600&q=80" alt="よくある質問" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/70 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-4">
              <h3 class="font-bold text-white text-base">よくある質問</h3>
            </div>
          </div>
          <div class="bg-white border border-gray-100 px-4 py-3">
            <p class="text-sm text-gray-500">デイユースホテルに関するよくある質問と回答。</p>
            <span class="text-xs font-semibold text-teal-600 mt-2 inline-block">FAQを見る →</span>
          </div>
        </a>
      </div>

      <!-- Right: Contact Form -->
      <div class="md:col-span-2">
        {success ? (
          <div class="bg-teal-50 border border-teal-200 rounded-xl p-8 text-center">
            <div class="text-5xl mb-4">✅</div>
            <h2 class="text-xl font-bold text-teal-800 mb-2">送信完了！</h2>
            <p class="text-teal-600 mb-6">24時間以内にご返信いたします。</p>
            <a href="/ja/" class="inline-block bg-teal-600 hover:bg-teal-700 text-white font-semibold px-6 py-2.5 rounded-lg transition-colors">ホームに戻る</a>
          </div>
        ) : (
          <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-gray-800 mb-5">メッセージを送る</h2>

            {error && (
              <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm mb-4">{error}</div>
            )}

            <form method="POST" class="space-y-4">
              <!-- Notice -->
              <div class="bg-amber-50 border border-amber-200 rounded-lg px-3 py-2 text-xs text-amber-700 space-y-1">
                <p>⚠️ このフォームは一般的なお問い合わせ専用です。予約のリクエストや空き状況の確認にはお答えできません。ご予約は<a href="/ja/search" class="underline hover:text-amber-900">ホテル検索</a>よりご利用ください。</p>
                <p>🚫 営業・セールスに関するメッセージはお断りしております。</p>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">お問い合わせ種別 <span class="text-red-500">*</span></label>
                <select name="category" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-teal-400 outline-none bg-white">
                  <option value="booking">予約・ご予約に関するご質問</option>
                  <option value="payment">お支払いについて</option>
                  <option value="property">施設の掲載申し込み</option>
                  <option value="general">その他のご相談</option>
                </select>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">お名前 <span class="text-red-500">*</span></label>
                  <input type="text" name="name" required placeholder="山田 太郎"
                    class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-teal-400 outline-none" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">メールアドレス <span class="text-red-500">*</span></label>
                  <input type="email" name="email" required placeholder="your@email.com"
                    class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-teal-400 outline-none" />
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">件名</label>
                <input type="text" name="subject" placeholder="お問い合わせの概要"
                  class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-teal-400 outline-none" />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">メッセージ <span class="text-red-500">*</span></label>
                <textarea name="message" required rows="5" placeholder="ご質問・ご相談の内容をご記入ください..."
                  class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-400 focus:border-teal-400 outline-none resize-none"></textarea>
              </div>

              <button type="submit"
                class="w-full bg-teal-600 hover:bg-teal-700 text-white font-semibold py-3 rounded-lg transition-colors text-sm">
                送信する
              </button>
            </form>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>
