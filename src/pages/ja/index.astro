      <div class="flex flex-wrap gap-3">
        {specialities.map(spec => (
          <a href={localePath(`/search?speciality=${spec.value}`, locale)} class="inline-flex items-center px-5 py-2.5 rounded-full bg-white border border-gray-200 text-sm font-medium text-gray-700 hover:bg-[#45A2C1] hover:text-white hover:border-[#45A2C1] transition-colors shadow-sm">
            {t(spec.key, locale)}
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
<script is:inline define:vars={{ allCities }}>
(function() {
  var WORLD_CITIES = [
    {city:"東京",country:"日本"},{city:"大阪",country:"日本"},{city:"京都",country:"日本"},{city:"札幌",country:"日本"},
    {city:"福岡",country:"日本"},{city:"名古屋",country:"日本"},{city:"神戸",country:"日本"},{city:"横浜",country:"日本"},
    {city:"Bangkok",country:"タイ"},{city:"Phuket",country:"タイ"},{city:"Chiang Mai",country:"タイ"},
    {city:"Singapore",country:"シンガポール"},{city:"Kuala Lumpur",country:"マレーシア"},
    {city:"Bali",country:"インドネシア"},{city:"Jakarta",country:"インドネシア"},
    {city:"Ho Chi Minh City",country:"ベトナム"},{city:"Hanoi",country:"ベトナム"},{city:"Da Nang",country:"ベトナム"},
    {city:"Manila",country:"フィリピン"},{city:"Cebu",country:"フィリピン"},
    {city:"Dubai",country:"UAE"},{city:"Abu Dhabi",country:"UAE"},{city:"Doha",country:"カタール"},
    {city:"London",country:"イギリス"},{city:"Paris",country:"フランス"},{city:"Berlin",country:"ドイツ"},
    {city:"Rome",country:"イタリア"},{city:"Barcelona",country:"スペイン"},{city:"Amsterdam",country:"オランダ"},
    {city:"New York",country:"アメリカ"},{city:"Los Angeles",country:"アメリカ"},{city:"Chicago",country:"アメリカ"},
    {city:"Seoul",country:"韓国"},{city:"Busan",country:"韓国"},{city:"Taipei",country:"台湾"},
    {city:"Hong Kong",country:"香港"},{city:"Beijing",country:"中国"},{city:"Shanghai",country:"中国"},
    {city:"Sydney",country:"オーストラリア"},{city:"Melbourne",country:"オーストラリア"},
    {city:"Mumbai",country:"インド"},{city:"Delhi",country:"インド"},
    {city:"Cairo",country:"エジプト"},{city:"Nairobi",country:"ケニア"},
    {city:"Toronto",country:"カナダ"},{city:"Vancouver",country:"カナダ"},
  ];
  var dbCities = (allCities || []).map(function(c){ return {city: c.city, country: c.country, inDB: true}; });
  var dbKeys = new Set(dbCities.map(function(c){ return c.city.toLowerCase(); }));
  var extras = WORLD_CITIES.filter(function(c){ return !dbKeys.has(c.city.toLowerCase()); }).map(function(c){ return {city:c.city,country:c.country,inDB:false}; });
  var cities = dbCities.concat(extras);

  function normalize(s){ return (s||'').toLowerCase().replace(/\s+/g,' ').trim(); }
  function highlight(text, q){
    if (!q) return text;
    var re = new RegExp('('+q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','gi');
    return text.replace(re,'<strong class="text-teal-600">$1</strong>');
  }

  var input = document.getElementById('location-input-ja');
  var list = document.getElementById('location-suggestions-ja');
  if (!input || !list) return;
  var activeIdx = -1;

  function getMatches(q){
    if (!q){
      var db = cities.filter(function(c){return c.inDB;}).slice(0,8);
      return db.length>=8 ? db : db.concat(cities.filter(function(c){return !c.inDB;}).slice(0,8-db.length));
    }
    var nq = normalize(q);
    var pDB=[],pW=[],cDB=[],cW=[];
    cities.forEach(function(c){
      var nc=normalize(c.city),nco=normalize(c.country);
      var isP=nc.startsWith(nq)||nco.startsWith(nq);
      var isC=!isP&&(nc.includes(nq)||nco.includes(nq));
      if(isP){c.inDB?pDB.push(c):pW.push(c);}
      else if(isC){c.inDB?cDB.push(c):cW.push(c);}
    });
    return pDB.concat(pW).concat(cDB).concat(cW).slice(0,10);
  }

  function render(items, q){
    activeIdx = -1;
    if (!items.length){ list.classList.add('hidden'); return; }
    list.innerHTML = items.map(function(c,i){
      var badge = c.inDB ? '<span class="text-[10px] bg-teal-100 text-teal-700 px-1.5 py-0.5 rounded font-semibold ml-1.5">DDH</span>' : '';
      return '<li class="px-4 py-2.5 cursor-pointer hover:bg-teal-50 text-gray-800 flex justify-between items-center suggestion-item-ja" data-city="'+c.city+'" data-idx="'+i+'">' +
        '<span class="font-medium flex items-center">'+highlight(c.city,q)+badge+'</span>' +
        '<span class="text-gray-400 text-xs ml-2">'+c.country+'</span></li>';
    }).join('');
    list.classList.remove('hidden');
  }

  input.addEventListener('input', function(){ render(getMatches(this.value.trim()), normalize(this.value.trim())); });
  input.addEventListener('focus', function(){ render(getMatches(this.value.trim()), normalize(this.value.trim())); });
  input.addEventListener('keydown', function(e){
    var lis = list.querySelectorAll('.suggestion-item-ja');
    if (!lis.length) return;
    if (e.key==='ArrowDown'){e.preventDefault();activeIdx=Math.min(activeIdx+1,lis.length-1);lis.forEach(function(l,i){l.classList.toggle('bg-teal-50',i===activeIdx);});if(lis[activeIdx])input.value=lis[activeIdx].dataset.city;}
    else if (e.key==='ArrowUp'){e.preventDefault();activeIdx=Math.max(activeIdx-1,0);lis.forEach(function(l,i){l.classList.toggle('bg-teal-50',i===activeIdx);});if(lis[activeIdx])input.value=lis[activeIdx].dataset.city;}
    else if (e.key==='Enter'){e.preventDefault();if(lis[activeIdx]){input.value=lis[activeIdx].dataset.city;list.classList.add('hidden');}}
    else if (e.key==='Escape'){list.classList.add('hidden');}
  });
  list.addEventListener('mousedown', function(e){ var li=e.target.closest('.suggestion-item-ja'); if(li){input.value=li.dataset.city;list.classList.add('hidden');} });
  document.addEventListener('click', function(e){ if(!input.contains(e.target)&&!list.contains(e.target)){list.classList.add('hidden');} });

  // Flatpickr
  if (typeof flatpickr !== 'undefined') {
    flatpickr('#checkin-fp-ja', { dateFormat: 'm/d/Y', minDate: 'today', locale: 'ja' });
  } else {
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/flatpickr';
    s.onload = function(){ flatpickr('#checkin-fp-ja', { dateFormat: 'm/d/Y', minDate: 'today' }); };
    document.head.appendChild(s);
  }

  // AI Chat
  var messagesEl = document.getElementById('hero-chat-messages-ja');
  var inputEl = document.getElementById('hero-chat-input-ja');
  var sendBtn = document.getElementById('hero-chat-send-ja');
  var sessionId = 'ja-hero-' + Date.now();

  function showMessages(){ if(messagesEl) messagesEl.classList.remove('hidden'); }

  function extractSlugs(text){
    var slugs=[], re=/\/hotel\/([\w-]+)/g, m;
    var seen = new Set();
    while((m=re.exec(text))!==null){ if(!seen.has(m[1])){seen.add(m[1]);slugs.push(m[1]);} }
    return slugs;
  }

  function extractExternal(text){
    var hotels=[];
    text.split('\n').forEach(function(line){
      var pm=line.match(/📞\s*([\+\d][\d\s\-\(\)\.]{6,20})/);
      if(!pm) return;
      var phone=pm[1].trim();
      var nm=line.match(/\*\*(.*?)\*\*/)||line.match(/^\s*\d+\.\s+(.+?)(?:\s*[|｜]|\s*📍|\s*📞)/)||line.match(/^\s*[-•]\s+(.+?)(?:\s*[|｜]|\s*📍|\s*📞)/);
      var name=nm?nm[1].replace(/\*\*/g,'').trim():'';
      if(!name||name.length<2||line.indexOf('/hotel/')!==-1) return;
      hotels.push({name:name,phone:phone});
    });
    return hotels;
  }

  function renderContent(text){
    var html=text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    html=html.replace(/^### (.+)$/gm,'<strong class="block text-amber-300 text-sm mt-2">$1</strong>');
    html=html.replace(/^## (.+)$/gm,'<strong class="block text-amber-200 text-sm mt-2 mb-1">$1</strong>');
    html=html.replace(/\*\*([^*\n]+)\*\*/g,'<strong>$1</strong>');
    html=html.replace(/\*([^*\n]+)\*/g,'<em>$1</em>');
    html=html.replace(/^---+$/gm,'<hr class="border-white/20 my-2"/>');
    html=html.replace(/^[-•]\s+(.+)$/gm,'<span class="flex gap-1.5"><span class="text-amber-400 flex-shrink-0">•</span><span>$1</span></span>');
    html=html.replace(/\[([^\]]+)\]\((https?:\/\/[^)]*?\/hotel\/([\w-]+)[^)]*)\)/g,'<a href="/hotel/$3" class="underline text-amber-300 hover:text-amber-200">$1</a>');
    html=html.replace(/\[([^\]]+)\]\((\/hotel\/([\w-]+))\)/g,'<a href="/hotel/$3" class="underline text-amber-300 hover:text-amber-200">$1</a>');
    html=html.replace(/(\/hotel\/([\w-]+))/g,'<a href="$1" class="underline text-amber-300 hover:text-amber-200">$1</a>');
    return html;
  }

  function addMsg(text, role){
    showMessages();
    var wrap=document.createElement('div');
    wrap.className='flex gap-2'+(role==='user'?' flex-row-reverse':'');
    if(role==='assistant'){
      var slugs=extractSlugs(text);
      var ext=extractExternal(text);
      var bookBtns=slugs.map(function(s){
        return '<button onclick="window._heroBookNowJa(\''+s+'\',this)" class="flex items-center gap-1.5 bg-amber-500 hover:bg-amber-400 text-gray-900 text-xs font-bold px-3 py-1.5 rounded-lg">🏨 予約する — '+s.replace(/-/g,' ').replace(/\b\w/g,function(c){return c.toUpperCase();}).slice(0,28)+'</button>';
      }).join('');
      var callBtns=ext.map(function(h){
        var sn=h.name.replace(/'/g,'').slice(0,40),sp=h.phone.replace(/'/g,'');
        return '<button onclick="window._heroCallBookJa(\''+sn+'\',\''+sp+'\',this)" class="flex items-center gap-1.5 bg-blue-500 hover:bg-blue-400 text-white text-xs font-bold px-3 py-1.5 rounded-lg">📞 電話予約 (+$7) — '+h.name.slice(0,26)+'</button>';
      }).join('');
      var allBtns=bookBtns+callBtns;
      wrap.innerHTML='<div class="w-6 h-6 bg-white/20 rounded-full flex-shrink-0 flex items-center justify-center text-white text-[10px] font-bold mt-0.5">AI</div>' +
        '<div class="bg-white/20 text-white rounded-xl rounded-tl-none px-3 py-2.5 text-sm max-w-[85%] shadow border border-white/10">' +
        '<div class="whitespace-pre-wrap leading-relaxed">'+renderContent(text)+'</div>' +
        (allBtns?'<div class="flex flex-wrap gap-2 mt-2.5">'+allBtns+'</div>':'')+
        '</div>';
    } else {
      wrap.innerHTML='<div class="bg-amber-500 text-gray-900 rounded-xl rounded-tr-none px-3 py-2 text-sm max-w-[85%] font-medium">'+text+'</div>';
    }
    messagesEl.appendChild(wrap);
    messagesEl.scrollTop=messagesEl.scrollHeight;
  }

  async function sendChat(msg){
    addMsg(msg,'user');
    var thinkDiv=document.createElement('div');
    thinkDiv.className='flex gap-2';
    thinkDiv.innerHTML='<div class="w-6 h-6 bg-white/20 rounded-full flex-shrink-0 flex items-center justify-center text-white text-[10px] font-bold mt-0.5">AI</div><div class="bg-white/20 text-white/70 rounded-xl rounded-tl-none px-3 py-2 text-sm italic">検索中...</div>';
    messagesEl.appendChild(thinkDiv);
    messagesEl.scrollTop=messagesEl.scrollHeight;
    try {
      var res=await fetch('/api/concierge/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({session_id:sessionId,message:msg,locale:'ja'})});
      var data=await res.json();
      messagesEl.removeChild(thinkDiv);
      addMsg(data.response||data.reply||'エラーが発生しました。','assistant');
    } catch(e){
      messagesEl.removeChild(thinkDiv);
      addMsg('通信エラーが発生しました。','assistant');
    }
  }

  if(sendBtn) sendBtn.addEventListener('click', function(){
    var v=inputEl.value.trim();
    if(!v) return;
    inputEl.value='';
    sendChat(v);
  });
  if(inputEl) inputEl.addEventListener('keydown', function(e){ if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendBtn.click();} });

  window._startCallPollingJa = function(groupId, sid) {
    var maxAttempts = 36;
    var attempt = 0;
    var waitEl = document.createElement('div');
    waitEl.className = 'flex gap-2';
    waitEl.innerHTML = '<div class="w-6 h-6 bg-white/20 rounded-full flex-shrink-0 flex items-center justify-center text-white text-[10px] font-bold mt-0.5">AI</div>' +
      '<div class="bg-white/20 text-white/80 rounded-xl rounded-tl-none px-3 py-2 text-sm border border-white/10"><span class="inline-block w-2 h-2 rounded-full bg-amber-400 animate-pulse mr-2"></span>📞 AIがホテルに電話中...</div>';
    messagesEl.appendChild(waitEl);
    messagesEl.scrollTop = messagesEl.scrollHeight;

    var timer = setInterval(async function(){
      attempt++;
      if(attempt > maxAttempts){ clearInterval(timer); waitEl.remove(); addMsg('⏱️ タイムアウトしました。少し後に確認してください。','assistant'); return; }
      try {
        var r = await fetch('/api/concierge/chat',{method:'POST',headers:{'Content-Type':'application/json'},
          body:JSON.stringify({session_id:sid,message:'__check_group_status:'+groupId,locale:'ja'})});
        var d = await r.json();
        var gs = d.metadata?.group_status;
        if(!gs || gs === 'calling' || gs === 'pending') return;
        clearInterval(timer); waitEl.remove();
        if(d.response) addMsg(d.response,'assistant');
        if(gs === 'all_failed'){
          setTimeout(function(){
            addMsg('💸 **全ホテルへの電話が繋がりませんでした。**\n\n$7は自動全額返金されます（PayPal処理に2〜5営業日）。\n\n別の日時や都市でお試しください。','assistant');
          },1000);
        }
      } catch(e){}
    }, 5000);
  };

  window._heroAskAIJa = function(){
    var loc=document.getElementById('location-input-ja')?.value.trim();
    var date=document.getElementById('checkin-fp-ja')?.value;
    var cin=document.querySelector('select[name="checkin_time"]')?.value||'10:00';
    var cout=document.querySelector('select[name="checkout_time"]')?.value||'18:00';
    var guests=document.querySelector('select[name="guests"]')?.value||'1';
    if(!loc){addMsg('📍 都市名または空港名を入力してください','assistant');showMessages();return;}
    var msg=loc+' でデイユースホテルを探しています。'+(date?date+'、':'')+cin+'〜'+cout+'、'+guests+'名。おすすめを教えてください。';
    sendChat(msg);
  };

  window._heroBookNowJa = async function(slug, btn){
    btn.disabled=true; btn.textContent='読み込み中...';
    try {
      var res=await fetch('/api/hotels/'+slug+'/plans');
      var data=await res.json();
      if(!data.hotel||!data.plans||!data.plans.length){btn.textContent='❌ プランなし';return;}
      // シンプルなメッセージ表示
      var plans=data.plans.slice(0,3).map(function(p,i){return (i+1)+'. '+p.name_ja+'（¥'+Math.round(p.price_usd*150)+'〜 / $'+p.price_usd+'）';}).join('\n');
      addMsg('🏨 **'+data.hotel.name+'**\n\n'+plans+'\n\n予約するには /hotel/'+slug+' をご覧ください。','assistant');
    } catch(e){ btn.textContent='❌ エラー'; }
  };

  window._heroCallBookJa = function(hotelName, hotelPhone, btn){
    btn.disabled=true;
    var today=new Date().toISOString().split('T')[0];
    var formDiv=document.createElement('div');
    formDiv.className='flex gap-2';
    formDiv.innerHTML=
      '<div class="w-6 h-6 bg-white/20 rounded-full flex-shrink-0 flex items-center justify-center text-white text-[10px] font-bold mt-0.5">AI</div>'+
      '<div class="bg-gray-900/80 border border-white/20 text-white rounded-xl rounded-tl-none px-4 py-3 text-sm max-w-[92%] w-full">'+
        '<p class="font-bold text-base mb-1">📞 AI電話予約代行</p>'+
        '<p class="text-amber-300 text-xs mb-3">🏨 '+hotelName+'</p>'+
        '<p class="text-white/70 text-xs mb-3">AIがホテルへ電話します。<strong class="text-amber-400">$7</strong>（不成立全額返金）</p>'+
        '<div class="space-y-2">'+
          '<input id="call-name-ja" type="text" placeholder="お名前" class="w-full bg-white/10 text-white placeholder-white/30 rounded-lg px-3 py-2 text-sm border border-white/20"/>'+
          '<input id="call-email-ja" type="email" placeholder="メールアドレス" class="w-full bg-white/10 text-white placeholder-white/30 rounded-lg px-3 py-2 text-sm border border-white/20"/>'+
          '<input id="call-date-ja" type="text" placeholder="YYYY-MM-DD" value="'+today+'" class="w-full bg-white/10 text-white placeholder-white/50 rounded-lg px-3 py-2 text-sm border border-white/20"/>'+
        '</div>'+
        '<button onclick="window._heroSubmitCallBookJa(\''+hotelName.replace(/'/g,'&#39;')+'\',\''+hotelPhone+'\')" '+
          'class="mt-3 w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-2.5 rounded-lg text-sm">💳 PayPalで$7支払い → 電話予約へ</button>'+
        '<button onclick="this.closest(\'.flex\').remove()" class="mt-1 w-full text-white/40 text-xs py-1">キャンセル</button>'+
      '</div>';
    messagesEl.appendChild(formDiv);
    messagesEl.scrollTop=messagesEl.scrollHeight;
    btn.disabled=false;
  };

  window._heroSubmitCallBookJa = async function(hotelName, hotelPhone){
    var name=document.getElementById('call-name-ja')?.value?.trim();
    var email=document.getElementById('call-email-ja')?.value?.trim();
    var date=document.getElementById('call-date-ja')?.value;
    if(!name||!email||!date){alert('お名前・メール・日付を入力してください');return;}
    try {
      var res=await fetch('/api/concierge/chat',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({session_id:sessionId,message:'__create_call_group_direct',locale:'ja',
          _call_group:{hotels:[{hotel_name:hotelName,hotel_phone:hotelPhone,hotel_source:'external'}],
            guest_name:name,guest_email:email,check_in_date:date}})});
      var data=await res.json();
      if(data.paypal_url){window.open(data.paypal_url,'_blank');addMsg('✅ PayPalページを開きました。\n📞 '+hotelName+'\n👤 '+name+'\n📅 '+date,'assistant');if(data.group_id){window._startCallPollingJa(data.group_id,sessionId);}}
      else{addMsg(data.response||'予約リクエストを受け付けました。','assistant');}
    } catch(e){addMsg('通信エラーが発生しました。','assistant');}
  };
})();
</script>
