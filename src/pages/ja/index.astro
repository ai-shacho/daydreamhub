<Layout title={t('site.name', locale)} description={t('hero.tagline', locale)}>
  <!-- Hero Section with AI Chat -->
  <section class="relative min-h-[560px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image:url('https://images.unsplash.com/photo-1566073771259-6a8506099945?w=1600&q=80')"></div>
    <div class="absolute inset-0 bg-teal-900/80"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 py-14 w-full">
      <div class="text-center text-white mb-8">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">ホテルを、時間単位で。世界60都市以上。</h1>
        <p class="text-lg text-teal-100 max-w-2xl mx-auto mb-5">デイユースホテル予約のグローバルプラットフォーム。空港乗り継ぎ・仕事・休息・カップルのひとときに。</p>
        <div class="flex flex-wrap justify-center gap-3 mb-6">
          <span class="bg-white/15 border border-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full">1時間〜利用可能</span>
          <span class="bg-white/15 border border-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full">宿泊費の半額以下</span>
          <span class="bg-white/15 border border-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full">AI即時検索</span>
        </div>
      </div>

      <!-- AI Chat Box -->
      <div class="max-w-3xl mx-auto" id="ai-chat-wrapper-ja">
        <div id="hero-chat-messages-ja" class="hidden bg-gray-900/75 backdrop-blur-sm border border-white/20 rounded-xl p-4 mb-3 space-y-3 max-h-72 overflow-y-auto"></div>

        <p class="text-white font-semibold text-sm mb-2 pl-1 flex items-center gap-2">
          <span class="inline-block w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          💬 AIコンシェルジュ — 都市名・空港名を入力してください
        </p>
        <div class="bg-white rounded-xl p-3 flex items-center gap-2 shadow-lg border border-amber-400/50 focus-within:ring-2 focus-within:ring-amber-400/40 transition-all">
          <input type="text" id="hero-chat-input-ja"
            placeholder="例: 東京、バンコク、シンガポール、Dubai..."
            class="flex-1 bg-transparent text-gray-800 placeholder-gray-400 text-sm focus:outline-none font-medium"
            maxlength="300" />
          <button id="hero-chat-send-ja"
            class="flex-shrink-0 bg-amber-500 hover:bg-amber-400 text-white font-bold text-sm px-4 py-2 rounded-lg transition-colors flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
            送信
          </button>
        </div>

        <!-- Quick Search Form -->
        <form action="/ja/search" method="get" class="mt-3 bg-white/95 rounded-2xl p-4 shadow-xl">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-3">
            <div class="relative col-span-2 md:col-span-1">
              <label class="block text-xs text-gray-600 mb-1 font-semibold">エリア</label>
              <input type="text" name="location" id="location-input-ja" placeholder="都市・空港名..." autocomplete="off"
                class="w-full rounded-lg px-3 py-2.5 text-sm bg-white text-gray-800 border border-gray-200 focus:outline-none focus:ring-2 focus:ring-amber-400" />
              <ul id="location-suggestions-ja" class="hidden absolute left-0 right-0 top-full mt-1 bg-white border border-gray-200 rounded-lg shadow-lg z-50 max-h-60 overflow-y-auto text-sm"></ul>
            </div>
            <div>
              <label class="block text-xs text-gray-600 mb-1 font-semibold">日付</label>
              <input type="text" name="checkin" id="checkin-fp-ja" placeholder="MM / DD / YYYY" autocomplete="off"
                class="w-full rounded-lg px-3 py-2.5 text-sm bg-white text-gray-800 border border-gray-200 focus:outline-none focus:ring-2 focus:ring-amber-400" />
            </div>
            <div>
              <label class="block text-xs text-gray-600 mb-1 font-semibold">チェックイン</label>
              <select name="checkin_time" class="w-full rounded-lg px-3 py-2.5 text-sm bg-white text-gray-800 border border-gray-200 focus:outline-none focus:ring-2 focus:ring-amber-400">
                {['06:00','07:00','08:00','09:00','10:00','11:00','12:00','13:00','14:00','15:00','16:00','17:00','18:00'].map(t => (
