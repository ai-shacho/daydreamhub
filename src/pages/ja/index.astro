              '<div class="absolute bottom-0 left-0 right-0 p-3">' +
                '<h3 class="text-white font-semibold text-sm">' + city.city.replace(/</g, '&lt;') + '</h3>' +
                '<p class="text-white/60 text-xs">' + city.country.replace(/</g, '&lt;') + '</p>' +
                '<p class="text-white/70 text-xs">' + city.hotel_count + '件</p>' +
              '</div>';
            grid.appendChild(a);
          });
          panel.appendChild(grid);
          container.appendChild(panel);
          existingPanel = panel;
        }

        // Show this panel, hide others
        container.querySelectorAll('[data-region-panel]').forEach(function(p) {
          p.classList.toggle('hidden', p.getAttribute('data-region-panel') !== region);
        });

        // Switch tab styles
        document.querySelectorAll('.region-tab').forEach(function(t) {
          t.classList.remove('bg-teal-600', 'text-white', 'border-teal-600');
          t.classList.add('bg-white', 'text-gray-600', 'border-gray-300', 'hover:border-teal-400', 'hover:text-teal-600');
        });
        btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-300', 'hover:border-teal-400', 'hover:text-teal-600');
        btn.classList.add('bg-teal-600', 'text-white', 'border-teal-600');
      });
    });
