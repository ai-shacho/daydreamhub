          <a href={localePath(`/city/${city.slug}`, locale)} class="group block relative rounded-xl overflow-hidden aspect-[4/3] shadow-md hover:shadow-xl transition-shadow duration-300">
            <img src={`/images/cities/${city.slug}.jpg`} alt={locale === 'ja' ? city.name_ja : city.name} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <h3 class="text-white text-lg sm:text-xl font-bold drop-shadow-md">
                {locale === 'ja' ? city.name_ja : city.name}
