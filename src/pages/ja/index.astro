  { key: 'search.personal_time', value: 'personal' },
  { key: 'search.transit', value: 'transit' },
];

function getHotelName(hotel: any) {
  return locale === 'ja' && hotel.name_ja ? hotel.name_ja : hotel.name;
}

function getMinPrice(hotelId: number) {
  const plans = allPlans.get(hotelId) || [];
  if (plans.length === 0) return null;
  return Math.min(...plans.map((p: any) => p.price_usd));
}
