  <!-- Map Script (Leaflet) -->
  <script is:inline>
    (function() {
      function initMap() {
        var mapEl = document.getElementById('homepage-map');
        if (!mapEl) return;

        var hotelsEl = document.getElementById('map-hotels-data');
        var hotels = [];
        try { hotels = JSON.parse(hotelsEl ? hotelsEl.textContent : '[]'); } catch(e) { console.error('map hotels parse error', e); }

        // Load Leaflet CSS
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
        document.head.appendChild(link);

        // Load Leaflet JS
        var script = document.createElement('script');
        script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
        script.onload = function() {
          mapEl.innerHTML = '';
          var map = L.map('homepage-map', { scrollWheelZoom: false }).setView([13.75, 100.5], 3);
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
          }).addTo(map);

          hotels.forEach(function(h) {
            if (!h.latitude || !h.longitude) return;
            var marker = L.circleMarker([h.latitude, h.longitude], {
              radius: 7,
              fillColor: '#0d9488',
              color: '#fff',
              weight: 2,
              opacity: 1,
              fillOpacity: 0.9
            }).addTo(map);
            marker.bindPopup(
              '<a href="/ja/hotel/' + h.slug + '" style="font-weight:600;color:#0d9488">' + h.name + '</a>' +
              '<br><span style="font-size:12px;color:#6b7280">' + h.city + ', ' + h.country + '</span>' +
              (h.min_price ? '<br><span style="font-size:12px;font-weight:700">$' + h.min_price + '〜</span>' : '')
            );
          });
        };
        document.head.appendChild(script);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initMap);
      } else {
        initMap();
      }
    })();
  </script>

  <!-- Slideshow Script -->
  <script>
    (function() {
      const slides = [
        document.getElementById('hero-slide-0'),
        document.getElementById('hero-slide-1'),
        document.getElementById('hero-slide-2'),
      ];
      let current = 0;
      function loadSlide(el: HTMLElement | null) {
        if (el && (el as any).dataset?.bg && !el.style.backgroundImage) {
          el.style.backgroundImage = `url('${(el as any).dataset.bg}')`;
        }
      }
      setInterval(() => {
        const next = (current + 1) % 3;
        loadSlide(slides[next]);
        if (slides[current]) slides[current].style.opacity = '0';
        if (slides[next]) slides[next].style.opacity = '1';
        current = next;
      }, 4000);
    })();
  </script>

