  'Bangladesh': 'バングラデシュ', 'Russia': 'ロシア',
};
function getCountryNameJa(name: string): string { return countryNameJa[name] || name; }

// Apply aliases and merge hotel counts
const cityMap: Record<string, any> = {};
for (const city of allCities) {
  const canonicalName = cityAliases[city.city] || city.city;
  const normalizedCountry = (city.country || '').toLowerCase();
  const key = `${canonicalName}__${normalizedCountry}`;
  if (cityMap[key]) {
    cityMap[key].hotel_count = (cityMap[key].hotel_count || 0) + (city.hotel_count || 0);
  } else {
    cityMap[key] = { ...city, city: canonicalName };
  }
}
const mergedCities = Object.values(cityMap);

// Normalize country lookup (case-insensitive)
function getRegionForCountry(country: string): string | undefined {
  if (!country) return undefined;
  if (countryRegion[country]) return countryRegion[country];
  const titled = country.charAt(0).toUpperCase() + country.slice(1).toLowerCase();
  if (countryRegion[titled]) return countryRegion[titled];
  const lower = country.toLowerCase();
  for (const [key, val] of Object.entries(countryRegion)) {
    if (key.toLowerCase() === lower) return val;
  }
  return undefined;
}

// Group cities by region
const citiesByRegion: Record<string, any[]> = {};
for (const city of mergedCities) {
  let region = cityRegionOverride[city.city] || getRegionForCountry(city.country);
  if (!region) {
    for (const [country, r] of Object.entries(countryRegion)) {
      if (city.city?.includes(country) || city.country?.includes(country)) {
        region = r;
        break;
      }
    }
  }
  region = region || 'その他';
  if (!citiesByRegion[region]) citiesByRegion[region] = [];
  citiesByRegion[region].push(city);
}
// Sort each region's cities
for (const region of Object.keys(citiesByRegion)) {
  citiesByRegion[region].sort((a: any, b: any) => {
    const cmp = (a.country || '').localeCompare(b.country || '');
    if (cmp !== 0) return cmp;
    return b.hotel_count - a.hotel_count;
  });
}
const availableRegions = regionOrder.filter(r => citiesByRegion[r]?.length > 0);
// 'その他' は表示しない

// Pre-compute city data with images for JS dynamic rendering (non-default tabs)
const citiesDataForJS: Record<string, Array<{city: string; country: string; hotel_count: number; image: string; href: string}>> = {};
for (const [region, cities] of Object.entries(citiesByRegion)) {
  citiesDataForJS[region] = (cities as any[]).map((city) => ({
    city: getCityNameJa(city.city),
    country: getCountryNameJa(city.country),
    hotel_count: city.hotel_count,
    image: getCityImage(city.city),
    href: `/ja/search?city=${encodeURIComponent(city.city)}`
  }));
}

// Unique city count
const uniqueCityCount = new Set(mergedCities.map((c: any) => c.city)).size || 85;
