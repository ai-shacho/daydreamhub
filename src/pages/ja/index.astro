          '🏨 予約する — ' + slug.replace(/-/g, ' ').replace(/\b\w/g, function(c){ return c.toUpperCase(); }).slice(0,30) +
          '</button>';
      }).join('');

      // 外部ホテル: 電話代行予約ボタン（$7）
      var callBtns = externalHotels.map(function(h) {
        var safePhone = h.phone.replace(/'/g, '');
