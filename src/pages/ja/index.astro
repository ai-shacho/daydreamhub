              <select name="checkout_time" class="w-full rounded-lg px-3 py-2.5 text-sm bg-white text-gray-800 border border-gray-200 focus:outline-none focus:ring-2 focus:ring-amber-400">
                {['10:00','11:00','12:00','13:00','14:00','15:00','16:00','17:00','18:00','19:00','20:00','21:00','22:00'].map(t => (
                  <option value={t} selected={t === '18:00'}>{t}</option>
                ))}
              </select>
            </div>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
            <div>
              <label class="block text-xs text-gray-600 mb-1 font-semibold">人数</label>
              <select name="guests" class="w-full rounded-lg px-3 py-2.5 text-sm bg-white text-gray-800 border border-gray-200 focus:outline-none focus:ring-2 focus:ring-amber-400">
                {[1,2,3,4,5].map(n => <option value={n}>{n}名{n===5?'以上':''}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-xs text-gray-600 mb-1 font-semibold">予算</label>
              <select name="budget" class="w-full rounded-lg px-3 py-2.5 text-sm bg-white text-gray-800 border border-gray-200 focus:outline-none focus:ring-2 focus:ring-amber-400">
                <option value="">指定なし</option>
                <option value="budget">格安（$30以下）</option>
                <option value="mid">スタンダード（$30〜$100）</option>
                <option value="premium">プレミアム（$100以上）</option>
              </select>
            </div>
            <div class="flex items-end col-span-2 md:col-span-1">
              <button type="button" id="hero-search-btn-ja" onclick="window._heroAskAIJa()"
                class="w-full bg-amber-500 hover:bg-amber-400 text-gray-900 font-bold px-6 py-2.5 rounded-lg transition-colors text-sm flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                AIに聞く
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Category Sections -->
  {[
    { title: t('section.workspace', locale), hotels: workspaceHotels, link: localePath('/search?speciality=work', locale) },
    { title: t('section.layover', locale), hotels: layoverHotels, link: localePath('/search?speciality=transit', locale) },
    { title: t('section.couple', locale), hotels: coupleHotels, link: localePath('/search?speciality=couple', locale) },
    { title: t('section.luxury', locale), hotels: luxuryHotels, link: localePath('/search?speciality=luxury', locale) },
    { title: t('section.experience', locale), hotels: experienceHotels, link: localePath('/search?speciality=daycation', locale) },
  ].map(section => section.hotels.length > 0 && (
    <section class="py-10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl sm:text-2xl font-bold text-gray-800">{section.title}</h2>
          <a href={section.link} class="text-sm text-[#45A2C1] hover:underline font-medium">{t('common.view_more', locale)}</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {section.hotels.map((hotel: any) => {
            const minPrice = getMinPrice(hotel.id);
            return (
              <a href={localePath(`/hotel/${hotel.slug}`, locale)} class="group bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden">
                <div class="aspect-[4/3] overflow-hidden bg-gray-100">
                  <img src={hotel.thumbnail_url || '/images/placeholder-hotel.jpg'} alt={getHotelName(hotel)} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                </div>
                <div class="p-4">
                  <h3 class="font-semibold text-gray-900 text-sm mb-1 line-clamp-1">{getHotelName(hotel)}</h3>
                  <p class="text-xs text-gray-500 mb-2">{hotel.city}, {hotel.country}</p>
                  {minPrice && <p class="text-sm font-bold text-[#45A2C1]">{t('hotel.from', locale)} ${minPrice} {t('hotel.usd', locale)}</p>}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  ))}

  <!-- Cities Section -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-6">
        {t('section.by_city', locale)}
