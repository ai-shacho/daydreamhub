import Layout from '../../layouts/Layout.astro';
import { getLocale, t, localePath } from '../../lib/i18n';

const locale = getLocale(Astro.url);

// AIチャット用: DB登録都市一覧取得
let allCities: any[] = [];
try {
  const runtime2 = (Astro.locals as any).runtime;
  const db2 = runtime2?.env?.DB;
  if (db2) {
    const cityResult = await db2.prepare(
      `SELECT DISTINCT h.city, h.country, COUNT(*) as hotel_count
       FROM hotels h WHERE h.is_active = 1 GROUP BY h.city ORDER BY hotel_count DESC LIMIT 100`
    ).all();
    allCities = cityResult?.results ?? [];
  }
} catch (e) {}

let workspaceHotels: any[] = [];
let layoverHotels: any[] = [];
let coupleHotels: any[] = [];
let luxuryHotels: any[] = [];
let experienceHotels: any[] = [];
let allPlans = new Map<number, any[]>();
let dbAvailable = false;

try {
  const runtime = (Astro.locals as any).runtime;
  const db = runtime?.env?.DB;
  if (db) {
    dbAvailable = true;
    async function fetchByCategory(db: any, categoryKey: string, limit = 4) {
      const result = await db.prepare(
        `SELECT h.id, h.name, h.name_ja, h.slug, h.city, h.country, h.thumbnail_url, h.categories, h.property_type
         FROM hotels h
         WHERE h.categories LIKE ? AND h.is_active = 1
         LIMIT ?`
      ).bind(`%${categoryKey}%`, limit).all();
      return result?.results || [];
    }
    [workspaceHotels, layoverHotels, coupleHotels, luxuryHotels, experienceHotels] = await Promise.all([
      fetchByCategory(db, 'workspace'),
      fetchByCategory(db, 'transit'),
      fetchByCategory(db, 'couple'),
      fetchByCategory(db, 'luxury'),
      fetchByCategory(db, 'daycation'),
    ]);
    const allHotels = [...workspaceHotels, ...layoverHotels, ...coupleHotels, ...luxuryHotels, ...experienceHotels];
    const hotelIds = [...new Set(allHotels.map((h: any) => h.id))];
    if (hotelIds.length > 0) {
      const placeholders = hotelIds.map(() => '?').join(',');
      const plansResult = await db.prepare(
        `SELECT * FROM plans WHERE hotel_id IN (${placeholders}) AND is_active = 1`
      ).bind(...hotelIds).all();
      for (const plan of plansResult?.results || []) {
        if (!allPlans.has(plan.hotel_id)) {
          allPlans.set(plan.hotel_id, []);
        }
        allPlans.get(plan.hotel_id)!.push(plan);
      }
    }
  }
} catch (e) {
  dbAvailable = false;
}

