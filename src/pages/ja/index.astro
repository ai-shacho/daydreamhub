        var container = document.getElementById('region-panels-container');

        // Create panel on demand if not yet rendered
        var existingPanel = container.querySelector('[data-region-panel="' + region + '"]');
        if (!existingPanel) {
          var cities = (window.__CITIES_DATA__ || {})[region] || [];
          var panel = document.createElement('div');
          panel.setAttribute('data-region-panel', region);
          var grid = document.createElement('div');
          grid.className = 'grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4';
          cities.forEach(function(city) {
            var a = document.createElement('a');
            a.href = city.href;
            a.className = 'group relative rounded-xl overflow-hidden aspect-[4/3] shadow-sm hover:shadow-lg transition-shadow';
            a.innerHTML =
              '<img src="' + city.image + '" alt="' + city.city.replace(/"/g, '&quot;') + '" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />' +
