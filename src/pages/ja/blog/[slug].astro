---
import Layout from '../../../layouts/Layout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getLocale, t, localePath } from '../../../lib/i18n';

const locale = getLocale(Astro.url);
const { slug } = Astro.params;

let post: any = null;
let relatedPosts: any[] = [];
let dbAvailable = false;

try {
  const runtime = (Astro.locals as any).runtime;
  const db = runtime?.env?.DB;
  if (db) {
    dbAvailable = true;
    const result = await db.prepare(
      `SELECT id, title, title_ja, slug, excerpt, excerpt_ja, content, content_ja, city, thumbnail_url, published_at
       FROM blog_posts
       WHERE slug = ?
       LIMIT 1`
    ).bind(slug).first();
    if (result) {
      post = result;
      if (post.content) {
        post.content = post.content.replace(/<div class=['"]rp4wp-related-posts['"][\s\S]*?<\/div>\s*<\/ul>\s*<\/div>/gi, '');
      }
      if (post.content_ja) {
        post.content_ja = post.content_ja.replace(/<div class=['"]rp4wp-related-posts['"][\s\S]*?<\/div>\s*<\/ul>\s*<\/div>/gi, '');
      }
      if (post.city) {
        const relatedResult = await db.prepare(
          `SELECT id, title, title_ja, slug, excerpt, city, thumbnail_url, published_at
           FROM blog_posts
           WHERE city = ? AND slug != ?
           ORDER BY published_at DESC
           LIMIT 3`
        ).bind(post.city, slug).all();
        relatedPosts = relatedResult?.results || [];
      }
    }
  }
} catch (e) {
  dbAvailable = false;
}

if (!dbAvailable) {
  const samplePosts = [
    {
      id: 1, title: 'Best Day-Use Hotels in Bangkok for Remote Work',
      title_ja: 'バンコクでリモートワークに最適なデイユースホテル',
      slug: 'best-dayuse-hotels-bangkok-remote-work',
      excerpt: 'Discover the top hotels in Bangkok that offer comfortable workspaces.',
      excerpt_ja: 'バンコクでリモートワークに最適な、快適なワークスペースと高速Wi-Fiを備えたホテルをご紹介。',
      content: '<h2>Why Bangkok is Perfect for Remote Work</h2><p>Bangkok has become one of the top destinations for digital nomads.</p>',
      content_ja: '<h2>バンコクがリモートワークに最適な理由</h2><p>バンコクは東南アジアでデジタルノマドやリモートワーカーにとってトップの目的地の一つになっています。</p>',
      city: 'Bangkok', thumbnail_url: '', published_at: '2025-01-15T09:00:00Z'
    },
    {
      id: 2, title: 'Singapore Airport Transit Hotels: A Complete Guide',
      title_ja: 'シンガポール空港トランジットホテル完全ガイド',
      slug: 'singapore-airport-transit-hotels-guide',
      excerpt: 'Everything you need to know about transit hotels near Changi Airport.',
      excerpt_ja: 'チャンギ空港近くのトランジットホテルについて、料金・設備・予約のコツまで徹底解説。',
      content: '<h2>Changi Airport Transit Hotels</h2><p>Changi Airport offers several rest options within the transit area.</p>',
      content_ja: '<h2>シンガポール空港トランジットホテル</h2><p>チャンギ空港のトランジットエリア内にはいくつかの休憩オプションがあります。</p>',
      city: 'Singapore', thumbnail_url: '', published_at: '2025-01-10T09:00:00Z'
    },
    {
      id: 3, title: 'Romantic Day-Use Hotels in Bali for Couples',
      title_ja: 'バリ島カップルにおすすめのデイユースホテル',
      slug: 'romantic-dayuse-hotels-bali-couples',
      excerpt: 'Looking for a romantic daytime escape in Bali?',
      excerpt_ja: 'バリ島でロマンチックなひとときを。プライバシーと贅沢を求めるカップルにぴったりのデイユースホテル＆ヴィラを厳選しました。',
      content: '<h2>Best Romantic Day-Use Hotels in Bali</h2><p>Bali is the ultimate romantic destination.</p>',
      content_ja: '<h2>バリ島のロマンチックなデイユースホテル</h2><p>バリ島は究極のロマンチックな旅行先です。</p>',
      city: 'Bali', thumbnail_url: '', published_at: '2025-01-05T09:00:00Z'
    },
    {
      id: 4, title: 'Top Luxury Day-Use Hotels in Kuala Lumpur',
      title_ja: 'クアラルンプールのラグジュアリーデイユースホテルTOP',
      slug: 'luxury-dayuse-hotels-kuala-lumpur',
      excerpt: 'Experience five-star luxury without the overnight stay.',
      excerpt_ja: '宿泊なしで五つ星の贅沢を。クアラルンプールのトップホテルが提供するプレミアムデイユースプランをご紹介。',
      content: '<h2>Luxury Day-Use in Kuala Lumpur</h2><p>KL offers affordable luxury hotel experiences.</p>',
      content_ja: '<h2>クアラルンプールのラグジュアリーデイユース</h2><p>クアラルンプールでは手頃な価格で高級ホテル体験が可能です。</p>',
      city: 'Kuala Lumpur', thumbnail_url: '', published_at: '2024-12-28T09:00:00Z'
    },
    {
      id: 5, title: 'How to Book Day-Use Hotels: A Beginner Guide',
      title_ja: 'デイユースホテルの予約方法：初心者ガイド',
      slug: 'how-to-book-dayuse-hotels-beginner-guide',
      excerpt: 'New to day-use hotel booking? This guide covers everything.',
      excerpt_ja: 'デイユースホテルが初めての方へ。ホテルの選び方から短時間滞在を最大限楽しむコツまで解説します。',
      content: '<h2>What is a Day-Use Hotel?</h2><p>A day-use hotel allows you to book a room for a few hours during the day.</p>',
      content_ja: '<h2>デイユースホテルとは？</h2><p>デイユースホテルとは、日中数時間だけ部屋を予約できるホテルのことです。</p>',
      city: '', thumbnail_url: '', published_at: '2024-12-20T09:00:00Z'
    },
    {
      id: 6, title: 'Hong Kong Daycation: Pool & Spa Day Passes',
      title_ja: '香港デイケーション：プール＆スパのデイパス',
      slug: 'hong-kong-daycation-pool-spa-day-passes',
      excerpt: 'Enjoy a refreshing daycation in Hong Kong.',
      excerpt_ja: '香港のトップホテルでプール＆スパのデイパスを利用して、街を離れずに週末リフレッシュ。',
      content: '<h2>Daycation in Hong Kong</h2><p>Top hotels offer incredible pool and spa day passes.</p>',
      content_ja: '<h2>香港でのデイケーション</h2><p>トップホテルがプールとスパの素晴らしいデイパスを提供しています。</p>',
      city: 'Hong Kong', thumbnail_url: '', published_at: '2024-12-15T09:00:00Z'
    },
  ];
  post = samplePosts.find(p => p.slug === slug) || null;
  if (post && post.city) {
    relatedPosts = samplePosts.filter(p => p.city === post.city && p.slug !== post.slug).slice(0, 3);
  }
}

if (!post) {
  return Astro.redirect(localePath('/blog', locale), 302);
}

const displayTitle = post ? (locale === 'ja' && post.title_ja ? post.title_ja : post.title) : '';
const displayContent = post ? (locale === 'ja' && post.content_ja ? post.content_ja : post.content) : '';
const imageUrl = post?.thumbnail_url || '/images/placeholder-hotel.jpg';
const formattedDate = post ? new Date(post.published_at).toLocaleDateString(
  locale === 'ja' ? 'ja-JP' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
) : '';
---

<Layout title={post ? displayTitle : t('blog.not_found', locale)} description={post ? (post.excerpt_ja || post.excerpt || '') : ''}>
  {post ? (
    <article class="overflow-x-hidden">
      <div class="w-full aspect-[21/9] max-h-[400px] overflow-hidden bg-gray-100">
        <img src={imageUrl} alt={displayTitle} class="w-full h-full object-cover" />
      </div>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
        <nav class="mb-6 text-sm text-gray-500">
          <a href={localePath('/', locale)} class="hover:text-[#45A2C1] transition-colors">{t('breadcrumb.home', locale)}</a>
          <span class="mx-2">/</span>
          <a href={localePath('/blog', locale)} class="hover:text-[#45A2C1] transition-colors">{t('blog.title', locale)}</a>
          <span class="mx-2">/</span>
          <span class="text-gray-700">{displayTitle}</span>
        </nav>
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">{displayTitle}</h1>
        <div class="flex items-center gap-3 mb-8 text-sm text-gray-500">
          <time datetime={post.published_at}>{t('blog.published_on', locale)}: {formattedDate}</time>
          {post.city && (
            <a href={localePath(`/blog?city=${encodeURIComponent(post.city)}`, locale)} class="bg-blue-50 text-blue-600 rounded px-2.5 py-0.5 hover:bg-blue-100 transition-colors font-medium">
              {post.city}
            </a>
          )}
        </div>
        {displayContent && (
          <div class="prose prose-base sm:prose-lg max-w-none prose-headings:text-gray-800 prose-p:text-gray-600 prose-a:text-[#45A2C1] prose-a:no-underline hover:prose-a:underline prose-li:text-gray-600 prose-img:rounded-lg wp-blog-content overflow-x-hidden" set:html={displayContent} />
        )}

        <!-- GA4 internal_link_click tracking + locale-aware link fix for hotel links -->
        <script is:inline>
          (function() {
            function getLinkType(url) {
              if (url.includes('/search')) return 'search';
              if (url.includes('/city/')) return 'city';
              if (url.includes('/hotel/')) return 'hotel';
              if (url.includes('/booking/')) return 'booking';
              if (url.includes('/blog/')) return 'blog';
              return 'other_internal';
            }

            function fixInternalLinks() {
              const isJa = window.location.pathname.startsWith('/ja/');
              const links = document.querySelectorAll('article .wp-blog-content a[href^="/hotel/"]');
              links.forEach(function(link) {
                const href = link.getAttribute('href');
                if (href && isJa && !href.startsWith('/ja/')) {
                  link.setAttribute('href', '/ja' + href);
                }
              });
            }

            function attachTracking() {
              // Use event delegation for reliability with View Transitions / SPA nav
              const container = document.querySelector('article .wp-blog-content');
              if (!container) return;

              container.addEventListener('click', function(e) {
                const link = e.target.closest('a[href]');
                if (!link) return;
                const href = link.getAttribute('href');
                if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
                if (href.startsWith('http') && !href.includes(window.location.hostname)) return;

                const linkUrl = link.href;
                const linkText = (link.textContent || '').trim();
                const sourcePage = window.location.pathname;
                const sourceTitle = document.title;
                const linkType = getLinkType(linkUrl);

                if (typeof gtag === 'function') {
                  gtag('event', 'internal_link_click', {
                    link_url: linkUrl,
                    link_text: linkText,
                    source_page: sourcePage,
                    source_title: sourceTitle,
                    link_type: linkType,
                    transport_type: 'beacon'
                  });
                }
              }, true);
            }

            function init() {
              fixInternalLinks();
              attachTracking();
            }

            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', init);
            } else {
              init();
            }

            // Support Astro View Transitions
            document.addEventListener('astro:page-load', init);
          })();
        </script>

        <div class="mt-10 pt-6 border-t border-gray-200">
          <a href={localePath('/blog', locale)} class="inline-flex items-center text-sm text-[#45A2C1] hover:text-[#3891af] font-medium transition-colors">
            <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
            </svg>
            {t('blog.back_to_blog', locale)}
          </a>
        </div>

      </div>
    </article>
  ) : (
    <div class="text-center py-20">
      <svg class="w-20 h-20 mx-auto text-gray-300 mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"></path>
      </svg>
      <h1 class="text-2xl font-bold text-gray-600 mb-3">{t('blog.not_found', locale)}</h1>
      <p class="text-gray-400 mb-6 max-w-md mx-auto">{t('blog.not_found_desc', locale)}</p>
      <a href={localePath('/blog', locale)} class="inline-flex items-center px-5 py-2.5 bg-[#45A2C1] text-white rounded-lg text-sm font-medium hover:bg-[#3891af] transition-colors">
        {t('blog.back_to_blog', locale)}
      </a>
    </div>
  )}
</Layout>

<style is:global>
  .wp-blog-content img,
  .wp-blog-content video,
  .wp-blog-content iframe,
  .wp-blog-content embed,
  .wp-blog-content object {
    max-width: 100%;
    height: auto;
  }
  .wp-blog-content table {
    display: block;
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .wp-blog-content pre {
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-all;
  }
  /* モバイル向け: 自然な位置で折り返し、英単語はハイフン分割 */
  @media (max-width: 639px) {
    .wp-blog-content p,
    .wp-blog-content li,
    .wp-blog-content h1,
    .wp-blog-content h2,
    .wp-blog-content h3,
    .wp-blog-content h4 {
      overflow-wrap: break-word;
      word-break: normal;
      hyphens: auto;
    }
  }
</style>
