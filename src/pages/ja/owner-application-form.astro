<script is:inline>
// 国番号「その他」切替
function setupPhoneCodeOther(selectId, manualId) {
  var sel = document.getElementById(selectId);
  var manual = document.getElementById(manualId);
  if (!sel || !manual) return;
  sel.addEventListener('change', function() {
    if (sel.value === 'other') {
      manual.classList.remove('hidden');
      manual.required = true;
      manual.focus();
      sel.classList.add('hidden');
    }
  });
  manual.addEventListener('blur', function() {
    if (!manual.value.trim()) {
      manual.classList.add('hidden');
      manual.required = false;
      sel.classList.remove('hidden');
      sel.value = '+81';
    }
  });
}
setupPhoneCodeOther('hotel_phone_code', 'hotel_phone_code_manual');
setupPhoneCodeOther('contact_phone_code', 'contact_phone_code_manual');

// VCCトグル
document.getElementById('payment_method')?.addEventListener('change', function () {
  const isVCC = this.value === 'VCC';
  document.getElementById('payment-account-fields').style.display = isVCC ? 'none' : '';
  document.getElementById('vcc-notice').className = isVCC
    ? 'block bg-teal-50 border border-teal-200 text-teal-700 text-sm rounded-lg px-4 py-3'
    : 'hidden bg-teal-50 border border-teal-200 text-teal-700 text-sm rounded-lg px-4 py-3';
});

document.getElementById('owner-application-form')?.addEventListener('submit', async function (e) {
  e.preventDefault();
  const btn = document.getElementById('submit-btn');
  const errEl = document.getElementById('form-error');
  const successEl = document.getElementById('form-success');

  errEl.className = 'hidden';
  successEl.className = 'hidden';

  // 国番号 + 番号を結合
  function getPhoneCode(selectId, manualId) {
    var sel = document.getElementById(selectId);
    var manual = document.getElementById(manualId);
    if (sel && sel.value === 'other' || (sel && sel.classList.contains('hidden'))) {
      return manual?.value?.trim() || '';
    }
    return sel?.value || '';
  }
  const hotelCode = getPhoneCode('hotel_phone_code', 'hotel_phone_code_manual');
  const hotelNum = document.getElementById('hotel_phone_number')?.value?.trim() || '';
  document.getElementById('hotel_phone').value = hotelNum ? hotelCode + hotelNum : '';

  const contactCode = getPhoneCode('contact_phone_code', 'contact_phone_code_manual');
  const contactNum = document.getElementById('contact_phone_number')?.value?.trim() || '';
  document.getElementById('contact_phone').value = contactNum ? contactCode + contactNum : '';

  if (!hotelNum) { errEl.className = 'block bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3'; errEl.textContent = '施設電話番号を入力してください。'; return; }
  if (!contactNum) { errEl.className = 'block bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3'; errEl.textContent = '担当者電話番号を入力してください。'; return; }

  btn.disabled = true;
  btn.textContent = '送信中...';

  const fields = [
    'hotel_name', 'booking_email', 'hotel_phone', 'site_url', 'management_company',
    'contact_name', 'contact_email', 'contact_phone', 'contact_method',
    'messenger_url', 'whatsapp_url', 'line_url', 'other_sns_url',
    'payment_method', 'paypal_account', 'wise_account', 'payoneer_account',
  ];
  const body = {};
  for (const f of fields) {
    body[f] = document.getElementById(f)?.value || '';
  }

  try {
    const res = await fetch('/api/owner-application', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json();
    if (res.ok && data.success) {
      successEl.className = 'block bg-green-50 border border-green-200 text-green-700 text-sm rounded-lg px-4 py-3';
      successEl.textContent = '✅ 申込を受け付けました。近日中にご連絡いたします。';
      document.getElementById('owner-application-form').reset();
    } else {
      errEl.className = 'block bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3';
      errEl.textContent = data.error || '送信に失敗しました。もう一度お試しください。';
    }
  } catch {
    errEl.className = 'block bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3';
    errEl.textContent = '接続エラーが発生しました。もう一度お試しください。';
  } finally {
    btn.disabled = false;
    btn.textContent = '申込を送信する';
  }
});
</script>
