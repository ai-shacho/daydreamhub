---
import Layout from '../../layouts/Layout.astro';
import { getLocale } from '../../lib/i18n';

const locale = getLocale(Astro.url);

const steps = [
  { number: 1, title: 'お申し込み', description: '施設情報を記載した申込フォームを送信してください。' },
  { number: 2, title: '本人確認', description: '確認のための身分証明書を提出してください。' },
  { number: 3, title: '登録完了', description: '承認後、メールにてログイン情報をお届けします。' },
  { number: 4, title: '掲載開始', description: 'ログインしてお部屋を掲載し、ゲストをお迎えしましょう。' },
];
---

<Layout title="施設オーナー様へ" description="DayDreamHubにホテルを掲載して、アジア各地の旅行者にリーチしましょう">
  <!-- Hero -->
  <section class="bg-[#EBF8FC] py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-800 mb-6">
        あなたの施設とサービスを世界へ！
      </h1>
      <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
        DayDreamHubに参加して、アジア各地からデイユースを求める旅行者とつながりましょう。
      </p>
      <a href="#register" class="btn-primary text-lg px-10 py-4 inline-block font-semibold">
        お部屋を掲載する
      </a>
    </div>
  </section>

  <!-- About -->
  <section class="py-12 sm:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-6 text-center">
        DayDreamHubについて
      </h2>
      <p class="text-gray-600 leading-relaxed text-center max-w-2xl mx-auto">
        DayDreamHubは、アジア初のデイユース（日帰り利用）に特化したオンライン旅行代理店（OTA）です。
        トランジット、ビジネス、パーソナルブレイク、デイケーション体験など、
        短時間の宿泊を求める旅行者と施設オーナー様をつなぎます。
      </p>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-12 sm:py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-8 text-center">
        DayDreamHubに掲載するメリット
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100 text-center">
          <div class="w-14 h-14 bg-[#EBF8FC] rounded-full flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-[#45A2C1]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-800 mb-3">掲載料無料</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            初期費用は一切かかりません。予約が成立した場合のみ手数料をいただきます。収益が発生するまで費用はゼロです。
          </p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100 text-center">
          <div class="w-14 h-14 bg-[#EBF8FC] rounded-full flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-[#45A2C1]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-800 mb-3">オープンな掲載方針</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            法人・個人の施設オーナー様どなたでも歓迎です。ホテルチェーンから1室のみの運営まで、お気軽にご参加ください。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Steps -->
  <section class="py-12 sm:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-10 text-center">
        ご登録の流れ
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {steps.map(step => (
          <div class="text-center">
            <div class="w-14 h-14 rounded-full bg-[#45A2C1] text-white text-xl font-bold flex items-center justify-center mx-auto mb-4">
              {step.number}
            </div>
            <h3 class="font-semibold text-gray-800 mb-2">{step.title}</h3>
            <p class="text-gray-500 text-sm">{step.description}</p>
          </div>
        ))}
      </div>
      <div class="hidden lg:block relative -mt-[7.5rem] mb-[5.5rem] mx-auto" style="width: calc(100% - 8rem);">
        <div class="border-t-2 border-dashed border-gray-200"></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="register" class="py-16 sm:py-20 bg-[#EBF8FC]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-4">
        DayDreamHubに施設を掲載して、世界中からゲストをお迎えしましょう！
      </h2>
      <p class="text-gray-600 mb-8 max-w-xl mx-auto">
        今すぐ始めて、空室を収益に変えましょう。
      </p>
      <a href="mailto:customer@daydreamhub.com?subject=施設掲載のお問い合わせ" class="btn-primary text-lg px-10 py-4 inline-block font-semibold">
        お部屋を掲載する
      </a>
      <p class="mt-6 text-gray-500 text-sm">
        お電話でのお問い合わせ：
        <a href="tel:+81-90-2202-8701" class="text-[#45A2C1] hover:underline font-medium">
          +81-90-2202-8701
        </a>
      </p>
    </div>
  </section>
</Layout>
