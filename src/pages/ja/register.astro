---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="新規登録 - DayDreamHub" description="DayDreamHubアカウントを作成してデイユースホテルを予約しましょう。">
  <div class="min-h-[80vh] flex items-center justify-center px-4 py-12 bg-slate-50">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/ja/" class="inline-flex items-center gap-2 text-2xl font-bold text-teal-700">
          <svg class="w-9 h-9" viewBox="0 0 32 32" fill="none">
            <circle cx="16" cy="16" r="14" fill="#f59e0b"/>
            <path d="M10 20 Q16 10 22 20" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            <circle cx="16" cy="13" r="3" fill="white"/>
          </svg>
          DayDreamHub
        </a>
        <p class="text-slate-500 text-sm mt-2">アカウントを作成する</p>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <form id="register-form" class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="first-name" class="block text-sm font-medium text-slate-700 mb-1.5">名<span class="text-red-500 ml-0.5">*</span></label>
              <input id="first-name" name="first_name" type="text" required placeholder="太郎"
                class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
              <p id="err-first-name" class="hidden mt-1 text-xs text-red-500"></p>
            </div>
            <div>
              <label for="last-name" class="block text-sm font-medium text-slate-700 mb-1.5">姓<span class="text-red-500 ml-0.5">*</span></label>
              <input id="last-name" name="last_name" type="text" required placeholder="山田"
                class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
              <p id="err-last-name" class="hidden mt-1 text-xs text-red-500"></p>
            </div>
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">メールアドレス<span class="text-red-500 ml-0.5">*</span></label>
            <input id="email" name="email" type="email" required autocomplete="email" placeholder="you@example.com"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
            <p id="err-email" class="hidden mt-1 text-xs text-red-500"></p>
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-slate-700 mb-1.5">電話番号（任意）</label>
            <div class="flex">
              <select id="phone-country" name="phone_country"
                class="flex-shrink-0 px-2 py-2.5 border border-r-0 border-slate-300 rounded-l-xl text-sm bg-white focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none appearance-none cursor-pointer">
                <option value="+1" data-flag="🇺🇸">🇺🇸 +1</option>
                <option value="+81" data-flag="🇯🇵" selected>🇯🇵 +81</option>
                <option value="+44" data-flag="🇬🇧">🇬🇧 +44</option>
                <option value="+61" data-flag="🇦🇺">🇦🇺 +61</option>
                <option value="+49" data-flag="🇩🇪">🇩🇪 +49</option>
                <option value="+33" data-flag="🇫🇷">🇫🇷 +33</option>
                <option value="+86" data-flag="🇨🇳">🇨🇳 +86</option>
                <option value="+82" data-flag="🇰🇷">🇰🇷 +82</option>
                <option value="+66" data-flag="🇹🇭">🇹🇭 +66</option>
                <option value="+63" data-flag="🇵🇭">🇵🇭 +63</option>
                <option value="+60" data-flag="🇲🇾">🇲🇾 +60</option>
                <option value="+62" data-flag="🇮🇩">🇮🇩 +62</option>
                <option value="+65" data-flag="🇸🇬">🇸🇬 +65</option>
                <option value="+84" data-flag="🇻🇳">🇻🇳 +84</option>
                <option value="+91" data-flag="🇮🇳">🇮🇳 +91</option>
                <option value="+971" data-flag="🇦🇪">🇦🇪 +971</option>
                <option value="+7" data-flag="🇷🇺">🇷🇺 +7</option>
                <option value="+55" data-flag="🇧🇷">🇧🇷 +55</option>
                <option value="+52" data-flag="🇲🇽">🇲🇽 +52</option>
              </select>
              <input id="phone" name="phone" type="tel" placeholder="90 1234 5678"
                class="flex-1 min-w-0 px-4 py-2.5 border border-slate-300 rounded-r-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
            </div>
            <p id="err-phone" class="hidden mt-1 text-xs text-red-500"></p>
          </div>
          <div>
            <label for="password" class="block text-sm font-medium text-slate-700 mb-1.5">パスワード<span class="text-red-500 ml-0.5">*</span></label>
            <input id="password" name="password" type="password" required autocomplete="new-password" placeholder="8文字以上"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
            <p id="err-password" class="hidden mt-1 text-xs text-red-500"></p>
          </div>
          <div>
            <label for="password2" class="block text-sm font-medium text-slate-700 mb-1.5">パスワード（確認）<span class="text-red-500 ml-0.5">*</span></label>
            <input id="password2" name="password2" type="password" required placeholder="パスワードを再入力"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none transition-all" />
            <p id="err-password2" class="hidden mt-1 text-xs text-red-500"></p>
          </div>
          <div class="flex items-start gap-2">
            <input id="agree" name="agree" type="checkbox" required class="mt-0.5 rounded" />
            <label for="agree" class="text-sm text-slate-600">
              <a href="/ja/privacy-policy" class="text-teal-600 hover:underline">プライバシーポリシー</a>と<a href="/ja/terms" class="text-teal-600 hover:underline">利用規約</a>に同意する<span class="text-red-500 ml-0.5">*</span>
            </label>
          </div>
          <p id="err-agree" class="hidden mt-1 text-xs text-red-500"></p>
          <div id="register-error" class="hidden bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3"></div>
          <div id="register-success" class="hidden bg-green-50 border border-green-200 text-green-700 text-sm rounded-lg px-4 py-3"></div>
          <button type="submit" id="register-btn"
            class="w-full bg-teal-600 hover:bg-teal-700 text-white font-semibold py-3 rounded-xl transition-colors">
            アカウントを作成する
          </button>
        </form>

        <div class="mt-6 text-center">
          <p class="text-sm text-slate-500">
            すでにアカウントをお持ちの方は
            <a href="/ja/login" class="text-teal-600 font-medium hover:underline ml-1">ログイン</a>
          </p>
        </div>
      </div>

      <!-- Hotel Owner CTA -->
      <div class="mt-6 bg-amber-50 border border-amber-200 rounded-2xl p-6">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-10 h-10 bg-amber-100 rounded-xl flex items-center justify-center text-xl">
            🏨
          </div>
          <div class="flex-1">
            <h3 class="text-sm font-semibold text-slate-800">ホテル・施設オーナー様へ</h3>
            <p class="mt-1 text-xs text-slate-600 leading-relaxed">
              こちらはゲスト向けの登録ページです。DayDreamHubに施設を掲載をご希望の場合は、オーナー申込フォームからお申し込みください。
            </p>
            <a
              href="/ja/owner-application-form"
              class="inline-flex items-center gap-1.5 mt-3 px-4 py-2 bg-amber-500 hover:bg-amber-600 text-white text-xs font-semibold rounded-lg transition-colors"
            >
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
              施設オーナーとして申し込む
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>

<script is:inline>
(function() {
  function showError(fieldId, message) {
    var errEl = document.getElementById('err-' + fieldId);
    var inputEl = document.getElementById(fieldId);
    if (errEl) {
      errEl.textContent = message;
      errEl.classList.remove('hidden');
    }
    if (inputEl && inputEl.type !== 'checkbox') {
      inputEl.classList.add('border-red-400');
      inputEl.classList.remove('border-slate-300');
    }
    if (inputEl) {
      inputEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }

  function clearError(fieldId) {
    var errEl = document.getElementById('err-' + fieldId);
    var inputEl = document.getElementById(fieldId);
    if (errEl) {
      errEl.textContent = '';
      errEl.classList.add('hidden');
    }
    if (inputEl && inputEl.type !== 'checkbox') {
      inputEl.classList.remove('border-red-400');
      inputEl.classList.add('border-slate-300');
    }
  }

  // Attach input listeners for clearing errors
  ['first-name', 'last-name', 'email', 'phone', 'password', 'password2'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) {
      el.addEventListener('input', function() { clearError(id); });
    }
  });
  var agreeEl = document.getElementById('agree');
  if (agreeEl) {
    agreeEl.addEventListener('change', function() { clearError('agree'); });
  }

  document.getElementById('register-form')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn = document.getElementById('register-btn');
    var err = document.getElementById('register-error');
    var success = document.getElementById('register-success');

    // Clear all field errors
    ['first-name', 'last-name', 'email', 'phone', 'password', 'password2', 'agree'].forEach(clearError);
    err.className = 'hidden';

    var firstName = document.getElementById('first-name').value.trim();
    var lastName = document.getElementById('last-name').value.trim();
    var email = document.getElementById('email').value.trim();
    var phoneVal = document.getElementById('phone').value.trim();
    var password = document.getElementById('password').value;
    var password2 = document.getElementById('password2').value;
    var agree = document.getElementById('agree').checked;

    // Validate fields in order, stop at first error
    if (!firstName) {
      showError('first-name', '名前を入力してください');
      return;
    }
    if (!lastName) {
      showError('last-name', '名字を入力してください');
      return;
    }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError('email', '有効なメールアドレスを入力してください');
      return;
    }
    if (phoneVal) {
      if (!/^[\d\s\-\(\)]+$/.test(phoneVal)) {
        showError('phone', '電話番号は数字のみ入力してください');
        return;
      }
      if (phoneVal.replace(/\D/g, '').length < 6) {
        showError('phone', '有効な電話番号を入力してください');
        return;
      }
    }
    if (password.length < 8) {
      showError('password', 'パスワードは8文字以上にしてください');
      return;
    }
    if (password !== password2) {
      showError('password2', 'パスワードが一致しません');
      return;
    }
    if (!agree) {
      showError('agree', '利用規約に同意してください');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'アカウント作成中...';

    try {
      var res = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          first_name: firstName,
          last_name: lastName,
          email: email,
          phone: document.getElementById('phone-country').value + phoneVal,
          password: password,
        }),
      });
      if (res.ok) {
        success.className = 'block bg-green-50 border border-green-200 text-green-700 text-sm rounded-lg px-4 py-3';
        success.textContent = '✅ アカウントを作成しました！リダイレクト中...';
        setTimeout(function() { window.location.href = '/ja/'; }, 1500);
      } else {
        var data = await res.json();
        err.className = 'block bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3';
        err.textContent = data.error || '登録に失敗しました。もう一度お試しください。';
      }
    } catch(ex) {
      err.className = 'block bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3';
      err.textContent = '接続エラーが発生しました。もう一度お試しください。';
    } finally {
      btn.disabled = false;
      btn.textContent = 'アカウントを作成する';
    }
  });
})();
</script>
