---
import Layout from '../../layouts/Layout.astro';
import { formatDisplayDate } from '../../lib/dateFormat';

async function verifyJWT(token: string, secret: string): Promise<Record<string, any> | null> {
  try {
    const parts = token.split('.');
    if (parts.length !== 3) return null;
    const [header, body, signature] = parts;
    const key = await crypto.subtle.importKey(
      'raw', new TextEncoder().encode(secret),
      { name: 'HMAC', hash: 'SHA-256' }, false, ['verify']
    );
    const sigBytes = Uint8Array.from(
      atob(signature.replace(/-/g, '+').replace(/_/g, '/')), c => c.charCodeAt(0)
    );
    const valid = await crypto.subtle.verify('HMAC', key, sigBytes, new TextEncoder().encode(`${header}.${body}`));
    if (!valid) return null;
    const payload = JSON.parse(atob(body));
    if (payload.exp && payload.exp < Math.floor(Date.now() / 1000)) return null;
    return payload;
  } catch { return null; }
}

const env = (Astro.locals as any).runtime?.env;
const DB = env?.DB;
const jwtSecret = env?.JWT_SECRET || 'ddh-secret-2025';
const cookieHeader = Astro.request.headers.get('cookie') || '';
const tokenMatch = cookieHeader.match(/ddh_token=([^;]+)/);
const authPayload = tokenMatch ? await verifyJWT(tokenMatch[1], jwtSecret) : null;
const currentUser = authPayload
  ? { id: authPayload.sub, name: authPayload.name, email: authPayload.email, role: authPayload.role }
  : null;

if (!currentUser) {
  return Astro.redirect('/ja/login?redirect=/ja/mypage');
}

let bookings: any[] = [];
let error = '';

try {
  if (DB) {
    const result = await DB.prepare(`
      SELECT
        b.id, b.status, b.check_in_date, b.total_price_usd,
        b.adults, b.children, b.created_at, b.paypal_order_id,
        b.notes,
        h.name as hotel_name, h.slug as hotel_slug,
        h.city, h.country, h.thumbnail_url,
        p.name as plan_name, p.check_in_time, p.check_out_time
      FROM bookings b
      LEFT JOIN hotels h ON h.id = b.hotel_id
      LEFT JOIN plans p ON p.id = b.plan_id
      WHERE b.guest_email = ?
      ORDER BY b.created_at DESC
      LIMIT 50
    `).bind(currentUser.email).all();
    bookings = result?.results ?? [];

    // 未読メッセージ数（ホテル→ゲスト）
    if (bookings.length > 0) {
      const bookingIds = bookings.map((b: any) => b.id);
      const ph = bookingIds.map(() => '?').join(',');
      const unreadResult = await DB.prepare(
        `SELECT booking_id, COUNT(*) as unread_count FROM booking_messages
         WHERE booking_id IN (${ph}) AND sender_type = 'hotel' AND is_read = 0
         GROUP BY booking_id`
      ).bind(...bookingIds).all();
      const unreadMap: Record<number, number> = {};
      for (const r of (unreadResult?.results || []) as any[]) {
        unreadMap[r.booking_id] = r.unread_count;
      }
      bookings = bookings.map((b: any) => ({ ...b, unread_messages: unreadMap[b.id] || 0 }));
    }
  }
} catch (e: any) {
  error = '予約情報の読み込みに失敗しました。';
}

const statusConfig: Record<string, { label: string; color: string; icon: string }> = {
  pending:              { label: 'お支払い待ち',     color: 'bg-yellow-100 text-yellow-700 border-yellow-200', icon: '⏳' },
  pending_confirmation: { label: 'ホテル確認待ち',   color: 'bg-blue-100 text-blue-700 border-blue-200',       icon: '📨' },
  confirmed:            { label: '確定済み',          color: 'bg-green-100 text-green-700 border-green-200',    icon: '✅' },
  completed:            { label: '利用済み',          color: 'bg-gray-100 text-gray-600 border-gray-200',       icon: '🏁' },
  cancelled:            { label: 'キャンセル済み',    color: 'bg-red-100 text-red-600 border-red-200',          icon: '❌' },
  failed:               { label: '失敗',              color: 'bg-red-100 text-red-600 border-red-200',          icon: '⚠️' },
};

---

<Layout title="マイページ — DayDreamHub">
  <div class="max-w-4xl mx-auto px-4 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">マイページ</h1>
        <p class="text-sm text-gray-500 mt-1">おかえりなさい、<span class="font-medium text-gray-700">{currentUser.name}</span>さん</p>
      </div>
      <a href="/ja/search" class="inline-flex items-center gap-2 bg-teal-600 hover:bg-teal-700 text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        新しい予約
      </a>
    </div>

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm mb-6">{error}</div>
    )}

    {bookings.length === 0 ? (
      <div class="text-center py-20 bg-white rounded-2xl border border-gray-100 shadow-sm">
        <div class="text-6xl mb-4">🏨</div>
        <h2 class="text-xl font-semibold text-gray-700 mb-2">まだ予約がありません</h2>
        <p class="text-gray-400 mb-6 text-sm">デイユースホテルの予約がここに表示されます。</p>
        <a href="/ja/search" class="inline-block bg-teal-600 hover:bg-teal-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors">ホテルを探す</a>
      </div>
    ) : (
      <div class="space-y-4">
        {bookings.map((b: any) => {
          const status = statusConfig[b.status] || { label: b.status, color: 'bg-gray-100 text-gray-600 border-gray-200', icon: '•' };
          const guestCount = b.children > 0 ? `${b.adults}+${b.children}` : `${b.adults}`;
          return (
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
              <div class="flex flex-col sm:flex-row">
                <!-- Hotel thumbnail -->
                <div class="sm:w-36 h-28 sm:h-auto flex-shrink-0 bg-gray-100 overflow-hidden">
                  {b.thumbnail_url ? (
                    <img src={b.thumbnail_url} alt={b.hotel_name} class="w-full h-full object-cover" loading="lazy" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-gray-300">
                      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    </div>
                  )}
                </div>

                <!-- Booking info -->
                <div class="flex-1 p-4 sm:p-5">
                  <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
                    <div>
                      <div class="flex items-center gap-2 flex-wrap">
                        <span class="text-xs font-mono text-gray-400">#{b.id}</span>
                        <span class={`inline-flex items-center gap-1 text-xs font-semibold px-2.5 py-1 rounded-full border ${status.color}`}>
                          {status.icon} {status.label}
                        </span>
                      </div>
                      <h2 class="font-semibold text-gray-900 mt-1 text-base">
                        <a href={`/ja/hotel/${b.hotel_slug}`} class="hover:text-teal-700 transition-colors">{b.hotel_name || 'ホテル'}</a>
                      </h2>
                      <p class="text-xs text-gray-400">{b.city}{b.country ? `、${b.country}` : ''}</p>
                    </div>
                    <div class="text-right">
                      <div class="text-lg font-bold text-teal-700">${Number(b.total_price_usd || 0).toFixed(2)}</div>
                      <div class="text-xs text-gray-400">USD</div>
                    </div>
                  </div>

                  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm">
                    <div>
                      <div class="text-xs text-gray-400 mb-0.5">プラン</div>
                      <div class="font-medium text-gray-700 text-xs leading-snug">{b.plan_name || '-'}</div>
                    </div>
                    <div>
                      <div class="text-xs text-gray-400 mb-0.5">日付</div>
                      <div class="font-medium text-gray-700 text-xs">{formatDisplayDate(b.check_in_date)}</div>
                    </div>
                    <div>
                      <div class="text-xs text-gray-400 mb-0.5">時間</div>
                      <div class="font-medium text-gray-700 text-xs">
                        {b.check_in_time && b.check_out_time ? `${b.check_in_time} – ${b.check_out_time}` : '-'}
                      </div>
                    </div>
                    <div>
                      <div class="text-xs text-gray-400 mb-0.5">人数</div>
                      <div class="font-medium text-gray-700 text-xs">{guestCount}名</div>
                    </div>
                  </div>

                  {b.status === 'pending_confirmation' && (
                    <div class="mt-3 bg-blue-50 border border-blue-100 rounded-lg px-3 py-2 text-xs text-blue-700">
                      📨 予約リクエストをホテルに送信しました。通常24時間以内に確認が届きます。
                    </div>
                  )}
                  {b.status === 'confirmed' && (
                    <div class="mt-3 bg-green-50 border border-green-100 rounded-lg px-3 py-2 text-xs text-green-700">
                      ✅ 予約が確定しました！{formatDisplayDate(b.check_in_date)}に{b.check_in_time || 'チェックイン時間'}までにホテルにお越しください。
                    </div>
                  )}
                  {(b.status === 'cancelled' || b.status === 'failed') && (
                    <div class="mt-3 bg-red-50 border border-red-100 rounded-lg px-3 py-2 text-xs text-red-700">
                      キャンセル済み、または決済が完了していない予約です。未完了の決済は請求されず、二重請求も発生しないよう保護されています。ご不明点は<a href="/ja/contact" class="underline font-medium">お問い合わせ</a>ください。
                    </div>
                  )}

                  <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-50">
                    <span class="text-xs text-gray-300">予約日 {formatDisplayDate(b.created_at)}</span>
                    <div class="flex gap-2 flex-wrap justify-end">
                      <a href={`/ja/hotel/${b.hotel_slug}`}
                        class="text-xs text-teal-600 hover:text-teal-700 font-medium border border-teal-200 hover:border-teal-400 px-3 py-1.5 rounded-lg transition-colors">
                        ホテルを見る
                      </a>
                      {(b.status !== 'failed') && (
                        <button
                          class="btn-message-hotel relative text-xs text-blue-600 hover:text-blue-700 font-medium border border-blue-200 hover:border-blue-400 px-3 py-1.5 rounded-lg transition-colors"
                          data-booking-id={b.id}
                          data-hotel-name={b.hotel_name}
                        >
                          💬 メッセージ
                          {b.unread_messages > 0 && (
                            <span class="absolute -top-1.5 -right-1.5 bg-red-500 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center">{b.unread_messages}</span>
                          )}
                        </button>
                      )}
                      {(b.status === 'confirmed' || b.status === 'completed') && new Date(b.check_in_date) < new Date(new Date().toDateString()) && (
                        <button
                          class="btn-write-review text-xs text-amber-600 hover:text-amber-700 font-medium border border-amber-200 hover:border-amber-400 px-3 py-1.5 rounded-lg transition-colors"
                          data-booking-id={b.id}
                          data-hotel-name={b.hotel_name}
                        >
                          ⭐ レビュー
                        </button>
                      )}
                      {(b.status === 'pending_confirmation' || b.status === 'confirmed') && (
                        <button
                          class="btn-cancel-booking text-xs text-red-500 hover:text-red-700 font-medium border border-red-200 hover:border-red-400 px-3 py-1.5 rounded-lg transition-colors"
                          data-booking-id={b.id}
                          data-hotel-name={b.hotel_name}
                        >
                          キャンセルを依頼
                        </button>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    )}
    <!-- お問い合わせ -->
    <div class="mt-8 bg-gray-50 rounded-xl p-5 flex flex-col sm:flex-row items-center gap-4">
      <div class="flex-1">
        <h3 class="font-semibold text-gray-800 text-sm mb-1">予約についてお困りですか？</h3>
        <p class="text-xs text-gray-500">月〜金 9:00〜18:00 JST にサポートチームが対応します。通常数時間以内にご返信いたします。</p>
      </div>
      <a href="/ja/contact" class="flex-shrink-0 bg-white border border-gray-200 hover:border-teal-400 text-gray-700 hover:text-teal-700 text-sm font-medium px-5 py-2.5 rounded-lg transition-colors">
        サポートに連絡
      </a>
    </div>
  </div>

<!-- レビューモーダル -->
<div id="review-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4">
  <div class="bg-white rounded-2xl shadow-xl max-w-md w-full p-6">
    <h3 class="text-lg font-bold text-gray-900 mb-1">レビューを書く</h3>
    <p class="text-sm text-gray-500 mb-4">ホテル：<span id="review-hotel-name" class="font-medium text-gray-700"></span></p>
    <div class="flex gap-2 mb-4" id="star-rating">
      {[1,2,3,4,5].map(n => (
        <button class="star-btn text-3xl text-gray-300 hover:text-amber-400 transition-colors" data-value={n}>★</button>
      ))}
    </div>
    <textarea id="review-content" rows="4" placeholder="ご感想をどうぞ（任意）"
      class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-amber-400 outline-none resize-none mb-4"></textarea>
    <div class="flex gap-3">
      <button id="review-modal-close" class="flex-1 py-2.5 border border-gray-200 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50">閉じる</button>
      <button id="review-modal-confirm" class="flex-1 py-2.5 bg-amber-500 hover:bg-amber-600 text-white rounded-lg text-sm font-bold">レビューを送信</button>
    </div>
  </div>
</div>

<!-- メッセージモーダル -->
<div id="message-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4">
  <div class="bg-white rounded-2xl shadow-xl max-w-md w-full p-6">
    <h3 class="text-lg font-bold text-gray-900 mb-1">ホテルへのメッセージ</h3>
    <p class="text-sm text-gray-500 mb-4">ホテル：<span id="message-hotel-name" class="font-medium text-gray-700"></span></p>
    <div id="message-thread" class="max-h-48 overflow-y-auto mb-3 space-y-2 bg-gray-50 rounded-lg p-3 hidden"></div>
    <textarea id="message-content" rows="3" placeholder="メッセージを入力..."
      class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-400 outline-none resize-none mb-4"></textarea>
    <div class="flex gap-3">
      <button id="message-modal-close" class="flex-1 py-2.5 border border-gray-200 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50">閉じる</button>
      <button id="message-modal-send" class="flex-1 py-2.5 bg-blue-500 hover:bg-blue-600 text-white rounded-lg text-sm font-bold">送信</button>
    </div>
  </div>
</div>

<!-- キャンセルモーダル -->
<div id="cancel-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4">
  <div class="bg-white rounded-2xl shadow-xl max-w-md w-full p-6">
    <h3 class="text-lg font-bold text-gray-900 mb-2">予約のキャンセル</h3>
    <p class="text-sm text-gray-500 mb-1">予約先：<span id="cancel-hotel-name" class="font-medium text-gray-700"></span></p>
    <p class="text-sm text-gray-500 mb-2">キャンセル理由をお知らせください。</p>
    <p class="text-xs text-emerald-700 bg-emerald-50 border border-emerald-100 rounded-lg px-3 py-2 mb-4">決済が完了していない場合は請求されません。二重請求も発生しないよう保護されています。</p>
    <textarea id="cancel-reason" rows="3" placeholder="キャンセル理由（任意）"
      class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-red-400 focus:border-red-400 outline-none resize-none mb-4"></textarea>
    <div class="flex gap-3">
      <button id="cancel-modal-close" class="flex-1 py-2.5 border border-gray-200 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors">
        予約を続ける
      </button>
      <button id="cancel-modal-confirm" class="flex-1 py-2.5 bg-red-500 hover:bg-red-600 text-white rounded-lg text-sm font-bold transition-colors">
        キャンセルを確定
      </button>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  // --- レビューモーダル ---
  var reviewModal = document.getElementById('review-modal');
  var reviewHotelName = document.getElementById('review-hotel-name');
  var reviewContent = document.getElementById('review-content');
  var reviewConfirm = document.getElementById('review-modal-confirm');
  var reviewClose = document.getElementById('review-modal-close');
  var currentReviewBookingId = null;
  var currentRating = 0;

  document.querySelectorAll('.star-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      currentRating = Number(btn.dataset.value);
      document.querySelectorAll('.star-btn').forEach(function(s, i) {
        s.classList.toggle('text-amber-400', i < currentRating);
        s.classList.toggle('text-gray-300', i >= currentRating);
      });
    });
  });

  document.querySelectorAll('.btn-write-review').forEach(function(btn) {
    btn.addEventListener('click', function() {
      currentReviewBookingId = btn.dataset.bookingId;
      reviewHotelName.textContent = btn.dataset.hotelName;
      currentRating = 0;
      reviewContent.value = '';
      document.querySelectorAll('.star-btn').forEach(function(s) { s.classList.add('text-gray-300'); s.classList.remove('text-amber-400'); });
      reviewModal.classList.remove('hidden'); reviewModal.classList.add('flex');
    });
  });

  reviewClose.addEventListener('click', function() { reviewModal.classList.add('hidden'); reviewModal.classList.remove('flex'); });
  reviewModal.addEventListener('click', function(e) { if (e.target === reviewModal) { reviewModal.classList.add('hidden'); reviewModal.classList.remove('flex'); } });

  reviewConfirm.addEventListener('click', async function() {
    if (!currentRating) { showToast('星評価を選択してください。'); return; }
    reviewConfirm.textContent = '送信中...'; reviewConfirm.disabled = true;
    try {
      var res = await fetch('/api/guest/review', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ booking_id: Number(currentReviewBookingId), rating: currentRating, content: reviewContent.value.trim() }) });
      var data = await res.json();
      if (data.success) { reviewModal.classList.add('hidden'); reviewModal.classList.remove('flex'); showToast('レビューありがとうございます！'); }
      else { showToast(data.error || '送信に失敗しました'); }
    } catch { showToast('レビューの送信中にエラーが発生しました'); }
    reviewConfirm.textContent = 'レビューを送信'; reviewConfirm.disabled = false;
  });

  // --- メッセージモーダル ---
  var msgModal = document.getElementById('message-modal');
  var msgHotelName = document.getElementById('message-hotel-name');
  var msgContent = document.getElementById('message-content');
  var msgSend = document.getElementById('message-modal-send');
  var msgClose = document.getElementById('message-modal-close');
  var msgThread = document.getElementById('message-thread');
  var currentMsgBookingId = null;

  async function loadMessages(bookingId) {
    try {
      var res = await fetch('/api/guest/message?booking_id=' + bookingId);
      var data = await res.json();
      if (data.messages && data.messages.length > 0) {
        msgThread.classList.remove('hidden');
        msgThread.innerHTML = data.messages.map(function(m) {
          var isGuest = m.sender_type === 'guest';
          return '<div class="' + (isGuest ? 'text-right' : 'text-left') + '"><span class="inline-block px-3 py-1.5 rounded-xl text-xs max-w-[85%] ' + (isGuest ? 'bg-blue-500 text-white' : 'bg-white border text-gray-700') + '">' + m.content + '</span><div class="text-xs text-gray-300 mt-0.5">' + m.sender_name + '</div></div>';
        }).join('');
        msgThread.scrollTop = msgThread.scrollHeight;
      }
    } catch {}
  }

  document.querySelectorAll('.btn-message-hotel').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      currentMsgBookingId = btn.dataset.bookingId;
      msgHotelName.textContent = btn.dataset.hotelName;
      msgContent.value = '';
      msgThread.innerHTML = ''; msgThread.classList.add('hidden');
      msgModal.classList.remove('hidden'); msgModal.classList.add('flex');
      await loadMessages(currentMsgBookingId);
    });
  });

  msgClose.addEventListener('click', function() { msgModal.classList.add('hidden'); msgModal.classList.remove('flex'); });
  msgModal.addEventListener('click', function(e) { if (e.target === msgModal) { msgModal.classList.add('hidden'); msgModal.classList.remove('flex'); } });

  msgSend.addEventListener('click', async function() {
    if (!msgContent.value.trim()) return;
    msgSend.textContent = '送信中...'; msgSend.disabled = true;
    try {
      var res = await fetch('/api/guest/message', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ booking_id: Number(currentMsgBookingId), content: msgContent.value.trim() }) });
      var data = await res.json();
      if (data.success) { msgContent.value = ''; await loadMessages(currentMsgBookingId); }
      else { showToast(data.error || '送信に失敗しました'); }
    } catch { showToast('メッセージの送信中にエラーが発生しました'); }
    msgSend.textContent = '送信'; msgSend.disabled = false;
  });

  // --- キャンセルモーダル ---
  var modal = document.getElementById('cancel-modal');
  var hotelNameEl = document.getElementById('cancel-hotel-name');
  var reasonEl = document.getElementById('cancel-reason');
  var confirmBtn = document.getElementById('cancel-modal-confirm');
  var closeBtn = document.getElementById('cancel-modal-close');
  var currentBookingId = null;

  function openModal(bookingId, hotelName) {
    currentBookingId = bookingId;
    hotelNameEl.textContent = hotelName;
    reasonEl.value = '';
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    currentBookingId = null;
  }

  document.querySelectorAll('.btn-cancel-booking').forEach(function(btn) {
    btn.addEventListener('click', function() {
      openModal(btn.dataset.bookingId, btn.dataset.hotelName);
    });
  });

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });

  confirmBtn.addEventListener('click', async function() {
    if (!currentBookingId) return;
    confirmBtn.textContent = 'キャンセル中...';
    confirmBtn.disabled = true;
    try {
      var res = await fetch('/api/guest/cancel-request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ booking_id: Number(currentBookingId), reason: reasonEl.value.trim() }),
      });
      var data = await res.json();
      if (data.success) {
        closeModal();
        window.location.reload();
      } else {
        showToast(data.error || '予約のキャンセルに失敗しました');
        confirmBtn.textContent = 'キャンセルを確定';
        confirmBtn.disabled = false;
      }
    } catch (e) {
      showToast('キャンセル中にエラーが発生しました。サポートにお問い合わせください。');
      confirmBtn.textContent = 'キャンセルを確定';
      confirmBtn.disabled = false;
    }
  });
})();
</script>
</Layout>
