---
import Layout from '../../../layouts/Layout.astro';
import { getLocale, t, localePath } from '../../../lib/i18n';

const locale = getLocale(Astro.url);
const { slug } = Astro.params;

let hotel: any = null;
let plans: any[] = [];
let images: any[] = [];
let reviews: any[] = [];
let avgRating = 0;
let reviewCount = 0;
let ratingDistribution: Record<number, number> = {};
let dbAvailable = false;

try {
  const runtime = (Astro.locals as any).runtime;
  const db = runtime?.env?.DB;
  if (db) {
    dbAvailable = true;
    hotel = await db.prepare('SELECT * FROM hotels WHERE slug = ?').bind(slug).first();
    if (hotel) {
      const plansResult = await db.prepare(
        'SELECT * FROM plans WHERE hotel_id = ? AND is_active = 1 ORDER BY price_usd ASC'
      ).bind(hotel.id).all();
      plans = plansResult?.results || [];

      const imagesResult = await db.prepare(
        'SELECT * FROM hotel_images WHERE hotel_id = ? ORDER BY sort_order ASC'
      ).bind(hotel.id).all();
      images = imagesResult?.results || [];

      const reviewsResult = await db.prepare(
        'SELECT r.*, rr.content as owner_reply FROM reviews r LEFT JOIN review_replies rr ON rr.review_id = r.id WHERE r.hotel_id = ? AND r.is_approved = 1 ORDER BY r.created_at DESC LIMIT 5'
      ).bind(hotel.id).all();
      reviews = reviewsResult?.results || [];

      avgRating = hotel.avg_rating || 0;
      reviewCount = hotel.review_count || 0;

      const distResult = await db.prepare(
        'SELECT rating, COUNT(*) as count FROM reviews WHERE hotel_id = ? AND is_approved = 1 GROUP BY rating'
      ).bind(hotel.id).all();
      for (const row of distResult?.results || []) {
        ratingDistribution[row.rating] = row.count;
      }
    }
  }
} catch (e) {
  dbAvailable = false;
}

if (!dbAvailable) {
  const sampleHotels = [
    { id: 1, name: 'The Work Loft Bangkok', name_ja: 'ザ ワークロフト バンコク', slug: 'work-loft-bangkok', city: 'Bangkok', country: 'Thailand', thumbnail_url: '', categories: '["workspace"]', property_type: 'hotel', rating: 4.5, description: 'A modern co-working hotel in the heart of Bangkok.', description_ja: 'バンコクの中心にあるモダンなコワーキングホテル。デジタルノマドやビジネス旅行者に最適。', amenities: '["wifi","desk","coffee","meeting_room","printer"]', address: '123 Sukhumvit Road, Bangkok', phone: '+66-2-123-4567', email: 'info@workloft.example.com' },
    { id: 5, name: 'Airport Transit Hotel', name_ja: 'エアポート トランジットホテル', slug: 'airport-transit-hotel', city: 'Singapore', country: 'Singapore', thumbnail_url: '', categories: '["transit"]', property_type: 'hotel', rating: 4, description: 'Conveniently located inside the airport terminal.', description_ja: '空港ターミナル内にある便利なホテル。長時間のトランジットに最適。', amenities: '["wifi","shower","luggage_storage"]', address: 'Changi Airport Terminal 3, Singapore', phone: '+65-6123-4567', email: 'info@transit.example.com' },
    { id: 9, name: 'Romance Suite Bali', name_ja: 'ロマンス スイート バリ', slug: 'romance-suite-bali', city: 'Bali', country: 'Indonesia', thumbnail_url: '', categories: '["couple","for_couple"]', property_type: 'villa', rating: 4.8, description: 'A romantic villa with private pool and garden.', description_ja: 'プライベートプールと庭園を備えたロマンチックなヴィラ。バリでの穏やかな休日を求めるカップルに最適です。', amenities: '["wifi","pool","garden","spa","breakfast"]', address: 'Jl. Raya Ubud, Bali', phone: '+62-361-123-456', email: 'info@romancebali.example.com' },
    { id: 13, name: 'The Ritz-Carlton KL', name_ja: 'ザ・リッツカールトン KL', slug: 'ritz-carlton-kl', city: 'Kuala Lumpur', country: 'Malaysia', thumbnail_url: '', categories: '["luxury"]', property_type: 'hotel', rating: 4.9, description: 'Experience unparalleled luxury with world-class amenities.', description_ja: 'クアラルンプールの中心で、世界クラスのアメニティ、素晴らしいルーフトッププール、完璧なサービスによる比類なきラグジュアリー体験を。', amenities: '["wifi","pool","spa","gym","restaurant","bar","concierge"]', address: '168 Jalan Imbi, Kuala Lumpur', phone: '+60-3-1234-5678', email: 'info@ritzcarltonkl.example.com' },
    { id: 17, name: 'Daycation Paradise', name_ja: 'デイケーション パラダイス', slug: 'daycation-paradise', city: 'Bali', country: 'Indonesia', thumbnail_url: '', categories: '["daycation","personal_time"]', property_type: 'villa', rating: 4.6, description: 'A beachfront villa offering the perfect daycation experience.', description_ja: 'ビーチフロントのヴィラで最高のデイケーション体験を。プール、ビーチアクセス、トロピカルガーデンをお楽しみください。', amenities: '["wifi","pool","beach","garden","restaurant"]', address: 'Jl. Pantai Kuta, Bali', phone: '+62-361-789-012', email: 'info@daycation.example.com' },
  ];
  const samplePlans = [
    { id: 1, hotel_id: 1, name: '4-Hour Workspace', name_ja: '4時間ワークスペース', price_usd: 25, check_in_time: '09:00', check_out_time: '13:00', plan_type: 'day-use', max_guests: 1, duration_hours: 4 },
    { id: 2, hotel_id: 1, name: 'Full Day Office', name_ja: '1日オフィス', price_usd: 45, check_in_time: '09:00', check_out_time: '18:00', plan_type: 'day-use', max_guests: 2, duration_hours: 9 },
    { id: 6, hotel_id: 5, name: '6-Hour Layover', name_ja: '6時間レイオーバー', price_usd: 40, check_in_time: '00:00', check_out_time: '06:00', plan_type: 'day-use', max_guests: 2, duration_hours: 6 },
    { id: 10, hotel_id: 9, name: 'Romantic Half Day', name_ja: 'ロマンチック半日', price_usd: 80, check_in_time: '12:00', check_out_time: '18:00', plan_type: 'day-use', max_guests: 2, duration_hours: 6 },
    { id: 14, hotel_id: 13, name: 'Luxury Day Pass', name_ja: 'ラグジュアリーデイパス', price_usd: 150, check_in_time: '10:00', check_out_time: '18:00', plan_type: 'day-use', max_guests: 2, duration_hours: 8 },
    { id: 18, hotel_id: 17, name: 'Beach & Pool Day', name_ja: 'ビーチ＆プールデイ', price_usd: 55, check_in_time: '09:00', check_out_time: '17:00', plan_type: 'day-use', max_guests: 4, duration_hours: 8 },
  ];
  hotel = sampleHotels.find(h => h.slug === slug) || null;
  if (hotel) {
    plans = samplePlans.filter(p => p.hotel_id === hotel.id);
  }
}

if (!hotel) {
  Astro.response.status = 404;
}

const displayName = hotel ? (locale === 'ja' && hotel.name_ja ? hotel.name_ja : hotel.name) : '';
const displayDescription = hotel ? (locale === 'ja' && hotel.description_ja ? hotel.description_ja : hotel.description || '') : '';

let categories: string[] = [];
if (hotel) {
  try { const parsed = JSON.parse(hotel.categories); if (Array.isArray(parsed)) categories = parsed; } catch { categories = []; }
}

let amenities: string[] = [];
if (hotel?.amenities) {
  try { const parsed = JSON.parse(hotel.amenities); if (Array.isArray(parsed)) amenities = parsed; } catch { amenities = []; }
}

const categoryColors: Record<string, string> = {
  workspace: 'bg-blue-100 text-blue-700', luxury: 'bg-purple-100 text-purple-700',
  transit: 'bg-green-100 text-green-700', couple: 'bg-pink-100 text-pink-700',
  for_couple: 'bg-pink-100 text-pink-700', daycation: 'bg-yellow-100 text-yellow-700',
  personal_time: 'bg-orange-100 text-orange-700', early_checkin: 'bg-teal-100 text-teal-700',
};
const categoryLabelKeys: Record<string, string> = {
  workspace: 'search.workspace', luxury: 'search.luxury', transit: 'search.transit',
  couple: 'search.for_couple', for_couple: 'search.for_couple', daycation: 'search.daycation',
  personal_time: 'search.personal_time', early_checkin: 'search.early_checkin',
};
const amenityLabels: Record<string, Record<string, string>> = {
  wifi: { en: 'Wi-Fi', ja: 'Wi-Fi' }, pool: { en: 'Pool', ja: 'プール' },
  spa: { en: 'Spa', ja: 'スパ' }, gym: { en: 'Gym', ja: 'ジム' },
  restaurant: { en: 'Restaurant', ja: 'レストラン' }, bar: { en: 'Bar', ja: 'バー' },
  parking: { en: 'Parking', ja: '駐車場' }, desk: { en: 'Work Desk', ja: 'デスク' },
  coffee: { en: 'Coffee', ja: 'コーヒー' }, meeting_room: { en: 'Meeting Room', ja: '会議室' },
  printer: { en: 'Printer', ja: 'プリンター' }, shower: { en: 'Shower', ja: 'シャワー' },
  luggage_storage: { en: 'Luggage Storage', ja: '荷物預かり' }, garden: { en: 'Garden', ja: '庭園' },
  beach: { en: 'Beach Access', ja: 'ビーチ' }, breakfast: { en: 'Breakfast', ja: '朝食' },
  concierge: { en: 'Concierge', ja: 'コンシェルジュ' },
};
const propertyTypeLabels: Record<string, Record<string, string>> = {
  hotel: { en: 'Hotel', ja: 'ホテル' }, villa: { en: 'Villa', ja: 'ヴィラ' },
  'capsule-hotel': { en: 'Capsule Hotel', ja: 'カプセルホテル' }, hostel: { en: 'Hostel', ja: 'ホステル' },
  apartment: { en: 'Apartment', ja: 'アパートメント' }, 'guest-house': { en: 'Guest House', ja: 'ゲストハウス' },
};

function renderStars(rating: number) {
  const clamped = Math.min(Math.max(rating, 0), 5);
  const full = Math.floor(clamped);
  const hasHalf = clamped % 1 >= 0.5;
  return '\u2605'.repeat(full) + (hasHalf ? '\u2606' : '') + '\u2606'.repeat(5 - full - (hasHalf ? 1 : 0));
}
---

<Layout title={hotel ? `${displayName} | ${t('site.name', locale)}` : t('hotel.not_found', locale)} description={hotel ? displayDescription.slice(0, 160) : t('hotel.not_found_desc', locale)}>
  {hotel ? (
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6">
      <!-- Breadcrumb -->
      <nav class="mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center text-sm text-gray-500 space-x-2">
          <li><a href={localePath('/', locale)} class="hover:text-teal-700 transition-colors">{t('breadcrumb.home', locale)}</a></li>
          <li><span class="mx-1">/</span></li>
          <li><a href={localePath('/search', locale)} class="hover:text-teal-700 transition-colors">{t('breadcrumb.hotels', locale)}</a></li>
          <li><span class="mx-1">/</span></li>
          <li class="text-slate-900 font-medium truncate max-w-[200px]" aria-current="page">{displayName}</li>
        </ol>
      </nav>

      <!-- Top Section -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-10">
        <!-- Image -->
        <div class="aspect-[4/3] rounded-xl overflow-hidden bg-gray-100">
          <img src={hotel.thumbnail_url || '/images/placeholder-hotel.jpg'} alt={displayName} class="w-full h-full object-cover" />
        </div>

        <!-- Info -->
        <div>
          {hotel.property_type && (
            <span class="inline-block text-xs font-medium bg-gray-100 text-gray-600 rounded-full px-3 py-1 mb-3">
              {propertyTypeLabels[hotel.property_type]?.[locale] || hotel.property_type}
            </span>
          )}
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">{displayName}</h1>

          {(avgRating > 0 || (hotel.rating && hotel.rating <= 5)) && (
            <div class="flex items-center gap-2 mb-3">
              <span class="text-yellow-500 text-lg tracking-wide">{renderStars(avgRating > 0 ? avgRating : hotel.rating || 0)}</span>
              <span class="text-sm text-gray-500">{Math.min(avgRating > 0 ? avgRating : hotel.rating || 0, 5).toFixed(1)}</span>
              {reviewCount > 0 && (
                <a href="#reviews-section" class="text-sm text-teal-700 hover:underline">
                  ({t('review.reviews_count', locale).replace('{count}', String(reviewCount))})
                </a>
              )}
            </div>
          )}

          <div class="flex items-center text-gray-600 mb-4">
            <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"></path>
            </svg>
            <span class="text-sm">{hotel.city}, {hotel.country}</span>
          </div>

          {categories.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-5">
              {categories.map(cat => (
                <span class:list={['text-xs font-medium rounded-full px-3 py-1', categoryColors[cat] || 'bg-gray-100 text-gray-700']}>
                  {t(categoryLabelKeys[cat] || cat, locale)}
                </span>
              ))}
            </div>
          )}

          {displayDescription && (
            <div class="mb-6">
              <h2 class="text-lg font-semibold text-slate-900 mb-2">{t('hotel.description', locale)}</h2>
              <p class="text-gray-600 leading-relaxed text-sm">{displayDescription}</p>
            </div>
          )}

          {/* Contact section hidden intentionally - prevent direct bookings bypassing the platform */}
        </div>
      </div>

      <!-- Amenities -->
      {amenities.length > 0 && (
        <section class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4">{t('hotel.amenities', locale)}</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
            {amenities.map(amenity => (
              <div class="flex items-center gap-2 bg-gray-50 rounded-lg px-3 py-2.5">
                <svg class="w-4 h-4 text-teal-700 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"></path>
                </svg>
                <span class="text-sm text-gray-700">{amenityLabels[amenity]?.[locale] || amenity}</span>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Plans -->
      {plans.length > 0 && (
        <section class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4">{t('hotel.available_plans', locale)}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {plans.map((plan: any) => {
              const planName = locale === 'ja' && plan.name_ja ? plan.name_ja : plan.name;
              return (
                <div class="bg-white border border-gray-200 rounded-xl p-5 hover:shadow-md transition-shadow">
                  <h3 class="font-semibold text-gray-900 mb-2">{planName}</h3>
                  <div class="text-sm text-gray-500 space-y-1 mb-4">
                    {plan.check_in_time && plan.check_out_time && (
                      <p>{plan.check_in_time} - {plan.check_out_time}</p>
                    )}
                    {plan.duration_hours && <p>{plan.duration_hours} {t('hotel.hours', locale)}</p>}
                    {plan.max_guests && <p>{t('hotel.max_guests', locale)}: {plan.max_guests} {t('hotel.guests_unit', locale)}</p>}
                  </div>
                  <div class="flex items-center justify-between">
                    <p class="text-xl font-bold text-[#45A2C1]">${plan.price_usd} <span class="text-sm font-normal text-gray-500">{t('hotel.usd', locale)}</span></p>
                    <a href={localePath(`/booking/${plan.id}`, locale)} class="px-4 py-2 bg-[#45A2C1] text-white text-sm font-medium rounded-lg hover:bg-[#3891AE] transition-colors">
                      {t('hotel.book_now', locale)}
                    </a>
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      )}

      <!-- Location -->
      {hotel.address && (
        <section class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4">{t('hotel.location', locale)}</h2>
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal-700 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"></path>
              </svg>
              <div>
                <p class="text-gray-700 font-medium">{hotel.address}</p>
                <p class="text-sm text-gray-500 mt-1">{hotel.city}, {hotel.country}</p>
              </div>
            </div>
          </div>
        </section>
      )}
    </div>
  ) : (
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-20 text-center">
      <svg class="w-20 h-20 mx-auto text-gray-300 mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"></path>
      </svg>
      <h1 class="text-2xl font-bold text-gray-700 mb-3">{t('hotel.not_found', locale)}</h1>
      <p class="text-gray-500 mb-8 max-w-md mx-auto">{t('hotel.not_found_desc', locale)}</p>
      <a href={localePath('/', locale)} class="inline-flex items-center px-6 py-3 bg-teal-700 text-white font-medium rounded-lg hover:bg-teal-800 transition-colors">
        {t('hotel.back_home', locale)}
      </a>
    </div>
  )}
</Layout>
