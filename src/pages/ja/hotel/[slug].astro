---
import Layout from '../../../layouts/Layout.astro';
import ReviewSection from '../../../components/ReviewSection.astro';
import { getLocale, t, localePath } from '../../../lib/i18n';
import { nearestAirport, airportNamesJa } from '../../../lib/airports';

const locale = getLocale(Astro.url);
const { slug } = Astro.params;

let hotel: any = null;
let plans: any[] = [];
let images: any[] = [];
let reviews: any[] = [];
let avgRating = 0;
let reviewCount = 0;
let ratingDistribution: Record<number, number> = {};
let dbAvailable = false;
let nearbyHotels: any[] = [];

try {
  const runtime = (Astro.locals as any).runtime;
  const db = runtime?.env?.DB;
  if (db) {
    dbAvailable = true;
    hotel = await db.prepare('SELECT * FROM hotels WHERE slug = ?').bind(slug).first();
    if (hotel) {
      const plansResult = await db.prepare(
        'SELECT * FROM plans WHERE hotel_id = ? AND is_active = 1 ORDER BY price_usd ASC'
      ).bind(hotel.id).all();
      plans = plansResult?.results || [];

      const imagesResult = await db.prepare(
        'SELECT * FROM hotel_images WHERE hotel_id = ? ORDER BY sort_order ASC'
      ).bind(hotel.id).all();
      images = imagesResult?.results || [];

      const reviewsResult = await db.prepare(
        'SELECT r.*, rr.content as owner_reply FROM reviews r LEFT JOIN review_replies rr ON rr.review_id = r.id WHERE r.hotel_id = ? AND r.is_approved = 1 ORDER BY r.created_at DESC LIMIT 5'
      ).bind(hotel.id).all();
      reviews = reviewsResult?.results || [];

      avgRating = hotel.avg_rating || 0;
      reviewCount = hotel.review_count || 0;

      const distResult = await db.prepare(
        'SELECT rating, COUNT(*) as count FROM reviews WHERE hotel_id = ? AND is_approved = 1 GROUP BY rating'
      ).bind(hotel.id).all();
      for (const row of distResult?.results || []) {
        ratingDistribution[row.rating] = row.count;
      }

      // Nearby hotels (same city, excluding current)
      const nearbyResult = await db.prepare(
        `SELECT h.id, h.name, h.slug, h.city, h.thumbnail_url, h.rating, MIN(p.price_usd) as min_price
         FROM hotels h
         LEFT JOIN plans p ON p.hotel_id = h.id AND p.is_active = 1
         WHERE h.city = ? AND h.id != ? AND h.is_active = 1
         GROUP BY h.id
         ORDER BY h.rating DESC
         LIMIT 4`
      ).bind(hotel.city, hotel.id).all();
      nearbyHotels = nearbyResult?.results || [];
    }
  }
} catch (e) {
  dbAvailable = false;
}

const airportInfo = (hotel?.latitude && hotel?.longitude)
  ? nearestAirport(hotel.latitude, hotel.longitude)
  : null;

if (!dbAvailable) {
  const sampleHotels = [
    { id: 1, name: 'The Work Loft Bangkok', name_ja: 'ザ ワークロフト バンコク', slug: 'work-loft-bangkok', city: 'Bangkok', country: 'Thailand', thumbnail_url: '', categories: '["workspace"]', property_type: 'hotel', rating: 4.5, description: 'A modern co-working hotel in the heart of Bangkok.', description_ja: 'バンコクの中心にあるモダンなコワーキングホテル。デジタルノマドやビジネス旅行者に最適。', amenities: '["wifi","desk","coffee","meeting_room","printer"]', address: '123 Sukhumvit Road, Bangkok', phone: '+66-2-123-4567', email: 'info@workloft.example.com' },
    { id: 5, name: 'Airport Transit Hotel', name_ja: 'エアポート トランジットホテル', slug: 'airport-transit-hotel', city: 'Singapore', country: 'Singapore', thumbnail_url: '', categories: '["transit"]', property_type: 'hotel', rating: 4, description: 'Conveniently located inside the airport terminal.', description_ja: '空港ターミナル内にある便利なホテル。長時間のトランジットに最適。', amenities: '["wifi","shower","luggage_storage"]', address: 'Changi Airport Terminal 3, Singapore', phone: '+65-6123-4567', email: 'info@transit.example.com' },
    { id: 9, name: 'Romance Suite Bali', name_ja: 'ロマンス スイート バリ', slug: 'romance-suite-bali', city: 'Bali', country: 'Indonesia', thumbnail_url: '', categories: '["couple","for_couple"]', property_type: 'villa', rating: 4.8, description: 'A romantic villa with private pool and garden.', description_ja: 'プライベートプールと庭園を備えたロマンチックなヴィラ。バリでの穏やかな休日を求めるカップルに最適です。', amenities: '["wifi","pool","garden","spa","breakfast"]', address: 'Jl. Raya Ubud, Bali', phone: '+62-361-123-456', email: 'info@romancebali.example.com' },
    { id: 13, name: 'The Ritz-Carlton KL', name_ja: 'ザ・リッツカールトン KL', slug: 'ritz-carlton-kl', city: 'Kuala Lumpur', country: 'Malaysia', thumbnail_url: '', categories: '["luxury"]', property_type: 'hotel', rating: 4.9, description: 'Experience unparalleled luxury with world-class amenities.', description_ja: 'クアラルンプールの中心で、世界クラスのアメニティ、素晴らしいルーフトッププール、完璧なサービスによる比類なきラグジュアリー体験を。', amenities: '["wifi","pool","spa","gym","restaurant","bar","concierge"]', address: '168 Jalan Imbi, Kuala Lumpur', phone: '+60-3-1234-5678', email: 'info@ritzcarltonkl.example.com' },
    { id: 17, name: 'Daycation Paradise', name_ja: 'デイケーション パラダイス', slug: 'daycation-paradise', city: 'Bali', country: 'Indonesia', thumbnail_url: '', categories: '["daycation","personal_time"]', property_type: 'villa', rating: 4.6, description: 'A beachfront villa offering the perfect daycation experience.', description_ja: 'ビーチフロントのヴィラで最高のデイケーション体験を。プール、ビーチアクセス、トロピカルガーデンをお楽しみください。', amenities: '["wifi","pool","beach","garden","restaurant"]', address: 'Jl. Pantai Kuta, Bali', phone: '+62-361-789-012', email: 'info@daycation.example.com' },
  ];
  const samplePlans = [
    { id: 1, hotel_id: 1, name: '4-Hour Workspace', name_ja: '4時間ワークスペース', price_usd: 25, check_in_time: '09:00', check_out_time: '13:00', plan_type: 'day-use', max_guests: 1, duration_hours: 4 },
    { id: 2, hotel_id: 1, name: 'Full Day Office', name_ja: '1日オフィス', price_usd: 45, check_in_time: '09:00', check_out_time: '18:00', plan_type: 'day-use', max_guests: 2, duration_hours: 9 },
    { id: 6, hotel_id: 5, name: '6-Hour Layover', name_ja: '6時間レイオーバー', price_usd: 40, check_in_time: '00:00', check_out_time: '06:00', plan_type: 'day-use', max_guests: 2, duration_hours: 6 },
    { id: 10, hotel_id: 9, name: 'Romantic Half Day', name_ja: 'ロマンチック半日', price_usd: 80, check_in_time: '12:00', check_out_time: '18:00', plan_type: 'day-use', max_guests: 2, duration_hours: 6 },
    { id: 14, hotel_id: 13, name: 'Luxury Day Pass', name_ja: 'ラグジュアリーデイパス', price_usd: 150, check_in_time: '10:00', check_out_time: '18:00', plan_type: 'day-use', max_guests: 2, duration_hours: 8 },
    { id: 18, hotel_id: 17, name: 'Beach & Pool Day', name_ja: 'ビーチ＆プールデイ', price_usd: 55, check_in_time: '09:00', check_out_time: '17:00', plan_type: 'day-use', max_guests: 4, duration_hours: 8 },
  ];
  hotel = sampleHotels.find(h => h.slug === slug) || null;
  if (hotel) {
    plans = samplePlans.filter(p => p.hotel_id === hotel.id);
  }
}

if (!hotel) {
  Astro.response.status = 404;
}

function decodeHtmlEntities(str: string): string {
  if (!str) return str;
  return str.replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '"').replace(/&#39;/g, "'");
}

// Hotel name: use name_ja if available, otherwise translate
let displayName = hotel ? decodeHtmlEntities(hotel.name_ja || hotel.name) : '';
if (hotel && !hotel.name_ja && hotel.name) {
  displayName = decodeHtmlEntities(await translateToJa(hotel.name).catch(() => hotel.name));
}
const siteUrl = 'https://www.daydreamhub.com';

// Helper: translate text with Cloudflare AI (en → ja)
// Plan name keyword map (handles 【NH】 hour-based plan names correctly)
const PLAN_NAME_MAP: Record<string, string> = {
  'morning':   '朝',
  'evening':   '夕方',
  'afternoon': '午後',
  'night':     '夜',
  'overnight': '宿泊',
  'daytime':   '昼間',
  'day use':   'デイユース',
  'day-use':   'デイユース',
  'late checkout': 'レイトチェックアウト',
  'early check-in': 'アーリーチェックイン',
  'early checkin': 'アーリーチェックイン',
};

// Translate plan names: converts 【NH】 → 【N時間】 and maps English keywords
function translatePlanName(name: string): string {
  if (!name) return name;
  // Replace 【NH】 prefix → 【N時間】
  let result = name.replace(/【(\d+)H】/gi, (_, n) => `【${n}時間】`);
  // Replace English keyword (case-insensitive)
  for (const [en, ja] of Object.entries(PLAN_NAME_MAP)) {
    const re = new RegExp(`\\b${en}\\b`, 'gi');
    result = result.replace(re, ja);
  }
  return result;
}

async function translateToJa(text: string): Promise<string> {
  if (!text) return text;
  try {
    const runtime = (Astro.locals as any).runtime;
    const ai = runtime?.env?.AI;
    if (!ai) return text;
    const result = await ai.run('@cf/meta/m2m100-1.2b', {
      text,
      source_lang: 'en',
      target_lang: 'ja',
    }) as any;
    return result?.translated_text || text;
  } catch {
    return text;
  }
}

// Auto-translate description if description_ja is missing
let displayDescription = '';
if (hotel) {
  if (hotel.description_ja) {
    displayDescription = hotel.description_ja;
  } else if (hotel.description) {
    displayDescription = await translateToJa(hotel.description);
  }
}

// Auto-translate plan names and room_type labels if name_ja is missing
if (plans.length > 0) {
  plans = await Promise.all(plans.map(async (plan: any) => {
    // Use dedicated plan name translator (handles 【NH】 hours correctly, no AI needed)
    const jaName = plan.name_ja || translatePlanName(plan.name);
    const jaRoomType = plan.room_type ? await translateToJa(plan.room_type) : '';
    return { ...plan, _ja_name: jaName, _ja_room_type: jaRoomType };
  }));
}

let categories: string[] = [];
if (hotel) {
  try { const parsed = JSON.parse(hotel.categories); if (Array.isArray(parsed)) categories = parsed; } catch { categories = []; }
}

let amenities: string[] = [];
if (hotel?.amenities) {
  try { const parsed = JSON.parse(hotel.amenities); if (Array.isArray(parsed)) amenities = parsed; } catch { amenities = []; }
}

const categoryColors: Record<string, string> = {
  workspace: 'bg-blue-100 text-blue-700', luxury: 'bg-purple-100 text-purple-700',
  transit: 'bg-green-100 text-green-700', couple: 'bg-pink-100 text-pink-700',
  for_couple: 'bg-pink-100 text-pink-700', daycation: 'bg-yellow-100 text-yellow-700',
  personal_time: 'bg-orange-100 text-orange-700', early_checkin: 'bg-teal-100 text-teal-700',
};
const categoryLabelKeys: Record<string, string> = {
  workspace: 'search.workspace', luxury: 'search.luxury', transit: 'search.transit',
  couple: 'search.for_couple', for_couple: 'search.for_couple', daycation: 'search.daycation',
  personal_time: 'search.personal_time', early_checkin: 'search.early_checkin',
};
// Amenity label map: supports both slug keys (wifi) and full English strings from DB
const amenityLabelMap: Record<string, string> = {
  // slug keys
  'wifi': 'Wi-Fi', 'pool': 'プール', 'spa': 'スパ', 'gym': 'ジム',
  'restaurant': 'レストラン', 'bar': 'バー', 'parking': '駐車場',
  'desk': 'デスク', 'coffee': 'コーヒー', 'meeting_room': '会議室',
  'printer': 'プリンター', 'shower': 'シャワー', 'luggage_storage': '荷物預かり',
  'garden': '庭園', 'beach': 'ビーチアクセス', 'breakfast': '朝食',
  'concierge': 'コンシェルジュ', 'air_conditioning': 'エアコン', 'tv': 'テレビ',
  'refrigerator': '冷蔵庫', 'kitchen': 'キッチン', 'laundry': 'ランドリー',
  'elevator': 'エレベーター', 'safe': 'セーフティボックス', 'minibar': 'ミニバー',
  // Full English strings from DB
  'Wi-Fi': 'Wi-Fi', 'Free Wi-Fi': '無料Wi-Fi', 'Pool': 'プール',
  'Swimming Pool': 'スイミングプール', 'Spa': 'スパ', 'Gym': 'ジム',
  'Fitness Center': 'フィットネスセンター', 'Restaurant': 'レストラン', 'Bar': 'バー',
  'Parking': '駐車場', 'Parking on Premises': '駐車場', 'Free Parking': '無料駐車場',
  'Desk': 'デスク', 'Desk/Workspace': 'デスク/ワークスペース',
  'Work Desk': 'ワークデスク', 'Coffee': 'コーヒー', 'Meeting Room': '会議室',
  'Printer': 'プリンター', 'Shower': 'シャワー', 'Luggage Storage': '荷物預かり',
  'Garden': '庭園', 'Beach Access': 'ビーチアクセス', 'Breakfast': '朝食',
  'Concierge': 'コンシェルジュ', 'Air Conditioning': 'エアコン',
  'Air Conditioner': 'エアコン', 'Air Conditioner (Cooling)': 'エアコン（冷房）',
  'Air Conditioner (Heating)': 'エアコン（暖房）', 'TV': 'テレビ', 'Television': 'テレビ',
  'Refrigerator': '冷蔵庫', 'Kitchen': 'キッチン', 'Kitchenette': 'キッチネット',
  'Laundry': 'ランドリー', 'Laundry Service': 'ランドリーサービス',
  'Elevator': 'エレベーター', 'Safe': 'セーフティボックス', 'Minibar': 'ミニバー',
  'Bathtub': 'バスタブ', 'Jacuzzi': 'ジャグジー', 'Sauna': 'サウナ',
  'Terrace': 'テラス', 'Balcony': 'バルコニー', 'Sea View': 'シービュー',
  'Mountain View': 'マウンテンビュー', 'City View': 'シティビュー',
  'Airport Shuttle': 'エアポートシャトル', 'Room Service': 'ルームサービス',
  'Housekeeping': 'ハウスキーピング', 'Reception 24h': '24時間フロント',
  '24-hour Front Desk': '24時間フロント', 'Non-smoking': '禁煙',
  'Hair Dryer': 'ヘアドライヤー', 'Hairdryer': 'ヘアドライヤー',
  'Iron': 'アイロン', 'Ironing Facilities': 'アイロン設備',
  'Electric pot': '電気ポット', 'Electric Kettle': '電気ケトル',
  'Night wear': 'ナイトウェア', 'Slippers': 'スリッパ', 'Bathrobes': 'バスローブ',
  'Towels': 'タオル', 'Toiletries': 'アメニティ', 'Toothbrush': '歯ブラシ',
  'Shampoo': 'シャンプー', 'Soap': 'ソープ', 'TEL': '電話', 'Telephone': '電話',
  'Wheelchair Accessible': '車椅子対応', 'Non Smoking': '禁煙',
  'Smoking Allowed': '喫煙可', 'Pets Allowed': 'ペット可',
  'Bicycle Rental': 'レンタサイクル', 'Car Rental': 'レンタカー',
  'ATM': 'ATM', 'Currency Exchange': '両替', 'Business Center': 'ビジネスセンター',
};
// Legacy map for backwards compatibility
const amenityLabels: Record<string, Record<string, string>> = {
  wifi: { en: 'Wi-Fi', ja: 'Wi-Fi' }, pool: { en: 'Pool', ja: 'プール' },
};
function getAmenityLabel(amenity: string): string {
  return amenityLabelMap[amenity] || amenity;
}
const propertyTypeLabels: Record<string, Record<string, string>> = {
  hotel: { en: 'Hotel', ja: 'ホテル' }, villa: { en: 'Villa', ja: 'ヴィラ' },
  'capsule-hotel': { en: 'Capsule Hotel', ja: 'カプセルホテル' }, hostel: { en: 'Hostel', ja: 'ホステル' },
  apartment: { en: 'Apartment', ja: 'アパートメント' }, 'guest-house': { en: 'Guest House', ja: 'ゲストハウス' },
};

function renderStars(rating: number) {
  const clamped = Math.min(Math.max(rating, 0), 5);
  const full = Math.floor(clamped);
  const hasHalf = clamped % 1 >= 0.5;
  return '\u2605'.repeat(full) + (hasHalf ? '\u2606' : '') + '\u2606'.repeat(5 - full - (hasHalf ? 1 : 0));
}

// Group plans by room_type
const plansByRoomType: Record<string, typeof plans> = {};
for (const plan of plans) {
  const rt = (plan.room_type as string) || '';
  if (!plansByRoomType[rt]) plansByRoomType[rt] = [];
  plansByRoomType[rt].push(plan);
}
const roomTypes = Object.keys(plansByRoomType);

// Group hotel_images by room_type
const imagesByRoomType: Record<string, string[]> = {};
for (const img of images) {
  const rt = (img as any).room_type || '';
  if (!imagesByRoomType[rt]) imagesByRoomType[rt] = [];
  imagesByRoomType[rt].push((img as any).image_url);
}
---

<Layout title={hotel ? `${displayName} | ${t('site.name', locale)}` : t('hotel.not_found', locale)} description={hotel ? displayDescription.slice(0, 160) : t('hotel.not_found_desc', locale)}>
  {hotel && (
    <script slot="head" type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LodgingBusiness",
      "name": displayName,
      "description": displayDescription?.substring(0, 200),
      "url": `${siteUrl}/ja/hotel/${hotel.slug}`,
      "image": hotel.thumbnail_url || null,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": hotel.city,
        "addressCountry": hotel.country
      },
      ...(hotel.avg_rating ? { "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": hotel.avg_rating,
        "bestRating": 5,
        "ratingCount": hotel.review_count || 1
      }} : {})
    })} />
  )}
  {hotel ? (
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6">
      <!-- Breadcrumb -->
      <nav class="mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center text-sm text-gray-500 space-x-2">
          <li><a href={localePath('/', locale)} class="hover:text-teal-700 transition-colors">{t('breadcrumb.home', locale)}</a></li>
          <li><span class="mx-1">/</span></li>
          <li><a href={localePath('/search', locale)} class="hover:text-teal-700 transition-colors">{t('breadcrumb.hotels', locale)}</a></li>
          <li><span class="mx-1">/</span></li>
          <li class="text-slate-900 font-medium truncate max-w-[200px]" aria-current="page">{displayName}</li>
        </ol>
      </nav>

      <!-- Top Section -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-10">
        <!-- Image -->
        <div class="aspect-[4/3] rounded-xl overflow-hidden bg-gray-100">
          <img src={hotel.thumbnail_url || '/images/placeholder-hotel.jpg'} alt={displayName} class="w-full h-full object-cover" />
        </div>

        <!-- Info -->
        <div>
          {hotel.property_type && (
            <span class="inline-block text-xs font-medium bg-gray-100 text-gray-600 rounded-full px-3 py-1 mb-3">
              {propertyTypeLabels[hotel.property_type]?.[locale] || hotel.property_type}
            </span>
          )}
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">{displayName}</h1>

          {(avgRating > 0 || (hotel.rating > 0 && hotel.rating <= 5)) && (
            <div class="flex items-center gap-2 mb-3">
              <span class="text-yellow-500 text-lg tracking-wide">{renderStars(avgRating > 0 ? avgRating : hotel.rating || 0)}</span>
              <span class="text-sm text-gray-500">{Math.min(avgRating > 0 ? avgRating : hotel.rating || 0, 5).toFixed(1)}</span>
              {reviewCount > 0 && (
                <a href="#reviews-section" class="text-sm text-teal-700 hover:underline">
                  ({t('review.reviews_count', locale).replace('{count}', String(reviewCount))})
                </a>
              )}
            </div>
          )}

          <div class="flex items-center text-gray-600 mb-4">
            <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"></path>
            </svg>
            <span class="text-sm">{hotel.city}, {hotel.country}</span>
          </div>

          {airportInfo && (
            <div class="flex items-center text-gray-600 mb-4">
              <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
              </svg>
              <span class="text-sm">最寄り空港: {airportNamesJa[airportInfo.code] || airportInfo.name}（{airportInfo.code}）ー 約{Math.round(airportInfo.km)}km</span>
            </div>
          )}

          {categories.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-5">
              {categories.map(cat => (
                <span class:list={['text-xs font-medium rounded-full px-3 py-1', categoryColors[cat] || 'bg-gray-100 text-gray-700']}>
                  {t(categoryLabelKeys[cat] || cat, locale)}
                </span>
              ))}
            </div>
          )}

          {displayDescription && (
            <div class="mb-6">
              <h2 class="text-lg font-semibold text-slate-900 mb-2">{t('hotel.description', locale)}</h2>
              <p class="text-gray-600 leading-relaxed text-sm">{displayDescription}</p>
            </div>
          )}

          {/* Contact section hidden intentionally - prevent direct bookings bypassing the platform */}
        </div>
      </div>

      <!-- Amenities -->
      {amenities.length > 0 && (
        <section class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4">{t('hotel.amenities', locale)}</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
            {amenities.map(amenity => (
              <div class="flex items-center gap-2 bg-gray-50 rounded-lg px-3 py-2.5">
                <svg class="w-4 h-4 text-teal-700 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"></path>
                </svg>
                <span class="text-sm text-gray-700">{getAmenityLabel(amenity)}</span>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Plans -->
      {plans.length > 0 && (
        <section class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4">{t('hotel.available_plans', locale)}</h2>
          {roomTypes.map(rt => {
              const rtImages = imagesByRoomType[rt] || [];
              return (
              <div class="mb-8">
                {rt && (
                  <div class="mb-3 pb-2 border-b border-gray-200">
                    <h3 class="text-lg font-semibold text-slate-800 mb-3 flex items-center gap-2">
                      <svg class="w-5 h-5 text-teal-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                      </svg>
                      {plansByRoomType[rt][0]?._ja_room_type || rt}
                    </h3>
                    {rtImages.length > 0 && (
                      <div class="flex gap-2 overflow-x-auto pb-2 mb-1">
                        {rtImages.map((url: string, i: number) => (
                          <img
                            src={url}
                            alt={`${rt} ${i + 1}`}
                            class="flex-shrink-0 h-40 w-60 object-cover rounded-lg hover:opacity-90 transition-opacity"
                            loading="lazy"
                          />
                        ))}
                      </div>
                    )}
                  </div>
                )}
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                  {plansByRoomType[rt].map((plan: any) => {
                    const planName = plan._ja_name || plan.name_ja || plan.name;
                    return (
                      <div class="bg-white border border-gray-200 rounded-xl p-5 hover:shadow-md transition-shadow">
                        <h3 class="font-semibold text-gray-900 mb-2">{planName}</h3>
                        <div class="text-sm text-gray-500 space-y-1 mb-4">
                          {plan.check_in_time && plan.check_out_time && (
                            <p>{plan.check_in_time} - {plan.check_out_time}</p>
                          )}
                          {plan.duration_hours && <p>{plan.duration_hours} {t('hotel.hours', locale)}</p>}
                          {plan.max_guests && <p>{t('hotel.max_guests', locale)}: {plan.max_guests} {t('hotel.guests_unit', locale)}</p>}
                        </div>
                        <p class="text-xl font-bold text-[#45A2C1] mb-3">${plan.price_usd} <span class="text-sm font-normal text-gray-500">{t('hotel.usd', locale)}</span></p>
                        {/* キャンセルポリシー */}
                        {(() => {
                          const policy = plan.cancellation_policy || hotel.cancellation_policy || '';
                          const hours = plan.cancellation_hours;
                          return (
                            <div class="mb-3 text-xs text-gray-600 bg-amber-50 border border-amber-100 rounded-lg px-3 py-2">
                              <div class="font-medium text-amber-800 mb-1">キャンセルポリシー</div>
                              {policy ? (
                                <p class="leading-relaxed line-clamp-3">{policy}</p>
                              ) : hours === 0 ? (
                                <p class="text-red-600 font-medium">❌ キャンセル不可</p>
                              ) : (
                                <p>✅ チェックイン {hours ?? 24}時間前まで無料キャンセル可能</p>
                              )}
                            </div>
                          );
                        })()}
                        {/* Date picker + Book Now */}
                        <div class="mb-3">
                          <label class="block text-xs text-gray-500 mb-1">
                            {locale === 'ja' ? '日付を選択' : 'Select Date'} <span class="text-red-500">*</span>
                          </label>
                          <input
                            type="text"
                            class="plan-date-input w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-400 focus:border-transparent outline-none"
                            placeholder={locale === 'ja' ? '日付を選択してください' : 'Select a date'}
                            readonly
                            data-plan-id={plan.id}
                          />
                        </div>
                        <button
                          type="button"
                          class="book-now-btn block w-full text-center bg-[#45A2C1] text-white text-sm font-medium py-2.5 rounded-lg hover:bg-[#3891AE] transition-colors"
                          data-plan-id={plan.id}
                          data-href={localePath(`/booking/${plan.id}`, locale)}
                        >
                          {t('hotel.book_now', locale)}
                        </button>
                      </div>
                    );
                  })}
                </div>
              </div>
            );
          })}
        </section>
      )}

      <!-- Reviews Section -->
      <ReviewSection
        hotelId={hotel.id}
        reviews={reviews}
        avgRating={avgRating}
        reviewCount={reviewCount}
        locale={locale}
        ratingDistribution={ratingDistribution}
      />

      <!-- Location -->
      {hotel.address && (
        <section class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4">{t('hotel.location', locale)}</h2>
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal-700 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"></path>
              </svg>
              <div>
                <p class="text-gray-700 font-medium">{hotel.address}</p>
                <p class="text-sm text-gray-500 mt-1">{hotel.city}, {hotel.country}</p>
              </div>
            </div>
          </div>
        </section>
      )}
      {/* Nearby hotels */}
      {nearbyHotels.length > 0 && (
        <section class="max-w-5xl mx-auto px-4 py-10 border-t border-gray-100">
          <h2 class="text-xl font-bold text-gray-900 mb-5">
            {locale === 'ja' ? `${hotel.city}の他のホテル` : `More Hotels in ${hotel.city}`}
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            {nearbyHotels.map((h: any) => (
              <a href={localePath(`/hotel/${h.slug}`, locale)} class="group block rounded-xl overflow-hidden border border-gray-100 hover:shadow-md transition-shadow">
                <div class="aspect-video bg-slate-100 overflow-hidden">
                  <img
                    src={h.thumbnail_url || 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=400&q=70&fm=webp'}
                    alt={h.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    onerror="this.src='https://images.unsplash.com/photo-1566073771259-6a8506099945?w=400&q=70&fm=webp'"
                  />
                </div>
                <div class="p-3">
                  <p class="text-sm font-semibold text-gray-900 truncate">{h.name}</p>
                  <p class="text-xs text-gray-500 mt-0.5">{h.city}</p>
                  {h.min_price && <p class="text-sm font-bold text-teal-600 mt-1">from ${h.min_price}</p>}
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  ) : (
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-20 text-center">
      <svg class="w-20 h-20 mx-auto text-gray-300 mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"></path>
      </svg>
      <h1 class="text-2xl font-bold text-gray-700 mb-3">{t('hotel.not_found', locale)}</h1>
      <p class="text-gray-500 mb-8 max-w-md mx-auto">{t('hotel.not_found_desc', locale)}</p>
      <a href={localePath('/', locale)} class="inline-flex items-center px-6 py-3 bg-teal-700 text-white font-medium rounded-lg hover:bg-teal-800 transition-colors">
        {t('hotel.back_home', locale)}
      </a>
    </div>
  )}
</Layout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
<style is:global>
  .flatpickr-day.ddh-blocked,
  .flatpickr-day.ddh-blocked:hover {
    background: #fee2e2 !important;
    color: #b91c1c !important;
    opacity: 1 !important;
    cursor: not-allowed !important;
    position: relative;
    text-decoration: line-through !important;
    border: 1px solid #fca5a5 !important;
    border-radius: 4px !important;
  }
  .flatpickr-day.ddh-blocked::before {
    content: '✕';
    position: absolute;
    top: 0; right: 0; bottom: 0; left: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    color: #dc2626;
    opacity: 0.5;
    pointer-events: none;
  }
</style>
<script is:inline>
(function() {
  // Load flatpickr and init date inputs with blocked dates
  var fpScript = document.createElement('script');
  fpScript.src = 'https://cdn.jsdelivr.net/npm/flatpickr';
  fpScript.onload = function() {
    if (typeof flatpickr === 'undefined') return;

    document.querySelectorAll('.plan-date-input').forEach(function(input) {
      var planId = input.dataset.planId;
      fetch('/api/availability?planId=' + planId)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var blocked = data.blocked || [];
          flatpickr(input, {
            minDate: 'today',
            dateFormat: 'Y-m-d',
            locale: 'ja',
            disable: blocked,
            onDayCreate: function(dObj, dStr, fp, dayElem) {
              var _d = dayElem.dateObj;
              var dateStr = _d.getFullYear() + '-' + String(_d.getMonth()+1).padStart(2,'0') + '-' + String(_d.getDate()).padStart(2,'0');
              if (blocked.includes(dateStr)) {
                dayElem.classList.add('ddh-blocked');
                dayElem.title = '予約不可';
              }
            },
            onOpen: function(selectedDates, dateStr, instance) {
              var cal = instance.calendarContainer;
              if (cal && !cal.querySelector('.ddh-cal-legend') && blocked.length > 0) {
                var legend = document.createElement('div');
                legend.className = 'ddh-cal-legend';
                legend.style.cssText = 'padding:6px 10px;display:flex;align-items:center;gap:8px;font-size:11px;color:#6b7280;border-top:1px solid #f3f4f6;';
                legend.innerHTML = '<span style="display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;background:#fee2e2;border:1px solid #fca5a5;border-radius:4px;color:#dc2626;font-size:10px;">✕</span>'
                  + '<span>予約不可</span>'
                  + '<span style="display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;background:#fff;border:1px solid #d1d5db;border-radius:4px;margin-left:8px;"></span>'
                  + '<span>予約可能</span>';
                cal.appendChild(legend);
              }
            }
          });
        })
        .catch(function() {
          flatpickr(input, { minDate: 'today', dateFormat: 'Y-m-d', locale: 'ja' });
        });
    });
  };
  document.head.appendChild(fpScript);

  // Book Now button handler
  document.querySelectorAll('.book-now-btn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var planId = btn.dataset.planId;
      var dateInput = document.querySelector('.plan-date-input[data-plan-id="' + planId + '"]');
      if (!dateInput || !dateInput.value) {
        if (dateInput) {
          dateInput.style.borderColor = '#ef4444';
          dateInput.focus();
        }
        return;
      }
      window.location.href = btn.dataset.href + '?date=' + dateInput.value;
    });
  });
})();
</script>
