---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | DayDreamHub" description="The page you're looking for doesn't exist.">
  <div class="min-h-[60vh] flex items-center justify-center px-4 py-20">
    <div class="text-center max-w-md">
      <p class="text-8xl font-bold text-teal-200 mb-4">404</p>
      <h1 class="text-2xl font-bold text-slate-900 mb-3">Page not found</h1>
      <p class="text-gray-500 mb-8">
        The page you're looking for may have been moved or no longer exists.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="px-6 py-3 bg-teal-600 hover:bg-teal-700 text-white font-medium rounded-xl transition-colors">
          Back to Home
        </a>
        <a href="/search" class="px-6 py-3 bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 font-medium rounded-xl transition-colors">
          Search Hotels
        </a>
      </div>
    </div>
  </div>
</Layout>
