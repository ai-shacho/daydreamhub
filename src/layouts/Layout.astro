                </svg>
                Owner Login
              </a>
              <!-- FOR_AI_AGENTS_REMOVED -->
            </div>
          </div>
        </nav>

        <!-- Right side controls -->
        <div class="flex items-center gap-2">
          <!-- Currency selector (custom dropdown) -->
          <div class="hidden sm:flex items-center relative">
            <button id="currency-btn" class="flex items-center gap-1 text-gray-600 hover:text-gray-900 px-2 py-1.5 rounded-md hover:bg-gray-100 transition-colors text-xs font-medium">
              <span id="currency-btn-label">USD $</span>
              <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div id="currency-dropdown" class="absolute right-0 top-full mt-1 bg-white rounded-lg shadow-lg border border-gray-100 py-1 z-50 w-28 hidden max-h-72 overflow-y-auto">
