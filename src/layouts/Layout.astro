---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  ogType?: string;
  ogPublishedTime?: string;
  noindex?: boolean;
}

const { title, description = "Day-use hotel booking platform - Find hourly hotels worldwide", ogImage, canonicalUrl, ogType, ogPublishedTime, noindex } = Astro.props;
const siteUrl = 'https://www.daydreamhub.com';
const resolvedOgImage = ogImage || `${siteUrl}/og-default.jpg`;
const resolvedCanonical = canonicalUrl || `${siteUrl}${Astro.url.pathname}`;
const currentPath = Astro.url.pathname;
const isJa = currentPath.startsWith('/ja');
const basePath = isJa ? (currentPath.replace(/^\/ja/, '') || '/') : currentPath;
const enPath = basePath;
const jaPath = `/ja${basePath === '/' ? '' : basePath}`;

const getPath = (path: string) => isJa ? `/ja${path}` : path;

// Auth: read ddh_token cookie and verify JWT
async function verifyJWT(token: string, secret: string): Promise<Record<string, any> | null> {
  try {
    const parts = token.split('.');
    if (parts.length !== 3) return null;
    const [header, body, signature] = parts;
    const key = await crypto.subtle.importKey(
      'raw', new TextEncoder().encode(secret),
      { name: 'HMAC', hash: 'SHA-256' }, false, ['verify']
    );
    const sigBytes = Uint8Array.from(
      atob(signature.replace(/-/g, '+').replace(/_/g, '/')), c => c.charCodeAt(0)
    );
    const valid = await crypto.subtle.verify('HMAC', key, sigBytes, new TextEncoder().encode(`${header}.${body}`));
    if (!valid) return null;
    const payload = JSON.parse(atob(body));
    if (payload.exp && payload.exp < Math.floor(Date.now() / 1000)) return null;
    return payload;
  } catch { return null; }
}
const env0 = (Astro.locals as any).runtime?.env;
const jwtSecret = env0?.JWT_SECRET || 'ddh-secret-2025';
const cookieHeader = Astro.request.headers.get('cookie') || '';
const tokenMatch = cookieHeader.match(/ddh_token=([^;]+)/);
const authPayload = tokenMatch ? await verifyJWT(tokenMatch[1], jwtSecret) : null;
const currentUser = authPayload ? { id: authPayload.sub, name: authPayload.name, email: authPayload.email, role: authPayload.role === 'inactive' ? 'owner' : authPayload.role } : null;

// GA4
const ga4Id: string | undefined = (Astro.locals as any).runtime?.env?.GA4_MEASUREMENT_ID;

// Footer dynamic data
const env = (Astro.locals as any).runtime?.env;
const DB = env?.DB;
let footerBlogs: any[] = [];
let footerCities: any[] = [];
try {
  if (DB) {
    const blogRes = await DB.prepare(
      "SELECT title, slug FROM blog_posts ORDER BY published_at DESC LIMIT 3"
    ).all();
    footerBlogs = blogRes?.results ?? [];
    const cityRes = await DB.prepare(
      "SELECT city, COUNT(*) as cnt FROM hotels WHERE is_active=1 AND city!='' GROUP BY city ORDER BY cnt DESC LIMIT 8"
    ).all();
    footerCities = cityRes?.results ?? [];
  }
} catch {}

const defaultCities = ['Bangkok','Bali','Kuala Lumpur','Singapore','Cebu','Hanoi','Ho Chi Minh City','Phuket'];
---

<!doctype html>
<html lang={isJa ? "ja" : "en"}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-5C6B1R3H1Q"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-5C6B1R3H1Q');
</script>

<!-- Canonical -->
  <link rel="canonical" href={resolvedCanonical} />
  <!-- OGP (Facebook/LINE/Slack等) -->
  <meta property="og:type" content={ogType || "website"} />
  <meta property="og:url" content={resolvedCanonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:site_name" content="DayDreamHub" />
  {ogPublishedTime && <meta property="article:published_time" content={ogPublishedTime} />}
  <!-- hreflang -->
  <link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
  <link rel="alternate" hreflang="ja" href={`${siteUrl}${jaPath}`} />
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}${enPath}`} />
  <!-- WebSite JSON-LD (top page only) -->
  {currentPath === '/' && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "DayDreamHub",
      "url": siteUrl,
      "description": "Day-use hotel booking platform - Find hourly hotels worldwide",
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${siteUrl}/search?location={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    })} />
  )}
  <slot name="head" />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>
  {ga4Id && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
      <script define:vars={{ ga4Id }}>
        window.__GA4_ID__ = ga4Id;
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', ga4Id, { anonymize_ip: true });
      </script>
    </>
  )}
</head>
<body class="min-h-screen flex flex-col bg-gray-50">

  <SiteHeader
    currentPath={currentPath}
    isJa={isJa}
    enPath={enPath}
    jaPath={jaPath}
    currentUser={currentUser}
    getPath={getPath}
  />

  <!-- Main content -->
  <main class="flex-1 pb-16 md:pb-0">
    <slot />
  </main>

  <!-- Mobile bottom navigation -->
  <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-[1050]" style="padding-bottom: env(safe-area-inset-bottom, 0px)">
    <div class="grid grid-cols-4 h-14">
      <a href="/" class={`flex flex-col items-center justify-center gap-0.5 text-[11px] font-medium transition-colors ${currentPath === '/' ? 'text-teal-700' : 'text-gray-500 hover:text-teal-700'}`}>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        <span>Home</span>
      </a>
      <a href="/search" class={`flex flex-col items-center justify-center gap-0.5 text-[11px] font-medium transition-colors ${currentPath === '/search' ? 'text-teal-700' : 'text-gray-500 hover:text-teal-700'}`}>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <span>Search</span>
      </a>
      <a href="/wishlist" class={`flex flex-col items-center justify-center gap-0.5 text-[11px] font-medium transition-colors ${currentPath === '/wishlist' ? 'text-teal-700' : 'text-gray-500 hover:text-teal-700'}`}>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
        <span>Wishlist</span>
      </a>
      <a href="/map" class={`flex flex-col items-center justify-center gap-0.5 text-[11px] font-medium transition-colors ${currentPath === '/map' ? 'text-teal-700' : 'text-gray-500 hover:text-teal-700'}`}>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
        <span>Map</span>
      </a>
    </div>
  </nav>

  <SiteFooter
    isJa={isJa}
    footerBlogs={footerBlogs}
    footerCities={footerCities}
    defaultCities={defaultCities}
  />


  <script>
    // ===== Wishlist (localStorage) =====
    const WISHLIST_KEY = 'ddh_wishlist';

    function getWishlist(): string[] {
      try { return JSON.parse(localStorage.getItem(WISHLIST_KEY) || '[]'); } catch { return []; }
    }
    function saveWishlist(slugs: string[]) {
      localStorage.setItem(WISHLIST_KEY, JSON.stringify(slugs));
    }
    function isInWishlist(slug: string): boolean {
      return getWishlist().includes(slug);
    }
    function toggleWishlist(slug: string): boolean {
      const list = getWishlist();
      const idx = list.indexOf(slug);
      if (idx >= 0) { list.splice(idx, 1); saveWishlist(list); return false; }
      else { list.push(slug); saveWishlist(list); return true; }
    }

    function updateWishlistBtn(btn: HTMLButtonElement, inWishlist: boolean) {
      const icon = btn.querySelector('.wishlist-icon') as SVGElement | null;
      const label = btn.querySelector('.wishlist-label') as HTMLElement | null;
      if (!icon) return;
      if (inWishlist) {
        icon.setAttribute('fill', '#ef4444');
        icon.setAttribute('stroke', '#ef4444');
        btn.title = 'Remove from wishlist';
        if (label) label.textContent = 'Saved';
        btn.classList.add('border-red-300', 'bg-red-50', 'text-red-500');
        btn.classList.remove('border-gray-200', 'bg-white', 'text-gray-600');
      } else {
        icon.setAttribute('fill', 'none');
        icon.setAttribute('stroke', 'currentColor');
        btn.title = 'Save to wishlist';
        if (label) label.textContent = 'Save';
        btn.classList.remove('border-red-300', 'bg-red-50', 'text-red-500');
        btn.classList.add('border-gray-200', 'bg-white', 'text-gray-600');
      }
    }

    // Expose for wishlist page
    (window as any).updateWishlistBtn = (slug: string, inWishlist: boolean) => {
      document.querySelectorAll<HTMLButtonElement>(`[data-slug="${slug}"].wishlist-btn`).forEach(btn => {
        updateWishlistBtn(btn, inWishlist);
      });
    };

    function initWishlistBtns() {
      document.querySelectorAll<HTMLButtonElement>('.wishlist-btn').forEach(btn => {
        const slug = btn.dataset.slug || '';
        updateWishlistBtn(btn, isInWishlist(slug));
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const inWishlist = toggleWishlist(slug);
          updateWishlistBtn(btn, inWishlist);
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initWishlistBtns);
    } else {
      initWishlistBtns();
    }

    // Mobile menu toggle
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });

    // Language dropdown toggle (click-based, not hover)
    const langBtn = document.getElementById('lang-toggle-btn');
    const langDropdown = document.getElementById('lang-dropdown');
    langBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      langDropdown?.classList.toggle('hidden');
    });
    document.addEventListener('click', () => langDropdown?.classList.add('hidden'));

    // More dropdown toggle
    const moreBtn = document.getElementById('more-menu-btn');
    const moreDropdown = document.getElementById('more-dropdown');
    moreBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      moreDropdown?.classList.toggle('hidden');
    });
    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (!document.getElementById('more-menu-wrapper')?.contains(e.target as Node)) {
        moreDropdown?.classList.add('hidden');
      }
      // Close user dropdown too
      if (!document.getElementById('user-menu-wrap')?.contains(e.target as Node)) {
        document.getElementById('user-dropdown')?.classList.add('hidden');
      }
    });

    // User menu dropdown toggle
    document.getElementById('user-menu-btn')?.addEventListener('click', (e) => {
      e.stopPropagation();
      document.getElementById('user-dropdown')?.classList.toggle('hidden');
    });

    // Logout
    async function doLogout() {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/';
    }
    document.getElementById('logout-btn')?.addEventListener('click', doLogout);
    document.getElementById('logout-btn-mobile')?.addEventListener('click', doLogout);

    // ===== Currency Converter =====
    const CURRENCY_SYMBOLS: Record<string, string> = {
      USD: '$', EUR: '€', JPY: '¥', THB: '฿', GBP: '£', AUD: 'A$', MYR: 'RM',
      SGD: 'S$', IDR: 'Rp', VND: '₫', PHP: '₱', KRW: '₩', AED: 'AED', INR: '₹'
    };
    const HIGH_DENOM = new Set(['JPY', 'KRW', 'IDR', 'VND']);
    const CURRENCY_KEY = 'ddh_currency';

    let cachedRates: Record<string, number> | null = null;

    async function fetchRates(): Promise<Record<string, number>> {
      if (cachedRates) return cachedRates;
      try {
        const res = await fetch('/api/exchange-rates');
        if (!res.ok) throw new Error('rate fetch failed');
        const data = await res.json();
        cachedRates = data.rates as Record<string, number>;
        return cachedRates;
      } catch {
        // Fallback rates
        return {
          USD: 1, JPY: 150, THB: 35, SGD: 1.35, KRW: 1350, MYR: 4.7,
          PHP: 56, INR: 83, AED: 3.67, GBP: 0.79, EUR: 0.92, AUD: 1.55,
          IDR: 15800, VND: 25000
        };
      }
    }

    function formatPrice(usd: number, currency: string, rate: number): string {
      const amount = usd * rate;
      const sym = CURRENCY_SYMBOLS[currency] || currency;
      if (HIGH_DENOM.has(currency)) {
        return `${sym}${Math.round(amount).toLocaleString()}`;
      }
      return `${sym}${amount.toFixed(2)}`;
    }

    async function applyConversion(currency: string) {
      const rates = await fetchRates();
      const rate = rates[currency] ?? 1;
      document.querySelectorAll<HTMLElement>('[data-usd]').forEach(el => {
        const usd = parseFloat(el.dataset.usd || '0');
        if (isNaN(usd)) return;
        el.textContent = formatPrice(usd, currency, rate);
      });
      // Update currency label spans
      document.querySelectorAll<HTMLElement>('[data-currency-label]').forEach(el => {
        el.textContent = currency;
      });
    }

    // Custom currency dropdown
    const currencyBtn = document.getElementById('currency-btn');
    const currencyDropdown = document.getElementById('currency-dropdown');
    const currencyBtnLabel = document.getElementById('currency-btn-label');
    const CURRENCY_LABELS: Record<string, string> = {
      USD:'USD $', EUR:'EUR €', JPY:'JPY ¥', THB:'THB ฿', GBP:'GBP £',
      AUD:'AUD $', MYR:'MYR RM', SGD:'SGD $', IDR:'IDR Rp', VND:'VND ₫',
      PHP:'PHP ₱', KRW:'KRW ₩', AED:'AED د.إ', INR:'INR ₹'
    };

    function setActiveCurrency(currency: string) {
      if (currencyBtnLabel) currencyBtnLabel.textContent = CURRENCY_LABELS[currency] || currency;
      document.querySelectorAll<HTMLElement>('.currency-option').forEach(opt => {
        const isActive = opt.dataset.currency === currency;
        opt.classList.toggle('text-teal-600', isActive);
        opt.classList.toggle('font-semibold', isActive);
      });
    }

    // Restore saved currency
    const saved = localStorage.getItem(CURRENCY_KEY) || 'USD';
    setActiveCurrency(saved);
    if (saved !== 'USD') applyConversion(saved);

    currencyBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      currencyDropdown?.classList.toggle('hidden');
    });
    document.addEventListener('click', () => currencyDropdown?.classList.add('hidden'));

    document.querySelectorAll<HTMLElement>('.currency-option').forEach(opt => {
      opt.addEventListener('click', (e) => {
        e.stopPropagation();
        const currency = opt.dataset.currency || 'USD';
        localStorage.setItem(CURRENCY_KEY, currency);
        setActiveCurrency(currency);
        applyConversion(currency);
        currencyDropdown?.classList.add('hidden');
      });
    });

    // ===== Password visibility toggle =====
    (function() {
      const EYE_SVG = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
      const EYE_OFF_SVG = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';

      function attachToggle(input: HTMLInputElement) {
        const parent = input.parentElement;
        if (!parent || parent.querySelector('.ddh-pw-toggle')) return;
        // ラップ div（相対位置）
        const wrap = document.createElement('div');
        wrap.style.cssText = 'position:relative;display:block;';
        parent.insertBefore(wrap, input);
        wrap.appendChild(input);
        // トグルボタン
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'ddh-pw-toggle';
        btn.setAttribute('aria-label', 'Show/hide password');
        btn.style.cssText = 'position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#9ca3af;padding:4px;display:flex;align-items:center;z-index:2;';
        btn.innerHTML = EYE_SVG;
        wrap.appendChild(btn);
        // パディング確保
        input.style.paddingRight = '38px';
        btn.addEventListener('click', function() {
          const show = input.type === 'password';
          input.type = show ? 'text' : 'password';
          btn.innerHTML = show ? EYE_OFF_SVG : EYE_SVG;
          btn.style.color = show ? '#0d9488' : '#9ca3af';
        });
      }

      function initToggles() {
        (document.querySelectorAll('input[type="password"]') as NodeListOf<HTMLInputElement>).forEach(attachToggle);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initToggles);
      } else {
        initToggles();
      }
    })();
  </script>

  <CookieBanner />
</body>
</html>
