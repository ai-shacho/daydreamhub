---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Day-use hotel booking platform - Find hourly hotels worldwide" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="min-h-screen flex flex-col bg-gray-50">

  <!-- Header -->
  <header class="bg-teal-700 text-white sticky top-0 z-[1100] shadow-md">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Top bar -->
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 font-bold text-xl tracking-tight">
          <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none">
            <circle cx="16" cy="16" r="14" fill="#f59e0b"/>
            <path d="M10 20 Q16 10 22 20" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            <circle cx="16" cy="13" r="3" fill="white"/>
          </svg>
          DayDreamHub
        </a>

        <!-- Nav links (desktop) -->
        <nav class="hidden md:flex items-center gap-1">
          <a href="/search" class:list={["px-3 py-2 rounded-lg text-sm font-medium transition-colors", currentPath === '/search' ? 'bg-teal-600 text-white' : 'text-teal-100 hover:bg-teal-600 hover:text-white']}>
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              Search
            </span>
          </a>
          <a href="/wishlist" class:list={["px-3 py-2 rounded-lg text-sm font-medium transition-colors", currentPath === '/wishlist' ? 'bg-teal-600 text-white' : 'text-teal-100 hover:bg-teal-600 hover:text-white']}>
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
              Wishlist
            </span>
          </a>
          <a href="/map" class:list={["px-3 py-2 rounded-lg text-sm font-medium transition-colors", currentPath === '/map' ? 'bg-teal-600 text-white' : 'text-teal-100 hover:bg-teal-600 hover:text-white']}>
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
              Map
            </span>
          </a>
          <a href="/blog" class:list={["px-3 py-2 rounded-lg text-sm font-medium transition-colors", currentPath.startsWith('/blog') ? 'bg-teal-600 text-white' : 'text-teal-100 hover:bg-teal-600 hover:text-white']}>
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              Blog
            </span>
          </a>
          <!-- More dropdown -->
          <div class="relative" id="more-menu-wrapper">
            <button id="more-menu-btn" class:list={["px-3 py-2 rounded-lg text-sm font-medium transition-colors inline-flex items-center gap-1.5", ['/about','/faq','/for-hotel-owner','/for-ai-agents'].includes(currentPath) ? 'bg-teal-600 text-white' : 'text-teal-100 hover:bg-teal-600 hover:text-white']}>
              More
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div id="more-dropdown" class="hidden absolute right-0 top-full mt-1 w-52 bg-white rounded-xl shadow-lg border border-gray-100 py-1 z-[1200]">
              <a href="/about" class:list={["block px-4 py-2.5 text-sm transition-colors", currentPath === '/about' ? 'text-teal-700 font-semibold bg-teal-50' : 'text-gray-700 hover:bg-gray-50']}>About Us</a>
              <a href="/faq" class:list={["block px-4 py-2.5 text-sm transition-colors", currentPath === '/faq' ? 'text-teal-700 font-semibold bg-teal-50' : 'text-gray-700 hover:bg-gray-50']}>FAQ</a>
              <a href="/for-hotel-owner" class:list={["block px-4 py-2.5 text-sm transition-colors", currentPath === '/for-hotel-owner' ? 'text-teal-700 font-semibold bg-teal-50' : 'text-gray-700 hover:bg-gray-50']}>For Property Owner</a>
              <a href="/for-ai-agents" class:list={["block px-4 py-2.5 text-sm transition-colors", currentPath === '/for-ai-agents' ? 'text-teal-700 font-semibold bg-teal-50' : 'text-gray-700 hover:bg-gray-50']}>For AI Agents</a>
            </div>
          </div>
        </nav>

        <!-- Right side controls -->
        <div class="flex items-center gap-2">
          <!-- Currency selector -->
          <select id="currency-selector" class="bg-teal-600 text-white text-xs border border-teal-500 rounded-md px-2 py-1.5 cursor-pointer focus:outline-none focus:ring-2 focus:ring-amber-400">
            <option value="USD">USD $</option>
            <option value="EUR">EUR &euro;</option>
            <option value="JPY">JPY &yen;</option>
            <option value="THB">THB &#3647;</option>
            <option value="GBP">GBP &pound;</option>
            <option value="AUD">AUD $</option>
            <option value="MYR">MYR RM</option>
          </select>

          <!-- Language toggle -->
          <div class="hidden sm:flex items-center bg-teal-600 rounded-md overflow-hidden border border-teal-500">
            <a href={currentPath} class="px-2 py-1.5 text-xs font-medium bg-teal-500 text-white">EN</a>
            <a href={`/ja${currentPath}`} class="px-2 py-1.5 text-xs font-medium text-teal-200 hover:text-white">JP</a>
          </div>

          <!-- Auth buttons -->
          <div class="hidden sm:flex items-center gap-2 ml-2">
            <a href="/login" class="text-xs font-medium text-teal-100 hover:text-white transition-colors px-3 py-1.5 rounded-md hover:bg-teal-600">Login</a>
            <a href="/register" class="text-xs font-medium bg-amber-500 hover:bg-amber-400 text-gray-900 px-3 py-1.5 rounded-md transition-colors">Register</a>
          </div>

          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-teal-600 transition-colors" aria-label="Menu">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden hidden border-t border-teal-600">
      <div class="px-4 py-3 space-y-1">
        <a href="/search" class="block px-3 py-2 rounded-lg text-sm font-medium text-teal-100 hover:bg-teal-600">Search</a>
        <a href="/wishlist" class="block px-3 py-2 rounded-lg text-sm font-medium text-teal-100 hover:bg-teal-600">Wishlist</a>
        <a href="/map" class="block px-3 py-2 rounded-lg text-sm font-medium text-teal-100 hover:bg-teal-600">Map</a>
        <a href="/blog" class="block px-3 py-2 rounded-lg text-sm font-medium text-teal-100 hover:bg-teal-600">Blog</a>
        <div class="pt-1 pb-0.5">
          <p class="px-3 py-1 text-xs font-semibold text-teal-400 uppercase tracking-wider">More</p>
          <a href="/about" class="block px-3 py-2 rounded-lg text-sm font-medium text-teal-100 hover:bg-teal-600">About Us</a>
          <a href="/faq" class="block px-3 py-2 rounded-lg text-sm font-medium text-teal-100 hover:bg-teal-600">FAQ</a>
          <a href="/for-hotel-owner" class="block px-3 py-2 rounded-lg text-sm font-medium text-teal-100 hover:bg-teal-600">For Property Owner</a>
          <a href="/for-ai-agents" class="block px-3 py-2 rounded-lg text-sm font-medium text-teal-100 hover:bg-teal-600">For AI Agents</a>
        </div>
        <hr class="border-teal-600" />
        <div class="flex items-center gap-2 pt-1">
          <a href="/login" class="text-sm text-teal-100 hover:text-white px-3 py-2">Login</a>
          <a href="/register" class="text-sm bg-amber-500 text-gray-900 px-3 py-2 rounded-md">Register</a>
        </div>
      </div>
    </div>
  </header>

  <!-- Main content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-gray-900 text-gray-300 mt-auto">
    <div class="max-w-7xl mx-auto px-4 py-12">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <!-- Brand -->
        <div>
          <a href="/" class="text-white font-bold text-lg">DayDreamHub</a>
          <p class="mt-3 text-sm text-gray-400">Find and book day-use hotels by the hour, worldwide. Perfect for rest stops, remote work, or a quick getaway.</p>
        </div>

        <!-- Blog Categories -->
        <div>
          <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Blog Categories</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/blog/category/travel-tips" class="hover:text-white transition-colors">Travel Tips</a></li>
            <li><a href="/blog/category/city-guides" class="hover:text-white transition-colors">City Guides</a></li>
            <li><a href="/blog/category/hotel-reviews" class="hover:text-white transition-colors">Hotel Reviews</a></li>
            <li><a href="/blog/category/digital-nomad" class="hover:text-white transition-colors">Digital Nomad</a></li>
          </ul>
        </div>

        <!-- What's New -->
        <div>
          <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">What's New</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/concierge" class="hover:text-white transition-colors">AI Concierge</a></li>
            <li><a href="/map" class="hover:text-white transition-colors">Map View</a></li>
            <li><a href="/search" class="hover:text-white transition-colors">Advanced Search</a></li>
            <li><a href="/wishlist" class="hover:text-white transition-colors">Wishlist</a></li>
          </ul>
        </div>

        <!-- Contact -->
        <div>
          <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contact</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="mailto:support@daydreamhub.com" class="hover:text-white transition-colors">support@daydreamhub.com</a></li>
            <li><a href="/terms" class="hover:text-white transition-colors">Terms of Service</a></li>
            <li><a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a></li>
          </ul>
          <div class="flex gap-3 mt-4">
            <a href="#" class="text-gray-400 hover:text-white transition-colors" aria-label="Twitter">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"/></svg>
            </a>
            <a href="#" class="text-gray-400 hover:text-white transition-colors" aria-label="Instagram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="border-t border-gray-800 mt-10 pt-6 text-center text-sm text-gray-500">
        &copy; {new Date().getFullYear()} DayDreamHub. All rights reserved.
      </div>
    </div>
  </footer>

  <script>
    // ===== Wishlist (localStorage) =====
    const WISHLIST_KEY = 'ddh_wishlist';

    function getWishlist(): string[] {
      try { return JSON.parse(localStorage.getItem(WISHLIST_KEY) || '[]'); } catch { return []; }
    }
    function saveWishlist(slugs: string[]) {
      localStorage.setItem(WISHLIST_KEY, JSON.stringify(slugs));
    }
    function isInWishlist(slug: string): boolean {
      return getWishlist().includes(slug);
    }
    function toggleWishlist(slug: string): boolean {
      const list = getWishlist();
      const idx = list.indexOf(slug);
      if (idx >= 0) { list.splice(idx, 1); saveWishlist(list); return false; }
      else { list.push(slug); saveWishlist(list); return true; }
    }

    function updateWishlistBtn(btn: HTMLButtonElement, inWishlist: boolean) {
      const icon = btn.querySelector('.wishlist-icon') as SVGElement | null;
      const label = btn.querySelector('.wishlist-label') as HTMLElement | null;
      if (!icon) return;
      if (inWishlist) {
        icon.setAttribute('fill', '#ef4444');
        icon.setAttribute('stroke', '#ef4444');
        btn.title = 'Remove from wishlist';
        if (label) label.textContent = 'Saved';
        btn.classList.add('border-red-300', 'bg-red-50', 'text-red-500');
        btn.classList.remove('border-gray-200', 'bg-white', 'text-gray-600');
      } else {
        icon.setAttribute('fill', 'none');
        icon.setAttribute('stroke', 'currentColor');
        btn.title = 'Save to wishlist';
        if (label) label.textContent = 'Save';
        btn.classList.remove('border-red-300', 'bg-red-50', 'text-red-500');
        btn.classList.add('border-gray-200', 'bg-white', 'text-gray-600');
      }
    }

    // Expose for wishlist page
    (window as any).updateWishlistBtn = (slug: string, inWishlist: boolean) => {
      document.querySelectorAll<HTMLButtonElement>(`[data-slug="${slug}"].wishlist-btn`).forEach(btn => {
        updateWishlistBtn(btn, inWishlist);
      });
    };

    function initWishlistBtns() {
      document.querySelectorAll<HTMLButtonElement>('.wishlist-btn').forEach(btn => {
        const slug = btn.dataset.slug || '';
        updateWishlistBtn(btn, isInWishlist(slug));
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const inWishlist = toggleWishlist(slug);
          updateWishlistBtn(btn, inWishlist);
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initWishlistBtns);
    } else {
      initWishlistBtns();
    }

    // Mobile menu toggle
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });

    // More dropdown toggle
    const moreBtn = document.getElementById('more-menu-btn');
    const moreDropdown = document.getElementById('more-dropdown');
    moreBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      moreDropdown?.classList.toggle('hidden');
    });
    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (!document.getElementById('more-menu-wrapper')?.contains(e.target as Node)) {
        moreDropdown?.classList.add('hidden');
      }
    });
  </script>
</body>
</html>
