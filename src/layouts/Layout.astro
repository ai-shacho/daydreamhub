---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  ogType?: string;
  ogPublishedTime?: string;
}

const { title, description = "Day-use hotel booking platform - Find hourly hotels worldwide", ogImage, canonicalUrl, ogType, ogPublishedTime } = Astro.props;
const siteUrl = 'https://www.daydreamhub.com';
const resolvedOgImage = ogImage || `${siteUrl}/og-default.jpg`;
const resolvedCanonical = canonicalUrl || `${siteUrl}${Astro.url.pathname}`;
const currentPath = Astro.url.pathname;
const isJa = currentPath.startsWith('/ja');
const basePath = isJa ? (currentPath.replace(/^\/ja/, '') || '/') : currentPath;
const enPath = basePath;
const jaPath = `/ja${basePath === '/' ? '' : basePath}`;

// Auth: read ddh_token cookie and verify JWT
async function verifyJWT(token: string, secret: string): Promise<Record<string, any> | null> {
  try {
    const parts = token.split('.');
    if (parts.length !== 3) return null;
    const [header, body, signature] = parts;
    const key = await crypto.subtle.importKey(
      'raw', new TextEncoder().encode(secret),
      { name: 'HMAC', hash: 'SHA-256' }, false, ['verify']
    );
    const sigBytes = Uint8Array.from(
      atob(signature.replace(/-/g, '+').replace(/_/g, '/')), c => c.charCodeAt(0)
    );
    const valid = await crypto.subtle.verify('HMAC', key, sigBytes, new TextEncoder().encode(`${header}.${body}`));
    if (!valid) return null;
    const payload = JSON.parse(atob(body));
    if (payload.exp && payload.exp < Math.floor(Date.now() / 1000)) return null;
    return payload;
  } catch { return null; }
}
const env0 = (Astro.locals as any).runtime?.env;
const jwtSecret = env0?.JWT_SECRET || 'ddh-secret-2025';
const cookieHeader = Astro.request.headers.get('cookie') || '';
const tokenMatch = cookieHeader.match(/ddh_token=([^;]+)/);
const authPayload = tokenMatch ? await verifyJWT(tokenMatch[1], jwtSecret) : null;
const currentUser = authPayload ? { id: authPayload.sub, name: authPayload.name, email: authPayload.email, role: authPayload.role === 'inactive' ? 'owner' : authPayload.role } : null;

// GA4
const ga4Id: string | undefined = (Astro.locals as any).runtime?.env?.GA4_MEASUREMENT_ID;

// Footer dynamic data
const env = (Astro.locals as any).runtime?.env;
const DB = env?.DB;
let footerBlogs: any[] = [];
let footerCities: any[] = [];
try {
  if (DB) {
    const blogRes = await DB.prepare(
      "SELECT title, slug FROM blog_posts ORDER BY published_at DESC LIMIT 3"
    ).all();
    footerBlogs = blogRes?.results ?? [];
    const cityRes = await DB.prepare(
      "SELECT city, COUNT(*) as cnt FROM hotels WHERE is_active=1 AND city!='' GROUP BY city ORDER BY cnt DESC LIMIT 8"
    ).all();
    footerCities = cityRes?.results ?? [];
  }
} catch {}

const defaultCities = ['Bangkok','Bali','Kuala Lumpur','Singapore','Cebu','Hanoi','Ho Chi Minh City','Phuket'];
---

<!doctype html>
<html lang={isJa ? "ja" : "en"}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <!-- Canonical -->
  <link rel="canonical" href={resolvedCanonical} />
  <!-- OGP (Facebook/LINE/Slack等) -->
  <meta property="og:type" content={ogType || "website"} />
  <meta property="og:url" content={resolvedCanonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:site_name" content="DayDreamHub" />
  {ogPublishedTime && <meta property="article:published_time" content={ogPublishedTime} />}
  <!-- hreflang -->
  <link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
  <link rel="alternate" hreflang="ja" href={`${siteUrl}${jaPath}`} />
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}${enPath}`} />
  <!-- WebSite JSON-LD (top page only) -->
  {currentPath === '/' && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "DayDreamHub",
      "url": siteUrl,
      "description": "Day-use hotel booking platform - Find hourly hotels worldwide",
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${siteUrl}/search?location={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    })} />
  )}
  <slot name="head" />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>
  {ga4Id && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
      <script define:vars={{ ga4Id }}>
        window.__GA4_ID__ = ga4Id;
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', ga4Id, { anonymize_ip: true });
      </script>
    </>
  )}
</head>
<body class="min-h-screen flex flex-col bg-gray-50">

  <!-- Header -->
  <header class="bg-white text-gray-800 sticky top-0 z-[1100] shadow-sm border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Top bar -->
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/" class="flex items-center">
          <img src="/logo-transparent.png" alt="DayDreamHub" class="h-10 w-auto" />
        </a>

        <!-- Nav links (desktop) -->
        <nav class="hidden md:flex items-center gap-1">
          <a href="/search" class:list={["px-3 py-2 rounded-lg text-sm font-medium transition-colors", currentPath === '/search' ? 'bg-teal-600 text-white' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900']}>
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              Search
            </span>
          </a>
          <a href="/wishlist" class:list={["px-3 py-2 rounded-lg text-sm font-medium transition-colors", currentPath === '/wishlist' ? 'bg-teal-600 text-white' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900']}>
