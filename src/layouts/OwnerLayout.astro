---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} | Owner Portal - DayDreamHub</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-slate-100 min-h-screen">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside id="owner-sidebar" class="fixed inset-y-0 left-0 z-50 w-64 bg-indigo-800 text-white transform -translate-x-full lg:translate-x-0 transition-transform duration-200 overflow-y-auto">
      <div class="flex items-center gap-3 px-6 h-16 border-b border-indigo-700">
        <span class="text-white font-bold text-lg">DayDreamHub</span>
        <span class="text-xs font-medium text-indigo-300 uppercase tracking-wider">Owner Portal</span>
      </div>
      <nav class="mt-4 px-3 space-y-4 pb-20">
        {navGroups.map((group) => (
          <div>
            {group.label && (
              <p class="px-3 mb-1 text-xs font-semibold text-indigo-400 uppercase tracking-wider">{group.label}</p>
            )}
            <div class="space-y-0.5">
              {group.items.map((item) => (
                <a
                  href={item.href}
                  class={`flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
                    activeNav === item.key
                      ? "bg-teal-600 text-white"
                      : "text-indigo-200 hover:bg-indigo-700 hover:text-white"
                  }`}
                >
                  <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <Fragment set:html={icons[item.icon]} />
                  </svg>
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        ))}
      </nav>
      <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-indigo-700 bg-indigo-800">
        <a href="/" class="flex items-center gap-2 text-indigo-300 hover:text-white text-sm transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
          </svg>
          Back to Site
        </a>
      </div>
    </aside>

    <!-- Mobile sidebar overlay -->
    <div id="owner-sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden"></div>

    <!-- Main content -->
    <div class="flex-1 lg:ml-64">
      <!-- Top bar -->
      <header class="sticky top-0 z-30 bg-white border-b border-slate-200 h-16 flex items-center px-4 lg:px-8">
        <button id="owner-sidebar-toggle" class="lg:hidden p-2 -ml-2 text-slate-600 hover:text-slate-900">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
        <h1 class="text-lg font-semibold text-slate-900 ml-2 lg:ml-0">{title}</h1>
      </header>

      <!-- Page content -->
      <main class="p-4 lg:p-8">
        <slot />
      </main>
    </div>
  </div>

  <script>
    const toggle = document.getElementById('owner-sidebar-toggle');
    const sidebar = document.getElementById('owner-sidebar');
    const overlay = document.getElementById('owner-sidebar-overlay');
    if (toggle && sidebar && overlay) {
      toggle.addEventListener('click', () => {
        sidebar.classList.toggle('-translate-x-full');
        overlay.classList.toggle('hidden');
      });
      overlay.addEventListener('click', () => {
        sidebar.classList.add('-translate-x-full');
        overlay.classList.add('hidden');
      });
    }
  </script>
</body>
</html>
