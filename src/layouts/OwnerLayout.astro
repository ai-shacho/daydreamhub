---
import '../styles/global.css';

interface Props {
  title: string;
  activeNav?: string;
}

const { title, activeNav = "" } = Astro.props;

const navGroups = [
  {
    label: "",
    items: [
      { key: "dashboard", label: "Dashboard", href: "/owner", icon: "home" },
      { key: "bookings", label: "Bookings", href: "/owner/bookings", icon: "calendar" },
      { key: "calendar-view", label: "Calendar", href: "/owner/calendar", icon: "calendar-days" },
    ]
  },
  {
    label: "Hotel",
    items: [
      { key: "hotels", label: "My Hotels", href: "/owner/hotels", icon: "hotel" },
      { key: "reviews", label: "Reviews", href: "/owner/reviews", icon: "star" },

    ]
  },
  {
    label: "Insights",
    items: [
      { key: "reports", label: "Reports", href: "/owner/reports", icon: "chart" },
      { key: "messages", label: "Messages", href: "/owner/messages", icon: "envelope" },
    ]
  },
  {
    label: "Settings",
    items: [
      { key: "staff", label: "Staff", href: "/owner/staff", icon: "users" },
      { key: "notifications", label: "Notifications", href: "/owner/notifications", icon: "bell" },
      { key: "call-logs", label: "Call Logs", href: "/owner/call-logs", icon: "phone" },
      { key: "settings", label: "Settings", href: "/owner/settings", icon: "cog" },
    ]
  }
];

